@typeparam TValue
@using Radzen
@using Radzen.Blazor

@*
    Standard dropdown filter for a DataListCard toolbar. Shows a placeholder when
    nothing is selected (i.e. "all"), and offers a clear affordance to reset back
    to that state. Use one per filterable column (status, role, type, ...).
*@

<div class="os-filter">
    <RadzenDropDown TValue="TValue"
                    Value="@Value"
                    ValueChanged="@OnValueChangedAsync"
                    Data="@Data"
                    TextProperty="@TextProperty"
                    ValueProperty="@ValueProperty"
                    Placeholder="@Placeholder"
                    AllowClear="@AllowClear"
                    AllowFiltering="@AllowFiltering"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    Multiple="@Multiple"
                    Chips="@Chips"
                    class="os-filter-select"
                    aria-label="@Placeholder" />
</div>

@code {
    /// <summary>Text shown when no option is selected (the "all" state).</summary>
    [Parameter] public string? Placeholder { get; set; }

    [Parameter] public IEnumerable<object>? Data { get; set; }
    [Parameter] public string TextProperty { get; set; } = "Label";
    [Parameter] public string ValueProperty { get; set; } = "Value";

    [Parameter] public TValue? Value { get; set; }
    [Parameter] public EventCallback<TValue?> ValueChanged { get; set; }

    /// <summary>Show a clear (×) button to reset the filter to its "all" state.</summary>
    [Parameter] public bool AllowClear { get; set; } = true;
    [Parameter] public bool AllowFiltering { get; set; }
    [Parameter] public bool Multiple { get; set; }
    [Parameter] public bool Chips { get; set; }

    private async Task OnValueChangedAsync(TValue? value)
    {
        await ValueChanged.InvokeAsync(value);
    }
}
