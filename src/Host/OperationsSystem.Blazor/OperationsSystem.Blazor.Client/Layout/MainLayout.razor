@inherits LayoutComponentBase
@implements IDisposable
@inject AuthSession Auth
@inject LocaleState Locale
@inject NavigationManager Navigation

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

<div class="os-shell @(navOpen ? "os-shell--nav-open" : null) @(railCollapsed ? "os-shell--rail" : null)">
    <div class="os-scrim" @onclick="CloseNav"></div>

    <aside class="os-sidebar" aria-label="Primary navigation">
        <div class="os-brand">
            <span class="os-brand-mark">
                <img src="/branding/portal-icon.png" alt="@UiStrings.App.Name" width="28" height="28" />
            </span>
            <span class="os-brand-text">
                <strong>@UiStrings.App.Name</strong>
                <small>@UiStrings.App.Version</small>
            </span>
        </div>

        <nav class="os-nav">
            <p class="os-nav-section">@UiStrings.Nav.Overview</p>
            <NavLink href="/" Match="NavLinkMatch.All" class="os-nav-link" title="@UiStrings.Nav.Dashboard" @onclick="CloseNav">
                <RadzenIcon Icon="dashboard" />
                <span>@UiStrings.Nav.Dashboard</span>
            </NavLink>

            <AuthorizeView Context="users">
                @if (HasNav)
                {
                    <p class="os-nav-section">@UiStrings.Nav.Administration</p>
                }
                @if (users.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.UsersView))
                {
                    <NavLink href="/users" class="os-nav-link" title="@UiStrings.Nav.Users" @onclick="CloseNav">
                        <RadzenIcon Icon="group" />
                        <span>@UiStrings.Nav.Users</span>
                    </NavLink>
                }
                @if (users.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.RolesView))
                {
                    <NavLink href="/roles" class="os-nav-link" title="@UiStrings.Nav.Roles" @onclick="CloseNav">
                        <RadzenIcon Icon="shield" />
                        <span>@UiStrings.Nav.Roles</span>
                    </NavLink>
                }
            </AuthorizeView>
        </nav>

        <div class="os-sidebar-foot">
            <span class="os-version-tag">@UiStrings.App.Version</span>
        </div>
    </aside>

    <div class="os-main">
        <header class="os-topbar">
            <div class="os-topbar-lead">
                <button type="button" class="os-icon-btn os-rail-toggle" aria-label="@UiStrings.Nav.ToggleMenu"
                        aria-expanded="@(!railCollapsed)" @onclick="ToggleRail">
                    <RadzenIcon Icon="menu" />
                </button>
                <button type="button" class="os-icon-btn os-nav-toggle" aria-label="@UiStrings.Nav.ToggleMenu" @onclick="ToggleNav">
                    <RadzenIcon Icon="menu" />
                </button>
                <span class="os-topbar-title">@UiStrings.App.Portal</span>
            </div>

            <div class="os-topbar-actions">
                <button type="button" class="os-lang-btn" @onclick="ToggleLanguageAsync">
                    <RadzenIcon Icon="translate" />
                    <span>@LanguageLabel</span>
                </button>

                @if (Auth.User is { } current)
                {
                    <div class="os-profile @(profileOpen ? "os-profile--open" : null)">
                        <button type="button" class="os-user-chip" @onclick="ToggleProfile"
                                aria-haspopup="true" aria-expanded="@profileOpen">
                            <span class="os-avatar">@Initials(current.DisplayName)</span>
                            <span class="os-user-meta">
                                <strong>@current.DisplayName</strong>
                                <small class="os-muted">@current.RoleName</small>
                            </span>
                            <RadzenIcon Icon="expand_more" class="os-profile-chev" />
                        </button>

                        <div class="os-profile-backdrop" @onclick="CloseProfile"></div>

                        <div class="os-profile-panel">
                            <div class="os-profile-identity">
                                <span class="os-avatar os-avatar--lg">@Initials(current.DisplayName)</span>
                                <div class="os-profile-identity-text">
                                    <strong>@current.DisplayName</strong>
                                    <small class="os-muted">@current.Email</small>
                                </div>
                            </div>
                            <div class="os-profile-menu">
                                <button type="button" class="os-profile-item" @onclick="GoToAccountAsync">
                                    <RadzenIcon Icon="account_circle" />
                                    <span>@UiStrings.Account.Title</span>
                                </button>
                                <button type="button" class="os-profile-item os-profile-item--danger" @onclick="LogoutAsync">
                                    <RadzenIcon Icon="logout" />
                                    <span>@UiStrings.Common.SignOut</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </header>

        <section class="os-content">
            <div class="os-content-inner">
                @Body
            </div>
        </section>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool navOpen;
    private bool railCollapsed;
    private bool profileOpen;

    private string LanguageLabel => Locale.Language == LocaleState.Arabic ? "EN" : "العربية";

    private bool HasNav => Auth.User?.Permissions.Any(p =>
        p == IdentityPermissions.UsersView || p == IdentityPermissions.RolesView) ?? false;

    protected override void OnInitialized()
    {
        Auth.StateChanged += OnStateChanged;
        Locale.Changed += OnStateChanged;
    }

    private void ToggleNav() => navOpen = !navOpen;

    private void CloseNav() => navOpen = false;

    private void ToggleRail() => railCollapsed = !railCollapsed;

    private void ToggleProfile() => profileOpen = !profileOpen;

    private void CloseProfile() => profileOpen = false;

    private async Task GoToAccountAsync()
    {
        profileOpen = false;
        Navigation.NavigateTo("/account");
        await Task.CompletedTask;
    }

    private async Task ToggleLanguageAsync() => await Locale.ToggleAsync();

    private async Task LogoutAsync()
    {
        profileOpen = false;
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }

    private void OnStateChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.StateChanged -= OnStateChanged;
        Locale.Changed -= OnStateChanged;
    }
}
