@inherits LayoutComponentBase
@implements IDisposable
@inject AuthSession Auth
@inject LocaleState Locale
@inject NavigationManager Navigation

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

<div class="os-shell @(navOpen ? "os-shell--nav-open" : null) @(railCollapsed ? "os-shell--rail" : null)">
    <div class="os-scrim" @onclick="CloseNav"></div>

    <aside class="os-sidebar" aria-label="Primary navigation">
        <div class="os-brand">
            <span class="os-brand-mark">
                <img src="/branding/portal-icon.png" alt="@UiStrings.App.Name" width="28" height="28" />
            </span>
            <span class="os-brand-text">
                <strong>@UiStrings.App.Name</strong>
                <small>@UiStrings.App.Version</small>
            </span>
        </div>

        <nav class="os-nav">
            <p class="os-nav-section">@UiStrings.Nav.Overview</p>
            <NavLink href="/" Match="NavLinkMatch.All" class="os-nav-link" title="@UiStrings.Nav.Dashboard" @onclick="CloseNav">
                <RadzenIcon Icon="dashboard" />
                <span>@UiStrings.Nav.Dashboard</span>
            </NavLink>

            <AuthorizeView Context="users">
                @if (HasNav)
                {
                    <p class="os-nav-section">@UiStrings.Nav.Administration</p>
                }
                @if (users.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.UsersView))
                {
                    <NavLink href="/users" class="os-nav-link" title="@UiStrings.Nav.Users" @onclick="CloseNav">
                        <RadzenIcon Icon="group" />
                        <span>@UiStrings.Nav.Users</span>
                    </NavLink>
                }
                @if (users.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.RolesView))
                {
                    <NavLink href="/roles" class="os-nav-link" title="@UiStrings.Nav.Roles" @onclick="CloseNav">
                        <RadzenIcon Icon="shield" />
                        <span>@UiStrings.Nav.Roles</span>
                    </NavLink>
                }
                @if (users.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, AuditPermissions.TrailsView))
                {
                    <NavLink href="/audit" class="os-nav-link" title="@UiStrings.Nav.Audit" @onclick="CloseNav">
                        <RadzenIcon Icon="history" />
                        <span>@UiStrings.Nav.Audit</span>
                    </NavLink>
                }
            </AuthorizeView>

            <AuthorizeView Context="masterData">
                @{
                    var canCountries = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.CountriesView);
                    var canManpower = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.ManpowerTypesView);
                    var canLicenses = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.LicensesView);
                    var canServices = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.ServicesView);
                    var canOperationTypes = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.OperationTypesView);
                    var canAircraftTypes = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.AircraftTypesView);
                    var canTools = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.ToolsView);
                    var canMaterials = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.MaterialsView);
                    var canGeneralSupports = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.GeneralSupportsView);
                    var canStations = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.StationsView);
                    var canCustomers = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.CustomersView);
                    var canStaff = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.StaffMembersView);
                }
                @if (canCountries || canManpower || canLicenses || canServices || canOperationTypes || canAircraftTypes || canTools || canMaterials || canGeneralSupports || canStations || canCustomers || canStaff)
                {
                    <p class="os-nav-section">@UiStrings.Nav.MasterData</p>
                }
                @if (canCountries)
                {
                    <NavLink href="/master-data/countries" class="os-nav-link" title="@UiStrings.Nav.Countries" @onclick="CloseNav">
                        <RadzenIcon Icon="public" />
                        <span>@UiStrings.Nav.Countries</span>
                    </NavLink>
                }
                @if (canManpower)
                {
                    <NavLink href="/master-data/manpower-types" class="os-nav-link" title="@UiStrings.Nav.ManpowerTypes" @onclick="CloseNav">
                        <RadzenIcon Icon="engineering" />
                        <span>@UiStrings.Nav.ManpowerTypes</span>
                    </NavLink>
                }
                @if (canLicenses)
                {
                    <NavLink href="/master-data/licenses" class="os-nav-link" title="@UiStrings.Nav.Licenses" @onclick="CloseNav">
                        <RadzenIcon Icon="badge" />
                        <span>@UiStrings.Nav.Licenses</span>
                    </NavLink>
                }
                @if (canServices)
                {
                    <NavLink href="/master-data/services" class="os-nav-link" title="@UiStrings.Nav.Services" @onclick="CloseNav">
                        <RadzenIcon Icon="settings" />
                        <span>@UiStrings.Nav.Services</span>
                    </NavLink>
                }
                @if (canOperationTypes)
                {
                    <NavLink href="/master-data/operation-types" class="os-nav-link" title="@UiStrings.Nav.OperationTypes" @onclick="CloseNav">
                        <RadzenIcon Icon="timeline" />
                        <span>@UiStrings.Nav.OperationTypes</span>
                    </NavLink>
                }
                @if (canAircraftTypes)
                {
                    <NavLink href="/master-data/aircraft-types" class="os-nav-link" title="@UiStrings.Nav.AircraftTypes" @onclick="CloseNav">
                        <RadzenIcon Icon="flight" />
                        <span>@UiStrings.Nav.AircraftTypes</span>
                    </NavLink>
                }
                @if (canTools)
                {
                    <NavLink href="/master-data/tools" class="os-nav-link" title="@UiStrings.Nav.Tools" @onclick="CloseNav">
                        <RadzenIcon Icon="build" />
                        <span>@UiStrings.Nav.Tools</span>
                    </NavLink>
                }
                @if (canMaterials)
                {
                    <NavLink href="/master-data/materials" class="os-nav-link" title="@UiStrings.Nav.Materials" @onclick="CloseNav">
                        <RadzenIcon Icon="category" />
                        <span>@UiStrings.Nav.Materials</span>
                    </NavLink>
                }
                @if (canGeneralSupports)
                {
                    <NavLink href="/master-data/general-supports" class="os-nav-link" title="@UiStrings.Nav.GeneralSupports" @onclick="CloseNav">
                        <RadzenIcon Icon="headset_mic" />
                        <span>@UiStrings.Nav.GeneralSupports</span>
                    </NavLink>
                }
                @if (canStations)
                {
                    <NavLink href="/master-data/stations" class="os-nav-link" title="@UiStrings.Nav.Stations" @onclick="CloseNav">
                        <RadzenIcon Icon="flight_takeoff" />
                        <span>@UiStrings.Nav.Stations</span>
                    </NavLink>
                }
                @if (canCustomers)
                {
                    <NavLink href="/master-data/customers" class="os-nav-link" title="@UiStrings.Nav.Customers" @onclick="CloseNav">
                        <RadzenIcon Icon="business" />
                        <span>@UiStrings.Nav.Customers</span>
                    </NavLink>
                }
                @if (canStaff)
                {
                    <NavLink href="/master-data/staff-members" class="os-nav-link" title="@UiStrings.Nav.StaffMembers" @onclick="CloseNav">
                        <RadzenIcon Icon="groups" />
                        <span>@UiStrings.Nav.StaffMembers</span>
                    </NavLink>
                }
            </AuthorizeView>
        </nav>

        <div class="os-sidebar-foot">
            <span class="os-version-tag">@UiStrings.App.Version</span>
        </div>
    </aside>

    <div class="os-main">
        <header class="os-topbar">
            <div class="os-topbar-lead">
                <button type="button" class="os-icon-btn os-rail-toggle" aria-label="@UiStrings.Nav.ToggleMenu"
                        aria-expanded="@(!railCollapsed)" @onclick="ToggleRail">
                    <RadzenIcon Icon="menu" />
                </button>
                <button type="button" class="os-icon-btn os-nav-toggle" aria-label="@UiStrings.Nav.ToggleMenu" @onclick="ToggleNav">
                    <RadzenIcon Icon="menu" />
                </button>
                <span class="os-topbar-title">@UiStrings.App.Portal</span>
            </div>

            <div class="os-topbar-actions">
                <button type="button" class="os-lang-btn" @onclick="ToggleLanguageAsync">
                    <RadzenIcon Icon="translate" />
                    <span>@LanguageLabel</span>
                </button>

                @if (Auth.User is { } current)
                {
                    <div class="os-profile @(profileOpen ? "os-profile--open" : null)">
                        <button type="button" class="os-user-chip" @onclick="ToggleProfile"
                                aria-haspopup="true" aria-expanded="@profileOpen">
                            <span class="os-avatar">@Initials(current.DisplayName)</span>
                            <span class="os-user-meta">
                                <strong>@current.DisplayName</strong>
                                <small class="os-muted">@current.RoleName</small>
                            </span>
                            <RadzenIcon Icon="expand_more" class="os-profile-chev" />
                        </button>

                        <div class="os-profile-backdrop" @onclick="CloseProfile"></div>

                        <div class="os-profile-panel">
                            <div class="os-profile-identity">
                                <span class="os-avatar os-avatar--lg">@Initials(current.DisplayName)</span>
                                <div class="os-profile-identity-text">
                                    <strong>@current.DisplayName</strong>
                                    <small class="os-muted">@current.Email</small>
                                </div>
                            </div>
                            <div class="os-profile-menu">
                                <button type="button" class="os-profile-item" @onclick="GoToAccountAsync">
                                    <RadzenIcon Icon="account_circle" />
                                    <span>@UiStrings.Account.Title</span>
                                </button>
                                <button type="button" class="os-profile-item os-profile-item--danger" @onclick="LogoutAsync">
                                    <RadzenIcon Icon="logout" />
                                    <span>@UiStrings.Common.SignOut</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </header>

        <section class="os-content">
            <div class="os-content-inner" @key="Locale.Language">
                @Body
            </div>
        </section>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private bool navOpen;
    private bool railCollapsed;
    private bool profileOpen;

    private string LanguageLabel => Locale.Language == LocaleState.Arabic ? "EN" : "العربية";

    private bool HasNav => Auth.User?.Permissions.Any(p =>
        p == IdentityPermissions.UsersView || p == IdentityPermissions.RolesView) ?? false;

    protected override async Task OnInitializedAsync()
    {
        await Locale.InitializeAsync();
        Auth.StateChanged += OnStateChanged;
        Locale.Changed += OnStateChanged;
    }

    private void ToggleNav() => navOpen = !navOpen;

    private void CloseNav() => navOpen = false;

    private void ToggleRail() => railCollapsed = !railCollapsed;

    private void ToggleProfile() => profileOpen = !profileOpen;

    private void CloseProfile() => profileOpen = false;

    private async Task GoToAccountAsync()
    {
        profileOpen = false;
        Navigation.NavigateTo("/account");
        await Task.CompletedTask;
    }

    private async Task ToggleLanguageAsync()
    {
        await Locale.ToggleAsync();
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true, replace: true);
    }

    private async Task LogoutAsync()
    {
        profileOpen = false;
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }

    private void OnStateChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Auth.StateChanged -= OnStateChanged;
        Locale.Changed -= OnStateChanged;
    }
}
