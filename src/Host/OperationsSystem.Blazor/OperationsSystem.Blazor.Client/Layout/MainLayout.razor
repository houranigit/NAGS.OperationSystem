@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject AuthSession Auth
@inject LocaleState Locale
@inject NavigationManager Navigation
@inject NotificationCenterState NotificationCenter
@inject NotificationsRealtimeClient NotificationsRealtime
@inject NotificationService ToastNotifications

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

<div class="os-shell @(navOpen ? "os-shell--nav-open" : null) @(railCollapsed ? "os-shell--rail" : null)">
    <div class="os-scrim" @onclick="CloseNav"></div>

    <aside class="os-sidebar" aria-label="Primary navigation">
        <div class="os-brand">
            <span class="os-brand-mark">
                <img src="/branding/portal-icon.png" alt="@UiStrings.App.Name" width="28" height="28" />
            </span>
            <span class="os-brand-text">
                <strong>@UiStrings.App.Name</strong>
                <small>@UiStrings.App.Version</small>
            </span>
        </div>

        <nav class="os-nav">
            <NavLink href="/" Match="NavLinkMatch.All" class="os-nav-link os-nav-link--root" title="@UiStrings.Nav.Dashboard" @onclick="CloseNav">
                <RadzenIcon Icon="dashboard" />
                <span>@UiStrings.Nav.Dashboard</span>
            </NavLink>

            <AuthorizeView Context="users">
                @{
                    var canUsers = users.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.UsersView);
                    var canRoles = users.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.RolesView);
                    var canAudit = users.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, AuditPermissions.TrailsView);
                    var canAdministration = canUsers || canRoles || canAudit;
                    var administrationActive = IsNavGroupActive("users", "roles", "audit");
                }
                @if (canAdministration)
                {
                    <div class="@NavGroupClass(NavGroupAdministration, administrationActive)">
                        <button type="button" class="os-nav-parent" title="@UiStrings.Nav.Administration"
                                aria-expanded="@(IsNavGroupExpanded(NavGroupAdministration) ? "true" : "false")" aria-controls="os-nav-administration"
                                @onclick="() => ToggleNavGroup(NavGroupAdministration)">
                            <RadzenIcon Icon="admin_panel_settings" />
                            <span>@UiStrings.Nav.Administration</span>
                            <RadzenIcon Icon="expand_more" class="os-nav-parent-chevron" />
                        </button>
                        <div id="os-nav-administration" class="os-nav-children">
                            <span class="os-nav-flyout-title">@UiStrings.Nav.Administration</span>
                            @if (canUsers)
                            {
                                <NavLink href="/users" class="os-nav-link" title="@UiStrings.Nav.Users" @onclick="CloseNav">
                                    <RadzenIcon Icon="group" />
                                    <span>@UiStrings.Nav.Users</span>
                                </NavLink>
                            }
                            @if (canRoles)
                            {
                                <NavLink href="/roles" class="os-nav-link" title="@UiStrings.Nav.Roles" @onclick="CloseNav">
                                    <RadzenIcon Icon="shield" />
                                    <span>@UiStrings.Nav.Roles</span>
                                </NavLink>
                            }
                            @if (canAudit)
                            {
                                <NavLink href="/audit" class="os-nav-link" title="@UiStrings.Nav.Audit" @onclick="CloseNav">
                                    <RadzenIcon Icon="history" />
                                    <span>@UiStrings.Nav.Audit</span>
                                </NavLink>
                            }
                        </div>
                    </div>
                }
            </AuthorizeView>

            <AuthorizeView Context="operations">
                @{
                    var canOpsFlights = operations.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, OperationsPermissions.FlightsView);
                    var canOpsWorkOrders = operations.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, OperationsPermissions.WorkOrdersView);
                    var canOperations = canOpsFlights || canOpsWorkOrders;
                    var operationsActive = IsNavGroupActive("operations");
                }
                @if (canOperations)
                {
                    <div class="@NavGroupClass(NavGroupOperations, operationsActive)">
                        <button type="button" class="os-nav-parent" title="Operations"
                                aria-expanded="@(IsNavGroupExpanded(NavGroupOperations) ? "true" : "false")" aria-controls="os-nav-operations"
                                @onclick="() => ToggleNavGroup(NavGroupOperations)">
                            <RadzenIcon Icon="route" />
                            <span>Operations</span>
                            <RadzenIcon Icon="expand_more" class="os-nav-parent-chevron" />
                        </button>
                        <div id="os-nav-operations" class="os-nav-children">
                            <span class="os-nav-flyout-title">Operations</span>
                            @if (canOpsFlights)
                            {
                                <NavLink href="/operations/calendar" class="os-nav-link" title="Flight calendar" @onclick="CloseNav">
                                    <RadzenIcon Icon="calendar_month" />
                                    <span>Calendar</span>
                                </NavLink>
                                <NavLink href="/operations/flights" class="os-nav-link" title="Flights" @onclick="CloseNav">
                                    <RadzenIcon Icon="flight" />
                                    <span>Flights</span>
                                </NavLink>
                            }
                            @if (canOpsWorkOrders)
                            {
                                <NavLink href="/operations/work-orders" class="os-nav-link" title="Work orders" @onclick="CloseNav">
                                    <RadzenIcon Icon="fact_check" />
                                    <span>Work Orders</span>
                                </NavLink>
                            }
                        </div>
                    </div>
                }
            </AuthorizeView>

            <AuthorizeView Context="masterData">
                @{
                    var canCountries = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.CountriesView);
                    var canManpower = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.ManpowerTypesView);
                    var canLicenses = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.LicensesView);
                    var canServices = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.ServicesView);
                    var canOperationTypes = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.OperationTypesView);
                    var canAircraftTypes = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.AircraftTypesView);
                    var canTools = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.ToolsView);
                    var canMaterials = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.MaterialsView);
                    var canGeneralSupports = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.GeneralSupportsView);
                    var canStations = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.StationsView);
                    var canCustomers = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.CustomersView);
                    var canStaff = masterData.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.StaffMembersView);
                    var canMasterData = canCountries || canManpower || canLicenses || canServices || canOperationTypes || canAircraftTypes || canTools || canMaterials || canGeneralSupports || canStations || canCustomers || canStaff;
                    var masterDataActive = IsNavGroupActive("master-data");
                }
                @if (canMasterData)
                {
                    <div class="@NavGroupClass(NavGroupMasterData, masterDataActive)">
                        <button type="button" class="os-nav-parent" title="@UiStrings.Nav.MasterData"
                                aria-expanded="@(IsNavGroupExpanded(NavGroupMasterData) ? "true" : "false")" aria-controls="os-nav-master-data"
                                @onclick="() => ToggleNavGroup(NavGroupMasterData)">
                            <RadzenIcon Icon="apps" />
                            <span>@UiStrings.Nav.MasterData</span>
                            <RadzenIcon Icon="expand_more" class="os-nav-parent-chevron" />
                        </button>
                        <div id="os-nav-master-data" class="os-nav-children">
                            <span class="os-nav-flyout-title">@UiStrings.Nav.MasterData</span>
                            @if (canCountries)
                            {
                                <NavLink href="/master-data/countries" class="os-nav-link" title="@UiStrings.Nav.Countries" @onclick="CloseNav">
                                    <RadzenIcon Icon="public" />
                                    <span>@UiStrings.Nav.Countries</span>
                                </NavLink>
                            }
                            @if (canManpower)
                            {
                                <NavLink href="/master-data/manpower-types" class="os-nav-link" title="@UiStrings.Nav.ManpowerTypes" @onclick="CloseNav">
                                    <RadzenIcon Icon="engineering" />
                                    <span>@UiStrings.Nav.ManpowerTypes</span>
                                </NavLink>
                            }
                            @if (canLicenses)
                            {
                                <NavLink href="/master-data/licenses" class="os-nav-link" title="@UiStrings.Nav.Licenses" @onclick="CloseNav">
                                    <RadzenIcon Icon="badge" />
                                    <span>@UiStrings.Nav.Licenses</span>
                                </NavLink>
                            }
                            @if (canServices)
                            {
                                <NavLink href="/master-data/services" class="os-nav-link" title="@UiStrings.Nav.Services" @onclick="CloseNav">
                                    <RadzenIcon Icon="settings" />
                                    <span>@UiStrings.Nav.Services</span>
                                </NavLink>
                            }
                            @if (canOperationTypes)
                            {
                                <NavLink href="/master-data/operation-types" class="os-nav-link" title="@UiStrings.Nav.OperationTypes" @onclick="CloseNav">
                                    <RadzenIcon Icon="timeline" />
                                    <span>@UiStrings.Nav.OperationTypes</span>
                                </NavLink>
                            }
                            @if (canAircraftTypes)
                            {
                                <NavLink href="/master-data/aircraft-types" class="os-nav-link" title="@UiStrings.Nav.AircraftTypes" @onclick="CloseNav">
                                    <RadzenIcon Icon="flight" />
                                    <span>@UiStrings.Nav.AircraftTypes</span>
                                </NavLink>
                            }
                            @if (canTools)
                            {
                                <NavLink href="/master-data/tools" class="os-nav-link" title="@UiStrings.Nav.Tools" @onclick="CloseNav">
                                    <RadzenIcon Icon="build" />
                                    <span>@UiStrings.Nav.Tools</span>
                                </NavLink>
                            }
                            @if (canMaterials)
                            {
                                <NavLink href="/master-data/materials" class="os-nav-link" title="@UiStrings.Nav.Materials" @onclick="CloseNav">
                                    <RadzenIcon Icon="category" />
                                    <span>@UiStrings.Nav.Materials</span>
                                </NavLink>
                            }
                            @if (canGeneralSupports)
                            {
                                <NavLink href="/master-data/general-supports" class="os-nav-link" title="@UiStrings.Nav.GeneralSupports" @onclick="CloseNav">
                                    <RadzenIcon Icon="headset_mic" />
                                    <span>@UiStrings.Nav.GeneralSupports</span>
                                </NavLink>
                            }
                            @if (canStations)
                            {
                                <NavLink href="/master-data/stations" class="os-nav-link" title="@UiStrings.Nav.Stations" @onclick="CloseNav">
                                    <RadzenIcon Icon="flight_takeoff" />
                                    <span>@UiStrings.Nav.Stations</span>
                                </NavLink>
                            }
                            @if (canCustomers)
                            {
                                <NavLink href="/master-data/customers" class="os-nav-link" title="@UiStrings.Nav.Customers" @onclick="CloseNav">
                                    <RadzenIcon Icon="business" />
                                    <span>@UiStrings.Nav.Customers</span>
                                </NavLink>
                            }
                            @if (canStaff)
                            {
                                <NavLink href="/master-data/staff-members" class="os-nav-link" title="@UiStrings.Nav.StaffMembers" @onclick="CloseNav">
                                    <RadzenIcon Icon="groups" />
                                    <span>@UiStrings.Nav.StaffMembers</span>
                                </NavLink>
                            }
                        </div>
                    </div>
                }
            </AuthorizeView>
        </nav>

        <div class="os-sidebar-foot">
            <span class="os-version-tag">@UiStrings.App.Version</span>
        </div>
    </aside>

    <div class="os-main">
        <header class="os-topbar">
            <div class="os-topbar-lead">
                <button type="button" class="os-icon-btn os-rail-toggle" aria-label="@UiStrings.Nav.ToggleMenu"
                        aria-expanded="@(!railCollapsed ? "true" : "false")" @onclick="ToggleRail">
                    <RadzenIcon Icon="menu" />
                </button>
                <button type="button" class="os-icon-btn os-nav-toggle" aria-label="@UiStrings.Nav.ToggleMenu" @onclick="ToggleNav">
                    <RadzenIcon Icon="menu" />
                </button>
                <span class="os-topbar-title">@UiStrings.App.Portal</span>
            </div>

            <div class="os-topbar-actions">
                @if (Auth.User is not null)
                {
                    <NotificationBell />
                }

                <button type="button" class="os-lang-btn" @onclick="ToggleLanguageAsync">
                    <RadzenIcon Icon="translate" />
                    <span>@LanguageLabel</span>
                </button>

                @if (Auth.User is { } current)
                {
                    <div class="os-profile @(profileOpen ? "os-profile--open" : null)">
                        <button type="button" class="os-user-chip" @onclick="ToggleProfile"
                                aria-haspopup="true" aria-expanded="@profileOpen">
                            <span class="os-avatar">@Initials(current.DisplayName)</span>
                            <span class="os-user-meta">
                                <strong>@current.DisplayName</strong>
                                <small class="os-muted">@current.RoleName</small>
                            </span>
                            <RadzenIcon Icon="expand_more" class="os-profile-chev" />
                        </button>

                        <div class="os-profile-backdrop" @onclick="CloseProfile"></div>

                        <div class="os-profile-panel">
                            <div class="os-profile-identity">
                                <span class="os-avatar os-avatar--lg">@Initials(current.DisplayName)</span>
                                <div class="os-profile-identity-text">
                                    <strong>@current.DisplayName</strong>
                                    <small class="os-muted">@current.Email</small>
                                </div>
                            </div>
                            <div class="os-profile-menu">
                                <button type="button" class="os-profile-item" @onclick="GoToAccountAsync">
                                    <RadzenIcon Icon="account_circle" />
                                    <span>@UiStrings.Account.Title</span>
                                </button>
                                <button type="button" class="os-profile-item os-profile-item--danger" @onclick="LogoutAsync">
                                    <RadzenIcon Icon="logout" />
                                    <span>@UiStrings.Common.SignOut</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </header>

        <section class="os-content">
            <div class="os-content-inner" @key="Locale.Language">
                @Body
            </div>
        </section>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private const string NavGroupAdministration = "administration";
    private const string NavGroupOperations = "operations";
    private const string NavGroupMasterData = "master-data";

    private bool navOpen;
    private bool railCollapsed;
    private bool profileOpen;
    private Guid? notificationUserId;
    private readonly HashSet<string> expandedNavGroups = new(StringComparer.Ordinal);

    private string LanguageLabel => Locale.Language == LocaleState.Arabic ? "EN" : "العربية";

    protected override async Task OnInitializedAsync()
    {
        await Locale.InitializeAsync();
        Auth.StateChanged += OnStateChanged;
        Locale.Changed += OnStateChanged;
        Navigation.LocationChanged += OnLocationChanged;
        NotificationsRealtime.NotificationReceived += OnNotificationReceived;
        NotificationsRealtime.Connected += OnNotificationsConnected;
        ExpandActiveNavGroup();
        RedirectToMfaEnrollmentIfNeeded();
        await SyncNotificationsForAuthAsync();
    }

    private void ToggleNav() => navOpen = !navOpen;

    private void CloseNav() => navOpen = false;

    private void ToggleRail()
    {
        railCollapsed = !railCollapsed;

        if (!railCollapsed)
            ExpandActiveNavGroup();
    }

    private void ToggleNavGroup(string group)
    {
        if (expandedNavGroups.Contains(group))
        {
            expandedNavGroups.Remove(group);
            return;
        }

        expandedNavGroups.Clear();
        expandedNavGroups.Add(group);
    }

    private bool IsNavGroupExpanded(string group) => expandedNavGroups.Contains(group);

    private string NavGroupClass(string group, bool isActive)
    {
        var classes = "os-nav-group";

        if (IsNavGroupExpanded(group))
            classes += " os-nav-group--open";

        if (isActive)
            classes += " os-nav-group--active";

        return classes;
    }

    private bool IsNavGroupActive(params string[] prefixes)
    {
        var path = CurrentPath;

        foreach (var prefix in prefixes)
        {
            if (string.Equals(path, prefix, StringComparison.OrdinalIgnoreCase) ||
                path.StartsWith($"{prefix}/", StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        return false;
    }

    private string CurrentPath
    {
        get
        {
            var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
            return relative.Split(['?', '#'], 2)[0].Trim('/');
        }
    }

    private void ExpandActiveNavGroup()
    {
        var activeGroup = CurrentActiveNavGroup();

        expandedNavGroups.Clear();

        if (activeGroup is not null)
            expandedNavGroups.Add(activeGroup);
    }

    private string? CurrentActiveNavGroup()
    {
        if (IsNavGroupActive("users", "roles", "audit"))
            return NavGroupAdministration;

        if (IsNavGroupActive("operations"))
            return NavGroupOperations;

        if (IsNavGroupActive("master-data"))
            return NavGroupMasterData;

        return null;
    }

    private void ToggleProfile() => profileOpen = !profileOpen;

    private void CloseProfile() => profileOpen = false;

    private async Task GoToAccountAsync()
    {
        profileOpen = false;
        Navigation.NavigateTo("/account");
        await Task.CompletedTask;
    }

    private async Task ToggleLanguageAsync()
    {
        await Locale.ToggleAsync();
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true, replace: true);
    }

    private async Task LogoutAsync()
    {
        profileOpen = false;
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }

    private bool RequiresMfaEnrollment =>
        Auth.User is { MfaEnrollmentRequired: true, MfaEnabled: false };

    private bool IsAccountRoute
    {
        get
        {
            var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
            var path = relative.Split(['?', '#'], 2)[0].TrimEnd('/');
            return string.Equals(path, "account", StringComparison.OrdinalIgnoreCase);
        }
    }

    private void RedirectToMfaEnrollmentIfNeeded()
    {
        if (RequiresMfaEnrollment && !IsAccountRoute)
            Navigation.NavigateTo("/account", replace: true);
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        try
        {
            await InvokeAsync(() =>
            {
                ExpandActiveNavGroup();
                RedirectToMfaEnrollmentIfNeeded();
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    private async void OnStateChanged()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                await SyncNotificationsForAuthAsync();
                ExpandActiveNavGroup();
                RedirectToMfaEnrollmentIfNeeded();
                StateHasChanged();
            });
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    private async Task SyncNotificationsForAuthAsync()
    {
        if (Auth.Status == AuthStatus.Authenticated && Auth.User is { } user)
        {
            if (notificationUserId == user.Id)
                return;

            if (notificationUserId is not null)
            {
                await NotificationsRealtime.StopAsync();
                NotificationCenter.Clear();
            }

            notificationUserId = user.Id;
            await NotificationCenter.InitializeAsync(user.Id);

            if (Auth.Status != AuthStatus.Authenticated || Auth.User?.Id != user.Id)
            {
                notificationUserId = null;
                NotificationCenter.Clear();
                return;
            }

            await NotificationsRealtime.StartAsync();
            return;
        }

        if (Auth.Status == AuthStatus.Anonymous && notificationUserId is not null)
        {
            notificationUserId = null;
            await NotificationsRealtime.StopAsync();
            NotificationCenter.Clear();
        }
    }

    private async void OnNotificationReceived(NotificationDto notification)
    {
        try
        {
            await InvokeAsync(async () =>
            {
                if (NotificationCenter.ApplyLive(notification))
                {
                    ToastNotifications.Notify(new NotificationMessage
                    {
                        Severity = NotificationSeverity.Info,
                        Summary = NotificationPresentation.Title(notification, Locale),
                        Detail = NotificationPresentation.Body(notification, Locale),
                        Duration = 7000,
                        ShowProgress = true,
                        CloseOnClick = true,
                        Payload = notification,
                        Click = OnToastClick
                    });
                }

                // A duplicate can be the delivery that exposes skew between the independently read
                // inbox page and unread count, so every hub message queues an authoritative pass.
                await NotificationCenter.ReconcileAfterSignalAsync();
            });
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    private async void OnNotificationsConnected()
    {
        try
        {
            await InvokeAsync(async () =>
            {
                if (Auth.Status == AuthStatus.Authenticated && notificationUserId == Auth.User?.Id)
                    await NotificationCenter.RefreshAsync();
            });
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    private async void OnToastClick(NotificationMessage message)
    {
        try
        {
            if (message.Payload is not NotificationDto notification)
                return;

            await InvokeAsync(async () =>
            {
                if (!notification.IsRead)
                {
                    try
                    {
                        await NotificationCenter.MarkAsReadAsync(notification.Id);
                    }
                    catch (Exception)
                    {
                        // Opening the flight is more important than a transient read-state failure.
                    }
                }

                Navigation.NavigateTo(NotificationPresentation.DeepLink(notification) ?? "/notifications");
            });
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    public async ValueTask DisposeAsync()
    {
        Auth.StateChanged -= OnStateChanged;
        Locale.Changed -= OnStateChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        NotificationsRealtime.NotificationReceived -= OnNotificationReceived;
        NotificationsRealtime.Connected -= OnNotificationsConnected;
        await NotificationsRealtime.StopAsync();
    }
}
