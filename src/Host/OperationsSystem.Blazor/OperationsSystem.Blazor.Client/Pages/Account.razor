@page "/account"
@implements IAsyncDisposable
@inject AuthSession Auth
@inject IdentityApiClient Identity
@inject NavigationManager Navigation
@inject NotificationService Notifications
@inject DialogService DialogService

<PageTitle>@UiStrings.Account.Title</PageTitle>

<RequireAuth>
    @if (Auth.User is { } user)
    {
        <div class="account-page">
            <PageHeader Title="@UiStrings.Account.Title" Description="Manage your account settings and security preferences" />

            <section class="account-summary-card">
                <div class="account-person">
                    <span class="account-avatar">@Initials(user.DisplayName)</span>
                    <div class="account-person-text">
                        <h2>@user.DisplayName</h2>
                        <span class="account-role-chip">@user.RoleName</span>
                        <p class="os-muted">@user.Email</p>
                    </div>
                </div>

                <span class="account-summary-divider"></span>

                <div class="account-stat-grid">
                    <div class="account-stat">
                        <span class="account-stat-icon"><RadzenIcon Icon="shield" /></span>
                        <div>
                            <span>@UiStrings.Account.Role</span>
                            <strong>@user.RoleName</strong>
                        </div>
                    </div>
                    <div class="account-stat">
                        <span class="account-stat-icon"><RadzenIcon Icon="mail" /></span>
                        <div>
                            <span>@UiStrings.Auth.Email</span>
                            <strong>@user.Email</strong>
                        </div>
                    </div>
                    <div class="account-stat">
                        <span class="account-stat-icon"><RadzenIcon Icon="vpn_key" /></span>
                        <div>
                            <span>@UiStrings.Account.Permissions</span>
                            <strong>@user.Permissions.Count</strong>
                        </div>
                    </div>
                </div>
            </section>

            <div class="account-security-grid">
                <section class="account-panel">
                    <div class="account-panel-head">
                        <span class="account-panel-icon"><RadzenIcon Icon="lock" /></span>
                        <div>
                            <h3>@UiStrings.Account.ChangePassword</h3>
                            <p class="os-muted">Update your password to keep your account secure</p>
                        </div>
                    </div>

                    <RadzenTemplateForm TItem="PasswordModel" Data="@password" Submit="@ChangePasswordAsync">
                        <div class="account-form-stack">
                            <RadzenFormField Text="@UiStrings.Account.CurrentPassword" Variant="Variant.Outlined" class="account-field">
                                <RadzenPassword @bind-Value="password.Current" class="account-control" />
                            </RadzenFormField>
                            <RadzenFormField Text="@UiStrings.Auth.NewPassword" Variant="Variant.Outlined" class="account-field">
                                <RadzenPassword @bind-Value="password.New" class="account-control" />
                            </RadzenFormField>
                            <RadzenFormField Text="@UiStrings.Auth.ConfirmPassword" Variant="Variant.Outlined" class="account-field">
                                <RadzenPassword @bind-Value="password.Confirm" class="account-control" />
                            </RadzenFormField>

                            @if (!string.IsNullOrWhiteSpace(passwordError))
                            {
                                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                                    @passwordError
                                </RadzenAlert>
                            }

                            <div class="account-actions">
                                <RadzenButton ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary"
                                              Icon="lock" Disabled="@isChangingPassword" Text="Update password" />
                            </div>
                        </div>
                    </RadzenTemplateForm>
                </section>

                <section class="account-panel">
                    <div class="account-panel-head account-panel-head--split">
                        <div class="account-panel-title">
                            <span class="account-panel-icon account-panel-icon--success"><RadzenIcon Icon="verified_user" /></span>
                            <div>
                                <h3>@UiStrings.Account.MfaTitle</h3>
                                <p class="os-muted">@MfaDescription(user)</p>
                            </div>
                        </div>
                        <StatusBadge Label="@MfaStatusLabel(user)" Tone="@MfaStatusTone(user)" />
                    </div>

                    <div class="account-feature-list">
                        <div class="account-feature">
                            <span><RadzenIcon Icon="security" /></span>
                            <div>
                                <strong>Enhanced security</strong>
                                <p class="os-muted">Add an extra layer of protection</p>
                            </div>
                        </div>
                        <div class="account-feature">
                            <span><RadzenIcon Icon="phone_iphone" /></span>
                            <div>
                                <strong>Authenticator app</strong>
                                <p class="os-muted">Use apps like Google Authenticator</p>
                            </div>
                        </div>
                        <div class="account-feature">
                            <span><RadzenIcon Icon="lock" /></span>
                            <div>
                                <strong>Account protection</strong>
                                <p class="os-muted">Protect against unauthorized access</p>
                            </div>
                        </div>
                    </div>

                    @if (user.MfaEnrollmentRequired && !user.MfaEnabled)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                            @UiStrings.Account.MfaRequiredHint
                        </RadzenAlert>
                    }

                    @if (mfaRecoveryCodes.Count > 0)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                            <strong>@UiStrings.Account.RecoveryCodesTitle</strong>
                            <div>@UiStrings.Account.RecoveryCodesHint</div>
                        </RadzenAlert>
                        <div class="account-recovery-grid">
                            @foreach (var recoveryCode in mfaRecoveryCodes)
                            {
                                <span class="os-mono" @key="recoveryCode">@recoveryCode</span>
                            }
                        </div>
                    }
                    else if (mfaEnrollment is not null)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                            @UiStrings.Account.MfaEnrollmentHint
                        </RadzenAlert>

                        <div class="account-mfa-setup">
                            <section class="account-mfa-panel account-mfa-panel--qr">
                                <div class="account-mfa-panel-heading">
                                    <span class="account-mfa-panel-icon"><RadzenIcon Icon="qr_code_2" /></span>
                                    <div>
                                        <h4>@UiStrings.Account.MfaScanTitle</h4>
                                        <p class="os-muted">@UiStrings.Account.MfaScanHint</p>
                                    </div>
                                </div>
                                <div class="account-mfa-qr">
                                    <RadzenQRCode Value="@mfaEnrollment.OtpAuthUri"
                                                  Size="13rem"
                                                  ModuleShape="QRCodeModuleShape.Rounded"
                                                  EyeShape="QRCodeEyeShape.Rounded" />
                                </div>
                            </section>

                            <section class="account-mfa-panel">
                                <div class="account-mfa-panel-heading">
                                    <span class="account-mfa-panel-icon"><RadzenIcon Icon="key" /></span>
                                    <div>
                                        <h4>@UiStrings.Account.MfaManualTitle</h4>
                                        <p class="os-muted">@UiStrings.Account.MfaManualHint</p>
                                    </div>
                                </div>
                                <DetailField Label="@UiStrings.Account.MfaSecret">
                                    <span class="account-mfa-secret os-mono">@mfaEnrollment.Secret</span>
                                </DetailField>
                            </section>
                        </div>

                        <RadzenTemplateForm TItem="MfaConfirmModel" Data="@mfaConfirm" Submit="@ConfirmMfaAsync">
                            <div class="account-form-stack">
                                <RadzenFormField Text="@UiStrings.Auth.MfaCode" Variant="Variant.Outlined" class="account-field">
                                    <RadzenTextBox @bind-Value="mfaConfirm.Code" class="account-control"
                                                   Immediate="true" AutoCompleteType="AutoCompleteType.OneTimeCode" />
                                </RadzenFormField>

                                @if (!string.IsNullOrWhiteSpace(mfaError))
                                {
                                    <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                                        @mfaError
                                    </RadzenAlert>
                                }

                                <div class="account-actions">
                                    <RadzenButton ButtonType="ButtonType.Submit" ButtonStyle="ButtonStyle.Primary"
                                                  Disabled="@isConfirmingMfa" Text="@UiStrings.Account.ConfirmMfa" />
                                </div>
                            </div>
                        </RadzenTemplateForm>
                    }
                    else if (!user.MfaEnabled)
                    {
                        @if (!string.IsNullOrWhiteSpace(mfaError))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                                @mfaError
                            </RadzenAlert>
                        }

                        <div class="account-actions">
                            <RadzenButton ButtonStyle="ButtonStyle.Light" Icon="verified_user"
                                          class="account-mfa-button" Disabled="@isStartingMfa"
                                          Text="Enable MFA" Click="@StartMfaEnrollmentAsync" />
                        </div>
                    }
                    else
                    {
                        @if (!string.IsNullOrWhiteSpace(mfaError))
                        {
                            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                                @mfaError
                            </RadzenAlert>
                        }

                        <div class="account-actions">
                            <RadzenButton ButtonStyle="ButtonStyle.Light" Icon="lock_open"
                                          Disabled="@isDisablingMfa" Text="@UiStrings.Account.TurnOffMfa"
                                          Click="@DisableMfaAsync" />
                        </div>
                    }
                </section>
            </div>

            <section class="account-panel account-panel--sessions">
                <div class="account-panel-head account-panel-head--split">
                    <div class="account-panel-title">
                        <span class="account-panel-icon account-panel-icon--muted"><RadzenIcon Icon="desktop_windows" /></span>
                        <div>
                            <h3>Active sessions</h3>
                            <p class="os-muted">@UiStrings.Account.SessionsDescription</p>
                        </div>
                    </div>
                    <RadzenButton Text="@UiStrings.Account.SignOutOthers" ButtonStyle="ButtonStyle.Light" Icon="logout"
                                  Disabled="@(sessionsTotalCount <= 1)" Click="@RevokeOthersAsync" />
                </div>

                @if (sessionsLoading)
                {
                    <LoadingCard />
                }
                else if (sessionsError)
                {
                    <ErrorState OnRetry="@LoadSessionsAsync" />
                }
                else if (sessions is null || sessions.Count == 0)
                {
                    <EmptyState Title="@UiStrings.Sessions.Empty" Icon="devices" />
                }
                else
                {
                    <RadzenDataGrid Data="@sessions" TItem="UserSession" Count="@sessionsTotalCount"
                                    LoadData="@LoadSessionsDataAsync" AllowPaging="true" PageSize="@sessionsPageSize"
                                    PageSizeOptions="@PageSizes" ShowPagingSummary="true"
                                    IsLoading="@sessionsLoading" GridLines="DataGridGridLines.Horizontal"
                                    class="account-sessions-grid">
                        <Columns>
                            <RadzenDataGridColumn TItem="UserSession" Title="@UiStrings.Sessions.Device">
                                <Template Context="session">
                                    <div class="account-session-device">
                                        <span class="account-session-icon"><RadzenIcon Icon="desktop_windows" /></span>
                                        <div>
                                            <strong>@SessionDeviceTitle(session)</strong>
                                            <span class="os-muted">@SessionDeviceSubtitle(session)</span>
                                        </div>
                                        @if (session.IsCurrent)
                                        {
                                            <StatusBadge Label="@UiStrings.Account.ThisDevice" Tone="success" />
                                        }
                                    </div>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="UserSession" Property="CreatedByIp" Title="@UiStrings.Sessions.IpAddress" Width="160px" />
                            <RadzenDataGridColumn TItem="UserSession" Title="@UiStrings.Sessions.Created" Width="210px">
                                <Template Context="session">@session.CreatedAtUtc.ToLocalTime().ToString("g")</Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="UserSession" Title="@UiStrings.Sessions.State" Width="130px">
                                <Template Context="session">
                                    @if (session.IsActive)
                                    {
                                        <StatusBadge Label="@UiStrings.Sessions.Active" Tone="success" />
                                    }
                                    else
                                    {
                                        <StatusBadge Label="@UiStrings.Sessions.Revoked" Tone="neutral" />
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="UserSession" Title="@UiStrings.Common.Actions" Width="120px" Sortable="false" TextAlign="TextAlign.Center">
                                <Template Context="session">
                                    @if (session is { IsActive: true, IsCurrent: false })
                                    {
                                        <RadzenButton Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text"
                                                      Text="@UiStrings.Account.RevokeSession" Click="@(() => RevokeSessionAsync(session.Id))" />
                                    }
                                    else
                                    {
                                        <span class="os-muted">-</span>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
            </section>
        </div>
    }
</RequireAuth>

@code {
    private readonly PasswordModel password = new();
    private readonly MfaConfirmModel mfaConfirm = new();
    private bool isChangingPassword;
    private string? passwordError;
    private bool isStartingMfa;
    private bool isConfirmingMfa;
    private bool isDisablingMfa;
    private string? mfaError;
    private MfaEnrollment? mfaEnrollment;
    private IReadOnlyList<string> mfaRecoveryCodes = [];

    private IReadOnlyList<UserSession>? sessions;
    private static readonly int[] PageSizes = [10, 25, 50, 100];
    private int sessionsTotalCount;
    private int sessionsPage = 1;
    private int sessionsPageSize = 10;
    private bool sessionsLoading = true;
    private bool sessionsError;

    protected override void OnInitialized() => Auth.StateChanged += OnAuthStateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadSessionsAsync();
    }

    private async Task LoadSessionsAsync()
    {
        sessionsPage = 1;
        await LoadSessionsCoreAsync();
    }

    private async Task LoadSessionsDataAsync(LoadDataArgs args)
    {
        sessionsPageSize = args.Top ?? sessionsPageSize;
        sessionsPage = ((args.Skip ?? 0) / Math.Max(sessionsPageSize, 1)) + 1;
        await LoadSessionsCoreAsync();
    }

    private async Task LoadSessionsCoreAsync()
    {
        sessionsLoading = true;
        sessionsError = false;
        StateHasChanged();

        try
        {
            var result = await Identity.GetMySessionsAsync(sessionsPage, sessionsPageSize);
            sessions = result.Items;
            sessionsTotalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            sessionsError = true;
            sessions = [];
            sessionsTotalCount = 0;
        }
        finally
        {
            sessionsLoading = false;
            StateHasChanged();
        }
    }

    private async Task ChangePasswordAsync()
    {
        passwordError = null;

        if (password.New.Length < 8)
        {
            passwordError = UiStrings.Auth.PasswordTooShort;
            return;
        }

        if (password.New != password.Confirm)
        {
            passwordError = UiStrings.Auth.PasswordsDoNotMatch;
            return;
        }

        isChangingPassword = true;

        try
        {
            await Identity.ChangePasswordAsync(new ChangePasswordRequest(password.Current, password.New));
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Account.PasswordChanged);
            await Auth.LogoutAsync();
            Navigation.NavigateTo("/login", replace: true);
        }
        catch (ApiException ex)
        {
            passwordError = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isChangingPassword = false;
        }
    }

    private async Task RevokeSessionAsync(Guid sessionId)
    {
        try
        {
            await Identity.RevokeMySessionAsync(sessionId);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Account.RevokeSession);
            await LoadSessionsAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task RevokeOthersAsync()
    {
        try
        {
            await Identity.RevokeMyOtherSessionsAsync();
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Account.SignOutOthers);
            await LoadSessionsAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task StartMfaEnrollmentAsync()
    {
        mfaError = null;
        mfaRecoveryCodes = [];
        isStartingMfa = true;

        try
        {
            mfaEnrollment = await Identity.EnrollMfaAsync();
            mfaConfirm.Code = string.Empty;
        }
        catch (ApiException ex)
        {
            mfaError = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isStartingMfa = false;
        }
    }

    private async Task ConfirmMfaAsync()
    {
        mfaError = null;

        if (string.IsNullOrWhiteSpace(mfaConfirm.Code))
        {
            mfaError = UiStrings.Auth.MfaCodeRequired;
            return;
        }

        isConfirmingMfa = true;

        try
        {
            var recovery = await Identity.ConfirmMfaAsync(new ConfirmMfaRequest(mfaConfirm.Code.Trim()));
            mfaRecoveryCodes = recovery.RecoveryCodes;
            mfaEnrollment = null;
            mfaConfirm.Code = string.Empty;
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Account.MfaEnabled);
            await Auth.ReloadUserAsync();
        }
        catch (ApiException ex)
        {
            mfaError = ex.StatusCode is 400 or 401
                ? UiStrings.Auth.InvalidMfaCode
                : ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isConfirmingMfa = false;
        }
    }

    private async Task DisableMfaAsync()
    {
        mfaError = null;

        var confirmed = await DialogService.Confirm(UiStrings.Account.ConfirmDisableMfa, UiStrings.Account.TurnOffMfa,
            new ConfirmOptions { OkButtonText = UiStrings.Account.TurnOffMfa, CancelButtonText = UiStrings.Common.Cancel });
        if (confirmed is not true)
            return;

        isDisablingMfa = true;

        try
        {
            await Identity.DisableMfaAsync();
            mfaEnrollment = null;
            mfaRecoveryCodes = [];
            mfaConfirm.Code = string.Empty;
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Account.MfaDisabled);
            await Auth.ReloadUserAsync();
        }
        catch (ApiException ex)
        {
            mfaError = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isDisablingMfa = false;
        }
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }

    private static string SessionDeviceTitle(UserSession session)
    {
        if (string.IsNullOrWhiteSpace(session.UserAgent))
            return UiStrings.Common.None;

        var userAgent = session.UserAgent.Trim();
        var closeParen = userAgent.IndexOf(')', StringComparison.Ordinal);
        if (closeParen > 0)
            return userAgent[..(closeParen + 1)];

        return userAgent.Length <= 72 ? userAgent : userAgent[..72];
    }

    private static string SessionDeviceSubtitle(UserSession session)
    {
        if (string.IsNullOrWhiteSpace(session.UserAgent))
            return UiStrings.Common.None;

        var userAgent = session.UserAgent.Trim();
        var closeParen = userAgent.IndexOf(')', StringComparison.Ordinal);
        var subtitle = closeParen >= 0 && closeParen + 1 < userAgent.Length
            ? userAgent[(closeParen + 1)..].Trim()
            : userAgent;

        return subtitle.Length <= 72 ? subtitle : subtitle[..72];
    }

    private static string MfaStatusLabel(AuthenticatedUser user)
    {
        if (user.MfaEnabled)
            return UiStrings.Users.MfaEnabled;

        return user.MfaEnrollmentRequired
            ? UiStrings.Users.MfaRequired
            : UiStrings.Users.MfaNotEnabled;
    }

    private static string MfaStatusTone(AuthenticatedUser user) =>
        user.MfaEnabled ? "success" : (user.MfaEnrollmentRequired ? "warning" : "neutral");

    private static string MfaDescription(AuthenticatedUser user)
    {
        if (user.MfaEnabled)
            return UiStrings.Account.MfaEnabledHint;

        return user.MfaEnrollmentRequired
            ? UiStrings.Account.MfaRequiredHint
            : UiStrings.Account.MfaOptionalHint;
    }

    private async void OnAuthStateChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    public ValueTask DisposeAsync()
    {
        Auth.StateChanged -= OnAuthStateChanged;
        return ValueTask.CompletedTask;
    }

    private sealed class PasswordModel
    {
        public string Current { get; set; } = string.Empty;
        public string New { get; set; } = string.Empty;
        public string Confirm { get; set; } = string.Empty;
    }

    private sealed class MfaConfirmModel
    {
        public string Code { get; set; } = string.Empty;
    }
}
