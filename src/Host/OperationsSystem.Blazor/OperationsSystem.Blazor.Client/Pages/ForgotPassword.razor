@page "/forgot-password"
@layout AuthLayout
@inject IdentityApiClient Identity
@inject NavigationManager Navigation

<PageTitle>@UiStrings.Auth.ForgotPasswordTitle</PageTitle>

<RadzenCard>
    <RadzenStack Gap="1.25rem">
        <div>
            <h1 class="os-page-title">@UiStrings.Auth.ForgotPasswordTitle</h1>
            <p class="os-muted">@UiStrings.Auth.ForgotPasswordSubtitle</p>
        </div>

        @if (submitted)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                @UiStrings.Auth.ForgotPasswordSuccess
            </RadzenAlert>
            <RadzenButton ButtonStyle="ButtonStyle.Primary" Text="@UiStrings.Auth.GoToSignIn"
                          Click="@(() => Navigation.NavigateTo("/login"))" Style="width: 100%;" />
        }
        else
        {
            <RadzenTemplateForm TItem="ForgotPasswordModel" Data="@model" Submit="@SubmitAsync">
                <RadzenStack Gap="1rem">
                    <RadzenFormField Text="@UiStrings.Auth.Email" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="model.Email" Name="email" autofocus Style="width: 100%;"
                                       Immediate="true" AutoCompleteType="AutoCompleteType.Username" />
                    </RadzenFormField>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                            @errorMessage
                        </RadzenAlert>
                    }

                    <RadzenButton ButtonType="ButtonType.Submit"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Disabled="@isSubmitting"
                                  Text="@UiStrings.Auth.ForgotPasswordButton"
                                  Style="width: 100%;" />
                    <RadzenButton ButtonType="ButtonType.Button"
                                  ButtonStyle="ButtonStyle.Light"
                                  Disabled="@isSubmitting"
                                  Text="@UiStrings.Auth.GoToSignIn"
                                  Click="@(() => Navigation.NavigateTo("/login"))" />
                </RadzenStack>
            </RadzenTemplateForm>
        }
    </RadzenStack>
</RadzenCard>

@code {
    private readonly ForgotPasswordModel model = new();
    private bool isSubmitting;
    private bool submitted;
    private string? errorMessage;

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Email))
        {
            errorMessage = UiStrings.Auth.EmailRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            await Identity.ForgotPasswordAsync(new ForgotPasswordRequest(model.Email.Trim()));
            submitted = true;
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ForgotPasswordModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
