@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<PageHeader Title="Something went wrong" Description="An error occurred while processing your request." />

@if (!string.IsNullOrEmpty(requestId))
{
    <p class="os-muted">Request ID: <code>@requestId</code></p>
}

<RadzenButton Text="Back to dashboard" ButtonStyle="ButtonStyle.Primary" Icon="home"
              Click="@(() => Navigation.NavigateTo("/"))" />

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string? requestId;

    protected override void OnInitialized() => requestId = Activity.Current?.Id;
}
