@page "/login"
@layout AuthLayout
@implements IAsyncDisposable
@inject AuthSession Auth
@inject NavigationManager Navigation

<PageTitle>@UiStrings.Auth.SignInTitle</PageTitle>

<RadzenCard>
    <RadzenStack Gap="1.25rem">
        <div>
            <h1 class="os-page-title">@UiStrings.Auth.SignInTitle</h1>
            <p class="os-muted">@UiStrings.Auth.SignInSubtitle</p>
        </div>

        @if (Auth.Status is AuthStatus.Loading)
        {
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        }
        else
        {
            <RadzenTemplateForm TItem="LoginModel" Data="@model" Submit="@SubmitAsync">
                <RadzenStack Gap="1rem">
                    @if (awaitingMfa)
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                            <strong>@UiStrings.Auth.MfaTitle</strong>
                            <div>@UiStrings.Auth.MfaSubtitle</div>
                        </RadzenAlert>

                        <RadzenFormField Text="@UiStrings.Auth.MfaCode" Variant="Variant.Outlined">
                            <RadzenTextBox @bind-Value="model.MfaCode" Name="mfaCode" autofocus Style="width: 100%;"
                                           AutoCompleteType="AutoCompleteType.OneTimeCode" />
                        </RadzenFormField>
                    }
                    else
                    {
                        <RadzenFormField Text="@UiStrings.Auth.Email" Variant="Variant.Outlined">
                            <RadzenTextBox @bind-Value="model.Email" Name="email" autofocus Style="width: 100%;"
                                           AutoCompleteType="AutoCompleteType.Username" />
                        </RadzenFormField>

                        <RadzenFormField Text="@UiStrings.Auth.Password" Component="password" Variant="Variant.Outlined">
                            <ChildContent>
                                <RadzenTextBox @bind-Value="model.Password"
                                               Name="password"
                                               type="@(passwordVisible ? "text" : "password")"
                                               Style="width: 100%;"
                                               AutoCompleteType="AutoCompleteType.CurrentPassword" />
                            </ChildContent>
                            <End>
                                <RadzenButton ButtonType="ButtonType.Button"
                                              ButtonStyle="ButtonStyle.Light"
                                              Variant="Variant.Text"
                                              Size="ButtonSize.Small"
                                              Icon="@(passwordVisible ? "visibility_off" : "visibility")"
                                              Click="@TogglePasswordVisibility"
                                              class="login-password-toggle"
                                              title="@PasswordVisibilityLabel"
                                              aria-label="@PasswordVisibilityLabel" />
                            </End>
                        </RadzenFormField>
                    }

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                            @errorMessage
                        </RadzenAlert>
                    }

                    <RadzenStack Gap="0.75rem">
                        <RadzenButton ButtonType="ButtonType.Submit"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Disabled="@isSubmitting"
                                      Text="@(awaitingMfa ? UiStrings.Auth.VerifyMfaButton : UiStrings.Auth.SignInButton)"
                                      Style="width: 100%;" />
                        @if (awaitingMfa)
                        {
                            <RadzenButton ButtonType="ButtonType.Button"
                                          ButtonStyle="ButtonStyle.Light"
                                          Disabled="@isSubmitting"
                                          Text="@UiStrings.Auth.BackToPassword"
                                          Click="@ResetMfaChallenge" />
                        }
                        else
                        {
                            <RadzenButton ButtonType="ButtonType.Button"
                                          ButtonStyle="ButtonStyle.Light"
                                          Disabled="@isSubmitting"
                                          Text="@UiStrings.Auth.ForgotPasswordLink"
                                          Click="@(() => Navigation.NavigateTo("/forgot-password"))" />
                        }
                    </RadzenStack>
                </RadzenStack>
            </RadzenTemplateForm>
        }
    </RadzenStack>
</RadzenCard>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")] private string? ReturnUrl { get; set; }

    private readonly LoginModel model = new();
    private bool isSubmitting;
    private bool awaitingMfa;
    private bool passwordVisible;
    private string? mfaToken;
    private string? errorMessage;

    private string PasswordVisibilityLabel => passwordVisible
        ? UiStrings.Auth.HidePassword
        : UiStrings.Auth.ShowPassword;

    protected override void OnInitialized() => Auth.StateChanged += OnAuthStateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Auth.InitializeAsync();

        if (Auth.Status is AuthStatus.Authenticated)
            NavigateAfterLogin();
    }

    private async Task SubmitAsync()
    {
        if (awaitingMfa)
            await SubmitMfaAsync();
        else
            await SubmitPasswordAsync();
    }

    private async Task SubmitPasswordAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Email) || string.IsNullOrWhiteSpace(model.Password))
        {
            errorMessage = UiStrings.Auth.CredentialsRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            var outcome = await Auth.LoginAsync(model.Email, model.Password);
            if (outcome.MfaRequired)
            {
                awaitingMfa = true;
                passwordVisible = false;
                mfaToken = outcome.MfaToken;
                model.Password = string.Empty;
                return;
            }

            NavigateAfterLogin();
        }
        catch (ApiException ex) when (ex.IsUnauthorized)
        {
            errorMessage = ex.ProblemCode == "Identity.Auth.LockedOut"
                ? UiStrings.Auth.AccountLocked
                : UiStrings.Auth.InvalidCredentials;
        }
        catch (ApiException)
        {
            errorMessage = UiStrings.Common.SomethingWentWrong;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task SubmitMfaAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.MfaCode) || string.IsNullOrWhiteSpace(mfaToken))
        {
            errorMessage = UiStrings.Auth.MfaCodeRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            await Auth.CompleteMfaLoginAsync(mfaToken, model.MfaCode.Trim());
            NavigateAfterLogin();
        }
        catch (ApiException ex) when (ex.IsUnauthorized || ex.StatusCode == 400)
        {
            errorMessage = UiStrings.Auth.InvalidMfaCode;
        }
        catch (ApiException)
        {
            errorMessage = UiStrings.Common.SomethingWentWrong;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void ResetMfaChallenge()
    {
        awaitingMfa = false;
        passwordVisible = false;
        mfaToken = null;
        model.MfaCode = string.Empty;
        errorMessage = null;
    }

    private void TogglePasswordVisibility() => passwordVisible = !passwordVisible;

    private void NavigateAfterLogin()
    {
        Navigation.NavigateTo(SafeReturnUrl(), replace: true);
    }

    private string SafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
            return "/";

        var candidate = ReturnUrl.Trim();
        if (candidate.StartsWith("//", StringComparison.Ordinal) ||
            candidate.Contains('\\') ||
            !Uri.TryCreate(candidate, UriKind.Relative, out _))
        {
            return "/";
        }

        if (!candidate.StartsWith("/", StringComparison.Ordinal))
            candidate = "/" + candidate;

        var path = candidate.Split(['?', '#'], 2)[0].Trim('/');
        return string.Equals(path, "login", StringComparison.OrdinalIgnoreCase)
            ? "/"
            : candidate;
    }

    private async void OnAuthStateChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            await DispatchExceptionAsync(ex);
        }
    }

    public ValueTask DisposeAsync()
    {
        Auth.StateChanged -= OnAuthStateChanged;
        return ValueTask.CompletedTask;
    }

    private sealed class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string MfaCode { get; set; } = string.Empty;
    }
}
