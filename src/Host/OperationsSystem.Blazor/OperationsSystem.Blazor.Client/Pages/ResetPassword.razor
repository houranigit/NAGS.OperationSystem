@page "/reset-password"
@layout AuthLayout
@inject IdentityApiClient Identity
@inject NavigationManager Navigation

<PageTitle>@UiStrings.Auth.ResetPasswordTitle</PageTitle>

<RadzenCard>
    <RadzenStack Gap="1.25rem">
        <div>
            <h1 class="os-page-title">@UiStrings.Auth.ResetPasswordTitle</h1>
            <p class="os-muted">@UiStrings.Auth.ResetPasswordSubtitle</p>
        </div>

        @if (resetComplete)
        {
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                @UiStrings.Auth.ResetPasswordSuccess
            </RadzenAlert>
            <RadzenButton ButtonStyle="ButtonStyle.Primary" Text="@UiStrings.Auth.GoToSignIn"
                          Click="@(() => Navigation.NavigateTo("/login"))" Style="width: 100%;" />
        }
        else
        {
            <RadzenTemplateForm TItem="ResetPasswordModel" Data="@model" Submit="@SubmitAsync">
                <RadzenStack Gap="1rem">
                    @if (!string.IsNullOrWhiteSpace(EmailQuery))
                    {
                        <DetailField Label="@UiStrings.Auth.Email" Value="@EmailQuery" />
                    }

                    <RadzenFormField Text="@UiStrings.Auth.NewPassword" Variant="Variant.Outlined">
                        <RadzenPassword @bind-Value="model.Password" Style="width: 100%;" />
                    </RadzenFormField>

                    <RadzenFormField Text="@UiStrings.Auth.ConfirmPassword" Variant="Variant.Outlined">
                        <RadzenPassword @bind-Value="model.ConfirmPassword" Style="width: 100%;" />
                    </RadzenFormField>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                            @errorMessage
                        </RadzenAlert>
                    }

                    <RadzenButton ButtonType="ButtonType.Submit"
                                  ButtonStyle="ButtonStyle.Primary"
                                  Disabled="@isSubmitting"
                                  Text="@UiStrings.Auth.ResetPasswordButton"
                                  Style="width: 100%;" />
                </RadzenStack>
            </RadzenTemplateForm>
        }
    </RadzenStack>
</RadzenCard>

@code {
    [SupplyParameterFromQuery(Name = "email")] private string? EmailQuery { get; set; }
    [SupplyParameterFromQuery(Name = "token")] private string? TokenQuery { get; set; }

    private readonly ResetPasswordModel model = new();
    private bool isSubmitting;
    private bool resetComplete;
    private string? errorMessage;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(TokenQuery) && string.IsNullOrWhiteSpace(model.Token))
            model.Token = TokenQuery;
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Token))
        {
            errorMessage = UiStrings.Auth.ResetPasswordInvalidLink;
            return;
        }

        if (model.Password.Length < 8)
        {
            errorMessage = UiStrings.Auth.PasswordTooShort;
            return;
        }

        if (model.Password != model.ConfirmPassword)
        {
            errorMessage = UiStrings.Auth.PasswordsDoNotMatch;
            return;
        }

        isSubmitting = true;

        try
        {
            await Identity.ResetPasswordAsync(new ResetPasswordRequest(model.Token, model.Password));
            resetComplete = true;
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Auth.ResetPasswordInvalidLink);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ResetPasswordModel
    {
        public string Token { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
