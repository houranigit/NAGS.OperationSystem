@page "/users"
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject GridPreferences GridPrefs

<PageTitle>@UiStrings.Users.Title</PageTitle>

<RequirePermission Permission="@IdentityPermissions.UsersView">
    <div class="os-list-page">
        <PageHeader Title="@UiStrings.Users.Title" Description="@UiStrings.Users.Description">
            <Actions>
                <AuthorizeView Context="invite">
                    @if (invite.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.UsersInvite))
                    {
                        <RadzenButton Text="@UiStrings.Users.Invite" Icon="person_add" ButtonStyle="ButtonStyle.Primary" Click="@OpenInviteAsync" />
                    }
                </AuthorizeView>
            </Actions>
        </PageHeader>

        <DataListCard @ref="list" TItem="UserListItem" Data="@users" Count="@totalCount" IsLoading="@isLoading"
                      HasError="@loadError" OnRetry="@ReloadAsync" LoadData="@LoadDataAsync"
                      PageSize="@currentPageSize" PageSizeChanged="@OnPageSizeChangedAsync"
                      SearchValue="@searchTerm" SearchValueChanged="@(v => searchTerm = v)" OnSearch="@ReloadAsync"
                      SearchPlaceholder="@UiStrings.Users.SearchPlaceholder"
                      CountLabel="@UiStrings.Users.CountLabel" EmptyText="@UiStrings.Users.Empty">
            <Filters>
                <DataListFilter TValue="string" Placeholder="@UiStrings.Users.FilterByStatus"
                                Data="@statusOptions" Value="@statusFilter" ValueChanged="@OnStatusFilterChangedAsync" />
                <DataListFilter TValue="Guid?" Placeholder="@UiStrings.Users.FilterByRole"
                                Data="@roleOptions" Value="@roleFilter" ValueChanged="@OnRoleFilterChangedAsync" />
            </Filters>
            <Columns>
                <RadzenDataGridColumn TItem="UserListItem" Property="DisplayName" Title="@UiStrings.Users.DisplayName">
                    <Template Context="user">
                        <div class="os-user-cell">
                            <span class="os-user-cell-avatar">@Initials(user.DisplayName)</span>
                            <div class="os-user-cell-text">
                                <strong>@user.DisplayName</strong>
                                <span class="os-muted">@user.Email</span>
                            </div>
                        </div>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UserListItem" Title="@UiStrings.Users.Status" Sortable="false" Width="140px">
                    <Template Context="user">
                        @if (user.IsLockedOut)
                        {
                            <StatusBadge Label="@UiStrings.Users.LockedOut" Tone="danger" />
                        }
                        else
                        {
                            <StatusBadge Label="@user.Status" Tone="@StatusTone(user.Status)" />
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UserListItem" Property="RoleName" Title="@UiStrings.Users.Role" Width="180px" />
                <RadzenDataGridColumn TItem="UserListItem" Title="@UiStrings.Users.LastLogin" Sortable="false" Width="170px">
                    <Template Context="user">
                        @(user.LastLoginAtUtc is { } at ? at.ToLocalTime().ToString("g") : UiStrings.Users.Never)
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
            <RowActions Context="user">
                <RowActionMenu>
                    <RowAction Text="@UiStrings.Common.Open" Icon="visibility" OnClick="@(() => OpenUser(user.Id))" />
                    <RowAction Text="@UiStrings.Common.Edit" Icon="edit" Permission="@IdentityPermissions.UsersUpdate"
                               OnClick="@(() => OpenEditAsync(user))" />
                    <RowAction Text="@UiStrings.Users.AssignRole" Icon="badge" Permission="@IdentityPermissions.UsersAssignRole"
                               OnClick="@(() => OpenAssignRoleAsync(user))" />
                    <RowAction Text="@UiStrings.Users.ResendInvitation" Icon="mail" Permission="@IdentityPermissions.UsersInvite"
                               Visible="@(user.Status == "Invited")" OnClick="@(() => ResendInvitationAsync(user))" />
                    <RowAction Separator="true" />
                    <RowAction Text="@UiStrings.Users.Unlock" Icon="lock_open" Permission="@IdentityPermissions.UsersUnlock"
                               Visible="@user.IsLockedOut" OnClick="@(() => UnlockAsync(user))" />
                    <RowAction Text="@UiStrings.Users.Lock" Icon="lock" Permission="@IdentityPermissions.UsersLock"
                               Visible="@(!user.IsLockedOut)" OnClick="@(() => LockAsync(user))" />
                    <RowAction Text="@UiStrings.Users.Deactivate" Icon="person_off" Danger="true"
                               Permission="@IdentityPermissions.UsersDeactivate"
                               Visible="@(user.Status != "Deactivated")" OnClick="@(() => DeactivateAsync(user))" />
                </RowActionMenu>
            </RowActions>
        </DataListCard>
    </div>
</RequirePermission>

@code {
    private const string GridKey = "users";
    private static readonly int[] PageSizes = [10, 25, 50, 100];

    private DataListCard<UserListItem>? list;
    private IReadOnlyList<UserListItem> users = [];
    private int totalCount;
    private int currentPage = 1;
    private int currentPageSize = 10;
    private bool isLoading;
    private bool loadError;

    private string searchTerm = string.Empty;
    private string? statusFilter;
    private Guid? roleFilter;
    private string? currentSort;

    private readonly List<StatusOption> statusOptions =
    [
        new("Invited", "Invited"),
        new("Active", "Active"),
        new("Deactivated", "Deactivated")
    ];

    private List<RoleOption> roleOptions = [];

    protected override async Task OnInitializedAsync()
    {
        currentPageSize = await GridPrefs.GetPageSizeAsync(GridKey, currentPageSize, PageSizes);
        await LoadRoleOptionsAsync();
        await FetchAsync();
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        currentPageSize = pageSize;
        await GridPrefs.SetPageSizeAsync(GridKey, pageSize);
    }

    private async Task OnStatusFilterChangedAsync(string? value)
    {
        statusFilter = value;
        await ReloadAsync();
    }

    private async Task OnRoleFilterChangedAsync(Guid? value)
    {
        roleFilter = value;
        await ReloadAsync();
    }

    private async Task LoadRoleOptionsAsync()
    {
        try
        {
            var roles = await Identity.GetRolesAsync(1, 100, null);
            roleOptions = [.. roles.Items.Select(r => new RoleOption(r.Name, r.Id))];
        }
        catch (ApiException)
        {
            // Filter is optional; leave just the "all" entry if roles can't be loaded.
        }
    }

    private async Task LoadDataAsync(LoadDataArgs args)
    {
        currentPageSize = args.Top ?? currentPageSize;
        currentPage = ((args.Skip ?? 0) / Math.Max(currentPageSize, 1)) + 1;
        currentSort = SortBuilder.From(args);
        await FetchAsync();
    }

    private async Task FetchAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            var result = await Identity.GetUsersAsync(currentPage, currentPageSize,
                string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm, statusFilter, roleFilter, currentSort);
            users = result.Items;
            totalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadAsync()
    {
        currentPage = 1;
        if (list is not null)
            await list.ReloadAsync();
        else
            await FetchAsync();
    }

    private async Task OpenInviteAsync()
    {
        var result = await DialogService.OpenAsync<InviteUserDialog>(UiStrings.Users.InviteTitle);
        if (result is true)
            await ReloadAsync();
    }

    private void OpenUser(Guid id) => Navigation.NavigateTo($"/users/{id}");

    private async Task OpenEditAsync(UserListItem user)
    {
        var result = await DialogService.OpenAsync<EditUserDialog>(UiStrings.Users.EditTitle,
            new Dictionary<string, object?> { [nameof(EditUserDialog.UserId)] = user.Id, [nameof(EditUserDialog.DisplayName)] = user.DisplayName });

        if (result is true)
            await ReloadAsync();
    }

    private async Task OpenAssignRoleAsync(UserListItem user)
    {
        var result = await DialogService.OpenAsync<AssignRoleDialog>(UiStrings.Users.AssignRoleTitle,
            new Dictionary<string, object?> { [nameof(AssignRoleDialog.UserId)] = user.Id, [nameof(AssignRoleDialog.CurrentRoleId)] = user.RoleId });

        if (result is true)
            await ReloadAsync();
    }

    private Task ResendInvitationAsync(UserListItem user) =>
        RunActionAsync(() => Identity.ResendInvitationAsync(user.Id), UiStrings.Users.ResendInvitation);

    private Task UnlockAsync(UserListItem user) =>
        RunActionAsync(() => Identity.UnlockUserAsync(user.Id), UiStrings.Users.Unlock);

    private async Task LockAsync(UserListItem user)
    {
        if (await Confirm(UiStrings.Users.ConfirmLock))
            await RunActionAsync(() => Identity.LockUserAsync(user.Id), UiStrings.Users.Lock);
    }

    private async Task DeactivateAsync(UserListItem user)
    {
        if (await Confirm(UiStrings.Users.ConfirmDeactivate))
            await RunActionAsync(() => Identity.DeactivateUserAsync(user.Id), UiStrings.Users.Deactivate);
    }

    private async Task RunActionAsync(Func<Task> action, string successMessage)
    {
        try
        {
            await action();
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task<bool> Confirm(string message) =>
        await DialogService.Confirm(message, UiStrings.Common.Confirm,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }

    private static string StatusTone(string status) => status switch
    {
        "Active" => "success",
        "Invited" => "warning",
        "Deactivated" => "neutral",
        _ => "neutral"
    };

    private sealed record StatusOption(string Label, string? Value);
    private sealed record RoleOption(string Label, Guid? Value);
}
