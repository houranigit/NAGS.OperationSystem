@page "/users"
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject NavigationManager Navigation
@inject GridPreferences GridPrefs

<PageTitle>@UiStrings.Users.Title</PageTitle>

<RequirePermission Permission="@IdentityPermissions.UsersView">
    <div class="os-list-page">
        <PageHeader Title="@UiStrings.Users.Title" Description="@UiStrings.Users.Description">
            <Actions>
                <AuthorizeView Context="invite">
                    @if (invite.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.UsersInvite))
                    {
                        <RadzenButton Text="@UiStrings.Users.Invite" Icon="person_add" ButtonStyle="ButtonStyle.Primary" Click="@OpenInviteAsync" />
                    }
                </AuthorizeView>
            </Actions>
        </PageHeader>

        <DataListCard @ref="list" TItem="UserListItem" Data="@users" Count="@totalCount" IsLoading="@isLoading"
                      HasError="@loadError" OnRetry="@ReloadAsync" LoadData="@LoadDataAsync"
                      PageSize="@currentPageSize" PageSizeChanged="@OnPageSizeChangedAsync"
                      SearchValue="@searchTerm" SearchValueChanged="@(v => searchTerm = v)" OnSearch="@ReloadAsync"
                      SearchPlaceholder="@UiStrings.Users.SearchPlaceholder"
                      CountLabel="@UiStrings.Users.CountLabel" EmptyText="@UiStrings.Users.Empty">
            <Filters>
                <RadzenDropDown @bind-Value="statusFilter" Data="@statusOptions" TextProperty="Label" ValueProperty="Value"
                                Change="@(async _ => await ReloadAsync())" Style="min-width: 11rem;" />
                <RadzenDropDown @bind-Value="roleFilter" Data="@roleOptions" TextProperty="Label" ValueProperty="Value"
                                Change="@(async _ => await ReloadAsync())" Style="min-width: 11rem;" />
            </Filters>
            <Columns>
                <RadzenDataGridColumn TItem="UserListItem" Property="DisplayName" Title="@UiStrings.Users.DisplayName">
                    <Template Context="user">
                        <div class="os-user-cell">
                            <span class="os-user-cell-avatar">@Initials(user.DisplayName)</span>
                            <div class="os-user-cell-text">
                                <strong>@user.DisplayName</strong>
                                <span class="os-muted">@user.Email</span>
                            </div>
                        </div>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UserListItem" Title="@UiStrings.Users.Status" Sortable="false" Width="140px">
                    <Template Context="user">
                        @if (user.IsLockedOut)
                        {
                            <StatusBadge Label="@UiStrings.Users.LockedOut" Tone="danger" />
                        }
                        else
                        {
                            <StatusBadge Label="@user.Status" Tone="@StatusTone(user.Status)" />
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="UserListItem" Property="RoleName" Title="@UiStrings.Users.Role" Width="180px" />
                <RadzenDataGridColumn TItem="UserListItem" Title="@UiStrings.Users.LastLogin" Sortable="false" Width="170px">
                    <Template Context="user">
                        @(user.LastLoginAtUtc is { } at ? at.ToLocalTime().ToString("g") : UiStrings.Users.Never)
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
            <RowActions Context="user">
                <RadzenButton Icon="arrow_forward" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat"
                              Click="@(() => OpenUser(user.Id))" title="@UiStrings.Common.Open" />
            </RowActions>
        </DataListCard>
    </div>
</RequirePermission>

@code {
    private const string GridKey = "users";
    private static readonly int[] PageSizes = [10, 25, 50, 100];

    private DataListCard<UserListItem>? list;
    private IReadOnlyList<UserListItem> users = [];
    private int totalCount;
    private int currentPage = 1;
    private int currentPageSize = 10;
    private bool isLoading;
    private bool loadError;

    private string searchTerm = string.Empty;
    private string? statusFilter;
    private Guid? roleFilter;

    private readonly List<StatusOption> statusOptions =
    [
        new(UiStrings.Users.AllStatuses, null),
        new("Invited", "Invited"),
        new("Active", "Active"),
        new("Deactivated", "Deactivated")
    ];

    private List<RoleOption> roleOptions = [new(UiStrings.Users.AllRoles, null)];

    protected override async Task OnInitializedAsync()
    {
        currentPageSize = await GridPrefs.GetPageSizeAsync(GridKey, currentPageSize, PageSizes);
        await LoadRoleOptionsAsync();
        await FetchAsync();
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        currentPageSize = pageSize;
        await GridPrefs.SetPageSizeAsync(GridKey, pageSize);
    }

    private async Task LoadRoleOptionsAsync()
    {
        try
        {
            var roles = await Identity.GetRolesAsync(1, 100, null);
            roleOptions = [new(UiStrings.Users.AllRoles, null), .. roles.Items.Select(r => new RoleOption(r.Name, r.Id))];
        }
        catch (ApiException)
        {
            // Filter is optional; leave just the "all" entry if roles can't be loaded.
        }
    }

    private async Task LoadDataAsync(LoadDataArgs args)
    {
        currentPageSize = args.Top ?? currentPageSize;
        currentPage = ((args.Skip ?? 0) / Math.Max(currentPageSize, 1)) + 1;
        await FetchAsync();
    }

    private async Task FetchAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            var result = await Identity.GetUsersAsync(currentPage, currentPageSize,
                string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm, statusFilter, roleFilter);
            users = result.Items;
            totalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadAsync()
    {
        currentPage = 1;
        if (list is not null)
            await list.ReloadAsync();
        else
            await FetchAsync();
    }

    private async Task OpenInviteAsync()
    {
        var result = await DialogService.OpenAsync<InviteUserDialog>(UiStrings.Users.InviteTitle);
        if (result is true)
            await ReloadAsync();
    }

    private void OpenUser(Guid id) => Navigation.NavigateTo($"/users/{id}");

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }

    private static string StatusTone(string status) => status switch
    {
        "Active" => "success",
        "Invited" => "warning",
        "Deactivated" => "neutral",
        _ => "neutral"
    };

    private sealed record StatusOption(string Label, string? Value);
    private sealed record RoleOption(string Label, Guid? Value);
}
