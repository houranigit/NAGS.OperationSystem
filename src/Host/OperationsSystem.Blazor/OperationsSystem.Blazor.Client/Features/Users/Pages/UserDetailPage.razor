        u.IsLockedOut ? "us-profile--locked" : (u.Status == "Active" ? "us-profile--active" : "us-profile--inactive");

    private static string AvatarClass(UserDetail u) =>
        u.IsLockedOut ? "us-avatar--locked" : (u.Status == "Active" ? "us-avatar--active" : "us-avatar--inactive");

    private static string DotClass(UserDetail u) =>
        u.IsLockedOut ? "us-avatar-dot--locked" : (u.Status == "Active" ? "us-avatar-dot--active" : "us-avatar-dot--inactive");

    private static string StatusToneColor(UserDetail u) =>
        u.IsLockedOut ? "danger" : u.Status switch
        {
            "Active" => "success",
            "Invited" => "warning",
            "Suspended" => "warning",
            _ => "neutral"
        };

    private static string StatusDescription(UserDetail u)
    {
        if (u.IsLockedOut)
            return UiStrings.Users.StatusLockedDesc;

        return u.Status switch
        {
            "Active" => UiStrings.Users.StatusActiveDesc,
            "Invited" => UiStrings.Users.StatusInvitedDesc,
            "Suspended" => UiStrings.Users.StatusSuspendedDesc,
            "Deactivated" => UiStrings.Users.StatusDeactivatedDesc,
            _ => UiStrings.Users.StatusActiveDesc
        };
    }

    private static string LockStatusLabel(UserDetail u)
    {
        if (!u.IsLockedOut)
            return UiStrings.Users.NotLocked;

        if (u.LockoutEndUtc is not { } end)
            return UiStrings.Users.LockedOut;

        return IsIndefiniteLockout(end)
            ? UiStrings.Users.LockedIndefinitely
            : string.Format(UiStrings.Users.LockedUntil, end.ToLocalTime().ToString("g"));
    }

    private static bool IsIndefiniteLockout(DateTimeOffset value) => value.UtcDateTime.Year >= 9000;

    private static string UserTypeLabel(string userType) => userType switch
    {
        UserTypes.SystemAdministrator => UiStrings.Users.TypeSystemAdministrator,
        UserTypes.ViewerOnly => UiStrings.Users.TypeViewerOnly,
        UserTypes.StationStaff => UiStrings.Users.TypeStationStaff,
        UserTypes.CustomerContact => UiStrings.Users.TypeCustomerContact,
        _ => userType
    };

    private string AccessScope(UserDetail u)
