@page "/users/{Id:guid}"
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject OperationsSystem.Blazor.Client.Api.AuditApiClient AuditApi

<PageTitle>@(user?.DisplayName ?? UiStrings.Users.Title)</PageTitle>

<RequirePermission Permission="@IdentityPermissions.UsersView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (user is { } u)
    {
        <div class="us-workspace">

            @* ---- Profile (hero + tabs as one unit) ----------------------- *@
            <section class="us-profile @ProfileClass(u)">
                <div class="us-hero">
                    <div class="us-avatar @AvatarClass(u)">
                        <span>@Initials(u.DisplayName)</span>
                        <span class="us-avatar-dot @DotClass(u)"></span>
                    </div>

                    <div class="us-identity">
                        <div class="us-identity-headline">
                            <h1 class="us-name">@u.DisplayName</h1>
                            @if (u.IsLockedOut)
                            {
                                <StatusBadge Label="@UiStrings.Users.LockedOut" Tone="danger" />
                            }
                            else
                            {
                                <StatusBadge Label="@u.Status" Tone="@StatusTone(u.Status)" />
                            }
                            <span class="us-role-badge"><RadzenIcon Icon="badge" />@u.RoleName</span>
                        </div>

                        <div class="us-email">
                            <RadzenIcon Icon="mail" />
                            <span>@u.Email</span>
                            <button type="button" class="us-copy" title="@UiStrings.Users.CopyEmail"
                                    aria-label="@UiStrings.Users.CopyEmail" @onclick="@(() => CopyAsync(u.Email))">
                                <RadzenIcon Icon="content_copy" />
                            </button>

                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(u.Id)</span>
                            <button type="button" class="us-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(u.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="us-hero-actions">
                        @if (Auth.HasPermission(IdentityPermissions.UsersUpdate))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(u))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions" ShowLabel="true">
                                <RowAction Text="@UiStrings.Users.AssignRole" Icon="badge"
                                           Permission="@IdentityPermissions.UsersAssignRole"
                                           Visible="@Auth.HasPermission(IdentityPermissions.RolesView)" OnClick="@OpenAssignRoleAsync" />
                                <RowAction Text="@UiStrings.Users.ResendInvitation" Icon="mail"
                                           Permission="@IdentityPermissions.UsersInvite"
                                           Visible="@(u.Status == "Invited")" OnClick="@ResendInvitationAsync" />
                                <RowAction Text="@UiStrings.Users.Unlock" Icon="lock_open"
                                           Permission="@IdentityPermissions.UsersUnlock"
                                           Visible="@u.IsLockedOut" OnClick="@UnlockAsync" />
                                <RowAction Text="@UiStrings.Users.RestoreAccess" Icon="person_check"
                                           Permission="@IdentityPermissions.UsersRestoreAccess"
                                           Visible="@(u.Status == "Suspended")" OnClick="@RestoreAccessAsync" />
                                <RowAction Text="@UiStrings.Users.ResetMfa" Icon="restart_alt"
                                           Permission="@IdentityPermissions.UsersResetMfa"
                                           Visible="@CanResetMfa(u)" OnClick="@ResetMfaAsync" />
                                <RowAction Separator="true" />
                                <RowAction Text="@UiStrings.Users.Lock" Icon="lock" Danger="true"
                                           Permission="@IdentityPermissions.UsersLock"
                                           Visible="@(!u.IsLockedOut)" OnClick="@LockAsync" />
                                <RowAction Text="@UiStrings.Users.Suspend" Icon="pause_circle" Danger="true"
                                           Permission="@IdentityPermissions.UsersSuspend"
                                           Visible="@(u.Status != "Suspended" && u.Status != "Deactivated")" OnClick="@SuspendAsync" />
                                <RowAction Text="@UiStrings.Users.Deactivate" Icon="person_off" Danger="true"
                                           Permission="@IdentityPermissions.UsersDeactivate"
                                           Visible="@(u.Status != "Deactivated")" OnClick="@DeactivateAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="us-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="us-tab @(activeTab == tab.Key ? "us-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            @* ---- Tab body ------------------------------------------------ *@
            <div class="us-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    UserTab.Overview => OverviewTab(u),
                    UserTab.Sessions => SessionsTab(u),
                    UserTab.History => HistoryTab(),
                    _ => ActivityTab()
                })
            </div>
        </div>
    }
</RequirePermission>

@* ================================================================ Overview *@
@code {
    private RenderFragment OverviewTab(UserDetail u) =>@<text>
        <div class="us-stack">
            <div class="us-overview-grid">
                @* --- Account status --- *@
                <RadzenCard class="us-card">
                    <div class="us-card-head"><RadzenIcon Icon="account_circle" /><h3>@UiStrings.Users.AccountStatus</h3></div>
                    <div class="us-lead">
                        <span class="us-lead-dot us-lead-dot--@StatusToneColor(u)"></span>
                        <div>
                            <p class="us-lead-title">@(u.IsLockedOut ? UiStrings.Users.LockedOut : u.Status)</p>
                            <p class="os-muted us-lead-desc">@StatusDescription(u)</p>
                        </div>
                    </div>
                    <dl class="us-metrics">
                        <div class="us-metric">
                            <dt>@UiStrings.Users.LockStatus</dt>
                            <dd>@LockStatusLabel(u)</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.MemberSince</dt>
                            <dd>@u.CreatedAtUtc.ToLocalTime().ToString("d")</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.LastUpdated</dt>
                            <dd>@(u.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>

                @* --- Permissions --- *@
                <RadzenCard class="us-card">
                    <div class="us-card-head"><RadzenIcon Icon="badge" /><h3>@UiStrings.Users.Permissions</h3></div>
                    <div class="us-lead">
                        <span class="us-lead-icon us-lead-icon--blue"><RadzenIcon Icon="shield_person" /></span>
                        <div>
                            <p class="us-lead-title">@u.RoleName</p>
                            <p class="os-muted us-lead-desc">@AccessScope(u)</p>
                        </div>
                    </div>
                    <dl class="us-metrics">
                        <div class="us-metric">
                            <dt>@UiStrings.Users.Role</dt>
                            <dd>@u.RoleName</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.UserType</dt>
                            <dd>@UserTypeLabel(u.UserType)</dd>
                        </div>
                        @if (roleDetail is { } role)
                        {
                            <div class="us-metric">
                                <dt>@UiStrings.Roles.PermissionCount</dt>
                                <dd>@role.Permissions.Count</dd>
                            </div>
                        }
                        <div class="us-metric">
                            <dt>@UiStrings.Users.AccessScope</dt>
                            <dd>@AccessScope(u)</dd>
                        </div>
                    </dl>
                    @if (Auth.HasPermission(IdentityPermissions.RolesView))
                    {
                        <button type="button" class="us-card-link" @onclick="@(() => Navigation.NavigateTo($"/roles/{u.RoleId}"))">
                            @UiStrings.Common.Open<RadzenIcon Icon="chevron_right" />
                        </button>
                    }
                </RadzenCard>

                @* --- Security --- *@
                <RadzenCard class="us-card">
                    <div class="us-card-head"><RadzenIcon Icon="security" /><h3>@UiStrings.Users.Security</h3></div>
                    <dl class="us-metrics us-metrics--tall">
                        <div class="us-metric">
                            <dt>@UiStrings.Users.Mfa</dt>
                            <dd>@MfaStatusLabel(u)</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.LastLogin</dt>
                            <dd title="@FullStamp(u.LastLoginAtUtc)">@LoginStamp(u.LastLoginAtUtc)</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.StatActiveSessions</dt>
                            <dd>@ActiveSessionCount</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.RecentDevice</dt>
                            <dd>@RecentDeviceLabel()</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Sessions.IpAddress</dt>
                            <dd class="us-mono">@(RecentIp() ?? UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>
            </div>

            @if (CanViewAudit)
            {
                <div class="us-audit-preview-grid">
                    <RadzenCard class="us-card">
                        <div class="us-card-head">
                            <RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3>
                            @if (history.Count > 0)
                            {
                                <button type="button" class="us-link" @onclick="@(() => activeTab = UserTab.History)">@UiStrings.Common.ViewAll</button>
                            }
                        </div>
                        <p class="us-audit-description os-muted">@UiStrings.Audit.HistoryDescription</p>
                        @AuditTimeline(history, showTarget: false, maxItems: OverviewAuditPreviewCount)
                    </RadzenCard>

                    <RadzenCard class="us-card">
                        <div class="us-card-head">
                            <RadzenIcon Icon="history" /><h3>@UiStrings.Audit.ActivityTitle</h3>
                            @if (userActivity.Count > 0)
                            {
                                <button type="button" class="us-link" @onclick="@(() => activeTab = UserTab.Activity)">@UiStrings.Common.ViewAll</button>
                            }
                        </div>
                        <p class="us-audit-description os-muted">@UiStrings.Audit.ActivityDescription</p>
                        @AuditTimeline(userActivity, showTarget: true, maxItems: OverviewAuditPreviewCount)
                    </RadzenCard>
                </div>
            }
        </div>
    </text>;

    @* ================================================================ Sessions *@
    private RenderFragment SessionsTab(UserDetail u) =>@<text>
        <div class="us-stack">
            @if (sessionsLoading)
            {
                <LoadingCard />
            }
            else if (sessionsError)
            {
                <ErrorState OnRetry="@LoadSessionsAsync" />
            }
            else if (sessions is null || sessions.Count == 0)
            {
                <EmptyState Title="@UiStrings.Sessions.Empty" Description="@UiStrings.Sessions.EmptyHint" Icon="devices" />
            }
            else
            {
                <RadzenCard class="us-card">
                    <div class="us-card-head">
                        <RadzenIcon Icon="devices" /><h3>@UiStrings.Sessions.Title</h3>
                        @if (Auth.HasPermission(IdentityPermissions.SessionsRevoke))
                        {
                            <span class="us-count"></span>
                            <RadzenButton Text="@UiStrings.Sessions.RevokeAll" ButtonStyle="ButtonStyle.Light" Icon="block"
                                          Size="ButtonSize.Small" Disabled="@(!HasActiveSessions)" Click="@RevokeAllAsync" />
                        }
                    </div>

                    <RadzenDataGrid TItem="UserSession" Data="@sessions" Count="@sessionsTotalCount"
                                    LoadData="@LoadSessionsDataAsync" AllowPaging="true" PageSize="@sessionsPageSize"
                                    PageSizeOptions="@PageSizes" ShowPagingSummary="true"
                                    IsLoading="@sessionsLoading" EmptyText="@UiStrings.Sessions.Empty"
                                    GridLines="DataGridGridLines.Horizontal">
                        <Columns>
                            <RadzenDataGridColumn TItem="UserSession" Title="@UiStrings.Sessions.Device">
                                <Template Context="s">
                                    <span class="us-td-device">
                                        <RadzenIcon Icon="@DeviceIcon(s.UserAgent)" />
                                        <span>@DeviceLabel(s.UserAgent)</span>
                                        @if (s.IsCurrent)
                                        {
                                            <StatusBadge Label="@UiStrings.Sessions.CurrentDeviceBadge" Tone="success" />
                                        }
                                    </span>
                                </Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="UserSession" Title="@UiStrings.Sessions.IpAddress" Width="150px">
                                <Template Context="s"><span class="us-mono">@(s.CreatedByIp ?? UiStrings.Common.None)</span></Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="UserSession" Title="@UiStrings.Sessions.LastActivity" Width="180px">
                                <Template Context="s">@s.CreatedAtUtc.ToLocalTime().ToString("g")</Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="UserSession" Title="@UiStrings.Sessions.State" Width="130px">
                                <Template Context="s">@SessionBadge(s)</Template>
                            </RadzenDataGridColumn>
                            <RadzenDataGridColumn TItem="UserSession" Title="" Width="92px" Sortable="false" TextAlign="TextAlign.End">
                                <Template Context="s">
                                    @if (s.IsActive && Auth.HasPermission(IdentityPermissions.SessionsRevoke))
                                    {
                                        <RowActionMenu>
                                            <RowAction Text="@UiStrings.Account.RevokeSession" Icon="block" Danger="true"
                                                       OnClick="@(() => RevokeSessionAsync(s.Id))" />
                                        </RowActionMenu>
                                    }
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </RadzenCard>
            }
        </div>
    </text>;

    @* ================================================================ History *@
    private RenderFragment HistoryTab() =>@<text>
        <RadzenCard class="us-card">
            <div class="us-card-head"><RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3></div>
            <p class="us-audit-description os-muted">@UiStrings.Audit.HistoryDescription</p>
            @AuditTimeline(history, showTarget: false)
        </RadzenCard>
    </text>;

    @* ================================================================ Activity *@
    private RenderFragment ActivityTab() =>@<text>
        <RadzenCard class="us-card">
            <div class="us-card-head"><RadzenIcon Icon="history" /><h3>@UiStrings.Audit.ActivityTitle</h3></div>
            <p class="us-audit-description os-muted">@UiStrings.Audit.ActivityDescription</p>
            @AuditTimeline(userActivity, showTarget: true)
        </RadzenCard>
    </text>;

    private RenderFragment AuditTimeline(
        IReadOnlyList<AuditTrailListItem> entries,
        bool showTarget,
        int? maxItems = null) =>@<text>
        @if (entries.Count == 0)
        {
            @TimelineEmpty(showTarget ? UiStrings.Audit.ActivityEmpty : UiStrings.Audit.HistoryEmpty)
        }
        else
        {
            <ol class="us-timeline">
                @foreach (var entry in maxItems is { } take ? entries.Take(take) : entries)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="us-timeline-row" @key="entry.Id">
                        <span class="us-timeline-icon us-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="us-timeline-content">
                            <p class="us-timeline-title">@(showTarget ? $"{entry.Action} · {TargetLabel(entry)}" : entry.Action)</p>
                            <p class="os-muted us-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="us-dot-sep">&middot;</span>
                                @(showTarget
                                    ? entry.Module
                                    : (entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None)))
                            </p>
                        </div>
                        <RadzenButton Text="@UiStrings.Audit.ViewDetails" Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      class="us-timeline-view" Click="@(() => OpenAuditDetailAsync(entry.Id))" />
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment SessionBadge(UserSession s) =>@<text>
        @if (s.IsActive)
        {
            <StatusBadge Label="@UiStrings.Sessions.Active" Tone="success" />
        }
        else if (s.RevokedAtUtc is not null)
        {
            <StatusBadge Label="@UiStrings.Sessions.Revoked" Tone="danger" />
        }
        else
        {
            <StatusBadge Label="@UiStrings.Sessions.Expired" Tone="neutral" />
        }
    </text>;

    private RenderFragment TimelineEmpty(string description) =>@<text>
        <div class="us-timeline-empty">
            <span class="us-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="us-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@description</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private UserDetail? user;
    private RoleDetail? roleDetail;
    private IReadOnlyList<AuditTrailListItem> history = [];
    private IReadOnlyList<AuditTrailListItem> userActivity = [];
    private bool isLoading = true;
    private bool loadError;
    private string errorMessage = UiStrings.Errors.LoadFailed;

    private IReadOnlyList<UserSession>? sessions;
    private static readonly int[] PageSizes = [10, 25, 50, 100];
    private int sessionsTotalCount;
    private int sessionsPage = 1;
    private int sessionsPageSize = 10;
    private bool sessionsLoading;
    private bool sessionsError;
    private UserTab activeTab = UserTab.Overview;

    private const int OverviewAuditPreviewCount = 4;

    private enum UserTab { Overview, Sessions, History, Activity }

    private sealed record TabDef(UserTab Key, string Label, string Icon);

    private bool HasActiveSessions => sessionsTotalCount > 0 || (sessions?.Any(s => s.IsActive) ?? false);
    private int ActiveSessionCount => sessions?.Count(s => s.IsActive) ?? 0;
    private bool CanViewAudit => Auth.HasPermission(AuditPermissions.TrailsView);

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(UserTab.Overview, UiStrings.Common.Overview, "dashboard");
        if (Auth.HasPermission(IdentityPermissions.SessionsView))
            yield return new TabDef(UserTab.Sessions, UiStrings.Sessions.Title, "devices");
        if (CanViewAudit)
        {
            yield return new TabDef(UserTab.History, UiStrings.Audit.HistoryTitle, "manage_history");
            yield return new TabDef(UserTab.Activity, UiStrings.Audit.ActivityTitle, "history");
        }
    }

    private bool HasMoreActions(UserDetail u) =>
        (Auth.HasPermission(IdentityPermissions.UsersAssignRole)
            && Auth.HasPermission(IdentityPermissions.RolesView))
        || (u.Status == "Invited" && Auth.HasPermission(IdentityPermissions.UsersInvite))
        || (u.IsLockedOut && Auth.HasPermission(IdentityPermissions.UsersUnlock))
        || (u.Status == "Suspended" && Auth.HasPermission(IdentityPermissions.UsersRestoreAccess))
        || (CanResetMfa(u) && Auth.HasPermission(IdentityPermissions.UsersResetMfa))
        || (!u.IsLockedOut && Auth.HasPermission(IdentityPermissions.UsersLock))
        || (u.Status != "Suspended" && u.Status != "Deactivated" && Auth.HasPermission(IdentityPermissions.UsersSuspend))
        || (u.Status != "Deactivated" && Auth.HasPermission(IdentityPermissions.UsersDeactivate));

    private static bool CanResetMfa(UserDetail u) => u.MfaEnabled || u.MfaEnrollmentRequired;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            user = await Identity.GetUserAsync(Id);
            roleDetail = null;
            sessions = null;
            sessionsPage = 1;
            sessionsTotalCount = 0;
            sessionsLoading = Auth.HasPermission(IdentityPermissions.SessionsView);
            sessionsError = false;
            history = [];
            userActivity = [];

            await Task.WhenAll(
                LoadSessionsCoreAsync(),
                LoadRoleAsync(user.RoleId),
                LoadAuditAsync());
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadRoleAsync(Guid roleId)
    {
        roleDetail = null;
        if (!Auth.HasPermission(IdentityPermissions.RolesView))
            return;

        try
        {
            roleDetail = await Identity.GetRoleAsync(roleId);
        }
        catch (ApiException)
        {
            roleDetail = null;
        }
    }

    private async Task LoadSessionsAsync()
    {
        sessionsPage = 1;
        sessionsLoading = true;
        sessionsError = false;
        StateHasChanged();
        await LoadSessionsCoreAsync();
        StateHasChanged();
    }

    private async Task LoadSessionsDataAsync(LoadDataArgs args)
    {
        sessionsPageSize = args.Top ?? sessionsPageSize;
        sessionsPage = ((args.Skip ?? 0) / Math.Max(sessionsPageSize, 1)) + 1;
        await LoadSessionsCoreAsync();
        StateHasChanged();
    }

    private async Task LoadSessionsCoreAsync()
    {
        if (!Auth.HasPermission(IdentityPermissions.SessionsView))
        {
            sessions = [];
            sessionsTotalCount = 0;
            sessionsLoading = false;
            sessionsError = false;
            return;
        }

        sessionsLoading = true;
        sessionsError = false;
        try
        {
            var result = await Identity.GetUserSessionsAsync(Id, sessionsPage, sessionsPageSize);
            sessions = result.Items;
            sessionsTotalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            sessionsError = true;
            sessions = [];
            sessionsTotalCount = 0;
        }
        finally
        {
            sessionsLoading = false;
        }
    }

    private async Task LoadAuditAsync()
    {
        history = [];
        userActivity = [];
        if (!CanViewAudit)
            return;

        try
        {
            var historyTask = AuditApi.GetTrailsAsync(entityType: "User", entityId: Id, pageSize: 50);
            var activityTask = AuditApi.GetTrailsAsync(actorId: Id, pageSize: 50);

            await Task.WhenAll(historyTask, activityTask);
            history = historyTask.Result.Items;
            userActivity = activityTask.Result.Items;
        }
        catch (ApiException)
        {
            history = [];
            userActivity = [];
        }
    }

    private async Task OpenEditAsync()
    {
        if (user is null)
            return;

        var result = await DialogService.OpenAsync<EditUserDialog>(UiStrings.Users.EditTitle,
            new Dictionary<string, object?> { [nameof(EditUserDialog.UserId)] = user.Id, [nameof(EditUserDialog.DisplayName)] = user.DisplayName });

        if (result is true)
            await LoadAsync();
    }

    private async Task OpenAssignRoleAsync()
    {
        if (user is null)
            return;

        var result = await DialogService.OpenAsync<AssignRoleDialog>(UiStrings.Users.AssignRoleTitle,
            new Dictionary<string, object?>
            {
                [nameof(AssignRoleDialog.UserId)] = user.Id,
                [nameof(AssignRoleDialog.CurrentRoleId)] = user.RoleId,
                [nameof(AssignRoleDialog.CompatibleUserType)] = user.UserType
            });

        if (result is true)
            await LoadAsync();
    }

    private async Task OpenAuditDetailAsync(Guid trailId)
    {
        await DialogService.OpenAsync<AuditTrailDetailDialog>(
            UiStrings.Audit.DetailsTitle,
            new Dictionary<string, object?> { [nameof(AuditTrailDetailDialog.TrailId)] = trailId },
            new DialogOptions { Width = "760px" });
    }

    private Task ResendInvitationAsync() =>
        RunActionAsync(() => Identity.ResendInvitationAsync(Id), UiStrings.Users.ResendInvitation);

    private Task UnlockAsync() =>
        RunActionAsync(() => Identity.UnlockUserAsync(Id), UiStrings.Users.Unlock);

    private async Task LockAsync()
    {
        if (await Confirm(UiStrings.Users.ConfirmLock))
            await RunActionAsync(() => Identity.LockUserAsync(Id), UiStrings.Users.Lock);
    }

    private async Task SuspendAsync()
    {
        if (await Confirm(UiStrings.Users.ConfirmSuspend))
            await RunActionAsync(() => Identity.SuspendUserAsync(Id), UiStrings.Users.Suspend);
    }

    private async Task RestoreAccessAsync()
    {
        if (await Confirm(UiStrings.Users.ConfirmRestoreAccess))
            await RunActionAsync(() => Identity.RestoreAccessAsync(Id), UiStrings.Users.RestoreAccess);
    }

    private async Task ResetMfaAsync()
    {
        if (await Confirm(UiStrings.Users.ConfirmResetMfa))
            await RunActionAsync(() => Identity.ResetMfaAsync(Id), UiStrings.Users.ResetMfa);
    }

    private async Task DeactivateAsync()
    {
        if (await Confirm(UiStrings.Users.ConfirmDeactivate))
            await RunActionAsync(() => Identity.DeactivateUserAsync(Id), UiStrings.Users.Deactivate);
    }

    private async Task RevokeSessionAsync(Guid sessionId)
    {
        try
        {
            await Identity.RevokeSessionAsync(sessionId);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Account.RevokeSession);
            await LoadSessionsAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task RevokeAllAsync()
    {
        try
        {
            await Identity.RevokeUserSessionsAsync(Id);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Sessions.RevokeAll);
            await LoadSessionsAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task RunActionAsync(Func<Task> action, string successMessage)
    {
        try
        {
            await action();
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private async Task<bool> Confirm(string message) =>
        await DialogService.Confirm(message, UiStrings.Common.Confirm,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

