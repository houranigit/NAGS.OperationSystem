    }

    private static string StatusTone(string status) => status switch
    {
        "Active" => "success",
        "Invited" => "warning",
        "Suspended" => "warning",
        "Deactivated" => "neutral",
        _ => "neutral"
    };

    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string TargetLabel(AuditTrailListItem entry) => entry.EntityId is { } id
        ? $"{entry.EntityType} {ShortId(id)}"
        : entry.EntityType;

    private static string FullStamp(DateTimeOffset? value) =>
        value is { } v ? v.ToLocalTime().ToString("F") : UiStrings.Users.Never;

    private static string LoginStamp(DateTimeOffset? value) =>
        value is { } v ? RelativeTime(v) : UiStrings.Users.Never;

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private string? RecentIp() => sessions?.FirstOrDefault(s => s.IsCurrent)?.CreatedByIp
        ?? sessions?.Where(s => s.IsActive).OrderByDescending(s => s.CreatedAtUtc).FirstOrDefault()?.CreatedByIp;

    private string RecentDeviceLabel()
    {
        var session = sessions?.FirstOrDefault(s => s.IsCurrent)
            ?? sessions?.Where(s => s.IsActive).OrderByDescending(s => s.CreatedAtUtc).FirstOrDefault();
        return session is null ? UiStrings.Common.None : DeviceLabel(session.UserAgent);
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("log in") || a.Contains("logged in") || a.Contains("sign in") || a.Contains("signed in"))
            return ("login", "blue");
        if (a.Contains("role"))
            return ("badge", "blue");
        if (a.Contains("password"))
            return ("key", "amber");
        if (a.Contains("unlock"))
            return ("lock_open", "green");
        if (a.Contains("lock"))
            return ("lock", "amber");
        if (a.Contains("deactivat"))
            return ("person_off", "red");
        if (a.Contains("invit"))
            return ("mail", "blue");
        if (a.Contains("creat"))
            return ("person_add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }

    private static string DeviceIcon(string? userAgent)
    {
        if (string.IsNullOrWhiteSpace(userAgent))
            return "devices";

        var ua = userAgent.ToLowerInvariant();
        if (ua.Contains("iphone") || ua.Contains("android") || ua.Contains("mobile"))
            return "smartphone";
        if (ua.Contains("ipad") || ua.Contains("tablet"))
            return "tablet_mac";
        return "computer";
    }

    private static string DeviceLabel(string? userAgent)
    {
        if (string.IsNullOrWhiteSpace(userAgent))
            return UiStrings.Sessions.UnknownDevice;

        var ua = userAgent;
        var os =
            ua.Contains("Windows", StringComparison.OrdinalIgnoreCase) ? "Windows" :
            ua.Contains("iPhone", StringComparison.OrdinalIgnoreCase) ? "iPhone" :
            ua.Contains("iPad", StringComparison.OrdinalIgnoreCase) ? "iPad" :
            ua.Contains("Mac", StringComparison.OrdinalIgnoreCase) ? "macOS" :
            ua.Contains("Android", StringComparison.OrdinalIgnoreCase) ? "Android" :
            ua.Contains("Linux", StringComparison.OrdinalIgnoreCase) ? "Linux" :
            null;

        var browser =
            ua.Contains("Edg", StringComparison.OrdinalIgnoreCase) ? "Edge" :
            ua.Contains("OPR", StringComparison.OrdinalIgnoreCase) || ua.Contains("Opera", StringComparison.OrdinalIgnoreCase) ? "Opera" :
            ua.Contains("Firefox", StringComparison.OrdinalIgnoreCase) ? "Firefox" :
            ua.Contains("Chrome", StringComparison.OrdinalIgnoreCase) ? "Chrome" :
            ua.Contains("Safari", StringComparison.OrdinalIgnoreCase) ? "Safari" :
            null;

        return (os, browser) switch
        {
            (not null, not null) => $"{browser} · {os}",
            (not null, null) => os!,
            (null, not null) => browser!,
            _ => userAgent.Length > 48 ? userAgent[..48] + "…" : userAgent
        };
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }
