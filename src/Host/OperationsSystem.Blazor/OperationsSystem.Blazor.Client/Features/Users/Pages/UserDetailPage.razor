@page "/users/{Id:guid}"
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject OperationsSystem.Blazor.Client.Api.AuditApiClient AuditApi

<PageTitle>@(user?.DisplayName ?? UiStrings.Users.Title)</PageTitle>

<RequirePermission Permission="@IdentityPermissions.UsersView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (user is { } u)
    {
        <div class="us-workspace">
            <button type="button" class="us-back" @onclick="GoBack">
                <RadzenIcon Icon="arrow_back" />
                <span>@UiStrings.Users.Title</span>
            </button>

            @* ---- Profile (hero + tabs as one unit) ----------------------- *@
            <section class="us-profile @ProfileClass(u)">
                <div class="us-hero">
                    <div class="us-avatar @AvatarClass(u)">
                        <span>@Initials(u.DisplayName)</span>
                        <span class="us-avatar-dot @DotClass(u)"></span>
                    </div>

                    <div class="us-identity">
                        <div class="us-identity-headline">
                            <h1 class="us-name">@u.DisplayName</h1>
                            @if (u.IsLockedOut)
                            {
                                <StatusBadge Label="@UiStrings.Users.LockedOut" Tone="danger" />
                            }
                            else
                            {
                                <StatusBadge Label="@u.Status" Tone="@StatusTone(u.Status)" />
                            }
                            <span class="us-role-badge"><RadzenIcon Icon="badge" />@u.RoleName</span>
                        </div>

                        <div class="us-email">
                            <RadzenIcon Icon="mail" />
                            <span>@u.Email</span>
                            <button type="button" class="us-copy" title="@UiStrings.Users.CopyEmail"
                                    aria-label="@UiStrings.Users.CopyEmail" @onclick="@(() => CopyAsync(u.Email))">
                                <RadzenIcon Icon="content_copy" />
                            </button>

                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(u.Id)</span>
                            <button type="button" class="us-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(u.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="us-hero-actions">
                        @if (Auth.HasPermission(IdentityPermissions.UsersUpdate))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(u))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions">
                                <RowAction Text="@UiStrings.Users.AssignRole" Icon="badge"
                                           Permission="@IdentityPermissions.UsersAssignRole" OnClick="@OpenAssignRoleAsync" />
                                <RowAction Text="@UiStrings.Users.ResendInvitation" Icon="mail"
                                           Permission="@IdentityPermissions.UsersInvite"
                                           Visible="@(u.Status == "Invited")" OnClick="@ResendInvitationAsync" />
                                <RowAction Text="@UiStrings.Users.Unlock" Icon="lock_open"
                                           Permission="@IdentityPermissions.UsersUnlock"
                                           Visible="@u.IsLockedOut" OnClick="@UnlockAsync" />
                                <RowAction Separator="true" />
                                <RowAction Text="@UiStrings.Users.Lock" Icon="lock" Danger="true"
                                           Permission="@IdentityPermissions.UsersLock"
                                           Visible="@(!u.IsLockedOut)" OnClick="@LockAsync" />
                                <RowAction Text="@UiStrings.Users.Deactivate" Icon="person_off" Danger="true"
                                           Permission="@IdentityPermissions.UsersDeactivate"
                                           Visible="@(u.Status != "Deactivated")" OnClick="@DeactivateAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="us-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="us-tab @(activeTab == tab.Key ? "us-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            @* ---- Tab body ------------------------------------------------ *@
            <div class="us-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    UserTab.Overview => OverviewTab(u),
                    UserTab.Sessions => SessionsTab(u),
                    _ => ActivityTab(u)
                })
            </div>
        </div>
    }
</RequirePermission>

@* ================================================================ Overview *@
@code {
    private RenderFragment OverviewTab(UserDetail u) =>@<text>
        <div class="us-stack">
            <div class="us-overview-grid">
                @* --- Account status --- *@
                <RadzenCard class="us-card">
                    <div class="us-card-head"><RadzenIcon Icon="account_circle" /><h3>@UiStrings.Users.AccountStatus</h3></div>
                    <div class="us-lead">
                        <span class="us-lead-dot us-lead-dot--@StatusToneColor(u)"></span>
                        <div>
                            <p class="us-lead-title">@(u.IsLockedOut ? UiStrings.Users.LockedOut : u.Status)</p>
                            <p class="os-muted us-lead-desc">@StatusDescription(u)</p>
                        </div>
                    </div>
                    <dl class="us-metrics">
                        <div class="us-metric">
                            <dt>@UiStrings.Users.LockStatus</dt>
                            <dd>@(u.IsLockedOut
                                ? (u.LockoutEndUtc is { } end ? string.Format(UiStrings.Users.LockedUntil, end.ToLocalTime().ToString("g")) : UiStrings.Users.LockedOut)
                                : UiStrings.Users.NotLocked)</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.MemberSince</dt>
                            <dd>@u.CreatedAtUtc.ToLocalTime().ToString("d")</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.LastUpdated</dt>
                            <dd>@(u.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>

                @* --- Permissions --- *@
                <RadzenCard class="us-card">
                    <div class="us-card-head"><RadzenIcon Icon="badge" /><h3>@UiStrings.Users.Permissions</h3></div>
                    <div class="us-lead">
                        <span class="us-lead-icon us-lead-icon--blue"><RadzenIcon Icon="shield_person" /></span>
                        <div>
                            <p class="us-lead-title">@u.RoleName</p>
                            <p class="os-muted us-lead-desc">@AccessScope(u)</p>
                        </div>
                    </div>
                    <dl class="us-metrics">
                        <div class="us-metric">
                            <dt>@UiStrings.Users.Role</dt>
                            <dd>@u.RoleName</dd>
                        </div>
                        @if (roleDetail is { } role)
                        {
                            <div class="us-metric">
                                <dt>@UiStrings.Roles.PermissionCount</dt>
                                <dd>@role.Permissions.Count</dd>
                            </div>
                        }
                        <div class="us-metric">
                            <dt>@UiStrings.Users.AccessScope</dt>
                            <dd>@AccessScope(u)</dd>
                        </div>
                    </dl>
                    @if (Auth.HasPermission(IdentityPermissions.RolesView))
                    {
                        <button type="button" class="us-card-link" @onclick="@(() => Navigation.NavigateTo($"/roles/{u.RoleId}"))">
                            @UiStrings.Common.Open<RadzenIcon Icon="chevron_right" />
                        </button>
                    }
                </RadzenCard>

                @* --- Security --- *@
                <RadzenCard class="us-card">
                    <div class="us-card-head"><RadzenIcon Icon="security" /><h3>@UiStrings.Users.Security</h3></div>
                    <dl class="us-metrics us-metrics--tall">
                        <div class="us-metric">
                            <dt>@UiStrings.Users.LastLogin</dt>
                            <dd title="@FullStamp(u.LastLoginAtUtc)">@LoginStamp(u.LastLoginAtUtc)</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.StatActiveSessions</dt>
                            <dd>@ActiveSessionCount</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Users.RecentDevice</dt>
                            <dd>@RecentDeviceLabel()</dd>
                        </div>
                        <div class="us-metric">
                            <dt>@UiStrings.Sessions.IpAddress</dt>
                            <dd class="us-mono">@(RecentIp() ?? UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>
            </div>

            @* --- Recent activity preview --- *@
            <RadzenCard class="us-card">
                <div class="us-card-head">
                    <RadzenIcon Icon="history" /><h3>@UiStrings.Audit.ActivityTitle</h3>
                    @if (activity.Count > 0)
                    {
                        <button type="button" class="us-link" @onclick="@(() => activeTab = UserTab.Activity)">@UiStrings.Common.ViewAll</button>
                    }
                </div>
                @ActivityTimeline(OverviewActivityPreviewCount)
            </RadzenCard>
        </div>
    </text>;

    @* ================================================================ Sessions *@
    private RenderFragment SessionsTab(UserDetail u) =>@<text>
        <div class="us-stack">
            @if (sessionsLoading)
            {
                <LoadingCard />
            }
            else if (sessionsError)
            {
                <ErrorState OnRetry="@LoadSessionsAsync" />
            }
            else if (sessions is null || sessions.Count == 0)
            {
                <EmptyState Title="@UiStrings.Sessions.Empty" Description="@UiStrings.Sessions.EmptyHint" Icon="devices" />
            }
            else
            {
                var current = sessions.FirstOrDefault(s => s.IsCurrent);
                var others = sessions.Where(s => !s.IsCurrent).ToList();

                @if (current is { } cur)
                {
                    <RadzenCard class="us-card us-current">
                        <div class="us-current-main">
                            <span class="us-current-icon"><RadzenIcon Icon="@DeviceIcon(cur.UserAgent)" /></span>
                            <div class="us-current-body">
                                <div class="us-current-head">
                                    <h3>@UiStrings.Sessions.CurrentSession</h3>
                                    <StatusBadge Label="@UiStrings.Sessions.CurrentDeviceBadge" Tone="success" />
                                </div>
                                <p class="us-current-device">@DeviceLabel(cur.UserAgent)</p>
                                <dl class="us-current-meta">
                                    <div><dt>@UiStrings.Sessions.IpAddress</dt><dd class="us-mono">@(cur.CreatedByIp ?? UiStrings.Common.None)</dd></div>
                                    <div><dt>@UiStrings.Sessions.LastActivity</dt><dd>@cur.CreatedAtUtc.ToLocalTime().ToString("g")</dd></div>
                                    <div><dt>@UiStrings.Sessions.Expires</dt><dd>@cur.ExpiresAtUtc.ToLocalTime().ToString("g")</dd></div>
                                </dl>
                            </div>
                        </div>
                    </RadzenCard>
                }

                <RadzenCard class="us-card">
                    <div class="us-card-head">
                        <RadzenIcon Icon="devices" /><h3>@UiStrings.Sessions.OtherSessions</h3>
                        @if (Auth.HasPermission(IdentityPermissions.SessionsRevoke))
                        {
                            <span class="us-count"></span>
                            <RadzenButton Text="@UiStrings.Sessions.RevokeAll" ButtonStyle="ButtonStyle.Light" Icon="block"
                                          Size="ButtonSize.Small" Disabled="@(!HasActiveSessions)" Click="@RevokeAllAsync" />
                        }
                    </div>

                    @if (others.Count == 0)
                    {
                        <EmptyState Title="@UiStrings.Sessions.Empty" Description="@UiStrings.Sessions.EmptyHint" Icon="devices" />
                    }
                    else
                    {
                        <div class="us-table" role="table">
                            <div class="us-tr us-tr--head" role="row">
                                <span role="columnheader">@UiStrings.Sessions.Device</span>
                                <span role="columnheader">@UiStrings.Sessions.IpAddress</span>
                                <span role="columnheader">@UiStrings.Sessions.LastActivity</span>
                                <span role="columnheader">@UiStrings.Sessions.State</span>
                                <span role="columnheader" class="us-td--actions"></span>
                            </div>
                            @foreach (var s in others)
                            {
                                <div class="us-tr" role="row" @key="s.Id">
                                    <span role="cell" class="us-td-device" data-label="@UiStrings.Sessions.Device">
                                        <RadzenIcon Icon="@DeviceIcon(s.UserAgent)" />
                                        <span>@DeviceLabel(s.UserAgent)</span>
                                    </span>
                                    <span role="cell" class="us-mono" data-label="@UiStrings.Sessions.IpAddress">@(s.CreatedByIp ?? UiStrings.Common.None)</span>
                                    <span role="cell" data-label="@UiStrings.Sessions.LastActivity">@s.CreatedAtUtc.ToLocalTime().ToString("g")</span>
                                    <span role="cell" data-label="@UiStrings.Sessions.State">@SessionBadge(s)</span>
                                    <span role="cell" class="us-td--actions">
                                        @if (s.IsActive && Auth.HasPermission(IdentityPermissions.SessionsRevoke))
                                        {
                                            <RowActionMenu>
                                                <RowAction Text="@UiStrings.Account.RevokeSession" Icon="block" Danger="true"
                                                           OnClick="@(() => RevokeSessionAsync(s.Id))" />
                                            </RowActionMenu>
                                        }
                                    </span>
                                </div>
                            }
                        </div>
                    }
                </RadzenCard>
            }
        </div>
    </text>;

    @* ================================================================ Activity *@
    private RenderFragment ActivityTab(UserDetail u) =>@<text>
        <RadzenCard class="us-card">
            <div class="us-card-head"><RadzenIcon Icon="history" /><h3>@UiStrings.Audit.ActivityTitle</h3></div>
            @ActivityTimeline()
        </RadzenCard>
    </text>;

    private RenderFragment ActivityTimeline(int? maxItems = null) =>@<text>
        @if (activity.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="us-timeline">
                @foreach (var entry in maxItems is { } take ? activity.Take(take) : activity)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="us-timeline-row" @key="entry.Id">
                        <span class="us-timeline-icon us-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="us-timeline-content">
                            <p class="us-timeline-title">@entry.Action</p>
                            <p class="os-muted us-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="us-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment SessionBadge(UserSession s) =>@<text>
        @if (s.IsActive)
        {
            <StatusBadge Label="@UiStrings.Sessions.Active" Tone="success" />
        }
        else if (s.RevokedAtUtc is not null)
        {
            <StatusBadge Label="@UiStrings.Sessions.Revoked" Tone="danger" />
        }
        else
        {
            <StatusBadge Label="@UiStrings.Sessions.Expired" Tone="neutral" />
        }
    </text>;

    private RenderFragment TimelineEmpty() =>@<text>
        <div class="us-timeline-empty">
            <span class="us-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="us-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@UiStrings.Audit.Description</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private UserDetail? user;
    private RoleDetail? roleDetail;
    private IReadOnlyList<OperationsSystem.Blazor.Client.Api.AuditTrailListItem> activity = [];
    private bool isLoading = true;
    private bool loadError;
    private string errorMessage = UiStrings.Errors.LoadFailed;

    private IReadOnlyList<UserSession>? sessions;
    private bool sessionsLoading;
    private bool sessionsError;
    private UserTab activeTab = UserTab.Overview;

    private const int OverviewActivityPreviewCount = 4;

    private enum UserTab { Overview, Sessions, Activity }

    private sealed record TabDef(UserTab Key, string Label, string Icon);

    private bool HasActiveSessions => sessions?.Any(s => s.IsActive) ?? false;
    private int ActiveSessionCount => sessions?.Count(s => s.IsActive) ?? 0;

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(UserTab.Overview, UiStrings.Common.Overview, "dashboard");
        if (Auth.HasPermission(IdentityPermissions.SessionsView))
            yield return new TabDef(UserTab.Sessions, UiStrings.Sessions.Title, "devices");
        yield return new TabDef(UserTab.Activity, UiStrings.Audit.ActivityTitle, "history");
    }

    private bool HasMoreActions(UserDetail u) =>
        Auth.HasPermission(IdentityPermissions.UsersAssignRole)
        || (u.Status == "Invited" && Auth.HasPermission(IdentityPermissions.UsersInvite))
        || (u.IsLockedOut && Auth.HasPermission(IdentityPermissions.UsersUnlock))
        || (!u.IsLockedOut && Auth.HasPermission(IdentityPermissions.UsersLock))
        || (u.Status != "Deactivated" && Auth.HasPermission(IdentityPermissions.UsersDeactivate));

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            user = await Identity.GetUserAsync(Id);
            await LoadSessionsAsync();
            await LoadRoleAsync(user.RoleId);

            activity = [];
            if (Auth.HasPermission(AuditPermissions.TrailsView))
            {
                try
                {
                    var trails = await AuditApi.GetTrailsAsync(entityType: "User", entityId: Id, pageSize: 25);
                    activity = trails.Items;
                }
                catch (ApiException)
                {
                    activity = [];
                }
            }
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadRoleAsync(Guid roleId)
    {
        roleDetail = null;
        if (!Auth.HasPermission(IdentityPermissions.RolesView))
            return;

        try
        {
            roleDetail = await Identity.GetRoleAsync(roleId);
        }
        catch (ApiException)
        {
            roleDetail = null;
        }
    }

    private async Task LoadSessionsAsync()
    {
        sessionsLoading = true;
        sessionsError = false;
        StateHasChanged();

        try
        {
            sessions = await Identity.GetUserSessionsAsync(Id);
        }
        catch (ApiException)
        {
            sessionsError = true;
        }
        finally
        {
            sessionsLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenEditAsync()
    {
        if (user is null)
            return;

        var result = await DialogService.OpenAsync<EditUserDialog>(UiStrings.Users.EditTitle,
            new Dictionary<string, object?> { [nameof(EditUserDialog.UserId)] = user.Id, [nameof(EditUserDialog.DisplayName)] = user.DisplayName });

        if (result is true)
            await LoadAsync();
    }

    private async Task OpenAssignRoleAsync()
    {
        if (user is null)
            return;

        var result = await DialogService.OpenAsync<AssignRoleDialog>(UiStrings.Users.AssignRoleTitle,
            new Dictionary<string, object?> { [nameof(AssignRoleDialog.UserId)] = user.Id, [nameof(AssignRoleDialog.CurrentRoleId)] = user.RoleId });

        if (result is true)
            await LoadAsync();
    }

    private Task ResendInvitationAsync() =>
        RunActionAsync(() => Identity.ResendInvitationAsync(Id), UiStrings.Users.ResendInvitation);

    private Task UnlockAsync() =>
        RunActionAsync(() => Identity.UnlockUserAsync(Id), UiStrings.Users.Unlock);

    private async Task LockAsync()
    {
        if (await Confirm(UiStrings.Users.ConfirmLock))
            await RunActionAsync(() => Identity.LockUserAsync(Id), UiStrings.Users.Lock);
    }

    private async Task DeactivateAsync()
    {
        if (await Confirm(UiStrings.Users.ConfirmDeactivate))
            await RunActionAsync(() => Identity.DeactivateUserAsync(Id), UiStrings.Users.Deactivate);
    }

    private async Task RevokeSessionAsync(Guid sessionId)
    {
        try
        {
            await Identity.RevokeSessionAsync(sessionId);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Account.RevokeSession);
            await LoadSessionsAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task RevokeAllAsync()
    {
        try
        {
            await Identity.RevokeUserSessionsAsync(Id);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Sessions.RevokeAll);
            await LoadSessionsAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task RunActionAsync(Func<Task> action, string successMessage)
    {
        try
        {
            await action();
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private async Task<bool> Confirm(string message) =>
        await DialogService.Confirm(message, UiStrings.Common.Confirm,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

    private void GoBack() => Navigation.NavigateTo("/users");

    // --- Presentation helpers ---------------------------------------------

    private static string ProfileClass(UserDetail u) =>
        u.IsLockedOut ? "us-profile--locked" : (u.Status == "Active" ? "us-profile--active" : "us-profile--inactive");

    private static string AvatarClass(UserDetail u) =>
        u.IsLockedOut ? "us-avatar--locked" : (u.Status == "Active" ? "us-avatar--active" : "us-avatar--inactive");

    private static string DotClass(UserDetail u) =>
        u.IsLockedOut ? "us-avatar-dot--locked" : (u.Status == "Active" ? "us-avatar-dot--active" : "us-avatar-dot--inactive");

    private static string StatusToneColor(UserDetail u) =>
        u.IsLockedOut ? "danger" : u.Status switch
        {
            "Active" => "success",
            "Invited" => "warning",
            _ => "neutral"
        };

    private static string StatusDescription(UserDetail u)
    {
        if (u.IsLockedOut)
            return UiStrings.Users.StatusLockedDesc;

        return u.Status switch
        {
            "Active" => UiStrings.Users.StatusActiveDesc,
            "Invited" => UiStrings.Users.StatusInvitedDesc,
            "Deactivated" => UiStrings.Users.StatusDeactivatedDesc,
            _ => UiStrings.Users.StatusActiveDesc
        };
    }

    private string AccessScope(UserDetail u)
    {
        var type = roleDetail?.CompatibleUserType;
        return type switch
        {
            UserTypes.SystemAdministrator => UiStrings.Users.ScopeFullAccess,
            UserTypes.StationStaff => UiStrings.Users.ScopeStation,
            UserTypes.CustomerContact => UiStrings.Users.ScopeCustomer,
            _ => UiStrings.Users.ScopeFullAccess
        };
    }

    private static string StatusTone(string status) => status switch
    {
        "Active" => "success",
        "Invited" => "warning",
        "Deactivated" => "neutral",
        _ => "neutral"
    };

    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string FullStamp(DateTimeOffset? value) =>
        value is { } v ? v.ToLocalTime().ToString("F") : UiStrings.Users.Never;

    private static string LoginStamp(DateTimeOffset? value) =>
        value is { } v ? RelativeTime(v) : UiStrings.Users.Never;

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private string? RecentIp() => sessions?.FirstOrDefault(s => s.IsCurrent)?.CreatedByIp
        ?? sessions?.Where(s => s.IsActive).OrderByDescending(s => s.CreatedAtUtc).FirstOrDefault()?.CreatedByIp;

    private string RecentDeviceLabel()
    {
        var session = sessions?.FirstOrDefault(s => s.IsCurrent)
            ?? sessions?.Where(s => s.IsActive).OrderByDescending(s => s.CreatedAtUtc).FirstOrDefault();
        return session is null ? UiStrings.Common.None : DeviceLabel(session.UserAgent);
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("log in") || a.Contains("logged in") || a.Contains("sign in") || a.Contains("signed in"))
            return ("login", "blue");
        if (a.Contains("role"))
            return ("badge", "blue");
        if (a.Contains("password"))
            return ("key", "amber");
        if (a.Contains("unlock"))
            return ("lock_open", "green");
        if (a.Contains("lock"))
            return ("lock", "amber");
        if (a.Contains("deactivat"))
            return ("person_off", "red");
        if (a.Contains("invit"))
            return ("mail", "blue");
        if (a.Contains("creat"))
            return ("person_add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }

    private static string DeviceIcon(string? userAgent)
    {
        if (string.IsNullOrWhiteSpace(userAgent))
            return "devices";

        var ua = userAgent.ToLowerInvariant();
        if (ua.Contains("iphone") || ua.Contains("android") || ua.Contains("mobile"))
            return "smartphone";
        if (ua.Contains("ipad") || ua.Contains("tablet"))
            return "tablet_mac";
        return "computer";
    }

    private static string DeviceLabel(string? userAgent)
    {
        if (string.IsNullOrWhiteSpace(userAgent))
            return UiStrings.Sessions.UnknownDevice;

        var ua = userAgent;
        var os =
            ua.Contains("Windows", StringComparison.OrdinalIgnoreCase) ? "Windows" :
            ua.Contains("iPhone", StringComparison.OrdinalIgnoreCase) ? "iPhone" :
            ua.Contains("iPad", StringComparison.OrdinalIgnoreCase) ? "iPad" :
            ua.Contains("Mac", StringComparison.OrdinalIgnoreCase) ? "macOS" :
            ua.Contains("Android", StringComparison.OrdinalIgnoreCase) ? "Android" :
            ua.Contains("Linux", StringComparison.OrdinalIgnoreCase) ? "Linux" :
            null;

        var browser =
            ua.Contains("Edg", StringComparison.OrdinalIgnoreCase) ? "Edge" :
            ua.Contains("OPR", StringComparison.OrdinalIgnoreCase) || ua.Contains("Opera", StringComparison.OrdinalIgnoreCase) ? "Opera" :
            ua.Contains("Firefox", StringComparison.OrdinalIgnoreCase) ? "Firefox" :
            ua.Contains("Chrome", StringComparison.OrdinalIgnoreCase) ? "Chrome" :
            ua.Contains("Safari", StringComparison.OrdinalIgnoreCase) ? "Safari" :
            null;

        return (os, browser) switch
        {
            (not null, not null) => $"{browser} · {os}",
            (not null, null) => os!,
            (null, not null) => browser!,
            _ => userAgent.Length > 48 ? userAgent[..48] + "…" : userAgent
        };
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }
}
