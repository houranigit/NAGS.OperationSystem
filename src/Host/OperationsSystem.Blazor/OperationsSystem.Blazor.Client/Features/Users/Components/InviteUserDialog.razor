@inject IdentityApiClient Identity
@inject DialogService DialogService

@if (invited is not null)
{
    <RadzenStack Gap="1rem">
        <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
            @UiStrings.Users.InviteSuccess
        </RadzenAlert>
        <RadzenFormField Text="@UiStrings.Users.InvitationTokenLabel" Variant="Variant.Outlined">
            <RadzenTextBox Value="@invited.InvitationToken.ToString()" ReadOnly="true" Style="width: 100%;" />
        </RadzenFormField>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
            <RadzenButton Text="@UiStrings.Common.Close" ButtonStyle="ButtonStyle.Primary" Click="@(() => DialogService.Close(true))" />
        </RadzenStack>
    </RadzenStack>
}
else
{
    <RadzenTemplateForm TItem="InviteModel" Data="@model" Submit="@SubmitAsync">
        <RadzenStack Gap="1rem">
            <RadzenFormField Text="@UiStrings.Auth.Email" Variant="Variant.Outlined">
                <RadzenTextBox @bind-Value="model.Email" Name="email" Style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="@UiStrings.Users.DisplayName" Variant="Variant.Outlined">
                <RadzenTextBox @bind-Value="model.DisplayName" Name="displayName" Style="width: 100%;" />
            </RadzenFormField>

            <RadzenFormField Text="@UiStrings.Users.Role" Variant="Variant.Outlined">
                <RadzenDropDown @bind-Value="model.RoleId" Data="@roles" TextProperty="@nameof(RoleListItem.Name)"
                                ValueProperty="@nameof(RoleListItem.Id)" Style="width: 100%;" />
            </RadzenFormField>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">@errorMessage</RadzenAlert>
            }

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="@UiStrings.Users.Invite" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
            </RadzenStack>
        </RadzenStack>
    </RadzenTemplateForm>
}

@code {
    private readonly InviteModel model = new();
    private IReadOnlyList<RoleListItem> roles = [];
    private InvitedUser? invited;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Identity.GetRolesAsync(1, 100, null);
            roles = result.Items;
            model.RoleId = roles.FirstOrDefault()?.Id ?? Guid.Empty;
        }
        catch (ApiException)
        {
            errorMessage = UiStrings.Errors.LoadFailed;
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (model.RoleId == Guid.Empty)
        {
            errorMessage = UiStrings.Users.Role;
            return;
        }

        isSubmitting = true;

        try
        {
            invited = await Identity.InviteUserAsync(new InviteUserRequest(model.Email.Trim(), model.DisplayName.Trim(), model.RoleId));
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class InviteModel
    {
        public string Email { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public Guid RoleId { get; set; } = Guid.Empty;
    }
}
