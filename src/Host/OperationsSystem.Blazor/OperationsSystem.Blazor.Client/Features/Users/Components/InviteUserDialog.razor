@inject IdentityApiClient Identity
@inject DialogService DialogService

@if (invited is not null)
{
    <RadzenStack Gap="1rem">
        <DismissibleDialogMessage AlertStyle="AlertStyle.Success">
            @UiStrings.Users.InviteSuccess
        </DismissibleDialogMessage>
        <RadzenFormField Text="@UiStrings.Users.InvitationDeliveryLabel" Variant="Variant.Outlined">
            <RadzenTextBox Value="@invited.DeliveryStatus" ReadOnly="true" Style="width: 100%;" />
        </RadzenFormField>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
            <RadzenButton Text="@UiStrings.Common.Close" ButtonStyle="ButtonStyle.Primary" Click="@(() => DialogService.Close(true))" />
        </RadzenStack>
    </RadzenStack>
}
else
{
    <RadzenTemplateForm TItem="InviteModel" Data="@model" Submit="@SubmitAsync">
        <div class="iud-form">
            <p class="iud-intro os-muted">@UiStrings.Users.InviteIntro</p>

            <DismissibleDialogMessage AlertStyle="AlertStyle.Info">
                @UiStrings.Users.InviteAdminNote
            </DismissibleDialogMessage>

            <RadzenFormField Text="@UiStrings.Users.UserType" Variant="Variant.Outlined" Style="width: 100%;">
                <Start><RadzenIcon Icon="manage_accounts" /></Start>
                <ChildContent>
                    <RadzenDropDown TValue="string"
                                    Value="@model.UserType"
                                    Change="@((object? value) => OnUserTypeChangedAsync(value?.ToString()))"
                                    Data="@DirectUserTypeOptions"
                                    TextProperty="@nameof(UserTypeOption.Label)"
                                    ValueProperty="@nameof(UserTypeOption.Value)"
                                    Disabled="@(isSubmitting || isLoadingRoles)"
                                    Style="width: 100%;" />
                </ChildContent>
            </RadzenFormField>

            <RadzenFormField Text="@UiStrings.Auth.Email" Variant="Variant.Outlined" Style="width: 100%;">
                <Start><RadzenIcon Icon="mail" /></Start>
                <ChildContent>
                    <RadzenTextBox @bind-Value="model.Email" Name="email" Style="width: 100%;" />
                </ChildContent>
            </RadzenFormField>

            <RadzenFormField Text="@UiStrings.Users.DisplayName" Variant="Variant.Outlined" Style="width: 100%;">
                <Start><RadzenIcon Icon="person" /></Start>
                <ChildContent>
                    <RadzenTextBox @bind-Value="model.DisplayName" Name="displayName" Style="width: 100%;" />
                </ChildContent>
            </RadzenFormField>

            @if (isLoadingRoles)
            {
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
            }
            else if (roles.Count == 0)
            {
                <DismissibleDialogMessage AlertStyle="AlertStyle.Warning">
                    @UiStrings.Users.NoCompatibleRoles
                </DismissibleDialogMessage>
            }
            else
            {
                <RadzenFormField Text="@UiStrings.Users.Role" Variant="Variant.Outlined" Style="width: 100%;">
                    <Start><RadzenIcon Icon="badge" /></Start>
                    <ChildContent>
                        <RadzenDropDown @bind-Value="model.RoleId" Data="@roles" TextProperty="@nameof(RoleOption.Name)"
                                        ValueProperty="@nameof(RoleOption.Id)" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" Style="width: 100%;" />
                    </ChildContent>
                </RadzenFormField>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" StateKey="@errorMessage"
                                          OnDismiss="@(() => errorMessage = null)">
                    @errorMessage
                </DismissibleDialogMessage>
            }

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="@UiStrings.Users.Invite" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
            </RadzenStack>
        </div>
    </RadzenTemplateForm>
}

@code {
    private readonly InviteModel model = new();
    private InvitedUser? invited;
    private IReadOnlyList<RoleOption> roles = [];
    private bool isSubmitting;
    private bool isLoadingRoles;
    private string? errorMessage;

    protected override Task OnInitializedAsync() => LoadRolesAsync(model.UserType);

    private async Task OnUserTypeChangedAsync(string? userType)
    {
        if (string.IsNullOrWhiteSpace(userType) ||
            string.Equals(model.UserType, userType, StringComparison.Ordinal))
        {
            return;
        }

        model.UserType = userType;
        await LoadRolesAsync(userType);
    }

    private async Task LoadRolesAsync(string userType)
    {
        isLoadingRoles = true;
        roles = [];
        model.RoleId = null;
        errorMessage = null;

        try
        {
            roles = await Identity.GetRoleOptionsAsync(userType, assignableOnly: true);
            model.RoleId = roles.FirstOrDefault()?.Id;
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoadingRoles = false;
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Email))
        {
            errorMessage = UiStrings.Auth.EmailRequired;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.DisplayName))
        {
            errorMessage = UiStrings.Users.DisplayNameRequired;
            return;
        }

        if (model.RoleId is null)
        {
            errorMessage = UiStrings.Users.RoleRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            invited = await Identity.InviteUserAsync(new InviteUserRequest(model.Email.Trim(), model.DisplayName.Trim(), model.RoleId));
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class InviteModel
    {
        public string UserType { get; set; } = UserTypes.SystemAdministrator;
        public string Email { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
        public Guid? RoleId { get; set; }
    }

    private static IReadOnlyList<UserTypeOption> DirectUserTypeOptions =>
        UserTypes.Direct
            .Select(value => new UserTypeOption(value, UserTypeLabel(value)))
            .ToArray();

    private static string UserTypeLabel(string userType) => userType switch
    {
        UserTypes.SystemAdministrator => UiStrings.Users.TypeSystemAdministrator,
        UserTypes.ViewerOnly => UiStrings.Users.TypeViewerOnly,
        _ => userType
    };

    private sealed record UserTypeOption(string Value, string Label);
}
