@inject IdentityApiClient Identity
@inject DialogService DialogService

@if (invited is not null)
{
    <RadzenStack Gap="1rem">
        <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
            @UiStrings.Users.InviteSuccess
        </RadzenAlert>
        <RadzenFormField Text="@UiStrings.Users.InvitationDeliveryLabel" Variant="Variant.Outlined">
            <RadzenTextBox Value="@invited.DeliveryStatus" ReadOnly="true" Style="width: 100%;" />
        </RadzenFormField>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
            <RadzenButton Text="@UiStrings.Common.Close" ButtonStyle="ButtonStyle.Primary" Click="@(() => DialogService.Close(true))" />
        </RadzenStack>
    </RadzenStack>
}
else
{
    <RadzenTemplateForm TItem="InviteModel" Data="@model" Submit="@SubmitAsync">
        <div class="iud-form">
            <p class="iud-intro os-muted">@UiStrings.Users.InviteIntro</p>

            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                @UiStrings.Users.InviteAdminNote
            </RadzenAlert>

            <RadzenFormField Text="@UiStrings.Auth.Email" Variant="Variant.Outlined" Style="width: 100%;">
                <Start><RadzenIcon Icon="mail" /></Start>
                <ChildContent>
                    <RadzenTextBox @bind-Value="model.Email" Name="email" Style="width: 100%;" />
                </ChildContent>
            </RadzenFormField>

            <RadzenFormField Text="@UiStrings.Users.DisplayName" Variant="Variant.Outlined" Style="width: 100%;">
                <Start><RadzenIcon Icon="person" /></Start>
                <ChildContent>
                    <RadzenTextBox @bind-Value="model.DisplayName" Name="displayName" Style="width: 100%;" />
                </ChildContent>
            </RadzenFormField>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">@errorMessage</RadzenAlert>
            }

            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="@UiStrings.Users.Invite" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
            </RadzenStack>
        </div>
    </RadzenTemplateForm>
}

@code {
    private readonly InviteModel model = new();
    private InvitedUser? invited;
    private bool isSubmitting;
    private string? errorMessage;

    private async Task SubmitAsync()
    {
        errorMessage = null;
        isSubmitting = true;

        try
        {
            invited = await Identity.InviteUserAsync(new InviteUserRequest(model.Email.Trim(), model.DisplayName.Trim()));
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class InviteModel
    {
        public string Email { get; set; } = string.Empty;
        public string DisplayName { get; set; } = string.Empty;
    }
}
