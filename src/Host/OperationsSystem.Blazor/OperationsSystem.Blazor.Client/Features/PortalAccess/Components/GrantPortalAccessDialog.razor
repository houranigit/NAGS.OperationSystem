@inject IdentityApiClient Identity
@inject DialogService DialogService

<div class="gpa-form">
    <p class="gpa-intro os-muted">@UiStrings.PortalAccess.Explanation</p>

    @if (isLoading)
    {
        <div class="gpa-loading">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        </div>
    }
    else if (roles.Count == 0)
    {
        @if (loadErrorMessage is not null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" AllowClose="false">
                @loadErrorMessage
            </RadzenAlert>
        }
        else
        {
            <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" ShowIcon="true" AllowClose="false">
                @UiStrings.PortalAccess.NoCompatibleRoles
            </RadzenAlert>
        }
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
            <RadzenButton Text="@UiStrings.Common.Close" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
        </RadzenStack>
    }
    else
    {
        <RadzenFormField Text="@UiStrings.PortalAccess.Role" Variant="Variant.Outlined" Style="width: 100%;">
            <Start><RadzenIcon Icon="badge" /></Start>
            <ChildContent>
                <RadzenDropDown @bind-Value="selectedRoleId" Data="@roles" TextProperty="Name" ValueProperty="Id"
                                Placeholder="@UiStrings.PortalAccess.RolePlaceholder" AllowFiltering="true" Style="width: 100%;" />
            </ChildContent>
        </RadzenFormField>

        @if (errorMessage is not null)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" ShowIcon="true" AllowClose="false">@errorMessage</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" Disabled="@isSubmitting" />
            <RadzenButton Text="@UiStrings.PortalAccess.Grant" Icon="send" ButtonStyle="ButtonStyle.Primary" Click="@SubmitAsync" Disabled="@(isSubmitting || selectedRoleId is null)" />
        </RadzenStack>
    }
</div>

@code {
    /// <summary>The user type a candidate role must declare to be eligible (e.g. "StationStaff").</summary>
    [Parameter] public string CompatibleUserType { get; set; } = string.Empty;

    /// <summary>Performs the grant against the selected role; throws <see cref="ApiException"/> on failure.</summary>
    [Parameter] public Func<Guid, CancellationToken, Task>? GrantAsync { get; set; }

    private readonly List<RoleOption> roles = [];
    private Guid? selectedRoleId;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? loadErrorMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            roles.AddRange(await Identity.GetRoleOptionsAsync(CompatibleUserType));
            selectedRoleId = roles.FirstOrDefault()?.Id;
        }
        catch (ApiException ex)
        {
            loadErrorMessage = ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (selectedRoleId is not { } roleId)
        {
            errorMessage = UiStrings.PortalAccess.RoleRequired;
            return;
        }

        if (GrantAsync is null)
        {
            errorMessage = UiStrings.Common.SomethingWentWrong;
            return;
        }

        isSubmitting = true;
        try
        {
            await GrantAsync(roleId, CancellationToken.None);
            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
