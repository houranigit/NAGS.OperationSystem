@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject AuditApiClient AuditApi

<PageTitle>@(item?.Name ?? Title)</PageTitle>

<RequirePermission Permission="@ViewPermission">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (item is { } catalog)
    {
        <div class="md-workspace">
            <section class="md-profile @ProfileClass(catalog)">
                <div class="md-hero">
                    <div class="md-avatar @AvatarClass(catalog)">
                        <RadzenIcon Icon="@Icon" />
                        <span class="md-avatar-dot @DotClass(catalog)"></span>
                    </div>

                    <div class="md-identity">
                        <div class="md-identity-headline">
                            <h1 class="md-name">@catalog.Name</h1>
                            <StatusBadge Label="@(catalog.IsActive ? "Active" : "Inactive")" Tone="@(catalog.IsActive ? "success" : "neutral")" />
                            <span class="md-info-badge"><RadzenIcon Icon="@Icon" />@Title</span>
                        </div>

                        <div class="md-meta-row">
                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(catalog.Id)</span>
                            <button type="button" class="md-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(catalog.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="md-hero-actions">
                        @if (Auth.HasPermission(UpdatePermission))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(catalog))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions" ShowLabel="true">
                                <RowAction Text="Activate" Icon="check_circle" Permission="@ActivatePermission"
                                           Visible="@(!catalog.IsActive)" OnClick="@ActivateAsync" />
                                <RowAction Text="Deactivate" Icon="cancel" Danger="true" Permission="@DeactivatePermission"
                                           Visible="@catalog.IsActive" OnClick="@DeactivateAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="md-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="md-tab @(activeTab == tab.Key ? "md-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            <div class="md-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    SimpleCatalogTab.History => HistoryTab(catalog),
                    _ => OverviewTab(catalog)
                })
            </div>
        </div>
    }
</RequirePermission>

@code {
    private RenderFragment OverviewTab(SimpleCatalogDetail catalog) =>@<text>
        <div class="md-stack">
            <div class="md-overview-grid">
                <RadzenCard class="md-card">
                    <div class="md-card-head"><RadzenIcon Icon="toggle_on" /><h3>Status</h3></div>
                    <div class="md-lead">
                        <span class="md-lead-dot md-lead-dot--@StatusToneColor(catalog)"></span>
                        <div>
                            <p class="md-lead-title">@(catalog.IsActive ? "Active" : "Inactive")</p>
                            <p class="os-muted md-lead-desc">@StatusDescription(catalog)</p>
                        </div>
                    </div>
                    <dl class="md-metrics">
                        <div class="md-metric">
                            <dt>Created</dt>
                            <dd>@catalog.CreatedAtUtc.ToLocalTime().ToString("d")</dd>
                        </div>
                        <div class="md-metric">
                            <dt>Updated</dt>
                            <dd>@(catalog.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>

                <RadzenCard class="md-card">
                    <div class="md-card-head"><RadzenIcon Icon="@Icon" /><h3>@UiStrings.Common.Details</h3></div>
                    <div class="md-lead">
                        <span class="md-lead-icon md-lead-icon--blue"><RadzenIcon Icon="@Icon" /></span>
                        <div>
                            <p class="md-lead-title">@catalog.Name</p>
                            <p class="os-muted md-lead-desc">@DescriptionOrNone(catalog.Description)</p>
                        </div>
                    </div>
                    <dl class="md-metrics md-metrics--tall">
                        <div class="md-metric">
                            <dt>Name</dt>
                            <dd>@catalog.Name</dd>
                        </div>
                        <div class="md-metric">
                            <dt>Description</dt>
                            <dd>@DescriptionOrNone(catalog.Description)</dd>
                        </div>
                        <div class="md-metric">
                            <dt>Status</dt>
                            <dd>@(catalog.IsActive ? "Active" : "Inactive")</dd>
                        </div>
                    </dl>
                </RadzenCard>
            </div>

            @if (CanViewAudit)
            {
                <RadzenCard class="md-card">
                    <div class="md-card-head">
                        <RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3>
                        @if (history.Count > 0)
                        {
                            <button type="button" class="md-link" @onclick="@(() => activeTab = SimpleCatalogTab.History)">@UiStrings.Common.ViewAll</button>
                        }
                    </div>
                    <p class="os-muted">@UiStrings.Audit.Description</p>
                    @HistoryTimeline(OverviewHistoryPreviewCount)
                </RadzenCard>
            }
        </div>
    </text>;

    private RenderFragment HistoryTab(SimpleCatalogDetail catalog) =>@<text>
        <RadzenCard class="md-card">
            <div class="md-card-head"><RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3></div>
            <p class="os-muted">@UiStrings.Audit.Description</p>
            @HistoryTimeline()
        </RadzenCard>
    </text>;

    private RenderFragment HistoryTimeline(int? maxItems = null) =>@<text>
        @if (history.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="md-timeline">
                @foreach (var entry in maxItems is { } take ? history.Take(take) : history)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="md-timeline-row" @key="entry.Id">
                        <span class="md-timeline-icon md-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="md-timeline-content">
                            <p class="md-timeline-title">@entry.Action</p>
                            <p class="os-muted md-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="md-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                        <RadzenButton Text="@UiStrings.Audit.ViewDetails" Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      class="md-timeline-view" Click="@(() => OpenAuditDetailAsync(entry.Id))" />
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment TimelineEmpty() =>@<text>
        <div class="md-timeline-empty">
            <span class="md-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="md-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@UiStrings.Audit.Empty</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public SimpleCatalogKind Kind { get; set; }
    [Parameter] public Guid Id { get; set; }

    private SimpleCatalogDetail? item;
    private IReadOnlyList<AuditTrailListItem> history = [];
    private bool isLoading = true;
    private bool loadError;
    private string errorMessage = UiStrings.Errors.LoadFailed;
    private SimpleCatalogTab activeTab = SimpleCatalogTab.Overview;

    private const int OverviewHistoryPreviewCount = 4;

    private enum SimpleCatalogTab { Overview, History }

    private sealed record TabDef(SimpleCatalogTab Key, string Label, string Icon);

    private string Title => SimpleCatalogText.Title(Kind);
    private string Icon => SimpleCatalogText.Icon(Kind);
    private string Route => SimpleCatalogText.Route(Kind);
    private string ViewPermission => SimpleCatalogText.ViewPermission(Kind);
    private string UpdatePermission => SimpleCatalogText.UpdatePermission(Kind);
    private string ActivatePermission => SimpleCatalogText.ActivatePermission(Kind);
    private string DeactivatePermission => SimpleCatalogText.DeactivatePermission(Kind);

    private bool CanViewAudit => Auth.HasPermission(AuditPermissions.TrailsView);

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(SimpleCatalogTab.Overview, UiStrings.Common.Overview, "dashboard");
        if (CanViewAudit)
            yield return new TabDef(SimpleCatalogTab.History, UiStrings.Audit.HistoryTitle, "manage_history");
    }

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        var historyTask = LoadHistoryAsync();

        try
        {
            item = await LoadDetailAsync();
            history = await historyTask;
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<IReadOnlyList<AuditTrailListItem>> LoadHistoryAsync()
    {
        if (!CanViewAudit)
            return [];

        try
        {
            var trails = await AuditApi.GetTrailsAsync(entityType: EntityType, entityId: Id, pageSize: 25);
            return trails.Items;
        }
        catch (ApiException)
        {
            return [];
        }
    }

    private async Task OpenEditAsync()
    {
        var result = await DialogService.OpenAsync<SimpleCatalogFormDialog>($"Edit {SimpleCatalogText.Singular(Kind)}",
            new Dictionary<string, object?> { [nameof(SimpleCatalogFormDialog.Kind)] = Kind, [nameof(SimpleCatalogFormDialog.EntityId)] = Id },
            new DialogOptions { Width = "760px" });
        if (result is true)
            await LoadAsync();
    }

    private async Task ActivateAsync()
    {
        if (item is not { } catalog)
            return;

        await RunAsync((rv, ct) => ActivateAsync(rv, ct), $"{SimpleCatalogText.Singular(Kind)} activated.", catalog.RowVersion);
    }

    private async Task DeactivateAsync()
    {
        if (item is not { } catalog)
            return;

        var confirmed = await DialogService.Confirm($"Deactivate this {SimpleCatalogText.Singular(Kind)}?", "Deactivate",
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;
        if (!confirmed)
            return;

        await RunAsync((rv, ct) => DeactivateAsync(rv, ct), $"{SimpleCatalogText.Singular(Kind)} deactivated.", catalog.RowVersion);
    }

    private async Task RunAsync(Func<string, CancellationToken, Task> action, string message, string rowVersion)
    {
        try
        {
            await action(rowVersion, CancellationToken.None);
            Notifications.Notify(NotificationSeverity.Success, message);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private Task ActivateAsync(string rowVersion, CancellationToken ct) => Kind switch
    {
        SimpleCatalogKind.Services => MasterData.ActivateServiceAsync(Id, rowVersion, ct),
        SimpleCatalogKind.OperationTypes => MasterData.ActivateOperationTypeAsync(Id, rowVersion, ct),
        SimpleCatalogKind.Materials => MasterData.ActivateMaterialAsync(Id, rowVersion, ct),
        SimpleCatalogKind.GeneralSupports => MasterData.ActivateGeneralSupportAsync(Id, rowVersion, ct),
        _ => Task.CompletedTask
    };

    private Task DeactivateAsync(string rowVersion, CancellationToken ct) => Kind switch
    {
        SimpleCatalogKind.Services => MasterData.DeactivateServiceAsync(Id, rowVersion, ct),
        SimpleCatalogKind.OperationTypes => MasterData.DeactivateOperationTypeAsync(Id, rowVersion, ct),
        SimpleCatalogKind.Materials => MasterData.DeactivateMaterialAsync(Id, rowVersion, ct),
        SimpleCatalogKind.GeneralSupports => MasterData.DeactivateGeneralSupportAsync(Id, rowVersion, ct),
        _ => Task.CompletedTask
    };

    private async Task<SimpleCatalogDetail> LoadDetailAsync() => Kind switch
    {
        SimpleCatalogKind.Services => ToDetail(await MasterData.GetServiceAsync(Id)),
        SimpleCatalogKind.OperationTypes => ToDetail(await MasterData.GetOperationTypeAsync(Id)),
        SimpleCatalogKind.Materials => ToDetail(await MasterData.GetMaterialAsync(Id)),
        SimpleCatalogKind.GeneralSupports => ToDetail(await MasterData.GetGeneralSupportAsync(Id)),
        _ => throw new InvalidOperationException("Unsupported catalog kind.")
    };

    private async Task OpenAuditDetailAsync(Guid trailId)
    {
        await DialogService.OpenAsync<AuditTrailDetailDialog>(
            UiStrings.Audit.DetailsTitle,
            new Dictionary<string, object?> { [nameof(AuditTrailDetailDialog.TrailId)] = trailId },
            new DialogOptions { Width = "760px" });
    }

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private bool HasMoreActions(SimpleCatalogDetail catalog) =>
        (!catalog.IsActive && Auth.HasPermission(ActivatePermission))
        || (catalog.IsActive && Auth.HasPermission(DeactivatePermission));

    private string EntityType => Kind switch
    {
        SimpleCatalogKind.Services => "Service",
        SimpleCatalogKind.OperationTypes => "OperationType",
        SimpleCatalogKind.Materials => "Material",
        SimpleCatalogKind.GeneralSupports => "GeneralSupport",
        _ => "Catalog"
    };

    private static SimpleCatalogDetail ToDetail(ServiceDetail value) => new(value.Id, value.Name, value.Description, value.IsActive, value.CreatedAtUtc, value.UpdatedAtUtc, value.RowVersion);
    private static SimpleCatalogDetail ToDetail(OperationTypeDetail value) => new(value.Id, value.Name, value.Description, value.IsActive, value.CreatedAtUtc, value.UpdatedAtUtc, value.RowVersion);
    private static SimpleCatalogDetail ToDetail(MaterialDetail value) => new(value.Id, value.Name, value.Description, value.IsActive, value.CreatedAtUtc, value.UpdatedAtUtc, value.RowVersion);
    private static SimpleCatalogDetail ToDetail(GeneralSupportDetail value) => new(value.Id, value.Name, value.Description, value.IsActive, value.CreatedAtUtc, value.UpdatedAtUtc, value.RowVersion);

    private void GoBack() => Navigation.NavigateTo($"/master-data/{Route}");

    private static string DescriptionOrNone(string? value) => string.IsNullOrWhiteSpace(value) ? UiStrings.Common.None : value;

    private static string ProfileClass(SimpleCatalogDetail catalog) => catalog.IsActive ? "md-profile--active" : "md-profile--inactive";
    private static string AvatarClass(SimpleCatalogDetail catalog) => catalog.IsActive ? "md-avatar--active" : "md-avatar--inactive";
    private static string DotClass(SimpleCatalogDetail catalog) => catalog.IsActive ? "md-avatar-dot--active" : "md-avatar-dot--inactive";
    private static string StatusToneColor(SimpleCatalogDetail catalog) => catalog.IsActive ? "success" : "neutral";
    private static string StatusDescription(SimpleCatalogDetail catalog) => catalog.IsActive ? "Available for use in operational workflows." : "Hidden from active selection lists until reactivated.";
    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("activ"))
            return ("check_circle", "green");
        if (a.Contains("deactiv"))
            return ("cancel", "red");
        if (a.Contains("delet"))
            return ("delete", "red");
        if (a.Contains("creat"))
            return ("add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }
}
