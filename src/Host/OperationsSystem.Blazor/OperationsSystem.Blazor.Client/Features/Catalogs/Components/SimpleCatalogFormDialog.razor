@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="SimpleCatalogModel" Data="@model" Submit="@SubmitAsync">
    <div class="mtf-form">
        <p class="mtf-intro os-muted">@SimpleCatalogText.Description(Kind)</p>
        <div class="mtf-section-line"><RadzenIcon Icon="@SimpleCatalogText.Icon(Kind)" /><span>@UiStrings.Common.Details</span></div>

        <div class="mtf-field-block">
            <label class="mtf-label">Name <span>*</span></label>
            <div class="mtf-input-wrap">
                <RadzenIcon Icon="@SimpleCatalogText.Icon(Kind)" class="mtf-field-icon" />
                <RadzenTextBox @bind-Value="model.Name" Name="name" class="mtf-control mtf-control-icon" MaxLength="@NameMaxLength" />
            </div>
        </div>
        <div class="mtf-field-block">
            <label class="mtf-label">Description</label>
            <RadzenTextArea @bind-Value="model.Description" Name="description" Rows="4" class="mtf-control" MaxLength="500" />
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" Title="Please fix the following errors before continuing"
                                      StateKey="@errorMessage" OnDismiss="@(() => errorMessage = null)">
                <ul><li>@errorMessage</li></ul>
            </DismissibleDialogMessage>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="mtf-actions">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(EntityId is null ? UiStrings.Common.Create : UiStrings.Common.Save)"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
        </RadzenStack>
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public SimpleCatalogKind Kind { get; set; }
    [Parameter] public Guid? EntityId { get; set; }

    private SimpleCatalogModel model = new();
    private string? rowVersion;
    private bool isSubmitting;
    private string? errorMessage;

    private int NameMaxLength => Kind is SimpleCatalogKind.Materials or SimpleCatalogKind.GeneralSupports ? 200 : 100;

    protected override async Task OnInitializedAsync()
    {
        if (EntityId is not { } id)
            return;

        try
        {
            var detail = await LoadDetailAsync(id);
            model = new SimpleCatalogModel { Name = detail.Name, Description = detail.Description };
            rowVersion = detail.RowVersion;
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorMessage = "A name is required.";
            return;
        }

        isSubmitting = true;
        try
        {
            var name = model.Name.Trim();
            var description = string.IsNullOrWhiteSpace(model.Description) ? null : model.Description.Trim();

            if (EntityId is { } id)
                await UpdateAsync(id, name, description);
            else
                await CreateAsync(name, description);

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private Task CreateAsync(string name, string? description) => Kind switch
    {
        SimpleCatalogKind.Services => MasterData.CreateServiceAsync(new CreateServiceRequest(name, description)),
        SimpleCatalogKind.OperationTypes => MasterData.CreateOperationTypeAsync(new CreateOperationTypeRequest(name, description)),
        SimpleCatalogKind.Materials => MasterData.CreateMaterialAsync(new CreateMaterialRequest(name, description)),
        SimpleCatalogKind.GeneralSupports => MasterData.CreateGeneralSupportAsync(new CreateGeneralSupportRequest(name, description)),
        _ => Task.CompletedTask
    };

    private Task UpdateAsync(Guid id, string name, string? description) => Kind switch
    {
        SimpleCatalogKind.Services => MasterData.UpdateServiceAsync(id, new UpdateServiceRequest(name, description), rowVersion ?? string.Empty),
        SimpleCatalogKind.OperationTypes => MasterData.UpdateOperationTypeAsync(id, new UpdateOperationTypeRequest(name, description), rowVersion ?? string.Empty),
        SimpleCatalogKind.Materials => MasterData.UpdateMaterialAsync(id, new UpdateMaterialRequest(name, description), rowVersion ?? string.Empty),
        SimpleCatalogKind.GeneralSupports => MasterData.UpdateGeneralSupportAsync(id, new UpdateGeneralSupportRequest(name, description), rowVersion ?? string.Empty),
        _ => Task.CompletedTask
    };

    private async Task<SimpleCatalogDetail> LoadDetailAsync(Guid id) => Kind switch
    {
        SimpleCatalogKind.Services => ToDetail(await MasterData.GetServiceAsync(id)),
        SimpleCatalogKind.OperationTypes => ToDetail(await MasterData.GetOperationTypeAsync(id)),
        SimpleCatalogKind.Materials => ToDetail(await MasterData.GetMaterialAsync(id)),
        SimpleCatalogKind.GeneralSupports => ToDetail(await MasterData.GetGeneralSupportAsync(id)),
        _ => throw new InvalidOperationException("Unsupported catalog kind.")
    };

    private static SimpleCatalogDetail ToDetail(ServiceDetail value) =>
        new(value.Id, value.Name, value.Description, value.IsActive, value.IsSystem, value.CreatedAtUtc, value.UpdatedAtUtc, value.RowVersion);

    private static SimpleCatalogDetail ToDetail(OperationTypeDetail value) =>
        new(value.Id, value.Name, value.Description, value.IsActive, value.IsSystem, value.CreatedAtUtc, value.UpdatedAtUtc, value.RowVersion);

    private static SimpleCatalogDetail ToDetail(MaterialDetail value) =>
        new(value.Id, value.Name, value.Description, value.IsActive, false, value.CreatedAtUtc, value.UpdatedAtUtc, value.RowVersion);

    private static SimpleCatalogDetail ToDetail(GeneralSupportDetail value) =>
        new(value.Id, value.Name, value.Description, value.IsActive, false, value.CreatedAtUtc, value.UpdatedAtUtc, value.RowVersion);

    private sealed class SimpleCatalogModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}
