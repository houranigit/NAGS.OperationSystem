@inject MasterDataApiClient MasterData
@inject IdentityApiClient Identity
@inject AuthSession Auth
@inject DialogService DialogService

<div class="sf-form @(StaffMemberId is null ? "sf-form-create" : "sf-form-edit")">
    @if (StaffMemberId is null)
    {
        @WizardStepper()
        <div class="sf-wizard-body">
            @(step switch { 0 => IdentityStep(), 1 => EmploymentStep(), _ => ReviewStep() })
        </div>
        @ErrorBanner()
        <div class="sf-actions">
            @if (step == 0)
            {
                <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            }
            else
            {
                <RadzenButton Text="@UiStrings.StaffMembers.Previous" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Click="@Previous" />
            }
            <div class="sf-actions-end">
                @if (step > 0)
                {
                    <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                }
                @if (step < 2)
                {
                    <RadzenButton Text="@UiStrings.StaffMembers.Next" Icon="arrow_forward" ButtonStyle="ButtonStyle.Primary" Click="@NextAsync" />
                }
                else
                {
                    <RadzenButton Text="@UiStrings.StaffMembers.CreateTitle" Icon="check" ButtonStyle="ButtonStyle.Primary" Click="@SubmitAsync" Disabled="@isSubmitting" />
                }
            </div>
        </div>
    }
    else
    {
        <RadzenTemplateForm TItem="StaffModel" Data="@model" Submit="@SubmitAsync">
            @IdentityStep()
            @EmploymentStep()
            @ErrorBanner()
            <div class="sf-actions sf-actions-edit">
                <span></span>
                <div class="sf-actions-end">
                    <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                    <RadzenButton ButtonType="ButtonType.Submit" Icon="check" Text="@UiStrings.Common.Save" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
                </div>
            </div>
        </RadzenTemplateForm>
    }
</div>

@code {
    [Parameter] public Guid? StaffMemberId { get; set; }
    [Parameter] public Guid? PreselectedStationId { get; set; }

    private StaffModel model = new();
    private readonly List<DayScheduleRow> scheduleDays =
    [
        new(DayOfWeek.Sunday, UiStrings.Days.Sunday),
        new(DayOfWeek.Monday, UiStrings.Days.Monday),
        new(DayOfWeek.Tuesday, UiStrings.Days.Tuesday),
        new(DayOfWeek.Wednesday, UiStrings.Days.Wednesday),
        new(DayOfWeek.Thursday, UiStrings.Days.Thursday),
        new(DayOfWeek.Friday, UiStrings.Days.Friday),
        new(DayOfWeek.Saturday, UiStrings.Days.Saturday)
    ];
    private readonly List<LicenseRow> licenseRows = [];
    private IReadOnlyList<StationOption> stations = [];
    private IReadOnlyList<ManpowerTypeOption> manpowerTypes = [];
    private IReadOnlyList<LicenseOption> licenses = [];
    private string? rowVersion;
    private bool isSubmitting;
    private string? errorMessage;
    private bool grantPortal;
    private Guid? portalRoleId;
    private IReadOnlyList<RoleOption> portalRoles = [];
    private int step;

    private RenderFragment WizardStepper() => @<div class="sf-stepper" aria-label="@UiStrings.StaffMembers.CreateTitle">
        @for (var i = 0; i < 3; i++)
        {
            var index = i;
            <div class="@StepClass(index)">
                <button type="button" class="sf-step-button" disabled="@(index > step)" @onclick="@(() => MoveToStep(index))">
                    <span class="sf-step-node">
                        @if (index < step) { <RadzenIcon Icon="check" /> }
                        else { @((index + 1).ToString()) }
                    </span>
                    <span class="sf-step-label">@StepLabel(index)</span>
                </button>
            </div>
        }
    </div>;

    private RenderFragment IdentityStep() => @<section class="sf-step-content">
        <div class="sf-section-line"><RadzenIcon Icon="badge" /><span>@UiStrings.StaffMembers.BasicInformation</span></div>
        <div class="sf-grid-2">
            <div class="sf-field-block"><label class="sf-label">@UiStrings.StaffMembers.EmployeeId <span class="sf-required">*</span></label><div class="sf-input-wrap"><RadzenIcon Icon="badge" class="sf-field-icon" /><RadzenTextBox @bind-Value="model.EmployeeId" Change="@((string? value) => model.EmployeeId = value)" class="sf-control sf-control-icon" MaxLength="50" Placeholder="e.g. EMP-1042" /></div></div>
            <div class="sf-field-block"><label class="sf-label">@UiStrings.StaffMembers.FullName <span class="sf-required">*</span></label><div class="sf-input-wrap"><RadzenIcon Icon="person" class="sf-field-icon" /><RadzenTextBox @bind-Value="model.FullName" Change="@((string? value) => model.FullName = value)" class="sf-control sf-control-icon" MaxLength="200" Placeholder="e.g. Jane Doe" /></div></div>
        </div>
        <div class="sf-field-block">
            <label class="sf-label">@UiStrings.StaffMembers.Email <span class="sf-required">*</span></label>
            <div class="sf-input-wrap"><RadzenIcon Icon="mail" class="sf-field-icon" /><RadzenTextBox @bind-Value="model.Email" Change="@((string? value) => model.Email = value)" class="sf-control sf-control-icon" MaxLength="256" Placeholder="jane.doe@example.com" /></div>
        </div>
        <div class="sf-section-line"><RadzenIcon Icon="flight_takeoff" /><span>@UiStrings.StaffMembers.Assignment</span></div>
        <div class="sf-grid-2">
            <div class="sf-field-block">
                <label class="sf-label">@UiStrings.StaffMembers.Station <span class="sf-required">*</span></label>
                <div class="sf-input-wrap"><RadzenIcon Icon="flight_takeoff" class="sf-field-icon" /><RadzenDropDown @bind-Value="model.StationId" Data="@stations" TextProperty="IataCode" ValueProperty="Id" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" class="sf-control sf-control-icon" Placeholder="@UiStrings.StaffMembers.SelectStation" /></div>
            </div>
            <div class="sf-field-block">
                <label class="sf-label">@UiStrings.StaffMembers.ManpowerType <span class="sf-required">*</span></label>
                <div class="sf-input-wrap"><RadzenIcon Icon="engineering" class="sf-field-icon" /><RadzenDropDown @bind-Value="model.ManpowerTypeId" Data="@manpowerTypes" TextProperty="Name" ValueProperty="Id" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" class="sf-control sf-control-icon" Placeholder="@UiStrings.StaffMembers.SelectManpowerType" /></div>
            </div>
        </div>
        <DismissibleDialogMessage AlertStyle="AlertStyle.Info" Title="@UiStrings.StaffMembers.EmployeeIdHintTitle">
            <p>@UiStrings.StaffMembers.EmployeeIdHint</p>
        </DismissibleDialogMessage>
    </section>;

    private RenderFragment EmploymentStep() => @<section class="sf-step-content">
        <div class="sf-section-heading"><RadzenIcon Icon="event" /><h3>@UiStrings.StaffMembers.EmploymentContract</h3></div>
        <div class="sf-grid-2">
            <div class="sf-field-block"><label class="sf-label">@UiStrings.StaffMembers.StartDate</label><RadzenDatePicker @bind-Value="model.StartDate" DateFormat="yyyy-MM-dd" class="sf-control" ShowTime="false" /></div>
            <div class="sf-field-block"><label class="sf-label">@UiStrings.StaffMembers.EndDate</label><RadzenDatePicker @bind-Value="model.EndDate" DateFormat="yyyy-MM-dd" class="sf-control" ShowTime="false" /></div>
        </div>
        <div class="sf-section-heading"><RadzenIcon Icon="calendar_month" /><h3>@UiStrings.StaffMembers.WorkingSchedule</h3></div>
        <div class="sf-days">
            @foreach (var day in scheduleDays)
            {
                <button type="button" class="sf-day @(day.Selected ? "sf-day--on" : "")" @onclick="@(() => day.Selected = !day.Selected)">
                    @if (day.Selected) { <RadzenIcon Icon="check" /> }<span>@day.Label</span>
                </button>
            }
        </div>
        <p class="sf-hint">@UiStrings.StaffMembers.ScheduleHint</p>
        <div class="sf-section-heading sf-section-heading-action">
            <div><RadzenIcon Icon="workspace_premium" /><h3>@UiStrings.StaffMembers.Licenses</h3></div>
            <RadzenButton Text="@UiStrings.StaffMembers.AddLicense" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@AddLicense" />
        </div>
        @if (licenseRows.Count == 0)
        {
            <div class="sf-empty"><RadzenIcon Icon="workspace_premium" /><span>@UiStrings.StaffMembers.LicensesEmpty</span></div>
        }
        else
        {
            <div class="sf-license-list">
                @foreach (var row in licenseRows)
                {
                    <div class="sf-license-row" @key="row.Key">
                        <RadzenDropDown @bind-Value="row.LicenseId" Data="@licenses" TextProperty="Code" ValueProperty="Id" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" Placeholder="@UiStrings.StaffMembers.License" class="sf-control" />
                        <RadzenTextBox @bind-Value="row.LicenseNumber" Placeholder="@UiStrings.StaffMembers.LicenseNumber" class="sf-control" MaxLength="100" />
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => licenseRows.Remove(row))" />
                    </div>
                }
            </div>
        }
        @if (StaffMemberId is null && Auth.CanGrantStaffPortalAccess)
        {
            <div class="sf-section-heading"><RadzenIcon Icon="vpn_key" /><h3>@UiStrings.PortalAccess.GrantTitle</h3></div>
            <div class="sf-portal-row"><RadzenSwitch @bind-Value="grantPortal" Name="grantPortal" /><div><RadzenLabel Text="@UiStrings.PortalAccess.GrantOnCreate" Component="grantPortal" /><p>@UiStrings.PortalAccess.GrantOnCreateHint</p></div></div>
            @if (grantPortal)
            {
                @if (portalRoles.Count == 0)
                {
                    <DismissibleDialogMessage AlertStyle="AlertStyle.Warning">
                        @UiStrings.PortalAccess.NoCompatibleRoles
                    </DismissibleDialogMessage>
                }
                else
                {
                    <RadzenDropDown @bind-Value="portalRoleId" Data="@portalRoles" TextProperty="Name" ValueProperty="Id" Placeholder="@UiStrings.PortalAccess.RolePlaceholder" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" class="sf-control" />
                }
            }
        }
    </section>;

    private RenderFragment ReviewStep() => @<section class="sf-step-content">
        <div class="sf-review-intro"><h3>@UiStrings.StaffMembers.ReviewTitle</h3><p>@UiStrings.StaffMembers.ReviewIntro</p></div>
        <div class="sf-review-card"><div class="sf-review-head"><h4>@UiStrings.StaffMembers.BasicInformation</h4><button type="button" @onclick="@(() => step = 0)"><RadzenIcon Icon="edit" />@UiStrings.Common.Edit</button></div>
            <dl class="sf-review-grid"><div><dt>@UiStrings.StaffMembers.EmployeeId</dt><dd>@model.EmployeeId</dd></div><div><dt>@UiStrings.StaffMembers.FullName</dt><dd>@model.FullName</dd></div><div><dt>@UiStrings.StaffMembers.Email</dt><dd>@model.Email</dd></div><div><dt>@UiStrings.StaffMembers.Station</dt><dd>@StationName</dd></div><div><dt>@UiStrings.StaffMembers.ManpowerType</dt><dd>@ManpowerTypeName</dd></div></dl>
        </div>
        <div class="sf-review-card"><div class="sf-review-head"><h4>@UiStrings.StaffMembers.EmploymentDetails</h4><button type="button" @onclick="@(() => step = 1)"><RadzenIcon Icon="edit" />@UiStrings.Common.Edit</button></div>
            <dl class="sf-review-grid"><div><dt>@UiStrings.StaffMembers.StartDate</dt><dd>@DateDisplay(model.StartDate)</dd></div><div><dt>@UiStrings.StaffMembers.EndDate</dt><dd>@DateDisplay(model.EndDate)</dd></div><div><dt>@UiStrings.StaffMembers.WorkingSchedule</dt><dd>@WorkingDaysDisplay</dd></div><div><dt>@UiStrings.StaffMembers.Licenses</dt><dd>@licenseRows.Count</dd></div><div><dt>@UiStrings.PortalAccess.GrantTitle</dt><dd>@(grantPortal ? UiStrings.Common.Yes : UiStrings.Common.No)</dd></div></dl>
        </div>
        <DismissibleDialogMessage AlertStyle="AlertStyle.Info" Icon="lock">
            @UiStrings.StaffMembers.ReviewNote
        </DismissibleDialogMessage>
    </section>;

    private RenderFragment ErrorBanner() => @<text>
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" Title="@UiStrings.StaffMembers.FixErrors"
                                      StateKey="@errorMessage" OnDismiss="@(() => errorMessage = null)">
                <ul><li>@errorMessage</li></ul>
            </DismissibleDialogMessage>
        }
    </text>;

    private string StepLabel(int index) => index switch { 0 => UiStrings.StaffMembers.StepProfile, 1 => UiStrings.StaffMembers.StepEmployment, _ => UiStrings.StaffMembers.StepReview };
    private string StepClass(int index) => $"sf-step sf-step-{(index < step ? "complete" : index == step ? "active" : "pending")}";
    private void MoveToStep(int index) { if (index > step) return; errorMessage = null; step = index; }
    private string StationName => stations.FirstOrDefault(s => s.Id == model.StationId)?.IataCode ?? UiStrings.Common.None;
    private string ManpowerTypeName => manpowerTypes.FirstOrDefault(m => m.Id == model.ManpowerTypeId)?.Name ?? UiStrings.Common.None;
    private string WorkingDaysDisplay => string.Join(", ", scheduleDays.Where(d => d.Selected).Select(d => d.Label)) is { Length: > 0 } value ? value : UiStrings.StaffMembers.NoSchedule;
    private static string DateDisplay(DateTime? value) => value?.ToString("yyyy-MM-dd") ?? UiStrings.Common.None;
    private void Previous() { errorMessage = null; step = Math.Max(0, step - 1); }

    private async Task NextAsync()
    {
        errorMessage = null;
        if (step == 0 && !ValidateIdentity()) return;
        if (step == 1 && !ValidateEmployment()) return;
        step = Math.Min(2, step + 1);
        await Task.CompletedTask;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var stationsTask = MasterData.GetStationOptionsAsync();
            var manpowerTypesTask = MasterData.GetManpowerTypeOptionsAsync();
            var licensesTask = MasterData.GetLicenseOptionsAsync();
            var portalRolesTask = StaffMemberId is null && Auth.CanGrantStaffPortalAccess
                ? Identity.GetRoleOptionsAsync("StationStaff", assignableOnly: true)
                : Task.FromResult<IReadOnlyList<RoleOption>>([]);
            Task<StaffMemberDetail?> detailTask = StaffMemberId is { } id
                ? GetStaffMemberForEditAsync(id)
                : Task.FromResult<StaffMemberDetail?>(null);

            await Task.WhenAll(stationsTask, manpowerTypesTask, licensesTask, portalRolesTask, detailTask);

            stations = await stationsTask;
            manpowerTypes = await manpowerTypesTask;
            licenses = await licensesTask;
            portalRoles = await portalRolesTask;

            if (PreselectedStationId is { } stationId)
                model.StationId = stationId;

            if (await detailTask is { } detail)
            {
                model = new StaffModel
                {
                    FullName = detail.FullName,
                    EmployeeId = detail.EmployeeId,
                    Email = detail.Email,
                    StationId = detail.StationId,
                    ManpowerTypeId = detail.ManpowerTypeId,
                    StartDate = detail.EmploymentContract?.StartDate.ToDateTime(TimeOnly.MinValue),
                    EndDate = detail.EmploymentContract?.EndDate?.ToDateTime(TimeOnly.MinValue)
                };
                rowVersion = detail.RowVersion;

                if (detail.WorkingDays is { } days)
                {
                    foreach (var row in scheduleDays)
                        row.Selected = days.Contains(row.Value);
                }

                foreach (var l in detail.Licenses)
                    licenseRows.Add(new LicenseRow { Id = l.Id, LicenseId = l.LicenseId, LicenseNumber = l.LicenseNumber });
            }
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
    }

    private async Task<StaffMemberDetail?> GetStaffMemberForEditAsync(Guid id) =>
        await MasterData.GetStaffMemberAsync(id);

    private void AddLicense() => licenseRows.Add(new LicenseRow());

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (!ValidateIdentity() || !ValidateEmployment())
            return;

        isSubmitting = true;

        try
        {
            EmploymentContractRequest? contract = model.StartDate is { } startDate
                ? new EmploymentContractRequest(DateOnly.FromDateTime(startDate), model.EndDate is { } e ? DateOnly.FromDateTime(e) : null)
                : null;

            var workingDays = scheduleDays.Where(d => d.Selected).Select(d => d.Value).ToList();
            IReadOnlyList<DayOfWeek>? days = workingDays.Count > 0 ? workingDays : null;

            var licenseRequests = licenseRows
                .Select(r => new StaffLicenseRequest(r.Id, r.LicenseId, r.LicenseNumber!.Trim().ToUpperInvariant()))
                .ToList();

            var name = model.FullName!.Trim();
            var employeeId = model.EmployeeId!.Trim();
            var email = model.Email!.Trim();

            if (StaffMemberId is { } id)
            {
                await MasterData.UpdateStaffMemberAsync(id,
                    new UpdateStaffMemberRequest(name, employeeId, email, model.StationId, model.ManpowerTypeId, contract, days, licenseRequests),
                    rowVersion ?? string.Empty);
            }
            else
            {
                await MasterData.CreateStaffMemberAsync(
                    new CreateStaffMemberRequest(
                        name, employeeId, email, model.StationId, model.ManpowerTypeId, contract, days, licenseRequests,
                        grantPortal ? portalRoleId : null));
            }

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private bool ValidateIdentity()
    {
        if (string.IsNullOrWhiteSpace(model.EmployeeId))
        {
            errorMessage = UiStrings.StaffMembers.EmployeeIdRequired;
            return false;
        }

        if (string.IsNullOrWhiteSpace(model.FullName))
        {
            errorMessage = UiStrings.StaffMembers.NameRequired;
            return false;
        }

        if (string.IsNullOrWhiteSpace(model.Email))
        {
            errorMessage = UiStrings.StaffMembers.EmailRequired;
            return false;
        }

        if (model.StationId == Guid.Empty)
        {
            errorMessage = UiStrings.StaffMembers.StationRequired;
            return false;
        }

        if (model.ManpowerTypeId == Guid.Empty)
        {
            errorMessage = UiStrings.StaffMembers.ManpowerTypeRequired;
            return false;
        }

        return true;
    }

    private bool ValidateEmployment()
    {
        if (model.StartDate is null && model.EndDate is not null)
        {
            errorMessage = UiStrings.StaffMembers.EndBeforeStart;
            return false;
        }

        if (model is { StartDate: { } start, EndDate: { } end } && end < start)
        {
            errorMessage = UiStrings.StaffMembers.EndBeforeStart;
            return false;
        }

        if (licenseRows.Any(r => r.LicenseId == Guid.Empty))
        {
            errorMessage = UiStrings.StaffMembers.LicenseRequired;
            return false;
        }

        if (licenseRows.Any(r => string.IsNullOrWhiteSpace(r.LicenseNumber)))
        {
            errorMessage = UiStrings.StaffMembers.LicenseNumberRequired;
            return false;
        }

        if (licenseRows.GroupBy(r => r.LicenseId).Any(g => g.Count() > 1))
        {
            errorMessage = UiStrings.StaffMembers.LicenseDuplicate;
            return false;
        }

        if (StaffMemberId is null && grantPortal && portalRoleId is null)
        {
            errorMessage = portalRoles.Count == 0
                ? UiStrings.PortalAccess.NoCompatibleRoles
                : UiStrings.PortalAccess.RoleRequired;
            return false;
        }

        return true;
    }

    private sealed class StaffModel
    {
        public string? FullName { get; set; }
        public string? EmployeeId { get; set; }
        public string? Email { get; set; }
        public Guid StationId { get; set; }
        public Guid ManpowerTypeId { get; set; }
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
    }

    private sealed class LicenseRow
    {
        public Guid Key { get; } = Guid.NewGuid();
        public Guid? Id { get; set; }
        public Guid LicenseId { get; set; }
        public string? LicenseNumber { get; set; }
    }

    private sealed class DayScheduleRow(DayOfWeek value, string label)
    {
        public DayOfWeek Value { get; } = value;
        public string Label { get; } = label;
        public bool Selected { get; set; }
    }
}
