@page "/master-data/staff-members/{Id:guid}"
@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject OperationsSystem.Blazor.Client.Api.AuditApiClient AuditApi

<PageTitle>@(item?.FullName ?? UiStrings.StaffMembers.Title)</PageTitle>

<RequirePermission Permission="@MasterDataPermissions.StaffMembersView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (item is { } s)
    {
        <div class="sm-workspace">
            <button type="button" class="sm-back" @onclick="GoBack">
                <RadzenIcon Icon="arrow_back" />
                <span>@UiStrings.StaffMembers.Title</span>
            </button>

            @* ---- Profile (hero + tabs as one unit) ----------------------- *@
            <section class="sm-profile @ProfileClass(s)">
                <div class="sm-hero">
                    <div class="sm-avatar @AvatarClass(s)">
                        <span>@Initials(s.FullName)</span>
                        <span class="sm-avatar-dot @DotClass(s)"></span>
                    </div>

                    <div class="sm-identity">
                        <div class="sm-identity-headline">
                            <h1 class="sm-name">@s.FullName</h1>
                            @if (s.IsActive)
                            {
                                <StatusBadge Label="@UiStrings.StaffMembers.Active" Tone="success" />
                            }
                            else
                            {
                                <StatusBadge Label="@UiStrings.StaffMembers.Inactive" Tone="neutral" />
                            }
                            <span class="sm-info-badge"><RadzenIcon Icon="engineering" />@s.ManpowerTypeName</span>
                        </div>

                        <div class="sm-meta-row">
                            <RadzenIcon Icon="mail" />
                            <span>@s.Email</span>
                            <button type="button" class="sm-copy" title="@UiStrings.Users.CopyEmail"
                                    aria-label="@UiStrings.Users.CopyEmail" @onclick="@(() => CopyAsync(s.Email))">
                                <RadzenIcon Icon="content_copy" />
                            </button>

                            <RadzenIcon Icon="flight_takeoff" />
                            <span>@s.StationCode</span>

                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(s.Id)</span>
                            <button type="button" class="sm-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(s.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="sm-hero-actions">
                        @if (Auth.HasPermission(MasterDataPermissions.StaffMembersUpdate))
                        {
                            <RadzenButton Text="@UiStrings.StaffMembers.EditMember" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(s))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions">
                                <RowAction Text="@UiStrings.StaffMembers.Activate" Icon="check_circle"
                                           Permission="@MasterDataPermissions.StaffMembersActivate"
                                           Visible="@(!s.IsActive)" OnClick="@ActivateAsync" />
                                <RowAction Text="@UiStrings.PortalAccess.GrantAction" Icon="person_add"
                                           Permission="@MasterDataPermissions.StaffMembersGrantAccess"
                                           Visible="@(s is { IsActive: true, LinkedUserId: null })" OnClick="@OpenGrantAccessAsync" />
                                <RowAction Separator="true" />
                                <RowAction Text="@UiStrings.StaffMembers.Deactivate" Icon="cancel" Danger="true"
                                           Permission="@MasterDataPermissions.StaffMembersDeactivate"
                                           Visible="@s.IsActive" OnClick="@DeactivateAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="sm-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="sm-tab @(activeTab == tab.Key ? "sm-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            @* ---- Tab body ------------------------------------------------ *@
            <div class="sm-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    StaffTab.Overview => OverviewTab(s),
                    StaffTab.Licenses => LicensesTab(s),
                    StaffTab.Schedule => ScheduleTab(s),
                    StaffTab.PortalAccess => PortalAccessTab(s),
                    _ => ActivityTab(s)
                })
            </div>
        </div>
    }
</RequirePermission>

@* ================================================================ Overview *@
@code {
    private RenderFragment OverviewTab(StaffMemberDetail s) =>@<text>
        <div class="sm-stack">
            <div class="sm-overview-grid">
                @* --- Employment status --- *@
                <RadzenCard class="sm-card">
                    <div class="sm-card-head"><RadzenIcon Icon="toggle_on" /><h3>@UiStrings.StaffMembers.Status</h3></div>
                    <div class="sm-lead">
                        <span class="sm-lead-dot sm-lead-dot--@StatusToneColor(s)"></span>
                        <div>
                            <p class="sm-lead-title">@(s.IsActive ? UiStrings.StaffMembers.Active : UiStrings.StaffMembers.Inactive)</p>
                            <p class="os-muted sm-lead-desc">@StatusDescription(s)</p>
                        </div>
                    </div>
                    <dl class="sm-metrics">
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.Status</dt>
                            <dd>@(s.IsActive ? UiStrings.StaffMembers.Active : UiStrings.StaffMembers.Inactive)</dd>
                        </div>
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.Created</dt>
                            <dd>@s.CreatedAtUtc.ToLocalTime().ToString("d")</dd>
                        </div>
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.Updated</dt>
                            <dd>@(s.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.EmploymentContract</dt>
                            <dd>
                                @if (s.EmploymentContract is { } ec)
                                {
                                    @($"{ec.StartDate:yyyy-MM-dd} — {(ec.EndDate is { } end ? end.ToString("yyyy-MM-dd") : UiStrings.StaffMembers.None)}")
                                }
                                else
                                {
                                    @UiStrings.StaffMembers.NoContract
                                }
                            </dd>
                        </div>
                    </dl>
                </RadzenCard>

                @* --- Assignment --- *@
                <RadzenCard class="sm-card">
                    <div class="sm-card-head"><RadzenIcon Icon="flight_takeoff" /><h3>@UiStrings.StaffMembers.Station</h3></div>
                    <div class="sm-lead">
                        <span class="sm-lead-icon sm-lead-icon--blue"><RadzenIcon Icon="engineering" /></span>
                        <div>
                            <p class="sm-lead-title">@s.StationCode</p>
                            <p class="os-muted sm-lead-desc">@s.StationName · @s.ManpowerTypeName</p>
                        </div>
                    </div>
                    <dl class="sm-metrics">
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.Station</dt>
                            <dd>@($"{s.StationCode} — {s.StationName}")</dd>
                        </div>
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.ManpowerType</dt>
                            <dd>@s.ManpowerTypeName</dd>
                        </div>
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.Licenses</dt>
                            <dd>@LicenseCountLabel(s.Licenses.Count)</dd>
                        </div>
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.StatWorkingDays</dt>
                            <dd>@((s.WorkingDays?.Count ?? 0).ToString())</dd>
                        </div>
                    </dl>
                    <button type="button" class="sm-card-link" @onclick="@(() => activeTab = StaffTab.Licenses)">
                        @UiStrings.Common.Open<RadzenIcon Icon="chevron_right" />
                    </button>
                </RadzenCard>

                @* --- Portal access summary --- *@
                <RadzenCard class="sm-card">
                    <div class="sm-card-head"><RadzenIcon Icon="vpn_key" /><h3>@UiStrings.StaffMembers.TabPortalAccess</h3></div>
                    <div class="sm-lead">
                        <span class="sm-lead-dot sm-lead-dot--@(s.LinkedUserId is not null ? "success" : "warning")"></span>
                        <div>
                            <p class="sm-lead-title">@(s.LinkedUserId is not null ? UiStrings.PortalAccess.HasAccess : UiStrings.PortalAccess.NoAccess)</p>
                            <p class="os-muted sm-lead-desc">@PortalAccessDescription(s)</p>
                        </div>
                    </div>
                    <dl class="sm-metrics">
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.StatPortalAccount</dt>
                            <dd>@(s.LinkedUserId is not null ? UiStrings.StaffMembers.PortalLinkedShort : UiStrings.StaffMembers.PortalNotLinkedShort)</dd>
                        </div>
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.Email</dt>
                            <dd>@s.Email</dd>
                        </div>
                        <div class="sm-metric">
                            <dt>@UiStrings.StaffMembers.Status</dt>
                            <dd>@(s.IsActive ? UiStrings.StaffMembers.Active : UiStrings.StaffMembers.Inactive)</dd>
                        </div>
                    </dl>
                    <button type="button" class="sm-card-link" @onclick="@(() => activeTab = StaffTab.PortalAccess)">
                        @UiStrings.Common.Open<RadzenIcon Icon="chevron_right" />
                    </button>
                </RadzenCard>
            </div>

            <RadzenCard class="sm-card">
                <div class="sm-card-head"><RadzenIcon Icon="calendar_month" /><h3>@UiStrings.StaffMembers.WorkingSchedule</h3></div>
                @ScheduleChips(s)
            </RadzenCard>

            @* --- Recent activity preview --- *@
            <RadzenCard class="sm-card">
                <div class="sm-card-head">
                    <RadzenIcon Icon="history" /><h3>@UiStrings.Audit.ActivityTitle</h3>
                    @if (activity.Count > 0 && Auth.HasPermission(AuditPermissions.TrailsView))
                    {
                        <button type="button" class="sm-link" @onclick="@(() => activeTab = StaffTab.Activity)">@UiStrings.Common.ViewAll</button>
                    }
                </div>
                @ActivityTimeline(OverviewActivityPreviewCount)
            </RadzenCard>
        </div>
    </text>;

    private RenderFragment LicensesTab(StaffMemberDetail s) =>@<text>
        <RadzenCard class="sm-card">
            <div class="sm-card-head">
                <RadzenIcon Icon="badge" /><h3>@UiStrings.StaffMembers.Licenses</h3>
                <span class="sm-count">@LicenseCountLabel(s.Licenses.Count)</span>
            </div>
            @if (s.Licenses.Count == 0)
            {
                <EmptyState Icon="badge" Title="@UiStrings.StaffMembers.LicensesEmpty" />
            }
            else
            {
                <RadzenDataGrid TItem="StaffMemberLicenseModel" Data="@s.Licenses" AllowSorting="false" class="os-grid">
                    <Columns>
                        <RadzenDataGridColumn TItem="StaffMemberLicenseModel" Property="LicenseCode" Title="@UiStrings.StaffMembers.License" Width="120px" />
                        <RadzenDataGridColumn TItem="StaffMemberLicenseModel" Property="LicenseName" Title="@UiStrings.Common.Name" />
                        <RadzenDataGridColumn TItem="StaffMemberLicenseModel" Property="LicenseNumber" Title="@UiStrings.StaffMembers.LicenseNumber" />
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenCard>
    </text>;

    private RenderFragment ScheduleTab(StaffMemberDetail s) =>@<text>
        <div class="sm-stack">
            <RadzenCard class="sm-card">
                <div class="sm-card-head"><RadzenIcon Icon="event" /><h3>@UiStrings.StaffMembers.EmploymentContract</h3></div>
                @if (s.EmploymentContract is { } ec)
                {
                    <div class="sm-field-list sm-field-list--row">
                        <DetailField Label="@UiStrings.StaffMembers.StartDate" Value="@ec.StartDate.ToString("yyyy-MM-dd")" Icon="event" />
                        <DetailField Label="@UiStrings.StaffMembers.EndDate" Value="@(ec.EndDate is { } end ? end.ToString("yyyy-MM-dd") : UiStrings.StaffMembers.None)" Icon="event_busy" />
                    </div>
                }
                else
                {
                    <p class="os-muted">@UiStrings.StaffMembers.NoContract</p>
                }
            </RadzenCard>

            <RadzenCard class="sm-card">
                <div class="sm-card-head"><RadzenIcon Icon="calendar_month" /><h3>@UiStrings.StaffMembers.WorkingSchedule</h3></div>
                @ScheduleChips(s)
            </RadzenCard>
        </div>
    </text>;

    private RenderFragment PortalAccessTab(StaffMemberDetail s) =>@<text>
        <RadzenCard class="sm-card">
            @if (s.LinkedUserId is not null)
            {
                <div class="sm-portal">
                    <span class="sm-portal-icon sm-portal-icon--ok"><RadzenIcon Icon="verified_user" /></span>
                    <div class="sm-portal-body">
                        <h3>@UiStrings.StaffMembers.PortalAccessLinkedTitle</h3>
                        <p class="os-muted">@UiStrings.StaffMembers.PortalAccessLinkedHint</p>
                    </div>
                </div>
                <div class="sm-portal-note">
                    <RadzenIcon Icon="construction" />
                    <div>
                        <strong>@UiStrings.StaffMembers.PortalAccessManageTitle</strong>
                        <p class="os-muted">@UiStrings.StaffMembers.PortalAccessManageHint</p>
                    </div>
                </div>
            }
            else if (s.IsActive)
            {
                <div class="sm-portal">
                    <span class="sm-portal-icon sm-portal-icon--warn"><RadzenIcon Icon="lock" /></span>
                    <div class="sm-portal-body">
                        <h3>@UiStrings.StaffMembers.PortalAccessUnlinkedTitle</h3>
                        <p class="os-muted">@UiStrings.StaffMembers.PortalAccessUnlinkedHint</p>
                    </div>
                    @if (Auth.HasPermission(MasterDataPermissions.StaffMembersGrantAccess))
                    {
                        <RadzenButton Text="@UiStrings.PortalAccess.GrantAction" Icon="person_add" ButtonStyle="ButtonStyle.Primary" Click="@OpenGrantAccessAsync" />
                    }
                </div>
            }
            else
            {
                <EmptyState Icon="lock" Title="@UiStrings.StaffMembers.PortalAccessUnlinkedTitle" Description="@UiStrings.StaffMembers.PortalAccessUnavailableHint" />
            }
        </RadzenCard>
    </text>;

    private RenderFragment ActivityTab(StaffMemberDetail s) =>@<text>
        <RadzenCard class="sm-card">
            <div class="sm-card-head"><RadzenIcon Icon="history" /><h3>@UiStrings.Audit.ActivityTitle</h3></div>
            @ActivityTimeline()
        </RadzenCard>
    </text>;

    private RenderFragment ActivityTimeline(int? maxItems = null) =>@<text>
        @if (activity.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="sm-timeline">
                @foreach (var entry in maxItems is { } take ? activity.Take(take) : activity)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="sm-timeline-row" @key="entry.Id">
                        <span class="sm-timeline-icon sm-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="sm-timeline-content">
                            <p class="sm-timeline-title">@entry.Action</p>
                            <p class="os-muted sm-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="sm-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment ScheduleChips(StaffMemberDetail s) =>@<text>
        @{
            var working = s.WorkingDays ?? Array.Empty<DayOfWeek>();
        }
        <div class="sm-days">
            @foreach (var day in WeekOrder)
            {
                var on = working.Contains(day);
                <span class="sm-day @(on ? "sm-day--on" : "sm-day--off")">
                    @if (on)
                    {
                        <RadzenIcon Icon="check" />
                    }
                    <span>@DayLabel(day)</span>
                </span>
            }
        </div>
        @if (working.Count == 0)
        {
            <p class="sm-days-empty os-muted">@UiStrings.StaffMembers.NoSchedule</p>
        }
        else
        {
            <p class="sm-days-empty os-muted">@string.Format(UiStrings.StaffMembers.WorkingDaysCount, working.Count)</p>
        }
    </text>;

    private RenderFragment TimelineEmpty() =>@<text>
        <div class="sm-timeline-empty">
            <span class="sm-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="sm-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@UiStrings.Audit.Description</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private StaffMemberDetail? item;
    private IReadOnlyList<OperationsSystem.Blazor.Client.Api.AuditTrailListItem> activity = [];
    private bool isLoading = true;
    private bool loadError;
    private string errorMessage = UiStrings.Errors.LoadFailed;
    private StaffTab activeTab = StaffTab.Overview;

    private const int OverviewActivityPreviewCount = 3;

    private enum StaffTab { Overview, Licenses, Schedule, PortalAccess, Activity }

    private sealed record TabDef(StaffTab Key, string Label, string Icon);

    private static readonly DayOfWeek[] WeekOrder =
    [
        DayOfWeek.Sunday, DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday
    ];

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(StaffTab.Overview, UiStrings.StaffMembers.TabOverview, "dashboard");
        yield return new TabDef(StaffTab.Licenses, UiStrings.StaffMembers.TabLicenses, "badge");
        yield return new TabDef(StaffTab.Schedule, UiStrings.StaffMembers.TabSchedule, "calendar_month");
        yield return new TabDef(StaffTab.PortalAccess, UiStrings.StaffMembers.TabPortalAccess, "vpn_key");
        if (Auth.HasPermission(AuditPermissions.TrailsView))
            yield return new TabDef(StaffTab.Activity, UiStrings.StaffMembers.TabActivity, "history");
    }

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            item = await MasterData.GetStaffMemberAsync(Id);

            activity = [];
            if (Auth.HasPermission(AuditPermissions.TrailsView))
            {
                try
                {
                    var trails = await AuditApi.GetTrailsAsync(entityType: "StaffMember", entityId: Id, pageSize: 25);
                    activity = trails.Items;
                }
                catch (ApiException)
                {
                    activity = [];
                }
            }
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenEditAsync()
    {
        var result = await DialogService.OpenAsync<StaffMemberFormDialog>(UiStrings.StaffMembers.EditTitle,
            new Dictionary<string, object?> { [nameof(StaffMemberFormDialog.StaffMemberId)] = Id },
            new DialogOptions { Width = "720px" });

        if (result is true)
            await LoadAsync();
    }

    private async Task OpenGrantAccessAsync()
    {
        var result = await DialogService.OpenAsync<GrantPortalAccessDialog>(UiStrings.PortalAccess.GrantTitle,
            new Dictionary<string, object?>
            {
                [nameof(GrantPortalAccessDialog.CompatibleUserType)] = "StationStaff",
                [nameof(GrantPortalAccessDialog.GrantAsync)] = (Func<Guid, CancellationToken, Task>)((roleId, ct) =>
                    MasterData.GrantStaffPortalAccessAsync(Id, new GrantPortalAccessRequest(roleId), ct))
            },
            new DialogOptions { Width = "520px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, UiStrings.PortalAccess.Granted);
            await LoadAsync();
        }
    }

    private async Task ActivateAsync()
    {
        if (item is not { } s)
            return;

        await RunAsync((rv, ct) => MasterData.ActivateStaffMemberAsync(Id, rv, ct), UiStrings.StaffMembers.Activated, s.RowVersion);
    }

    private async Task DeactivateAsync()
    {
        if (item is not { } s)
            return;

        var confirmed = await DialogService.Confirm(UiStrings.StaffMembers.ConfirmDeactivate, UiStrings.StaffMembers.Deactivate,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        await RunAsync((rv, ct) => MasterData.DeactivateStaffMemberAsync(Id, rv, ct), UiStrings.StaffMembers.Deactivated, s.RowVersion);
    }

    private async Task RunAsync(Func<string, CancellationToken, Task> action, string successMessage, string rowVersion)
    {
        try
        {
            await action(rowVersion, CancellationToken.None);
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private bool HasMoreActions(StaffMemberDetail s) =>
        (!s.IsActive && Auth.HasPermission(MasterDataPermissions.StaffMembersActivate))
        || (s.IsActive && Auth.HasPermission(MasterDataPermissions.StaffMembersDeactivate))
        || (s is { IsActive: true, LinkedUserId: null } && Auth.HasPermission(MasterDataPermissions.StaffMembersGrantAccess));

    private string LicenseCountLabel(int count) =>
        string.Format(count == 1 ? UiStrings.StaffMembers.LicenseCountSingular : UiStrings.StaffMembers.LicenseCountPlural, count);

    private static string ProfileClass(StaffMemberDetail s) =>
        s.IsActive ? "sm-profile--active" : "sm-profile--inactive";

    private static string AvatarClass(StaffMemberDetail s) =>
        s.IsActive ? "sm-avatar--active" : "sm-avatar--inactive";

    private static string DotClass(StaffMemberDetail s) =>
        s.IsActive ? "sm-avatar-dot--active" : "sm-avatar-dot--inactive";

    private static string StatusToneColor(StaffMemberDetail s) =>
        s.IsActive ? "success" : "neutral";

    private static string StatusDescription(StaffMemberDetail s)
    {
        if (!s.IsActive)
            return UiStrings.StaffMembers.PortalAccessUnavailableHint;

        return s.LinkedUserId is not null
            ? UiStrings.StaffMembers.PortalAccessLinkedHint
            : UiStrings.StaffMembers.PortalAccessUnlinkedHint;
    }

    private static string PortalAccessDescription(StaffMemberDetail s)
    {
        if (!s.IsActive)
            return UiStrings.StaffMembers.PortalAccessUnavailableHint;

        return s.LinkedUserId is not null
            ? UiStrings.StaffMembers.PortalAccessLinkedHint
            : UiStrings.StaffMembers.PortalAccessUnlinkedHint;
    }

    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("license"))
            return ("badge", "blue");
        if (a.Contains("portal") || a.Contains("access") || a.Contains("invit"))
            return ("vpn_key", "blue");
        if (a.Contains("activat"))
            return ("check_circle", "green");
        if (a.Contains("deactivat"))
            return ("cancel", "red");
        if (a.Contains("schedule") || a.Contains("contract"))
            return ("calendar_month", "blue");
        if (a.Contains("creat"))
            return ("person_add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }

    private static string DayLabel(DayOfWeek day) => day switch
    {
        DayOfWeek.Sunday => UiStrings.Days.Sunday,
        DayOfWeek.Monday => UiStrings.Days.Monday,
        DayOfWeek.Tuesday => UiStrings.Days.Tuesday,
        DayOfWeek.Wednesday => UiStrings.Days.Wednesday,
        DayOfWeek.Thursday => UiStrings.Days.Thursday,
        DayOfWeek.Friday => UiStrings.Days.Friday,
        _ => UiStrings.Days.Saturday
    };

    private static string Initials(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
            return "?";

        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }

    private void GoBack() => Navigation.NavigateTo("/master-data/staff-members");
}
