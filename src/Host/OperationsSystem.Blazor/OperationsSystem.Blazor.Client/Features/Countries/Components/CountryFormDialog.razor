@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="CountryModel" Data="@model" Submit="@SubmitAsync">
    <div class="cnf-form">
        <p class="cnf-intro os-muted">@UiStrings.Countries.FormIntro</p>
        <div class="cnf-section-line"><RadzenIcon Icon="public" /><span>@UiStrings.Common.Details</span></div>
        <div class="cnf-grid-2">
            <div class="cnf-field-block"><label class="cnf-label">@UiStrings.Countries.Name <span>*</span></label><div class="cnf-input-wrap"><RadzenIcon Icon="public" class="cnf-field-icon" /><RadzenTextBox @bind-Value="model.Name" Name="name" class="cnf-control cnf-control-icon" MaxLength="100" Placeholder="e.g. Saudi Arabia" /></div></div>
            <div class="cnf-field-block"><label class="cnf-label">@UiStrings.Countries.IsoCode <span>*</span></label><div class="cnf-input-wrap"><RadzenIcon Icon="tag" class="cnf-field-icon" /><RadzenTextBox @bind-Value="model.IsoCode" Name="isoCode" class="cnf-control cnf-control-icon" MaxLength="2" Placeholder="e.g. SA" /></div><span class="cnf-help">2-letter ISO code</span></div>
        </div>
        <div class="cnf-callout"><RadzenIcon Icon="info" /><div><strong>@UiStrings.Countries.IsoCode</strong><p>Use the official ISO 3166-1 alpha-2 country code.</p></div></div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="cnf-error-panel" role="alert"><RadzenIcon Icon="error_outline" /><div><strong>Please fix the following errors before continuing</strong><ul><li>@errorMessage</li></ul></div></div>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="cnf-actions">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(CountryId is null ? UiStrings.Common.Create : UiStrings.Common.Save)"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
        </RadzenStack>
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid? CountryId { get; set; }

    private CountryModel model = new();
    private string? rowVersion;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (CountryId is { } id)
        {
            try
            {
                var detail = await MasterData.GetCountryAsync(id);
                model = new CountryModel { Name = detail.Name, IsoCode = detail.IsoCode };
                rowVersion = detail.RowVersion;
            }
            catch (ApiException ex)
            {
                errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
            }
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorMessage = UiStrings.Countries.NameRequired;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.IsoCode) || model.IsoCode.Trim().Length != 2)
        {
            errorMessage = UiStrings.Countries.IsoCodeRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            var name = model.Name.Trim();
            var isoCode = model.IsoCode.Trim().ToUpperInvariant();

            if (CountryId is { } id)
                await MasterData.UpdateCountryAsync(id, new UpdateCountryRequest(name, isoCode), rowVersion ?? string.Empty);
            else
                await MasterData.CreateCountryAsync(new CreateCountryRequest(name, isoCode));

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class CountryModel
    {
        public string Name { get; set; } = string.Empty;
        public string IsoCode { get; set; } = string.Empty;
    }
}
