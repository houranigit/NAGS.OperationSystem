@page "/roles/{Id:guid}"
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth

<PageTitle>@(role?.Name ?? UiStrings.Roles.Title)</PageTitle>

<RequirePermission Permission="@IdentityPermissions.RolesView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (role is { } r)
    {
        <div class="rl-workspace">
            <button type="button" class="rl-back" @onclick="GoBack">
                <RadzenIcon Icon="arrow_back" />
                <span>@UiStrings.Roles.Title</span>
            </button>

            <RadzenCard class="@($"rl-hero {(r.IsSystem ? "rl-hero--system" : "rl-hero--custom")}")">
                <div class="rl-hero-main">
                    <div class="rl-avatar @(r.IsSystem ? "rl-avatar--system" : "rl-avatar--custom")">
                        <RadzenIcon Icon="shield" />
                    </div>

                    <div class="rl-hero-identity">
                        <h1 class="rl-hero-name">@r.Name</h1>
                        <p class="rl-hero-sub os-muted">@HeroSubtitle(r)</p>

                        <div class="rl-chips">
                            @if (r.IsSystem)
                            {
                                <StatusBadge Label="@UiStrings.Roles.System" Tone="neutral" />
                            }
                            else
                            {
                                <StatusBadge Label="@UiStrings.Roles.Custom" Tone="success" />
                            }
                            <span class="rl-chip"><RadzenIcon Icon="key" /><span>@selected.Count @UiStrings.Roles.Permissions.ToLowerInvariant()</span></span>
                            <span class="rl-chip"><RadzenIcon Icon="account_circle" /><span>@r.CompatibleUserType</span></span>
                        </div>
                    </div>

                    <div class="rl-hero-actions">
                        @if (!r.IsSystem && Auth.HasPermission(IdentityPermissions.RolesUpdate))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (!r.IsSystem && Auth.HasPermission(IdentityPermissions.RolesDelete))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions">
                                <RowAction Text="@UiStrings.Common.Delete" Icon="delete" Danger="true"
                                           Permission="@IdentityPermissions.RolesDelete" OnClick="@DeleteAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>
            </RadzenCard>

            <nav class="rl-tabs" role="tablist">
                @foreach (var tab in tabs)
                {
                    <button type="button" role="tab" class="rl-tab @(activeTab == tab.Key ? "rl-tab--active" : "")"
                            aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                        <RadzenIcon Icon="@tab.Icon" />
                        <span>@tab.Label</span>
                    </button>
                }
            </nav>

            <div class="rl-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    RoleTab.Permissions => PermissionsTab(r),
                    _ => OverviewTab(r)
                })
            </div>
        </div>
    }
</RequirePermission>

@code {
    private RenderFragment OverviewTab(RoleDetail r) =>@<text>
        <div class="rl-stack">
            <div class="rl-overview-grid">
                <RadzenCard class="rl-card">
                    <div class="rl-card-head"><RadzenIcon Icon="shield" /><h3>@UiStrings.Common.Details</h3></div>
                    <div class="rl-field-list">
                        <DetailField Label="@UiStrings.Roles.Name" Value="@r.Name" Icon="badge" />
                        <DetailField Label="@UiStrings.Roles.CompatibleUserType" Value="@r.CompatibleUserType" Icon="account_circle" />
                        <DetailField Label="@UiStrings.Roles.RoleDescription"
                                     Value="@(string.IsNullOrWhiteSpace(r.Description) ? UiStrings.Roles.NoDescription : r.Description)" Icon="notes" />
                        <DetailField Label="@UiStrings.Roles.RoleType" Icon="toggle_on">
                            @if (r.IsSystem)
                            {
                                <StatusBadge Label="@UiStrings.Roles.System" Tone="neutral" />
                            }
                            else
                            {
                                <StatusBadge Label="@UiStrings.Roles.Custom" Tone="success" />
                            }
                        </DetailField>
                    </div>
                </RadzenCard>
            </div>

            <div class="rl-stats">
                @StatTile("key", "blue", UiStrings.Roles.PermissionCount, selected.Count.ToString())
                @StatTile("account_circle", "blue", UiStrings.Roles.CompatibleUserType, r.CompatibleUserType)
                @StatTile("toggle_on", r.IsSystem ? "amber" : "green", UiStrings.Roles.RoleType, r.IsSystem ? UiStrings.Roles.System : UiStrings.Roles.Custom)
            </div>
        </div>
    </text>;

    private RenderFragment PermissionsTab(RoleDetail r) =>@<text>
        @{
            var canManage = !r.IsSystem && Auth.HasPermission(IdentityPermissions.RolesManagePermissions);
        }
        @if (r.IsSystem)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                @UiStrings.Roles.SystemRoleLocked
            </RadzenAlert>
        }
        <RadzenCard class="rl-card">
            <div class="rl-perm-head">
                <RadzenIcon Icon="key" />
                <div>
                    <h3>@UiStrings.Roles.Permissions</h3>
                    <p class="os-muted">@UiStrings.Roles.PermissionsDescription</p>
                </div>
                @if (canManage)
                {
                    <div class="rl-perm-head-actions">
                        <RadzenButton Text="@UiStrings.Common.Save" Icon="save" ButtonStyle="ButtonStyle.Primary"
                                      Disabled="@isSaving" Click="@SavePermissionsAsync" />
                    </div>
                }
            </div>

            <div class="rl-perm-groups">
                @foreach (var group in catalog)
                {
                    <div class="os-perm-group">
                        <strong>@group.Resource</strong>
                        <div class="os-perm-list">
                            @foreach (var permission in group.Permissions)
                            {
                                <label class="os-perm-item">
                                    <RadzenCheckBox TValue="bool" Value="@selected.Contains(permission)" Disabled="@(!canManage)"
                                                    Change="@(value => TogglePermission(permission, value))" />
                                    <span>@ActionLabel(permission)</span>
                                </label>
                            }
                        </div>
                    </div>
                }
            </div>
        </RadzenCard>
    </text>;

    private RenderFragment StatTile(string icon, string tone, string label, string value) =>@<text>
        <RadzenCard class="rl-stat">
            <span class="rl-stat-icon rl-stat-icon--@tone"><RadzenIcon Icon="@icon" /></span>
            <div class="rl-stat-body">
                <p class="rl-stat-label">@label</p>
                <p class="rl-stat-value">@value</p>
            </div>
        </RadzenCard>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private RoleDetail? role;
    private IReadOnlyList<PermissionGroup> catalog = [];
    private HashSet<string> selected = [];
    private bool isLoading = true;
    private bool loadError;
    private bool isSaving;
    private string errorMessage = UiStrings.Errors.LoadFailed;
    private RoleTab activeTab = RoleTab.Overview;

    private enum RoleTab { Overview, Permissions }

    private sealed record TabDef(RoleTab Key, string Label, string Icon);

    private static readonly TabDef[] tabs =
    [
        new(RoleTab.Overview, UiStrings.Common.Overview, "dashboard"),
        new(RoleTab.Permissions, UiStrings.Roles.Permissions, "key")
    ];

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            role = await Identity.GetRoleAsync(Id);
            // Only show permissions compatible with this role's account type.
            catalog = await Identity.GetPermissionCatalogAsync(role.CompatibleUserType);
            selected = [.. role.Permissions];
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void TogglePermission(string permission, bool isChecked)
    {
        if (isChecked)
            selected.Add(permission);
        else
            selected.Remove(permission);
    }

    private async Task SavePermissionsAsync()
    {
        isSaving = true;

        try
        {
            await Identity.UpdateRolePermissionsAsync(Id, new UpdateRolePermissionsRequest([.. selected]));
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Roles.PermissionsSaved);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task OpenEditAsync()
    {
        if (role is null)
            return;

        var result = await DialogService.OpenAsync<RoleFormDialog>(UiStrings.Roles.EditTitle,
            new Dictionary<string, object?>
            {
                [nameof(RoleFormDialog.RoleId)] = role.Id,
                [nameof(RoleFormDialog.Name)] = role.Name,
                [nameof(RoleFormDialog.Description)] = role.Description
            });

        if (result is true)
            await LoadAsync();
    }

    private async Task DeleteAsync()
    {
        var confirmed = await DialogService.Confirm(UiStrings.Roles.ConfirmDelete, UiStrings.Common.Delete,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        try
        {
            await Identity.DeleteRoleAsync(Id);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Roles.Deleted);
            Navigation.NavigateTo("/roles");
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private void GoBack() => Navigation.NavigateTo("/roles");

    private static string HeroSubtitle(RoleDetail r) =>
        string.IsNullOrWhiteSpace(r.Description) ? UiStrings.Roles.NoDescription : r.Description;

    private static string ActionLabel(string permission)
    {
        var lastDot = permission.LastIndexOf('.');
        return lastDot >= 0 && lastDot < permission.Length - 1 ? permission[(lastDot + 1)..] : permission;
    }
}
