@page "/roles/{Id:guid}"
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject OperationsSystem.Blazor.Client.Api.AuditApiClient AuditApi

<PageTitle>@(role?.Name ?? UiStrings.Roles.Title)</PageTitle>

<RequirePermission Permission="@IdentityPermissions.RolesView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (role is { } r)
    {
        <div class="rl-workspace">
            @* ---- Profile (hero + tabs as one unit) ----------------------- *@
            <section class="rl-profile @ProfileClass(r)">
                <div class="rl-hero">
                    <div class="rl-avatar @AvatarClass(r)">
                        <span>@Initials(r.Name)</span>
                        <span class="rl-avatar-dot @DotClass(r)"></span>
                    </div>

                    <div class="rl-identity">
                        <div class="rl-identity-headline">
                            <h1 class="rl-name">@r.Name</h1>
                            @if (r.IsSystem)
                            {
                                <StatusBadge Label="@UiStrings.Roles.System" Tone="neutral" />
                            }
                            else
                            {
                                <StatusBadge Label="@UiStrings.Roles.Custom" Tone="success" />
                            }
                            <span class="rl-perm-badge"><RadzenIcon Icon="key" />@selected.Count @UiStrings.Roles.Permissions.ToLowerInvariant()</span>
                        </div>

                        <div class="rl-meta-row">
                            <RadzenIcon Icon="account_circle" />
                            <span>@UserTypeLabel(r.CompatibleUserType)</span>

                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(r.Id)</span>
                            <button type="button" class="rl-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(r.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="rl-hero-actions">
                        @if (!r.IsSystem && Auth.HasPermission(IdentityPermissions.RolesUpdate))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(r))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions" ShowLabel="true">
                                <RowAction Text="@UiStrings.Common.Delete" Icon="delete" Danger="true"
                                           Permission="@IdentityPermissions.RolesDelete" OnClick="@DeleteAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="rl-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="rl-tab @(activeTab == tab.Key ? "rl-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            @* ---- Tab body ------------------------------------------------ *@
            <div class="rl-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    RoleTab.Permissions => PermissionsTab(r),
                    RoleTab.History => HistoryTab(r),
                    _ => OverviewTab(r)
                })
            </div>
        </div>
    }
</RequirePermission>

@* ================================================================ Overview *@
@code {
    private RenderFragment OverviewTab(RoleDetail r) =>@<text>
        <div class="rl-stack">
            <div class="rl-overview-grid">
                @* --- Role type --- *@
                <RadzenCard class="rl-card">
                    <div class="rl-card-head"><RadzenIcon Icon="shield" /><h3>@UiStrings.Roles.RoleType</h3></div>
                    <div class="rl-lead">
                        <span class="rl-lead-dot rl-lead-dot--@TypeToneColor(r)"></span>
                        <div>
                            <p class="rl-lead-title">@(r.IsSystem ? UiStrings.Roles.System : UiStrings.Roles.Custom)</p>
                            <p class="os-muted rl-lead-desc">@TypeDescription(r)</p>
                        </div>
                    </div>
                    <dl class="rl-metrics">
                        <div class="rl-metric">
                            <dt>@UiStrings.Roles.RoleType</dt>
                            <dd>@(r.IsSystem ? UiStrings.Roles.System : UiStrings.Roles.Custom)</dd>
                        </div>
                        <div class="rl-metric">
                            <dt>@UiStrings.Users.Created</dt>
                            <dd>@r.CreatedAtUtc.ToLocalTime().ToString("d")</dd>
                        </div>
                        <div class="rl-metric">
                            <dt>@UiStrings.Users.LastUpdated</dt>
                            <dd>@(r.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>

                @* --- Permissions summary --- *@
                <RadzenCard class="rl-card">
                    <div class="rl-card-head"><RadzenIcon Icon="key" /><h3>@UiStrings.Roles.Permissions</h3></div>
                    <div class="rl-lead">
                        <span class="rl-lead-icon rl-lead-icon--blue"><RadzenIcon Icon="vpn_key" /></span>
                        <div>
                            <p class="rl-lead-title">@selected.Count / @CatalogPermissionCount</p>
                            <p class="os-muted rl-lead-desc">@UiStrings.Roles.PermissionsDescription</p>
                        </div>
                    </div>
                    <dl class="rl-metrics">
                        <div class="rl-metric">
                            <dt>@UiStrings.Roles.PermissionCount</dt>
                            <dd>@selected.Count</dd>
                        </div>
                        <div class="rl-metric">
                            <dt>@UiStrings.Users.AccessScope</dt>
                            <dd>@AccessScope(r)</dd>
                        </div>
                        <div class="rl-metric">
                            <dt>@UiStrings.Roles.CompatibleUserType</dt>
                            <dd>@r.CompatibleUserType</dd>
                        </div>
                    </dl>
                    <button type="button" class="rl-card-link" @onclick="@(() => activeTab = RoleTab.Permissions)">
                        @UiStrings.Common.Open<RadzenIcon Icon="chevron_right" />
                    </button>
                </RadzenCard>

                @* --- Account type --- *@
                <RadzenCard class="rl-card">
                    <div class="rl-card-head"><RadzenIcon Icon="account_circle" /><h3>@UiStrings.Roles.CompatibleUserType</h3></div>
                    <dl class="rl-metrics rl-metrics--tall">
                        <div class="rl-metric">
                            <dt>@UiStrings.Roles.CompatibleUserType</dt>
                            <dd>@r.CompatibleUserType</dd>
                        </div>
                        <div class="rl-metric">
                            <dt>@UiStrings.Users.AccessScope</dt>
                            <dd>@AccessScope(r)</dd>
                        </div>
                        <div class="rl-metric">
                            <dt>@UiStrings.Roles.Name</dt>
                            <dd>@r.Name</dd>
                        </div>
                        <div class="rl-metric">
                            <dt>@UiStrings.Roles.RoleDescription</dt>
                            <dd>@(string.IsNullOrWhiteSpace(r.Description) ? UiStrings.Roles.NoDescription : r.Description)</dd>
                        </div>
                    </dl>
                </RadzenCard>
            </div>

            @* --- History preview --- *@
            <RadzenCard class="rl-card">
                <div class="rl-card-head">
                    <RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3>
                    @if (history.Count > 0)
                    {
                        <button type="button" class="rl-link" @onclick="@(() => activeTab = RoleTab.History)">@UiStrings.Common.ViewAll</button>
                    }
                </div>
                <p class="os-muted">@UiStrings.Audit.Description</p>
                @HistoryTimeline(OverviewHistoryPreviewCount)
            </RadzenCard>
        </div>
    </text>;

    @* ============================================================== Permissions *@
    private RenderFragment PermissionsTab(RoleDetail r) =>@<text>
        @{
            var canManage = !r.IsSystem && Auth.HasPermission(IdentityPermissions.RolesManagePermissions);
        }
        <div class="rl-stack">
            @if (r.IsSystem)
            {
                <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
                    @UiStrings.Roles.SystemRoleLocked
                </RadzenAlert>
            }

            <RadzenCard class="rl-card">
                <div class="rl-card-head">
                    <RadzenIcon Icon="key" /><h3>@UiStrings.Roles.Permissions</h3>
                    @if (canManage)
                    {
                        <span class="rl-count"></span>
                        <RadzenButton Text="@UiStrings.Common.Save" Icon="save" ButtonStyle="ButtonStyle.Primary"
                                      Size="ButtonSize.Small" Disabled="@isSaving" Click="@SavePermissionsAsync" />
                    }
                </div>
                <p class="os-muted rl-perm-intro">@UiStrings.Roles.PermissionsDescription</p>

                <div class="rl-perm-groups">
                    @foreach (var group in catalog)
                    {
                        <div class="rl-perm-group">
                            <strong>@group.Resource</strong>
                            <div class="rl-perm-list">
                                @foreach (var permission in group.Permissions)
                                {
                                    <label class="rl-perm-item">
                                        <RadzenCheckBox TValue="bool" Value="@selected.Contains(permission)" Disabled="@(!canManage)"
                                                        Change="@(value => TogglePermission(permission, value))" />
                                        <span>@ActionLabel(permission)</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                </div>
            </RadzenCard>
        </div>
    </text>;

    @* ================================================================ History *@
    private RenderFragment HistoryTab(RoleDetail r) =>@<text>
        <RadzenCard class="rl-card">
            <div class="rl-card-head"><RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3></div>
            <p class="os-muted">@UiStrings.Audit.Description</p>
            @HistoryTimeline()
        </RadzenCard>
    </text>;

    private RenderFragment HistoryTimeline(int? maxItems = null) =>@<text>
        @if (history.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="rl-timeline">
                @foreach (var entry in maxItems is { } take ? history.Take(take) : history)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="rl-timeline-row" @key="entry.Id">
                        <span class="rl-timeline-icon rl-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="rl-timeline-content">
                            <p class="rl-timeline-title">@entry.Action</p>
                            <p class="os-muted rl-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="rl-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                        <RadzenButton Text="@UiStrings.Audit.ViewDetails" Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      class="rl-timeline-view" Click="@(() => OpenAuditDetailAsync(entry.Id))" />
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment TimelineEmpty() =>@<text>
        <div class="rl-timeline-empty">
            <span class="rl-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="rl-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@UiStrings.Audit.Empty</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private RoleDetail? role;
    private IReadOnlyList<PermissionGroup> catalog = [];
    private HashSet<string> selected = [];
    private IReadOnlyList<OperationsSystem.Blazor.Client.Api.AuditTrailListItem> history = [];
    private bool isLoading = true;
    private bool loadError;
    private bool isSaving;
    private string errorMessage = UiStrings.Errors.LoadFailed;
    private RoleTab activeTab = RoleTab.Overview;

    private const int OverviewHistoryPreviewCount = 4;

    private enum RoleTab { Overview, Permissions, History }

    private sealed record TabDef(RoleTab Key, string Label, string Icon);

    private int CatalogPermissionCount => catalog.Sum(g => g.Permissions.Count);

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(RoleTab.Overview, UiStrings.Common.Overview, "dashboard");
        yield return new TabDef(RoleTab.Permissions, UiStrings.Roles.Permissions, "key");
        if (Auth.HasPermission(AuditPermissions.TrailsView))
            yield return new TabDef(RoleTab.History, UiStrings.Audit.HistoryTitle, "manage_history");
    }

    private bool HasMoreActions(RoleDetail r) =>
        !r.IsSystem && Auth.HasPermission(IdentityPermissions.RolesDelete);

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            role = await Identity.GetRoleAsync(Id);
            catalog = await Identity.GetPermissionCatalogAsync(role.CompatibleUserType);
            selected = [.. role.Permissions];

            history = [];
            if (Auth.HasPermission(AuditPermissions.TrailsView))
            {
                try
                {
                    var trails = await AuditApi.GetTrailsAsync(entityType: "Role", entityId: Id, pageSize: 25);
                    history = trails.Items;
                }
                catch (ApiException)
                {
                    history = [];
                }
            }
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void TogglePermission(string permission, bool isChecked)
    {
        if (isChecked)
            selected.Add(permission);
        else
            selected.Remove(permission);
    }

    private async Task SavePermissionsAsync()
    {
        isSaving = true;

        try
        {
            await Identity.UpdateRolePermissionsAsync(Id, new UpdateRolePermissionsRequest([.. selected]));
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Roles.PermissionsSaved);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task OpenEditAsync()
    {
        if (role is null)
            return;

        var result = await DialogService.OpenAsync<RoleFormDialog>(UiStrings.Roles.EditTitle,
            new Dictionary<string, object?>
            {
                [nameof(RoleFormDialog.RoleId)] = role.Id,
                [nameof(RoleFormDialog.Name)] = role.Name,
                [nameof(RoleFormDialog.Description)] = role.Description
            });

        if (result is true)
            await LoadAsync();
    }

    private async Task DeleteAsync()
    {
        var confirmed = await DialogService.Confirm(UiStrings.Roles.ConfirmDelete, UiStrings.Common.Delete,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        try
        {
            await Identity.DeleteRoleAsync(Id);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Roles.Deleted);
            Navigation.NavigateTo("/roles");
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task OpenAuditDetailAsync(Guid trailId)
    {
        await DialogService.OpenAsync<AuditTrailDetailDialog>(
            UiStrings.Audit.DetailsTitle,
            new Dictionary<string, object?> { [nameof(AuditTrailDetailDialog.TrailId)] = trailId },
            new DialogOptions { Width = "760px" });
    }

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private static string ProfileClass(RoleDetail r) =>
        r.IsSystem ? "rl-profile--system" : "rl-profile--custom";

    private static string AvatarClass(RoleDetail r) =>
        r.IsSystem ? "rl-avatar--system" : "rl-avatar--custom";

    private static string DotClass(RoleDetail r) =>
        r.IsSystem ? "rl-avatar-dot--system" : "rl-avatar-dot--custom";

    private static string TypeToneColor(RoleDetail r) =>
        r.IsSystem ? "neutral" : "success";

    private static string TypeDescription(RoleDetail r) =>
        r.IsSystem ? UiStrings.Roles.SystemRoleLocked : UiStrings.Roles.FormIntro;

    private static string AccessScope(RoleDetail r) => r.CompatibleUserType switch
    {
        UserTypes.SystemAdministrator => UiStrings.Users.ScopeFullAccess,
        UserTypes.StationStaff => UiStrings.Users.ScopeStation,
        UserTypes.CustomerContact => UiStrings.Users.ScopeCustomer,
        _ => UiStrings.Users.ScopeFullAccess
    };

    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("permission"))
            return ("key", "blue");
        if (a.Contains("role"))
            return ("badge", "blue");
        if (a.Contains("delet"))
            return ("delete", "red");
        if (a.Contains("creat"))
            return ("add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }

    private static string ActionLabel(string permission)
    {
        var lastDot = permission.LastIndexOf('.');
        return lastDot >= 0 && lastDot < permission.Length - 1 ? permission[(lastDot + 1)..] : permission;
    }

    private static string UserTypeLabel(string userType) => userType switch
    {
        UserTypes.SystemAdministrator => UiStrings.Users.TypeSystemAdministrator,
        UserTypes.StationStaff => UiStrings.Users.TypeStationStaff,
        UserTypes.CustomerContact => UiStrings.Users.TypeCustomerContact,
        _ => userType
    };

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpperInvariant(),
            _ => string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant()
        };
    }
}
