@page "/roles"
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject GridPreferences GridPrefs

<PageTitle>@UiStrings.Roles.Title</PageTitle>

<RequirePermission Permission="@IdentityPermissions.RolesView">
    <div class="os-list-page">
        <PageHeader Title="@UiStrings.Roles.Title" Description="@UiStrings.Roles.Description">
            <Actions>
                <AuthorizeView Context="create">
                    @if (create.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, IdentityPermissions.RolesCreate))
                    {
                        <RadzenButton Text="@UiStrings.Roles.Create" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@OpenCreateAsync" />
                    }
                </AuthorizeView>
            </Actions>
        </PageHeader>

        <DataListCard @ref="list" TItem="RoleListItem" Data="@roles" Count="@totalCount" IsLoading="@isLoading"
                      HasError="@loadError" OnRetry="@ReloadAsync" LoadData="@LoadDataAsync"
                      PageSize="@currentPageSize" PageSizeChanged="@OnPageSizeChangedAsync"
                      SearchValue="@searchTerm" SearchValueChanged="@(v => searchTerm = v)" OnSearch="@ReloadAsync"
                      SearchPlaceholder="@UiStrings.Roles.SearchPlaceholder"
                      CountLabel="@UiStrings.Roles.CountLabel" EmptyText="@UiStrings.Roles.Empty">
            <Columns>
                <RadzenDataGridColumn TItem="RoleListItem" Property="Name" Title="@UiStrings.Roles.Name">
                    <Template Context="role">
                        <div class="os-role-cell">
                            <span class="os-role-cell-icon"><RadzenIcon Icon="shield" /></span>
                            <strong>@role.Name</strong>
                            @if (role.IsSystem)
                            {
                                <StatusBadge Label="@UiStrings.Roles.System" Tone="neutral" />
                            }
                        </div>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="RoleListItem" Property="Description" Title="@UiStrings.Roles.RoleDescription" Sortable="false">
                    <Template Context="role">
                        @if (string.IsNullOrWhiteSpace(role.Description))
                        {
                            <span class="os-muted">@UiStrings.Roles.NoDescription</span>
                        }
                        else
                        {
                            @role.Description
                        }
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="RoleListItem" Property="PermissionCount" Title="@UiStrings.Roles.PermissionCount" Sortable="false" Width="140px" />
                <RadzenDataGridColumn TItem="RoleListItem" Property="UserCount" Title="@UiStrings.Roles.UserCount" Width="120px" />
            </Columns>
            <RowActions Context="role">
                <RowActionMenu>
                    <RowAction Text="@UiStrings.Common.Open" Icon="visibility" OnClick="@(() => OpenRole(role.Id))" />
                    <RowAction Text="@UiStrings.Common.Edit" Icon="edit" Permission="@IdentityPermissions.RolesUpdate"
                               Visible="@(!role.IsSystem)" OnClick="@(() => OpenEditAsync(role))" />
                    <RowAction Separator="true" />
                    <RowAction Text="@UiStrings.Common.Delete" Icon="delete" Danger="true"
                               Permission="@IdentityPermissions.RolesDelete"
                               Visible="@(!role.IsSystem)" OnClick="@(() => DeleteAsync(role))" />
                </RowActionMenu>
            </RowActions>
        </DataListCard>
    </div>
</RequirePermission>

@code {
    private const string GridKey = "roles";
    private static readonly int[] PageSizes = [10, 25, 50, 100];

    private DataListCard<RoleListItem>? list;
    private IReadOnlyList<RoleListItem> roles = [];
    private int totalCount;
    private int currentPage = 1;
    private int currentPageSize = 10;
    private bool isLoading;
    private bool loadError;

    private string searchTerm = string.Empty;
    private string? currentSort;

    protected override async Task OnInitializedAsync()
    {
        currentPageSize = await GridPrefs.GetPageSizeAsync(GridKey, currentPageSize, PageSizes);
        await FetchAsync();
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        currentPageSize = pageSize;
        await GridPrefs.SetPageSizeAsync(GridKey, pageSize);
    }

    private async Task LoadDataAsync(LoadDataArgs args)
    {
        currentPageSize = args.Top ?? currentPageSize;
        currentPage = ((args.Skip ?? 0) / Math.Max(currentPageSize, 1)) + 1;
        currentSort = SortBuilder.From(args);
        await FetchAsync();
    }

    private async Task FetchAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            var result = await Identity.GetRolesAsync(currentPage, currentPageSize,
                string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm, currentSort);
            roles = result.Items;
            totalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadAsync()
    {
        currentPage = 1;
        if (list is not null)
            await list.ReloadAsync();
        else
            await FetchAsync();
    }

    private async Task OpenCreateAsync()
    {
        var result = await DialogService.OpenAsync<RoleFormDialog>(UiStrings.Roles.CreateTitle);
        if (result is true)
            await ReloadAsync();
    }

    private void OpenRole(Guid id) => Navigation.NavigateTo($"/roles/{id}");

    private async Task OpenEditAsync(RoleListItem role)
    {
        var result = await DialogService.OpenAsync<RoleFormDialog>(UiStrings.Roles.EditTitle,
            new Dictionary<string, object?>
            {
                [nameof(RoleFormDialog.RoleId)] = role.Id,
                [nameof(RoleFormDialog.Name)] = role.Name,
                [nameof(RoleFormDialog.Description)] = role.Description
            });

        if (result is true)
            await ReloadAsync();
    }

    private async Task DeleteAsync(RoleListItem role)
    {
        var confirmed = await DialogService.Confirm(UiStrings.Roles.ConfirmDelete, UiStrings.Common.Delete,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        try
        {
            await Identity.DeleteRoleAsync(role.Id);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Roles.Deleted);
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }
}
