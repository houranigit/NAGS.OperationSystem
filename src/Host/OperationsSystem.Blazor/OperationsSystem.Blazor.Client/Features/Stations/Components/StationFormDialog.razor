@inject MasterDataApiClient MasterData
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject AuthSession Auth

<div class="stf-form @(StationId is null ? "stf-form-create" : "stf-form-edit")">
    @if (StationId is null)
    {
        @WizardStepper()

        <div class="stf-wizard-body">
            @if (step == 0)
            {
                @DetailsFields()
            }
            else if (step == 1)
            {
                @StaffStep()
            }
            else
            {
                @ReviewStep()
            }
        </div>

        @ErrorBanner()

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="stf-actions">
            @if (step == 0)
            {
                <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            }
            else
            {
                <RadzenButton Text="@UiStrings.Stations.Previous" ButtonStyle="ButtonStyle.Light" Icon="arrow_back"
                              Click="@(() => step = Math.Max(0, step - 1))" />
            }
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                @if (step > 0)
                {
                    <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                }
                @if (step < 2)
                {
                    <RadzenButton Text="@UiStrings.Stations.Next" Icon="arrow_forward" ButtonStyle="ButtonStyle.Primary" Click="@NextAsync" />
                }
                else
                {
                    <RadzenButton Text="@UiStrings.Stations.CreateTitle" Icon="check" ButtonStyle="ButtonStyle.Primary" Click="@SubmitAsync" Disabled="@isSubmitting" />
                }
            </RadzenStack>
        </RadzenStack>
    }
    else
    {
        <RadzenTemplateForm TItem="StationModel" Data="@model" Submit="@SubmitAsync">
            @DetailsFields()
            @ErrorBanner()
            <div class="stf-actions stf-actions-edit">
                <span></span>
                <div class="stf-actions-end">
                    <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                    <RadzenButton ButtonType="ButtonType.Submit" Text="@UiStrings.Common.Save" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
                </div>
            </div>
        </RadzenTemplateForm>
    }
</div>

@code {
    [Parameter] public Guid? StationId { get; set; }

    private StationModel model = new();
    private readonly List<StaffRow> staff = [];
    private IReadOnlyList<CountryOption> countries = [];
    private IReadOnlyList<ManpowerTypeOption> manpowerTypes = [];
    private IReadOnlyList<RoleOption> stationRoles = [];
    private bool canGrantPortal;
    private string? rowVersion;
    private int step;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var countriesTask = MasterData.GetCountryOptionsAsync();

            if (StationId is { } id)
            {
                var detailTask = MasterData.GetStationAsync(id);

                await Task.WhenAll(countriesTask, detailTask);

                countries = await countriesTask;
                var detail = await detailTask;
                model = new StationModel { IataCode = detail.IataCode, IcaoCode = detail.IcaoCode, Name = detail.Name, City = detail.City, CountryId = detail.CountryId };
                rowVersion = detail.RowVersion;
            }
            else
            {
                canGrantPortal = Auth.CanGrantStaffPortalAccess;
                var manpowerTypesTask = MasterData.GetManpowerTypeOptionsAsync();
                var stationRolesTask = canGrantPortal
                    ? Identity.GetRoleOptionsAsync("StationStaff")
                    : Task.FromResult<IReadOnlyList<RoleOption>>([]);

                await Task.WhenAll(countriesTask, manpowerTypesTask, stationRolesTask);

                countries = await countriesTask;
                manpowerTypes = await manpowerTypesTask;
                stationRoles = await stationRolesTask;
            }
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
    }

    private string CountryDisplay =>
        countries.FirstOrDefault(c => c.Id == model.CountryId) is { } country
            ? country.Name
            : UiStrings.Common.None;

    private string StepLabel(int index) => index switch
    {
        0 => UiStrings.Stations.StepDetails,
        1 => UiStrings.Stations.StepStaff,
        _ => UiStrings.Stations.StepReview
    };

    private string StepClass(int index)
    {
        var state = index < step ? "complete" : index == step ? "active" : "pending";
        return $"stf-step stf-step-{state}";
    }

    private void MoveToStep(int index)
    {
        if (index > step)
            return;

        errorMessage = null;
        step = index;
    }

    private void AddStaff()
    {
        staff.Add(new StaffRow
        {
            ManpowerTypeId = manpowerTypes.FirstOrDefault()?.Id ?? Guid.Empty,
            PortalRoleId = stationRoles.FirstOrDefault()?.Id
        });
    }

    private string ManpowerTypeName(Guid id) =>
        manpowerTypes.FirstOrDefault(t => t.Id == id)?.Name ?? UiStrings.Common.None;

    private string RoleName(Guid? id) =>
        id is { } roleId ? stationRoles.FirstOrDefault(r => r.Id == roleId)?.Name ?? UiStrings.Stations.PortalRole : UiStrings.Stations.PortalRole;

    private RenderFragment WizardStepper() =>@<div class="stf-stepper">
        @for (var i = 0; i < 3; i++)
        {
            var index = i;
            <div class="@StepClass(index)">
                <button type="button" class="stf-step-button" disabled="@(index > step)" @onclick="@(() => MoveToStep(index))">
                    <span class="stf-step-node">
                        @if (index < step)
                        {
                            <RadzenIcon Icon="check" />
                        }
                        else
                        {
                            @((index + 1).ToString())
                        }
                    </span>
                    <span class="stf-step-label">@StepLabel(index)</span>
                </button>
            </div>
        }
    </div>;

    private RenderFragment DetailsFields() =>@<section class="stf-step-content">
        @if (StationId is not null)
        {
            <p class="stf-intro os-muted">@UiStrings.Stations.FormIntro</p>
        }

        <div class="stf-section-line">
            <RadzenIcon Icon="flight_takeoff" />
            <span>Airport codes</span>
        </div>

        <div class="stf-grid-2">
            <div class="stf-field-block">
                <label class="stf-label">@UiStrings.Stations.IataCode <span class="stf-required">*</span></label>
                <div class="stf-input-wrap">
                    <RadzenIcon Icon="flight_takeoff" class="stf-field-icon" />
                    <RadzenTextBox @bind-Value="model.IataCode" class="stf-control stf-control-icon" MaxLength="3" Placeholder="e.g. JFK" />
                </div>
                <span class="stf-field-help">3 letters (e.g. JFK)</span>
            </div>
            <div class="stf-field-block">
                <label class="stf-label">@UiStrings.Stations.IcaoCode</label>
                <div class="stf-input-wrap">
                    <RadzenIcon Icon="flight_takeoff" class="stf-field-icon" />
                    <RadzenTextBox @bind-Value="model.IcaoCode" class="stf-control stf-control-icon" MaxLength="4" Placeholder="e.g. KJFK" />
                </div>
                <span class="stf-field-help">4 letters (e.g. KJFK)</span>
            </div>
        </div>

        <div class="stf-section-line">
            <RadzenIcon Icon="business" />
            <span>Station information</span>
        </div>

        <div class="stf-field-block">
            <label class="stf-label">@UiStrings.Stations.Name <span class="stf-required">*</span></label>
            <div class="stf-input-wrap">
                <RadzenIcon Icon="business" class="stf-field-icon" />
                <RadzenTextBox @bind-Value="model.Name" class="stf-control stf-control-icon" MaxLength="150" Placeholder="e.g. John F. Kennedy International Airport" />
            </div>
        </div>

        <div class="stf-grid-2">
            <div class="stf-field-block">
                <label class="stf-label">@UiStrings.Stations.City</label>
                <div class="stf-input-wrap">
                    <RadzenIcon Icon="location_on" class="stf-field-icon" />
                    <RadzenTextBox @bind-Value="model.City" class="stf-control stf-control-icon" MaxLength="100" Placeholder="e.g. New York" />
                </div>
            </div>

            <div class="stf-field-block">
                <label class="stf-label">@UiStrings.Stations.Country <span class="stf-required">*</span></label>
                <div class="stf-input-wrap">
                    <RadzenIcon Icon="public" class="stf-field-icon" />
                    <RadzenDropDown @bind-Value="model.CountryId" Data="@countries" TextProperty="Name" ValueProperty="Id"
                                    AllowFiltering="true" Placeholder="@UiStrings.Stations.SelectCountry" class="stf-control stf-control-icon" />
                </div>
            </div>
        </div>

        @if (StationId is null)
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Info" Title="Need help with airport codes?">
                <p>
                    @UiStrings.Stations.CodesHelpText
                    <a class="stf-inline-link" href="https://www.iata.org/en/publications/directories/code-search/" target="_blank" rel="noopener">Learn more <RadzenIcon Icon="open_in_new" /></a>
                </p>
            </DismissibleDialogMessage>
        }
    </section>;

    private RenderFragment StaffStep() =>@<section class="stf-step-content">
        <div class="stf-step-heading">
            <h3>@UiStrings.Stations.StepStaff</h3>
            <p>@UiStrings.Stations.StaffStepIntro</p>
        </div>

        <div class="stf-staff-list">
            @if (staff.Count == 0)
            {
                <div class="stf-empty-row">
                    <RadzenIcon Icon="group_add" />
                    <span>@UiStrings.Stations.NoStaffYet</span>
                </div>
            }

            @foreach (var row in staff)
            {
                <div @key="row.Key" class="stf-staff-card">
                    <div class="stf-grid-3">
                        <div class="stf-field-block">
                            <label class="stf-label">@UiStrings.Stations.StaffName</label>
                            <RadzenTextBox @bind-Value="row.FullName" class="stf-control" Placeholder="John Doe" MaxLength="150" />
                        </div>
                        <div class="stf-field-block">
                            <label class="stf-label">@UiStrings.StaffMembers.EmployeeId</label>
                            <RadzenTextBox @bind-Value="row.EmployeeId" class="stf-control" Placeholder="EMP-1042" MaxLength="50" />
                        </div>
                        <div class="stf-field-block">
                            <label class="stf-label">@UiStrings.Stations.StaffEmail</label>
                            <RadzenTextBox @bind-Value="row.Email" class="stf-control" Placeholder="john.doe@example.com" MaxLength="256" />
                        </div>
                        <div class="stf-field-block">
                            <label class="stf-label">@UiStrings.Stations.ManpowerType</label>
                            <RadzenDropDown @bind-Value="row.ManpowerTypeId" Data="@manpowerTypes" TextProperty="Name" ValueProperty="Id"
                                            Placeholder="@UiStrings.Stations.ManpowerType" class="stf-control" />
                        </div>
                    </div>

                    @if (canGrantPortal)
                    {
                        <div class="stf-portal">
                            <div class="stf-check-row">
                                <RadzenCheckBox @bind-Value="row.GrantPortal" Name="@($"gp-{row.Key}")" />
                                <RadzenLabel Text="@UiStrings.Stations.GrantPortal" Component="@($"gp-{row.Key}")" />
                            </div>
                            @if (row.GrantPortal)
                            {
                                <RadzenDropDown @bind-Value="row.PortalRoleId" Data="@stationRoles" TextProperty="Name" ValueProperty="Id"
                                                Placeholder="@UiStrings.Stations.PortalRole" class="stf-role-select" />
                            }
                        </div>
                    }

                    <RadzenButton Text="@UiStrings.Stations.RemoveStaff" Icon="delete" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small" class="stf-remove-button" Click="@(() => staff.Remove(row))" />
                </div>
            }
        </div>

        <RadzenButton Text="@UiStrings.Stations.AddAnotherStaff" Icon="add_circle" ButtonStyle="ButtonStyle.Light"
                      class="stf-add-staff" Click="@AddStaff" />

        <DismissibleDialogMessage AlertStyle="AlertStyle.Info">
            <p>@UiStrings.Stations.StaffLaterHint</p>
        </DismissibleDialogMessage>
    </section>;

    private RenderFragment ReviewStep() =>@<section class="stf-step-content">
        <div class="stf-step-heading">
            <h3>@UiStrings.Stations.ReviewTitle</h3>
            <p>@UiStrings.Stations.ReviewIntro</p>
        </div>

        <div class="stf-review-card">
            <div class="stf-review-card-head">
                <h4>@UiStrings.Stations.StationInformation</h4>
                <button type="button" class="stf-edit-step" @onclick="@(() => step = 0)">
                    <RadzenIcon Icon="edit" />
                    <span>@UiStrings.Common.Edit</span>
                </button>
            </div>
            <div class="stf-review-grid">
                <div>
                    <span>@UiStrings.Stations.IataCode</span>
                    <strong>@model.IataCode?.Trim().ToUpperInvariant()</strong>
                </div>
                <div>
                    <span>@UiStrings.Stations.Name</span>
                    <strong>@model.Name</strong>
                </div>
                <div>
                    <span>@UiStrings.Stations.Country</span>
                    <strong>@CountryDisplay</strong>
                </div>
                <div>
                    <span>@UiStrings.Stations.IcaoCode</span>
                    <strong>@(string.IsNullOrWhiteSpace(model.IcaoCode) ? UiStrings.Common.None : model.IcaoCode.Trim().ToUpperInvariant())</strong>
                </div>
                <div>
                    <span>@UiStrings.Stations.City</span>
                    <strong>@Display(model.City)</strong>
                </div>
            </div>
        </div>

        <div class="stf-review-card">
            <div class="stf-review-card-head">
                <h4>@UiStrings.Stations.StaffAssignments (@staff.Count)</h4>
                <button type="button" class="stf-edit-step" @onclick="@(() => step = 1)">
                    <RadzenIcon Icon="edit" />
                    <span>@UiStrings.Common.Edit</span>
                </button>
            </div>

            @if (staff.Count == 0)
            {
                <p class="stf-review-empty">@UiStrings.Stations.StaffMembersEmpty</p>
            }
            else
            {
                <div class="stf-review-staff">
                    <div class="stf-review-staff-head">
                        <span>@UiStrings.Stations.StaffName</span>
                        <span>@UiStrings.StaffMembers.EmployeeId</span>
                        <span>@UiStrings.Stations.StaffEmail</span>
                        <span>@UiStrings.Stations.ManpowerType</span>
                    </div>
                    @foreach (var row in staff)
                    {
                        <div class="stf-review-staff-row" @key="row.Key">
                            <strong>@row.FullName</strong>
                            <span>@row.EmployeeId</span>
                            <span>@row.Email</span>
                            <span>
                                @ManpowerTypeName(row.ManpowerTypeId)
                                @if (row.GrantPortal)
                                {
                                    <span class="stf-portal-badge">@RoleName(row.PortalRoleId)</span>
                                }
                            </span>
                        </div>
                    }
                </div>
            }
        </div>

        <DismissibleDialogMessage AlertStyle="AlertStyle.Info" Icon="lock">
            @UiStrings.Stations.ReviewNote
        </DismissibleDialogMessage>
    </section>;

    private RenderFragment ErrorBanner() =>@<text>
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" Title="Please fix the following errors before continuing"
                                      StateKey="@errorMessage" OnDismiss="@(() => errorMessage = null)">
                <ul><li>@errorMessage</li></ul>
            </DismissibleDialogMessage>
        }
    </text>;

    private async Task NextAsync()
    {
        errorMessage = null;
        if (step == 0)
        {
            if (!ValidateDetails())
                return;
        }
        else if (step == 1)
        {
            if (!ValidateStaff())
                return;
        }
        step = Math.Min(2, step + 1);
        await Task.CompletedTask;
    }

    private bool ValidateDetails()
    {
        if (string.IsNullOrWhiteSpace(model.IataCode) || model.IataCode.Trim().Length != 3) { errorMessage = UiStrings.Stations.IataRequired; return false; }
        if (!string.IsNullOrWhiteSpace(model.IcaoCode) && model.IcaoCode.Trim().Length != 4) { errorMessage = UiStrings.Stations.IcaoInvalid; return false; }
        if (string.IsNullOrWhiteSpace(model.Name)) { errorMessage = UiStrings.Stations.NameRequired; return false; }
        if (model.CountryId == Guid.Empty) { errorMessage = UiStrings.Stations.CountryRequired; return false; }
        return true;
    }

    private bool ValidateStaff()
    {
        foreach (var row in staff)
        {
            if (string.IsNullOrWhiteSpace(row.FullName) || string.IsNullOrWhiteSpace(row.EmployeeId) || string.IsNullOrWhiteSpace(row.Email) || row.ManpowerTypeId == Guid.Empty)
            {
                errorMessage = UiStrings.Stations.StaffIncomplete;
                return false;
            }
            if (row.GrantPortal && (row.PortalRoleId is null || row.PortalRoleId == Guid.Empty))
            {
                errorMessage = UiStrings.Stations.StaffRoleRequired;
                return false;
            }
        }
        return true;
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;
        if (!ValidateDetails() || !ValidateStaff())
            return;

        isSubmitting = true;
        try
        {
            var iata = model.IataCode.Trim().ToUpperInvariant();
            var icao = string.IsNullOrWhiteSpace(model.IcaoCode) ? null : model.IcaoCode.Trim().ToUpperInvariant();
            var name = model.Name.Trim();
            var city = Trim(model.City);

            if (StationId is { } id)
            {
                await MasterData.UpdateStationAsync(id, new UpdateStationRequest(iata, icao, name, city, model.CountryId), rowVersion ?? string.Empty);
            }
            else
            {
                var staffRequests = staff.Select(r => new NewStationStaffRequest(
                    r.FullName.Trim(), r.EmployeeId.Trim(), r.Email.Trim(), r.ManpowerTypeId, null, null, null,
                    r.GrantPortal ? r.PortalRoleId : null)).ToList();
                await MasterData.CreateStationAsync(new CreateStationRequest(iata, icao, name, city, model.CountryId, staffRequests));
            }

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
            step = 0;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class StationModel
    {
        public string IataCode { get; set; } = string.Empty;
        public string? IcaoCode { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? City { get; set; }
        public Guid CountryId { get; set; }
    }

    private static string? Trim(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? UiStrings.Common.None : value;

    private sealed class StaffRow
    {
        public Guid Key { get; } = Guid.NewGuid();
        public string FullName { get; set; } = string.Empty;
        public string EmployeeId { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public Guid ManpowerTypeId { get; set; }
        public bool GrantPortal { get; set; }
        public Guid? PortalRoleId { get; set; }
    }
}
