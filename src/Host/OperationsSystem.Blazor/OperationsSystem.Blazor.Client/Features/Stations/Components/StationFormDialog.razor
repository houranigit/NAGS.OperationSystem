@inject MasterDataApiClient MasterData
@inject IdentityApiClient Identity
@inject DialogService DialogService
@inject AuthSession Auth

<div class="stf-form">
    @if (StationId is null)
    {
        <RadzenSteps @bind-SelectedIndex="step" ShowStepsButtons="false">
            <Steps>
                <RadzenStepsItem Text="@UiStrings.Stations.StepDetails">
                    @DetailsFields()
                </RadzenStepsItem>
                <RadzenStepsItem Text="@UiStrings.Stations.StepStaff">
                    @StaffStep()
                </RadzenStepsItem>
                <RadzenStepsItem Text="@UiStrings.Stations.StepReview">
                    @ReviewStep()
                </RadzenStepsItem>
            </Steps>
        </RadzenSteps>

        @ErrorBanner()

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="stf-actions">
            <RadzenButton Text="@UiStrings.Stations.Previous" ButtonStyle="ButtonStyle.Light" Icon="arrow_back"
                          Click="@(() => step = Math.Max(0, step - 1))" Disabled="@(step == 0)" />
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                @if (step < 2)
                {
                    <RadzenButton Text="@UiStrings.Stations.Next" Icon="arrow_forward" ButtonStyle="ButtonStyle.Primary" Click="@NextAsync" />
                }
                else
                {
                    <RadzenButton Text="@UiStrings.Common.Create" Icon="check" ButtonStyle="ButtonStyle.Primary" Click="@SubmitAsync" Disabled="@isSubmitting" />
                }
            </RadzenStack>
        </RadzenStack>
    }
    else
    {
        <RadzenTemplateForm TItem="StationModel" Data="@model" Submit="@SubmitAsync">
            @DetailsFields()
            @ErrorBanner()
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="@UiStrings.Common.Save" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
            </RadzenStack>
        </RadzenTemplateForm>
    }
</div>

@code {
    [Parameter] public Guid? StationId { get; set; }

    private StationModel model = new();
    private readonly List<StaffRow> staff = [];
    private IReadOnlyList<CountryOption> countries = [];
    private IReadOnlyList<ManpowerTypeOption> manpowerTypes = [];
    private IReadOnlyList<RoleOption> stationRoles = [];
    private bool canGrantPortal;
    private string? rowVersion;
    private int step;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            countries = await MasterData.GetCountryOptionsAsync();

            if (StationId is { } id)
            {
                var detail = await MasterData.GetStationAsync(id);
                model = new StationModel { IataCode = detail.IataCode, IcaoCode = detail.IcaoCode, Name = detail.Name, City = detail.City, CountryId = detail.CountryId };
                rowVersion = detail.RowVersion;
            }
            else
            {
                manpowerTypes = await MasterData.GetManpowerTypeOptionsAsync();
                canGrantPortal = Auth.HasPermission(MasterDataPermissions.StaffMembersGrantAccess);
                if (canGrantPortal)
                    stationRoles = await Identity.GetRoleOptionsAsync("StationStaff");
            }
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
    }

    private RenderFragment DetailsFields() =>@<text>
        <p class="stf-intro os-muted">@UiStrings.Stations.FormIntro</p>
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="6">
                <RadzenFormField Text="@UiStrings.Stations.IataCode" Variant="Variant.Outlined" Style="width: 100%;">
                    <RadzenTextBox @bind-Value="model.IataCode" Style="width: 100%;" MaxLength="3" />
                </RadzenFormField>
            </RadzenColumn>
            <RadzenColumn Size="6">
                <RadzenFormField Text="@UiStrings.Stations.IcaoCode" Variant="Variant.Outlined" Style="width: 100%;">
                    <RadzenTextBox @bind-Value="model.IcaoCode" Style="width: 100%;" MaxLength="4" />
                </RadzenFormField>
            </RadzenColumn>
        </RadzenRow>
        <RadzenFormField Text="@UiStrings.Stations.Name" Variant="Variant.Outlined" Style="width: 100%;">
            <RadzenTextBox @bind-Value="model.Name" Style="width: 100%;" MaxLength="150" />
        </RadzenFormField>
        <RadzenFormField Text="@UiStrings.Stations.City" Variant="Variant.Outlined" Style="width: 100%;">
            <RadzenTextBox @bind-Value="model.City" Style="width: 100%;" MaxLength="100" />
        </RadzenFormField>
        <RadzenFormField Text="@UiStrings.Stations.Country" Variant="Variant.Outlined" Style="width: 100%;">
            <RadzenDropDown @bind-Value="model.CountryId" Data="@countries" TextProperty="Name" ValueProperty="Id" AllowFiltering="true" Style="width: 100%;" />
        </RadzenFormField>
    </text>;

    private RenderFragment StaffStep() =>@<text>
        <RadzenStack Gap="0.75rem">
            @if (staff.Count == 0)
            {
                <p class="os-muted">@UiStrings.Stations.NoStaffYet</p>
            }
            @foreach (var row in staff)
            {
                <RadzenCard @key="row.Key" class="stf-staff-row">
                    <RadzenRow Gap="0.75rem">
                        <RadzenColumn Size="4"><RadzenFormField Text="@UiStrings.Stations.StaffName" Variant="Variant.Outlined" Style="width:100%;"><RadzenTextBox @bind-Value="row.FullName" Style="width:100%;" /></RadzenFormField></RadzenColumn>
                        <RadzenColumn Size="4"><RadzenFormField Text="@UiStrings.Stations.StaffEmail" Variant="Variant.Outlined" Style="width:100%;"><RadzenTextBox @bind-Value="row.Email" Style="width:100%;" /></RadzenFormField></RadzenColumn>
                        <RadzenColumn Size="4"><RadzenFormField Text="@UiStrings.Stations.ManpowerType" Variant="Variant.Outlined" Style="width:100%;"><RadzenDropDown @bind-Value="row.ManpowerTypeId" Data="@manpowerTypes" TextProperty="Name" ValueProperty="Id" Style="width:100%;" /></RadzenFormField></RadzenColumn>
                    </RadzenRow>
                    @if (canGrantPortal)
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.75rem" class="stf-portal">
                            <RadzenCheckBox @bind-Value="row.GrantPortal" Name="@($"gp-{row.Key}")" />
                            <RadzenLabel Text="@UiStrings.Stations.GrantPortal" Component="@($"gp-{row.Key}")" />
                            @if (row.GrantPortal)
                            {
                                <RadzenDropDown @bind-Value="row.PortalRoleId" Data="@stationRoles" TextProperty="Name" ValueProperty="Id"
                                                Placeholder="@UiStrings.Stations.PortalRole" Style="min-width: 220px;" />
                            }
                        </RadzenStack>
                    }
                    <RadzenButton Text="@UiStrings.Stations.RemoveStaff" Icon="delete" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  Click="@(() => staff.Remove(row))" />
                </RadzenCard>
            }
            <RadzenButton Text="@UiStrings.Stations.AddStaff" Icon="person_add" ButtonStyle="ButtonStyle.Secondary"
                          Click="@(() => staff.Add(new StaffRow()))" />
        </RadzenStack>
    </text>;

    private RenderFragment ReviewStep() =>@<text>
        <RadzenStack Gap="0.5rem">
            <p><strong>@model.IataCode</strong> @model.Name — @model.City</p>
            <p class="os-muted">@string.Format(UiStrings.Stations.ReviewStaffCount, staff.Count)</p>
        </RadzenStack>
    </text>;

    private RenderFragment ErrorBanner() =>@<text>
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">@errorMessage</RadzenAlert>
        }
    </text>;

    private async Task NextAsync()
    {
        errorMessage = null;
        if (step == 0)
        {
            if (!ValidateDetails())
                return;
        }
        else if (step == 1)
        {
            if (!ValidateStaff())
                return;
        }
        step = Math.Min(2, step + 1);
        await Task.CompletedTask;
    }

    private bool ValidateDetails()
    {
        if (string.IsNullOrWhiteSpace(model.IataCode) || model.IataCode.Trim().Length != 3) { errorMessage = UiStrings.Stations.IataRequired; return false; }
        if (!string.IsNullOrWhiteSpace(model.IcaoCode) && model.IcaoCode.Trim().Length != 4) { errorMessage = UiStrings.Stations.IcaoInvalid; return false; }
        if (string.IsNullOrWhiteSpace(model.Name)) { errorMessage = UiStrings.Stations.NameRequired; return false; }
        if (string.IsNullOrWhiteSpace(model.City)) { errorMessage = UiStrings.Stations.CityRequired; return false; }
        if (model.CountryId == Guid.Empty) { errorMessage = UiStrings.Stations.CountryRequired; return false; }
        return true;
    }

    private bool ValidateStaff()
    {
        foreach (var row in staff)
        {
            if (string.IsNullOrWhiteSpace(row.FullName) || string.IsNullOrWhiteSpace(row.Email) || row.ManpowerTypeId == Guid.Empty)
            {
                errorMessage = UiStrings.Stations.StaffIncomplete;
                return false;
            }
            if (row.GrantPortal && (row.PortalRoleId is null || row.PortalRoleId == Guid.Empty))
            {
                errorMessage = UiStrings.Stations.StaffRoleRequired;
                return false;
            }
        }
        return true;
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;
        if (!ValidateDetails() || !ValidateStaff())
            return;

        isSubmitting = true;
        try
        {
            var iata = model.IataCode.Trim().ToUpperInvariant();
            var icao = string.IsNullOrWhiteSpace(model.IcaoCode) ? null : model.IcaoCode.Trim().ToUpperInvariant();
            var name = model.Name.Trim();
            var city = model.City.Trim();

            if (StationId is { } id)
            {
                await MasterData.UpdateStationAsync(id, new UpdateStationRequest(iata, icao, name, city, model.CountryId), rowVersion ?? string.Empty);
            }
            else
            {
                var staffRequests = staff.Select(r => new NewStationStaffRequest(
                    r.FullName.Trim(), r.Email.Trim(), r.ManpowerTypeId, null, null, null,
                    r.GrantPortal ? r.PortalRoleId : null)).ToList();
                await MasterData.CreateStationAsync(new CreateStationRequest(iata, icao, name, city, model.CountryId, staffRequests));
            }

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
            step = 0;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class StationModel
    {
        public string IataCode { get; set; } = string.Empty;
        public string? IcaoCode { get; set; }
        public string Name { get; set; } = string.Empty;
        public string City { get; set; } = string.Empty;
        public Guid CountryId { get; set; }
    }

    private sealed class StaffRow
    {
        public Guid Key { get; } = Guid.NewGuid();
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public Guid ManpowerTypeId { get; set; }
        public bool GrantPortal { get; set; }
        public Guid? PortalRoleId { get; set; }
    }
}
