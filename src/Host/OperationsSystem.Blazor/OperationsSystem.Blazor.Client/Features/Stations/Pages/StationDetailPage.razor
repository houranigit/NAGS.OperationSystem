@page "/master-data/stations/{Id:guid}"
@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject AuditApiClient AuditApi

<PageTitle>@(item?.Name ?? UiStrings.Stations.Title)</PageTitle>

<RequirePermission Permission="@MasterDataPermissions.StationsView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (item is { } s)
    {
        <div class="st-workspace">
            @* ---- Profile (hero + tabs as one unit) ----------------------- *@
            <section class="st-profile @ProfileClass(s)">
                <div class="st-hero">
                    <div class="st-avatar @AvatarClass(s)">
                        <RadzenIcon Icon="flight_takeoff" />
                        <span class="st-avatar-dot @DotClass(s)"></span>
                    </div>

                    <div class="st-identity">
                        <div class="st-identity-headline">
                            <h1 class="st-name">@s.Name</h1>
                            @if (s.IsActive)
                            {
                                <StatusBadge Label="@UiStrings.Stations.Active" Tone="success" />
                            }
                            else
                            {
                                <StatusBadge Label="@UiStrings.Stations.Inactive" Tone="neutral" />
                            }
                            <span class="st-info-badge"><RadzenIcon Icon="tag" />@s.IataCode</span>
                        </div>

                        <div class="st-meta-row">
                            <RadzenIcon Icon="location_city" />
                            <span>@s.City</span>

                            <RadzenIcon Icon="public" />
                            <span>@s.CountryName</span>

                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(s.Id)</span>
                            <button type="button" class="st-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(s.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="st-hero-actions">
                        @if (Auth.HasPermission(MasterDataPermissions.StationsUpdate))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(s))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions" ShowLabel="true">
                                <RowAction Text="@UiStrings.Stations.Activate" Icon="check_circle"
                                           Permission="@MasterDataPermissions.StationsActivate"
                                           Visible="@(!s.IsActive)" OnClick="@ActivateAsync" />
                                <RowAction Text="@UiStrings.Stations.Deactivate" Icon="cancel" Danger="true"
                                           Permission="@MasterDataPermissions.StationsDeactivate"
                                           Visible="@s.IsActive" OnClick="@DeactivateAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="st-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="st-tab @(activeTab == tab.Key ? "st-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            @* ---- Tab body ------------------------------------------------ *@
            <div class="st-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    StationTab.Overview => OverviewTab(s),
                    StationTab.Staff => StaffTab(s),
                    StationTab.History => HistoryTab(s),
                    _ => OverviewTab(s)
                })
            </div>
        </div>
    }
</RequirePermission>

@* ================================================================ Overview *@
@code {
    private RenderFragment OverviewTab(StationDetail s) =>@<text>
        <div class="st-stack">
            <div class="st-overview-grid">
                @* --- Station status --- *@
                <RadzenCard class="st-card">
                    <div class="st-card-head"><RadzenIcon Icon="toggle_on" /><h3>@UiStrings.Stations.Status</h3></div>
                    <div class="st-lead">
                        <span class="st-lead-dot st-lead-dot--@StatusToneColor(s)"></span>
                        <div>
                            <p class="st-lead-title">@(s.IsActive ? UiStrings.Stations.Active : UiStrings.Stations.Inactive)</p>
                            <p class="os-muted st-lead-desc">@StatusDescription(s)</p>
                        </div>
                    </div>
                    <dl class="st-metrics">
                        <div class="st-metric">
                            <dt>@UiStrings.Stations.Created</dt>
                            <dd>@s.CreatedAtUtc.ToLocalTime().ToString("g")</dd>
                        </div>
                        <div class="st-metric">
                            <dt>@UiStrings.Stations.Updated</dt>
                            <dd>@(s.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>

                @* --- Location --- *@
                <RadzenCard class="st-card">
                    <div class="st-card-head"><RadzenIcon Icon="location_city" /><h3>@UiStrings.Stations.StepDetails</h3></div>
                    <div class="st-lead">
                        <span class="st-lead-icon st-lead-icon--blue"><RadzenIcon Icon="flight_takeoff" /></span>
                        <div>
                            <p class="st-lead-title">@s.Name</p>
                            <p class="os-muted st-lead-desc">@($"{s.City}, {s.CountryName}")</p>
                        </div>
                    </div>
                    <dl class="st-metrics">
                        <div class="st-metric">
                            <dt>@UiStrings.Stations.IataCode</dt>
                            <dd>@s.IataCode</dd>
                        </div>
                        <div class="st-metric">
                            <dt>@UiStrings.Stations.IcaoCode</dt>
                            <dd>@(string.IsNullOrWhiteSpace(s.IcaoCode) ? UiStrings.Stations.NoIcao : s.IcaoCode)</dd>
                        </div>
                        <div class="st-metric">
                            <dt>@UiStrings.Stations.City</dt>
                            <dd>@s.City</dd>
                        </div>
                        <div class="st-metric">
                            <dt>@UiStrings.Stations.Country</dt>
                            <dd>@s.CountryName</dd>
                        </div>
                    </dl>
                </RadzenCard>

                @* --- Staff summary --- *@
                <RadzenCard class="st-card">
                    <div class="st-card-head"><RadzenIcon Icon="groups" /><h3>@UiStrings.Stations.StaffMembers</h3></div>
                    <div class="st-lead">
                        <span class="st-lead-icon st-lead-icon--blue"><RadzenIcon Icon="groups" /></span>
                        <div>
                            <p class="st-lead-title">@string.Format(UiStrings.Stations.StaffCountFormat, stationStaff.Count)</p>
                            <p class="os-muted st-lead-desc">@(stationStaff.Count == 0
                                ? UiStrings.Stations.StaffMembersEmpty
                                : string.Format("{0}: {1}", UiStrings.Stations.StatActiveStaff, stationStaff.Count(x => x.IsActive)))</p>
                        </div>
                    </div>
                    <dl class="st-metrics">
                        <div class="st-metric">
                            <dt>@UiStrings.Stations.StatStaff</dt>
                            <dd>@stationStaff.Count</dd>
                        </div>
                        <div class="st-metric">
                            <dt>@UiStrings.Stations.StatActiveStaff</dt>
                            <dd>@stationStaff.Count(x => x.IsActive)</dd>
                        </div>
                    </dl>
                    <button type="button" class="st-card-link" @onclick="@(() => activeTab = StationTab.Staff)">
                        @UiStrings.Common.Open<RadzenIcon Icon="chevron_right" />
                    </button>
                </RadzenCard>
            </div>

            @if (CanViewAudit)
            {
                <RadzenCard class="st-card">
                    <div class="st-card-head">
                        <RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3>
                        @if (history.Count > 0)
                        {
                            <button type="button" class="st-link" @onclick="@(() => activeTab = StationTab.History)">@UiStrings.Common.ViewAll</button>
                        }
                    </div>
                    <p class="os-muted">@UiStrings.Audit.Description</p>
                    @HistoryTimeline(OverviewHistoryPreviewCount)
                </RadzenCard>
            }
        </div>
    </text>;

    @* ================================================================ Staff *@
    private RenderFragment StaffTab(StationDetail s) =>@<text>
        <RadzenCard class="st-card">
            <div class="st-card-head">
                <RadzenIcon Icon="groups" /><h3>@UiStrings.Stations.StaffMembers</h3>
                <span class="st-count">@string.Format(UiStrings.Stations.StaffCountFormat, stationStaff.Count)</span>
                @if (Auth.HasPermission(MasterDataPermissions.StaffMembersCreate))
                {
                    <RadzenButton Text="@UiStrings.Stations.AddStaffMember" Icon="person_add" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small" Click="@OpenAddStaffAsync" />
                }
            </div>

            @if (staffLoading)
            {
                <LoadingCard />
            }
            else if (stationStaff.Count == 0)
            {
                <EmptyState Icon="groups" Title="@UiStrings.Stations.StaffMembersEmpty" />
            }
            else
            {
                <RadzenDataGrid TItem="StaffMemberListItem" Data="@stationStaff" AllowSorting="false"
                                GridLines="DataGridGridLines.Horizontal" RowSelect="@(st => NavigateToStaff(st.Id))">
                    <Columns>
                        <RadzenDataGridColumn TItem="StaffMemberListItem" Property="EmployeeId" Title="@UiStrings.StaffMembers.EmployeeId" />
                        <RadzenDataGridColumn TItem="StaffMemberListItem" Property="FullName" Title="@UiStrings.StaffMembers.FullName" />
                        <RadzenDataGridColumn TItem="StaffMemberListItem" Property="Email" Title="@UiStrings.StaffMembers.Email" />
                        <RadzenDataGridColumn TItem="StaffMemberListItem" Property="ManpowerTypeName" Title="@UiStrings.StaffMembers.ManpowerType" />
                        <RadzenDataGridColumn TItem="StaffMemberListItem" Title="@UiStrings.StaffMembers.Status" Width="120px">
                            <Template Context="st">
                                @if (st.IsActive)
                                {
                                    <StatusBadge Label="@UiStrings.StaffMembers.Active" Tone="success" />
                                }
                                else
                                {
                                    <StatusBadge Label="@UiStrings.StaffMembers.Inactive" Tone="neutral" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenCard>
    </text>;

    @* ================================================================ History *@
    private RenderFragment HistoryTab(StationDetail s) =>@<text>
        <RadzenCard class="st-card">
            <div class="st-card-head"><RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3></div>
            <p class="os-muted">@UiStrings.Audit.Description</p>
            @HistoryTimeline()
        </RadzenCard>
    </text>;

    private RenderFragment HistoryTimeline(int? maxItems = null) =>@<text>
        @if (history.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="st-timeline">
                @foreach (var entry in maxItems is { } take ? history.Take(take) : history)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="st-timeline-row" @key="entry.Id">
                        <span class="st-timeline-icon st-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="st-timeline-content">
                            <p class="st-timeline-title">@entry.Action</p>
                            <p class="os-muted st-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="st-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                        <RadzenButton Text="@UiStrings.Audit.ViewDetails" Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      class="st-timeline-view" Click="@(() => OpenAuditDetailAsync(entry.Id))" />
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment TimelineEmpty() =>@<text>
        <div class="st-timeline-empty">
            <span class="st-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="st-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@UiStrings.Audit.Empty</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private StationDetail? item;
    private bool isLoading = true;
    private bool loadError;
    private string errorMessage = UiStrings.Errors.LoadFailed;

    private IReadOnlyList<StaffMemberListItem> stationStaff = [];
    private IReadOnlyList<AuditTrailListItem> history = [];
    private bool staffLoading;
    private StationTab activeTab = StationTab.Overview;

    private const int OverviewHistoryPreviewCount = 4;

    private enum StationTab { Overview, Staff, History }

    private sealed record TabDef(StationTab Key, string Label, string Icon);

    private bool CanViewAudit => Auth.HasPermission(AuditPermissions.TrailsView);

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(StationTab.Overview, UiStrings.Common.Overview, "dashboard");
        yield return new TabDef(StationTab.Staff, UiStrings.Stations.StaffMembers, "groups");
        if (CanViewAudit)
            yield return new TabDef(StationTab.History, UiStrings.Audit.HistoryTitle, "manage_history");
    }

    private bool HasMoreActions(StationDetail s) =>
        (!s.IsActive && Auth.HasPermission(MasterDataPermissions.StationsActivate))
        || (s.IsActive && Auth.HasPermission(MasterDataPermissions.StationsDeactivate));

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        staffLoading = true;
        loadError = false;
        StateHasChanged();

        var staffTask = LoadStationStaffAsync();
        var historyTask = LoadHistoryAsync();

        try
        {
            item = await MasterData.GetStationAsync(Id);
            isLoading = false;
            StateHasChanged();

            stationStaff = await staffTask;
            history = await historyTask;
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            staffLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadStaffAsync()
    {
        staffLoading = true;
        StateHasChanged();

        stationStaff = await LoadStationStaffAsync();
        staffLoading = false;
        StateHasChanged();
    }

    private async Task<IReadOnlyList<StaffMemberListItem>> LoadStationStaffAsync()
    {
        try
        {
            var page = await MasterData.GetStaffMembersAsync(1, 100, null, stationId: Id);
            return page.Items;
        }
        catch (ApiException)
        {
            return [];
        }
    }

    private async Task<IReadOnlyList<OperationsSystem.Blazor.Client.Api.AuditTrailListItem>> LoadHistoryAsync()
    {
        if (!CanViewAudit)
            return [];

        try
        {
            var trails = await AuditApi.GetTrailsAsync(entityType: "Station", entityId: Id, pageSize: 25);
            return trails.Items;
        }
        catch (ApiException)
        {
            return [];
        }
    }

    private async Task OpenAddStaffAsync()
    {
        var result = await DialogService.OpenAsync<StaffMemberFormDialog>(UiStrings.StaffMembers.CreateTitle,
            new Dictionary<string, object?> { [nameof(StaffMemberFormDialog.PreselectedStationId)] = Id },
            new DialogOptions { Width = "720px" });

        if (result is true)
            await LoadStaffAsync();
    }

    private void NavigateToStaff(Guid staffId) => Navigation.NavigateTo($"/master-data/staff-members/{staffId}");

    private async Task OpenEditAsync()
    {
        var result = await DialogService.OpenAsync<StationFormDialog>(UiStrings.Stations.EditTitle,
            new Dictionary<string, object?> { [nameof(StationFormDialog.StationId)] = Id },
            new DialogOptions { Width = "760px" });

        if (result is true)
            await LoadAsync();
    }

    private async Task ActivateAsync()
    {
        if (item is not { } s)
            return;

        await RunAsync((rv, ct) => MasterData.ActivateStationAsync(Id, rv, ct), UiStrings.Stations.Activated, s.RowVersion);
    }

    private async Task DeactivateAsync()
    {
        if (item is not { } s)
            return;

        var confirmed = await DialogService.Confirm(UiStrings.Stations.ConfirmDeactivate, UiStrings.Stations.Deactivate,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        await RunAsync((rv, ct) => MasterData.DeactivateStationAsync(Id, rv, ct), UiStrings.Stations.Deactivated, s.RowVersion);
    }

    private async Task RunAsync(Func<string, CancellationToken, Task> action, string successMessage, string rowVersion)
    {
        try
        {
            await action(rowVersion, CancellationToken.None);
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task OpenAuditDetailAsync(Guid trailId)
    {
        await DialogService.OpenAsync<AuditTrailDetailDialog>(
            UiStrings.Audit.DetailsTitle,
            new Dictionary<string, object?> { [nameof(AuditTrailDetailDialog.TrailId)] = trailId },
            new DialogOptions { Width = "760px" });
    }

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private static string ProfileClass(StationDetail s) =>
        s.IsActive ? "st-profile--active" : "st-profile--inactive";

    private static string AvatarClass(StationDetail s) =>
        s.IsActive ? "st-avatar--active" : "st-avatar--inactive";

    private static string DotClass(StationDetail s) =>
        s.IsActive ? "st-avatar-dot--active" : "st-avatar-dot--inactive";

    private static string StatusToneColor(StationDetail s) =>
        s.IsActive ? "success" : "neutral";

    private static string StatusDescription(StationDetail s) =>
        s.IsActive ? UiStrings.Stations.FormIntro : UiStrings.Stations.Inactive;

    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("activat"))
            return ("check_circle", "green");
        if (a.Contains("deactivat"))
            return ("cancel", "red");
        if (a.Contains("staff"))
            return ("groups", "blue");
        if (a.Contains("creat"))
            return ("add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }
}
