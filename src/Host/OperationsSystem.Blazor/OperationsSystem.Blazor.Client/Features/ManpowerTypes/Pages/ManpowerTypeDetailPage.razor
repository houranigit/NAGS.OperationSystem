@page "/master-data/manpower-types/{Id:guid}"
@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject AuditApiClient AuditApi

<PageTitle>@(item?.Name ?? UiStrings.ManpowerTypes.Title)</PageTitle>

<RequirePermission Permission="@MasterDataPermissions.ManpowerTypesView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (item is { } m)
    {
        <div class="mt-workspace">
            <section class="mt-profile @ProfileClass(m)">
                <div class="mt-hero">
                    <div class="mt-avatar @AvatarClass(m)">
                        <RadzenIcon Icon="engineering" />
                        <span class="mt-avatar-dot @DotClass(m)"></span>
                    </div>

                    <div class="mt-identity">
                        <div class="mt-identity-headline">
                            <h1 class="mt-name">@m.Name</h1>
                            @if (m.IsActive)
                            {
                                <StatusBadge Label="@UiStrings.ManpowerTypes.Active" Tone="success" />
                            }
                            else
                            {
                                <StatusBadge Label="@UiStrings.ManpowerTypes.Inactive" Tone="neutral" />
                            }
                        </div>

                        <div class="mt-meta-row">
                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(m.Id)</span>
                            <button type="button" class="mt-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(m.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="mt-hero-actions">
                        @if (Auth.HasPermission(MasterDataPermissions.ManpowerTypesUpdate))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(m))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions" ShowLabel="true">
                                <RowAction Text="@UiStrings.ManpowerTypes.Activate" Icon="check_circle"
                                           Permission="@MasterDataPermissions.ManpowerTypesActivate"
                                           Visible="@(!m.IsActive)" OnClick="@ActivateAsync" />
                                <RowAction Text="@UiStrings.ManpowerTypes.Deactivate" Icon="cancel" Danger="true"
                                           Permission="@MasterDataPermissions.ManpowerTypesDeactivate"
                                           Visible="@m.IsActive" OnClick="@DeactivateAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="mt-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="mt-tab @(activeTab == tab.Key ? "mt-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            <div class="mt-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    ManpowerTypeTab.History => HistoryTab(m),
                    _ => OverviewTab(m)
                })
            </div>
        </div>
    }
</RequirePermission>

@code {
    private RenderFragment OverviewTab(ManpowerTypeDetail m) =>@<text>
        <div class="mt-stack">
            <div class="mt-overview-grid">
                <RadzenCard class="mt-card">
                    <div class="mt-card-head"><RadzenIcon Icon="toggle_on" /><h3>@UiStrings.ManpowerTypes.Status</h3></div>
                    <div class="mt-lead">
                        <span class="mt-lead-dot mt-lead-dot--@StatusToneColor(m)"></span>
                        <div>
                            <p class="mt-lead-title">@(m.IsActive ? UiStrings.ManpowerTypes.Active : UiStrings.ManpowerTypes.Inactive)</p>
                            <p class="os-muted mt-lead-desc">@StatusDescription(m)</p>
                        </div>
                    </div>
                    <dl class="mt-metrics">
                        <div class="mt-metric">
                            <dt>@UiStrings.ManpowerTypes.Created</dt>
                            <dd>@m.CreatedAtUtc.ToLocalTime().ToString("d")</dd>
                        </div>
                        <div class="mt-metric">
                            <dt>@UiStrings.ManpowerTypes.Updated</dt>
                            <dd>@(m.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>

                <RadzenCard class="mt-card">
                    <div class="mt-card-head"><RadzenIcon Icon="engineering" /><h3>@UiStrings.Common.Details</h3></div>
                    <div class="mt-lead">
                        <span class="mt-lead-icon mt-lead-icon--blue"><RadzenIcon Icon="engineering" /></span>
                        <div>
                            <p class="mt-lead-title">@m.Name</p>
                            <p class="os-muted mt-lead-desc">@(string.IsNullOrWhiteSpace(m.Description) ? UiStrings.ManpowerTypes.NoDescription : m.Description)</p>
                        </div>
                    </div>
                    <dl class="mt-metrics mt-metrics--tall">
                        <div class="mt-metric">
                            <dt>@UiStrings.ManpowerTypes.Name</dt>
                            <dd>@m.Name</dd>
                        </div>
                        <div class="mt-metric">
                            <dt>@UiStrings.ManpowerTypes.ManpowerDescription</dt>
                            <dd>@(string.IsNullOrWhiteSpace(m.Description) ? UiStrings.ManpowerTypes.NoDescription : m.Description)</dd>
                        </div>
                        <div class="mt-metric">
                            <dt>@UiStrings.ManpowerTypes.Status</dt>
                            <dd>@(m.IsActive ? UiStrings.ManpowerTypes.Active : UiStrings.ManpowerTypes.Inactive)</dd>
                        </div>
                    </dl>
                </RadzenCard>
            </div>

            @if (CanViewAudit)
            {
                <RadzenCard class="mt-card">
                    <div class="mt-card-head">
                        <RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3>
                        @if (history.Count > 0)
                        {
                            <button type="button" class="mt-link" @onclick="@(() => activeTab = ManpowerTypeTab.History)">@UiStrings.Common.ViewAll</button>
                        }
                    </div>
                    <p class="os-muted">@UiStrings.Audit.Description</p>
                    @HistoryTimeline(OverviewHistoryPreviewCount)
                </RadzenCard>
            }
        </div>
    </text>;

    private RenderFragment HistoryTab(ManpowerTypeDetail m) =>@<text>
        <RadzenCard class="mt-card">
            <div class="mt-card-head"><RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3></div>
            <p class="os-muted">@UiStrings.Audit.Description</p>
            @HistoryTimeline()
        </RadzenCard>
    </text>;

    private RenderFragment HistoryTimeline(int? maxItems = null) =>@<text>
        @if (history.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="mt-timeline">
                @foreach (var entry in maxItems is { } take ? history.Take(take) : history)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="mt-timeline-row" @key="entry.Id">
                        <span class="mt-timeline-icon mt-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="mt-timeline-content">
                            <p class="mt-timeline-title">@entry.Action</p>
                            <p class="os-muted mt-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="mt-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                        <RadzenButton Text="@UiStrings.Audit.ViewDetails" Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      class="mt-timeline-view" Click="@(() => OpenAuditDetailAsync(entry.Id))" />
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment TimelineEmpty() =>@<text>
        <div class="mt-timeline-empty">
            <span class="mt-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="mt-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@UiStrings.Audit.Empty</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ManpowerTypeDetail? item;
    private IReadOnlyList<AuditTrailListItem> history = [];
    private bool isLoading = true;
    private bool loadError;
    private string errorMessage = UiStrings.Errors.LoadFailed;
    private ManpowerTypeTab activeTab = ManpowerTypeTab.Overview;

    private const int OverviewHistoryPreviewCount = 4;

    private enum ManpowerTypeTab { Overview, History }

    private sealed record TabDef(ManpowerTypeTab Key, string Label, string Icon);

    private bool CanViewAudit => Auth.HasPermission(AuditPermissions.TrailsView);

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(ManpowerTypeTab.Overview, UiStrings.Common.Overview, "dashboard");
        if (CanViewAudit)
            yield return new TabDef(ManpowerTypeTab.History, UiStrings.Audit.HistoryTitle, "manage_history");
    }

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        var historyTask = LoadHistoryAsync();

        try
        {
            item = await MasterData.GetManpowerTypeAsync(Id);
            history = await historyTask;
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<IReadOnlyList<OperationsSystem.Blazor.Client.Api.AuditTrailListItem>> LoadHistoryAsync()
    {
        if (!CanViewAudit)
            return [];

        try
        {
            var trails = await AuditApi.GetTrailsAsync(entityType: "ManpowerType", entityId: Id, pageSize: 25);
            return trails.Items;
        }
        catch (ApiException)
        {
            return [];
        }
    }

    private async Task OpenEditAsync()
    {
        var result = await DialogService.OpenAsync<ManpowerTypeFormDialog>(UiStrings.ManpowerTypes.EditTitle,
            new Dictionary<string, object?> { [nameof(ManpowerTypeFormDialog.ManpowerTypeId)] = Id },
            new DialogOptions { Width = "760px" });

        if (result is true)
            await LoadAsync();
    }

    private async Task ActivateAsync()
    {
        if (item is not { } m)
            return;

        await RunAsync((rv, ct) => MasterData.ActivateManpowerTypeAsync(Id, rv, ct), UiStrings.ManpowerTypes.Activated, m.RowVersion);
    }

    private async Task DeactivateAsync()
    {
        if (item is not { } m)
            return;

        var confirmed = await DialogService.Confirm(UiStrings.ManpowerTypes.ConfirmDeactivate, UiStrings.ManpowerTypes.Deactivate,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        await RunAsync((rv, ct) => MasterData.DeactivateManpowerTypeAsync(Id, rv, ct), UiStrings.ManpowerTypes.Deactivated, m.RowVersion);
    }

    private async Task RunAsync(Func<string, CancellationToken, Task> action, string successMessage, string rowVersion)
    {
        try
        {
            await action(rowVersion, CancellationToken.None);
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task OpenAuditDetailAsync(Guid trailId)
    {
        await DialogService.OpenAsync<AuditTrailDetailDialog>(
            UiStrings.Audit.DetailsTitle,
            new Dictionary<string, object?> { [nameof(AuditTrailDetailDialog.TrailId)] = trailId },
            new DialogOptions { Width = "760px" });
    }

    private bool HasMoreActions(ManpowerTypeDetail m) =>
        (!m.IsActive && Auth.HasPermission(MasterDataPermissions.ManpowerTypesActivate))
        || (m.IsActive && Auth.HasPermission(MasterDataPermissions.ManpowerTypesDeactivate));

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private static string ProfileClass(ManpowerTypeDetail m) =>
        m.IsActive ? "mt-profile--active" : "mt-profile--inactive";

    private static string AvatarClass(ManpowerTypeDetail m) =>
        m.IsActive ? "mt-avatar--active" : "mt-avatar--inactive";

    private static string DotClass(ManpowerTypeDetail m) =>
        m.IsActive ? "mt-avatar-dot--active" : "mt-avatar-dot--inactive";

    private static string StatusToneColor(ManpowerTypeDetail m) =>
        m.IsActive ? "success" : "neutral";

    private static string StatusDescription(ManpowerTypeDetail m) =>
        m.IsActive ? UiStrings.ManpowerTypes.FormIntro : UiStrings.ManpowerTypes.ConfirmDeactivate;

    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("activ"))
            return ("check_circle", "green");
        if (a.Contains("deactiv"))
            return ("cancel", "red");
        if (a.Contains("delet"))
            return ("delete", "red");
        if (a.Contains("creat"))
            return ("add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }
}
