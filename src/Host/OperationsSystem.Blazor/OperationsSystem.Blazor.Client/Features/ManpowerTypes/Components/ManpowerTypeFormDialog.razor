@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="ManpowerTypeModel" Data="@model" Submit="@SubmitAsync">
    <div class="mtf-form">
        <p class="mtf-intro os-muted">@UiStrings.ManpowerTypes.FormIntro</p>

        <div class="mtf-section-line"><RadzenIcon Icon="engineering" /><span>@UiStrings.Common.Details</span></div>
        <div class="mtf-field-block"><label class="mtf-label">@UiStrings.ManpowerTypes.Name <span>*</span></label><div class="mtf-input-wrap"><RadzenIcon Icon="engineering" class="mtf-field-icon" /><RadzenTextBox @bind-Value="model.Name" Name="name" class="mtf-control mtf-control-icon" MaxLength="100" Placeholder="e.g. Operations Officer" /></div></div>
        <div class="mtf-field-block"><label class="mtf-label">@UiStrings.ManpowerTypes.ManpowerDescription</label><RadzenTextArea @bind-Value="model.Description" Name="description" Rows="4" class="mtf-control" MaxLength="500" Placeholder="Describe the responsibilities for this manpower type" /></div>
        <div class="mtf-callout"><RadzenIcon Icon="info" /><div><strong>@UiStrings.ManpowerTypes.Name</strong><p>Use a clear role name that can be recognized in assignments and schedules.</p></div></div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="mtf-error-panel" role="alert"><RadzenIcon Icon="error_outline" /><div><strong>Please fix the following errors before continuing</strong><ul><li>@errorMessage</li></ul></div></div>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="mtf-actions">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(ManpowerTypeId is null ? UiStrings.Common.Create : UiStrings.Common.Save)"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
        </RadzenStack>
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid? ManpowerTypeId { get; set; }

    private ManpowerTypeModel model = new();
    private string? rowVersion;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (ManpowerTypeId is { } id)
        {
            try
            {
                var detail = await MasterData.GetManpowerTypeAsync(id);
                model = new ManpowerTypeModel { Name = detail.Name, Description = detail.Description };
                rowVersion = detail.RowVersion;
            }
            catch (ApiException ex)
            {
                errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
            }
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorMessage = UiStrings.ManpowerTypes.NameRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            var name = model.Name.Trim();
            var description = string.IsNullOrWhiteSpace(model.Description) ? null : model.Description.Trim();

            if (ManpowerTypeId is { } id)
                await MasterData.UpdateManpowerTypeAsync(id, new UpdateManpowerTypeRequest(name, description), rowVersion ?? string.Empty);
            else
                await MasterData.CreateManpowerTypeAsync(new CreateManpowerTypeRequest(name, description));

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ManpowerTypeModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}
