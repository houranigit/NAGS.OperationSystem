@page "/master-data/customers/{Id:guid}"
@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject AuditApiClient AuditApi

<PageTitle>@(item?.Name ?? UiStrings.Customers.Title)</PageTitle>

<RequirePermission Permission="@MasterDataPermissions.CustomersView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (item is { } c)
    {
        <div class="cu-workspace">
            <button type="button" class="cu-back" @onclick="GoBack">
                <RadzenIcon Icon="arrow_back" />
                <span>@UiStrings.Customers.Title</span>
            </button>

            @* ---- Profile (hero + tabs as one unit) ----------------------- *@
            <section class="cu-profile @ProfileClass(c)">
                <div class="cu-hero">
                    <div class="cu-avatar @AvatarClass(c)">
                        <RadzenIcon Icon="business" />
                        <span class="cu-avatar-dot @DotClass(c)"></span>
                    </div>

                    <div class="cu-identity">
                        <div class="cu-identity-headline">
                            <h1 class="cu-name">@c.Name</h1>
                            @if (c.IsActive)
                            {
                                <StatusBadge Label="@UiStrings.Customers.Active" Tone="success" />
                            }
                            else
                            {
                                <StatusBadge Label="@UiStrings.Customers.Inactive" Tone="neutral" />
                            }
                            <span class="cu-info-badge"><RadzenIcon Icon="tag" />@c.IataCode</span>
                        </div>

                        <div class="cu-meta-row">
                            <RadzenIcon Icon="public" />
                            <span>@c.CountryName</span>

                            @if (!string.IsNullOrWhiteSpace(c.OfficialEmail))
                            {
                                <RadzenIcon Icon="mail" />
                                <span>@c.OfficialEmail</span>
                                <button type="button" class="cu-copy" title="@UiStrings.Users.CopyEmail"
                                        aria-label="@UiStrings.Users.CopyEmail" @onclick="@(() => CopyAsync(c.OfficialEmail!))">
                                    <RadzenIcon Icon="content_copy" />
                                </button>
                            }

                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(c.Id)</span>
                            <button type="button" class="cu-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(c.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="cu-hero-actions">
                        @if (Auth.HasPermission(MasterDataPermissions.CustomersUpdate))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(c))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions">
                                <RowAction Text="@UiStrings.Customers.Activate" Icon="check_circle"
                                           Permission="@MasterDataPermissions.CustomersActivate"
                                           Visible="@(!c.IsActive)" OnClick="@ActivateAsync" />
                                <RowAction Text="@UiStrings.Customers.Deactivate" Icon="cancel" Danger="true"
                                           Permission="@MasterDataPermissions.CustomersDeactivate"
                                           Visible="@c.IsActive" OnClick="@DeactivateAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="cu-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="cu-tab @(activeTab == tab.Key ? "cu-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            @* ---- Tab body ------------------------------------------------ *@
            <div class="cu-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    CustomerTab.Overview => OverviewTab(c),
                    CustomerTab.Address => AddressTab(c),
                    CustomerTab.Contacts => ContactsTab(c),
                    CustomerTab.Activity => ActivityTab(c),
                    _ => OverviewTab(c)
                })
            </div>
        </div>
    }
</RequirePermission>

@* ================================================================ Overview *@
@code {
    private RenderFragment OverviewTab(CustomerDetail c) =>@<text>
        <div class="cu-stack">
            <div class="cu-overview-grid">
                @* --- Customer status --- *@
                <RadzenCard class="cu-card">
                    <div class="cu-card-head"><RadzenIcon Icon="business" /><h3>@UiStrings.Customers.Status</h3></div>
                    <div class="cu-lead">
                        <span class="cu-lead-dot cu-lead-dot--@StatusToneColor(c)"></span>
                        <div>
                            <p class="cu-lead-title">@(c.IsActive ? UiStrings.Customers.Active : UiStrings.Customers.Inactive)</p>
                            <p class="os-muted cu-lead-desc">@StatusDescription(c)</p>
                        </div>
                    </div>
                    <dl class="cu-metrics">
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.IataCode</dt>
                            <dd>@c.IataCode</dd>
                        </div>
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.IcaoCode</dt>
                            <dd>@(string.IsNullOrWhiteSpace(c.IcaoCode) ? UiStrings.Customers.NoIcao : c.IcaoCode)</dd>
                        </div>
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.Created</dt>
                            <dd>@c.CreatedAtUtc.ToLocalTime().ToString("d")</dd>
                        </div>
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.Updated</dt>
                            <dd>@(c.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>

                @* --- Contact summary --- *@
                <RadzenCard class="cu-card">
                    <div class="cu-card-head"><RadzenIcon Icon="contacts" /><h3>@UiStrings.Customers.Contacts</h3></div>
                    <div class="cu-lead">
                        <span class="cu-lead-icon cu-lead-icon--blue"><RadzenIcon Icon="contacts" /></span>
                        <div>
                            <p class="cu-lead-title">@string.Format(UiStrings.Customers.ContactsCountFormat, ActiveContacts(c).Count)</p>
                            <p class="os-muted cu-lead-desc">@UiStrings.Customers.StatPortalAccounts: @LinkedContacts(c)</p>
                        </div>
                    </div>
                    <dl class="cu-metrics">
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.StatContacts</dt>
                            <dd>@ActiveContacts(c).Count</dd>
                        </div>
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.StatPortalAccounts</dt>
                            <dd>@LinkedContacts(c)</dd>
                        </div>
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.Country</dt>
                            <dd>@c.CountryName</dd>
                        </div>
                    </dl>
                    <button type="button" class="cu-card-link" @onclick="@(() => activeTab = CustomerTab.Contacts)">
                        @UiStrings.Common.Open<RadzenIcon Icon="chevron_right" />
                    </button>
                </RadzenCard>

                @* --- Official contact --- *@
                <RadzenCard class="cu-card">
                    <div class="cu-card-head"><RadzenIcon Icon="contact_mail" /><h3>@UiStrings.Customers.OfficialEmail</h3></div>
                    <dl class="cu-metrics cu-metrics--tall">
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.OfficialEmail</dt>
                            <dd>@(string.IsNullOrWhiteSpace(c.OfficialEmail) ? UiStrings.Customers.NoIcao : c.OfficialEmail)</dd>
                        </div>
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.OfficialPhone</dt>
                            <dd>@(string.IsNullOrWhiteSpace(c.OfficialPhone) ? UiStrings.Customers.NoIcao : c.OfficialPhone)</dd>
                        </div>
                        <div class="cu-metric">
                            <dt>@UiStrings.Customers.Country</dt>
                            <dd>@c.CountryName</dd>
                        </div>
                    </dl>
                </RadzenCard>
            </div>

            @* --- Recent activity preview --- *@
            @if (Auth.HasPermission(AuditPermissions.TrailsView))
            {
                <RadzenCard class="cu-card">
                    <div class="cu-card-head">
                        <RadzenIcon Icon="history" /><h3>@UiStrings.Audit.ActivityTitle</h3>
                        @if (activity.Count > 0)
                        {
                            <button type="button" class="cu-link" @onclick="@(() => activeTab = CustomerTab.Activity)">@UiStrings.Common.ViewAll</button>
                        }
                    </div>
                    @ActivityTimeline(OverviewActivityPreviewCount)
                </RadzenCard>
            }
        </div>
    </text>;

    @* ================================================================ Address *@
    private RenderFragment AddressTab(CustomerDetail c) =>@<text>
        <RadzenCard class="cu-card">
            <div class="cu-card-head"><RadzenIcon Icon="location_on" /><h3>@UiStrings.Customers.Address</h3></div>
            <dl class="cu-metrics cu-metrics--tall">
                <div class="cu-metric">
                    <dt>@UiStrings.Customers.AddressLine1</dt>
                    <dd>@c.Address.Line1</dd>
                </div>
                @if (!string.IsNullOrWhiteSpace(c.Address.Line2))
                {
                    <div class="cu-metric">
                        <dt>@UiStrings.Customers.AddressLine2</dt>
                        <dd>@c.Address.Line2</dd>
                    </div>
                }
                <div class="cu-metric">
                    <dt>@UiStrings.Customers.City</dt>
                    <dd>@c.Address.City</dd>
                </div>
                @if (!string.IsNullOrWhiteSpace(c.Address.Region))
                {
                    <div class="cu-metric">
                        <dt>@UiStrings.Customers.Region</dt>
                        <dd>@c.Address.Region</dd>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(c.Address.PostalCode))
                {
                    <div class="cu-metric">
                        <dt>@UiStrings.Customers.PostalCode</dt>
                        <dd>@c.Address.PostalCode</dd>
                    </div>
                }
            </dl>
        </RadzenCard>
    </text>;

    @* ================================================================ Contacts *@
    private RenderFragment ContactsTab(CustomerDetail c) =>@<text>
        @{
            var activeContacts = ActiveContacts(c);
        }
        <RadzenCard class="cu-card">
            <div class="cu-card-head">
                <RadzenIcon Icon="contacts" /><h3>@UiStrings.Customers.Contacts</h3>
                <span class="cu-count">@string.Format(UiStrings.Customers.ContactsCountFormat, activeContacts.Count)</span>
                @if (Auth.HasPermission(MasterDataPermissions.CustomerContactsCreate))
                {
                    <RadzenButton Text="@UiStrings.Customers.AddContact" Icon="person_add" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small" Click="@OpenAddContactAsync" />
                }
            </div>
            @if (activeContacts.Count == 0)
            {
                <EmptyState Icon="contacts" Title="@UiStrings.Customers.ContactsEmpty" />
            }
            else
            {
                <RadzenDataGrid TItem="CustomerContactModel" Data="@activeContacts" AllowSorting="false" GridLines="DataGridGridLines.Horizontal">
                    <Columns>
                        <RadzenDataGridColumn TItem="CustomerContactModel" Property="Name" Title="@UiStrings.Customers.ContactName" />
                        <RadzenDataGridColumn TItem="CustomerContactModel" Property="JobTitle" Title="@UiStrings.Customers.ContactJobTitle" />
                        <RadzenDataGridColumn TItem="CustomerContactModel" Property="Email" Title="@UiStrings.Customers.ContactEmail" />
                        <RadzenDataGridColumn TItem="CustomerContactModel" Property="Phone" Title="@UiStrings.Customers.ContactPhone" />
                        <RadzenDataGridColumn TItem="CustomerContactModel" Title="@UiStrings.Customers.PortalLinked" Width="160px">
                            <Template Context="contact">
                                @if (contact.LinkedUserId is not null)
                                {
                                    <StatusBadge Label="@UiStrings.PortalAccess.HasAccess" Tone="success" />
                                }
                                else
                                {
                                    <span class="os-muted">@UiStrings.PortalAccess.NoAccess</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="CustomerContactModel" Title="@UiStrings.Common.Actions" Width="84px" Sortable="false" TextAlign="TextAlign.Center" Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
                            <Template Context="contact">
                                @if (CanGrantContact(c, contact))
                                {
                                    <div class="os-row-actions">
                                        <RowActionMenu>
                                            <RowAction Text="@UiStrings.PortalAccess.GrantAction" Icon="person_add"
                                                       Permission="@MasterDataPermissions.CustomerContactsGrantAccess"
                                                       OnClick="@(() => OpenGrantContactAccessAsync(contact.Id))" />
                                        </RowActionMenu>
                                    </div>
                                }
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenCard>
    </text>;

    @* ================================================================ Activity *@
    private RenderFragment ActivityTab(CustomerDetail c) =>@<text>
        <RadzenCard class="cu-card">
            <div class="cu-card-head"><RadzenIcon Icon="history" /><h3>@UiStrings.Audit.ActivityTitle</h3></div>
            @ActivityTimeline()
        </RadzenCard>
    </text>;

    private RenderFragment ActivityTimeline(int? maxItems = null) =>@<text>
        @if (activity.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="cu-timeline">
                @foreach (var entry in maxItems is { } take ? activity.Take(take) : activity)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="cu-timeline-row" @key="entry.Id">
                        <span class="cu-timeline-icon cu-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="cu-timeline-content">
                            <p class="cu-timeline-title">@entry.Action</p>
                            <p class="os-muted cu-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="cu-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment TimelineEmpty() =>@<text>
        <div class="cu-timeline-empty">
            <span class="cu-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="cu-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@UiStrings.Audit.Description</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private CustomerDetail? item;
    private IReadOnlyList<AuditTrailListItem> activity = [];
    private bool isLoading = true;
    private bool loadError;
    private string errorMessage = UiStrings.Errors.LoadFailed;
    private CustomerTab activeTab = CustomerTab.Overview;

    private const int OverviewActivityPreviewCount = 4;

    private enum CustomerTab { Overview, Address, Contacts, Activity }

    private sealed record TabDef(CustomerTab Key, string Label, string Icon);

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(CustomerTab.Overview, UiStrings.Common.Overview, "dashboard");
        yield return new TabDef(CustomerTab.Address, UiStrings.Customers.TabAddress, "location_on");
        yield return new TabDef(CustomerTab.Contacts, UiStrings.Customers.Contacts, "contacts");
        if (Auth.HasPermission(AuditPermissions.TrailsView))
            yield return new TabDef(CustomerTab.Activity, UiStrings.Audit.ActivityTitle, "history");
    }

    private static List<CustomerContactModel> ActiveContacts(CustomerDetail c) =>
        c.Contacts.Where(ct => ct.IsActive).ToList();

    private static int LinkedContacts(CustomerDetail c) =>
        c.Contacts.Count(ct => ct.IsActive && ct.LinkedUserId is not null);

    private bool HasMoreActions(CustomerDetail c) =>
        (!c.IsActive && Auth.HasPermission(MasterDataPermissions.CustomersActivate))
        || (c.IsActive && Auth.HasPermission(MasterDataPermissions.CustomersDeactivate));

    private bool CanGrantContact(CustomerDetail c, CustomerContactModel contact) =>
        c.IsActive && contact.LinkedUserId is null && Auth.HasPermission(MasterDataPermissions.CustomerContactsGrantAccess);

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            item = await MasterData.GetCustomerAsync(Id);

            activity = [];
            if (Auth.HasPermission(AuditPermissions.TrailsView))
            {
                try
                {
                    var trails = await AuditApi.GetTrailsAsync(entityType: "Customer", entityId: Id, pageSize: 25);
                    activity = trails.Items;
                }
                catch (ApiException)
                {
                    activity = [];
                }
            }
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenEditAsync()
    {
        var result = await DialogService.OpenAsync<CustomerFormDialog>(UiStrings.Customers.EditTitle,
            new Dictionary<string, object?> { [nameof(CustomerFormDialog.CustomerId)] = Id },
            new DialogOptions { Width = "760px" });

        if (result is true)
            await LoadAsync();
    }

    private async Task OpenAddContactAsync()
    {
        if (item is not { } c)
            return;

        var result = await DialogService.OpenAsync<AddContactDialog>(UiStrings.Customers.AddContact,
            new Dictionary<string, object?>
            {
                [nameof(AddContactDialog.CustomerId)] = Id,
                [nameof(AddContactDialog.RowVersion)] = c.RowVersion
            },
            new DialogOptions { Width = "520px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Customers.ContactAdded);
            await LoadAsync();
        }
    }

    private async Task OpenGrantContactAccessAsync(Guid contactId)
    {
        var result = await DialogService.OpenAsync<GrantPortalAccessDialog>(UiStrings.PortalAccess.GrantTitle,
            new Dictionary<string, object?>
            {
                [nameof(GrantPortalAccessDialog.CompatibleUserType)] = "CustomerContact",
                [nameof(GrantPortalAccessDialog.GrantAsync)] = (Func<Guid, CancellationToken, Task>)((roleId, ct) =>
                    MasterData.GrantContactPortalAccessAsync(Id, contactId, new GrantPortalAccessRequest(roleId), ct))
            },
            new DialogOptions { Width = "520px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, UiStrings.PortalAccess.Granted);
            await LoadAsync();
        }
    }

    private async Task ActivateAsync()
    {
        if (item is not { } c)
            return;

        await RunAsync((rv, ct) => MasterData.ActivateCustomerAsync(Id, rv, ct), UiStrings.Customers.Activated, c.RowVersion);
    }

    private async Task DeactivateAsync()
    {
        if (item is not { } c)
            return;

        var confirmed = await DialogService.Confirm(UiStrings.Customers.ConfirmDeactivate, UiStrings.Customers.Deactivate,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        await RunAsync((rv, ct) => MasterData.DeactivateCustomerAsync(Id, rv, ct), UiStrings.Customers.Deactivated, c.RowVersion);
    }

    private async Task RunAsync(Func<string, CancellationToken, Task> action, string successMessage, string rowVersion)
    {
        try
        {
            await action(rowVersion, CancellationToken.None);
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private void GoBack() => Navigation.NavigateTo("/master-data/customers");

    private static string ProfileClass(CustomerDetail c) =>
        c.IsActive ? "cu-profile--active" : "cu-profile--inactive";

    private static string AvatarClass(CustomerDetail c) =>
        c.IsActive ? "cu-avatar--active" : "cu-avatar--inactive";

    private static string DotClass(CustomerDetail c) =>
        c.IsActive ? "cu-avatar-dot--active" : "cu-avatar-dot--inactive";

    private static string StatusToneColor(CustomerDetail c) =>
        c.IsActive ? "success" : "neutral";

    private static string StatusDescription(CustomerDetail c) =>
        c.IsActive ? UiStrings.Customers.FormIntro : UiStrings.Customers.ConfirmDeactivate;

    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("contact"))
            return ("contacts", "blue");
        if (a.Contains("portal") || a.Contains("access") || a.Contains("grant"))
            return ("vpn_key", "blue");
        if (a.Contains("activ"))
            return ("check_circle", "green");
        if (a.Contains("deactiv"))
            return ("cancel", "red");
        if (a.Contains("delet"))
            return ("delete", "red");
        if (a.Contains("creat"))
            return ("add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        if (a.Contains("customer"))
            return ("business", "blue");
        return ("history", "neutral");
    }
}
