@inject MasterDataApiClient MasterData
@inject IdentityApiClient Identity
@inject AuthSession Auth
@inject DialogService DialogService

<RadzenTemplateForm TItem="ContactModel" Data="@model" Submit="@SubmitAsync">
    <div class="acd-form">
        <div class="acd-section"><RadzenIcon Icon="contacts" /><h4>@DialogTitle</h4></div>

        <RadzenFormField Text="@UiStrings.Customers.ContactName" Variant="Variant.Outlined" Style="width: 100%;">
            <Start><RadzenIcon Icon="person" /></Start>
            <ChildContent>
                <RadzenTextBox @bind-Value="model.Name" Name="name" Style="width: 100%;" MaxLength="150" />
            </ChildContent>
        </RadzenFormField>
        <RadzenFormField Text="@UiStrings.Customers.ContactEmail" Variant="Variant.Outlined" Style="width: 100%;">
            <Start><RadzenIcon Icon="mail" /></Start>
            <ChildContent>
                <RadzenTextBox @bind-Value="model.Email" Name="email" Style="width: 100%;" MaxLength="256" />
            </ChildContent>
        </RadzenFormField>
        <RadzenFormField Text="@UiStrings.Customers.ContactJobTitle" Variant="Variant.Outlined" Style="width: 100%;">
            <Start><RadzenIcon Icon="work" /></Start>
            <ChildContent>
                <RadzenTextBox @bind-Value="model.JobTitle" Name="jobTitle" Style="width: 100%;" MaxLength="100" />
            </ChildContent>
        </RadzenFormField>
        <RadzenFormField Text="@UiStrings.Customers.ContactPhone" Variant="Variant.Outlined" Style="width: 100%;">
            <Start><RadzenIcon Icon="call" /></Start>
            <ChildContent>
                <RadzenTextBox @bind-Value="model.Phone" Name="phone" Style="width: 100%;" MaxLength="30" />
            </ChildContent>
        </RadzenFormField>

        @if (!IsEdit && Auth.CanGrantCustomerContactPortalAccess)
        {
            <div class="acd-section"><RadzenIcon Icon="vpn_key" /><h4>@UiStrings.PortalAccess.GrantTitle</h4></div>
            <RadzenStack Gap="0.5rem">
                <RadzenSwitch @bind-Value="grantPortal" Name="grantPortal" />
                <RadzenLabel Text="@UiStrings.PortalAccess.GrantOnCreate" Component="grantPortal" />
                <p class="acd-hint os-muted">@UiStrings.PortalAccess.GrantOnCreateHint</p>
                @if (grantPortal)
                {
                    @if (portalRoles.Count == 0)
                    {
                        <DismissibleDialogMessage AlertStyle="AlertStyle.Warning">
                            @UiStrings.PortalAccess.NoCompatibleRoles
                        </DismissibleDialogMessage>
                    }
                    else
                    {
                        <RadzenFormField Text="@UiStrings.PortalAccess.Role" Variant="Variant.Outlined" Style="width: 100%;">
                            <Start><RadzenIcon Icon="badge" /></Start>
                            <ChildContent>
                                <RadzenDropDown @bind-Value="portalRoleId" Data="@portalRoles" TextProperty="Name" ValueProperty="Id"
                                                Placeholder="@UiStrings.PortalAccess.RolePlaceholder" AllowFiltering="true" Style="width: 100%;" />
                            </ChildContent>
                        </RadzenFormField>
                    }
                }
            </RadzenStack>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" StateKey="@errorMessage"
                                      OnDismiss="@(() => errorMessage = null)">
                @errorMessage
            </DismissibleDialogMessage>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="@SubmitText" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
        </RadzenStack>
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid CustomerId { get; set; }
    [Parameter] public string RowVersion { get; set; } = string.Empty;
    [Parameter] public CustomerContactModel? Contact { get; set; }

    private ContactModel model = new();
    private Guid? initializedContactId;
    private bool isSubmitting;
    private string? errorMessage;
    private bool grantPortal;
    private Guid? portalRoleId;
    private IReadOnlyList<RoleOption> portalRoles = [];

    private bool IsEdit => Contact is not null;
    private string DialogTitle => IsEdit ? UiStrings.Customers.EditContact : UiStrings.Customers.AddContact;
    private string SubmitText => IsEdit ? UiStrings.Common.Save : UiStrings.Common.Create;

    protected override void OnParametersSet()
    {
        if (Contact is { } contact && initializedContactId != contact.Id)
        {
            model = new ContactModel
            {
                Name = contact.Name,
                JobTitle = contact.JobTitle,
                Email = contact.Email,
                Phone = contact.Phone
            };
            initializedContactId = contact.Id;
        }
        else if (Contact is null && initializedContactId is not null)
        {
            model = new ContactModel();
            initializedContactId = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        if (!IsEdit && Auth.CanGrantCustomerContactPortalAccess)
        {
            try
            {
                portalRoles = await Identity.GetRoleOptionsAsync("CustomerContact");
            }
            catch (ApiException ex)
            {
                errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
            }
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorMessage = UiStrings.Customers.ContactNameRequired;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.Email))
        {
            errorMessage = UiStrings.Customers.ContactEmailRequired;
            return;
        }

        if (grantPortal && portalRoleId is null)
        {
            errorMessage = portalRoles.Count == 0
                ? UiStrings.PortalAccess.NoCompatibleRoles
                : UiStrings.PortalAccess.RoleRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            var name = model.Name!.Trim();
            var jobTitle = string.IsNullOrWhiteSpace(model.JobTitle) ? null : model.JobTitle!.Trim();
            var email = model.Email!.Trim();
            var phone = string.IsNullOrWhiteSpace(model.Phone) ? null : model.Phone!.Trim();

            if (Contact is { } contact)
            {
                await MasterData.UpdateCustomerContactAsync(CustomerId, contact.Id,
                    new UpdateCustomerContactRequest(name, jobTitle, email, phone),
                    RowVersion);
            }
            else
            {
                await MasterData.AddCustomerContactAsync(CustomerId,
                    new AddCustomerContactRequest(name, jobTitle, email, phone, grantPortal ? portalRoleId : null),
                    RowVersion);
            }

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ContactModel
    {
        public string? Name { get; set; }
        public string? JobTitle { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
    }
}
