@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<div class="cuf-form">
    @if (IsCreate)
    {
        @WizardStepper()
        <div class="cuf-wizard-body">
            @(step switch { 0 => DetailsSection(), 1 => AddressSection(), 2 => ContactsSection(), _ => ReviewSection() })
        </div>

        @ErrorBanner()

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="cuf-actions">
            @if (step == 0)
            {
                <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            }
            else
            {
                <RadzenButton Text="@UiStrings.Customers.Previous" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Click="@Previous" />
            }
            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                @if (step > 0)
                {
                    <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                }
                @if (step < 3)
                {
                    <RadzenButton Text="@UiStrings.Customers.Next" Icon="arrow_forward" ButtonStyle="ButtonStyle.Primary" Click="@NextAsync" />
                }
                else
                {
                    <RadzenButton Text="@UiStrings.Common.Create" Icon="check" ButtonStyle="ButtonStyle.Primary" Click="@SubmitAsync" Disabled="@isSubmitting" />
                }
            </RadzenStack>
        </RadzenStack>
    }
    else
    {
        <p class="cuf-intro os-muted">@UiStrings.Customers.EditFormIntro</p>
        @DetailsSection()
        @AddressSection()
        @ErrorBanner()
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton Text="@UiStrings.Common.Save" ButtonStyle="ButtonStyle.Primary" Click="@SubmitAsync" Disabled="@isSubmitting" />
        </RadzenStack>
    }
</div>

@code {
    [Parameter] public Guid? CustomerId { get; set; }

    private CustomerModel model = new();
    private readonly List<ContactRow> contacts = [];
    private IReadOnlyList<CountryOption> countries = [];
    private string? rowVersion;
    private int step;
    private bool isSubmitting;
    private string? errorMessage;
    private byte[]? logoContent;
    private string? logoFileName;
    private string? logoContentType;
    private string? logoPreviewUrl;
    private string? existingLogoPreviewUrl;
    private Guid? savedCustomerId;

    private bool IsCreate => CustomerId is null;

    private RenderFragment WizardStepper() =>@<div class="cuf-stepper">
        @for (var i = 0; i < 4; i++)
        {
            var index = i;
            <div class="@StepClass(index)">
                <button type="button" class="cuf-step-button" disabled="@(index > step)" @onclick="@(() => MoveToStep(index))">
                    <span class="cuf-step-node">
                        @if (index < step) { <RadzenIcon Icon="check" /> }
                        else { @((index + 1).ToString()) }
                    </span>
                    <span class="cuf-step-label">@StepLabel(index)</span>
                </button>
            </div>
        }
    </div>;

    private string StepLabel(int index) => index switch
    {
        0 => UiStrings.Customers.StepDetails,
        1 => UiStrings.Customers.StepAddress,
        2 => UiStrings.Customers.StepContacts,
        _ => UiStrings.Customers.StepReview
    };

    private string StepClass(int index) => $"cuf-step-item cuf-step-{(index < step ? "complete" : index == step ? "active" : "pending")}";
    private void MoveToStep(int index) { if (index > step) return; errorMessage = null; step = index; }
    private void Previous() { errorMessage = null; step = Math.Max(0, step - 1); }

    private RenderFragment DetailsSection() =>@<section class="cuf-step-content">
        <div class="cuf-section-line"><RadzenIcon Icon="business" /><span>@UiStrings.Common.Details</span></div>
        <div class="cuf-logo-editor">
            <div class="cuf-logo-preview">
                @if (!string.IsNullOrWhiteSpace(logoPreviewUrl)) { <img src="@logoPreviewUrl" alt="Customer logo preview" /> }
                else { <RadzenIcon Icon="image" /> }
            </div>
            <div class="cuf-logo-copy">
                <strong>Customer logo</strong>
                <p>PNG, JPEG, WEBP or GIF. Maximum file size 2 MB.</p>
                <div class="cuf-logo-actions">
                    <label class="cuf-logo-button"><RadzenIcon Icon="upload" /><span>@(logoContent is null && existingLogoPreviewUrl is null ? "Choose logo" : "Replace logo")</span><InputFile OnChange="@SelectLogoAsync" accept="image/png,image/jpeg,image/webp,image/gif" /></label>
                    @if (logoContent is not null) { <button type="button" class="cuf-logo-remove" @onclick="ClearSelectedLogo"><RadzenIcon Icon="close" /><span>Clear selection</span></button> }
                </div>
                @if (!string.IsNullOrWhiteSpace(logoFileName)) { <span class="cuf-logo-file"><RadzenIcon Icon="check_circle" />@logoFileName (@FormatFileSize(logoContent?.LongLength ?? 0))</span> }
            </div>
        </div>
        <div class="cuf-grid-2">
            <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.IataCode</label><div class="cuf-input-wrap"><RadzenIcon Icon="tag" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.IataCode" class="cuf-control cuf-control-icon" MaxLength="2" Placeholder="e.g. SV" /></div></div>
            <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.IcaoCode</label><div class="cuf-input-wrap"><RadzenIcon Icon="tag" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.IcaoCode" class="cuf-control cuf-control-icon" MaxLength="3" Placeholder="e.g. SVA" /></div></div>
        </div>
        <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.Name <span class="cuf-required">*</span></label><div class="cuf-input-wrap"><RadzenIcon Icon="badge" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.Name" class="cuf-control cuf-control-icon" MaxLength="200" Placeholder="e.g. Saudi Arabian Airlines" /></div></div>
        <div class="cuf-grid-2">
            <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.Country <span class="cuf-required">*</span></label><div class="cuf-input-wrap"><RadzenIcon Icon="public" class="cuf-field-icon" /><RadzenDropDown @bind-Value="model.CountryId" Data="@countries" TextProperty="Name" ValueProperty="Id" AllowFiltering="true" class="cuf-control cuf-control-icon" Placeholder="@UiStrings.Stations.SelectCountry" /></div></div>
            <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.OfficialPhone</label><div class="cuf-input-wrap"><RadzenIcon Icon="call" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.OfficialPhone" class="cuf-control cuf-control-icon" MaxLength="30" Placeholder="e.g. +966 11 000 0000" /></div></div>
        </div>
        <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.OfficialEmail</label><div class="cuf-input-wrap"><RadzenIcon Icon="mail" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.OfficialEmail" class="cuf-control cuf-control-icon" MaxLength="256" Placeholder="operations@example.com" /></div></div>
    </section>;

    private RenderFragment AddressSection() =>@<section class="cuf-step-content">
        <div class="cuf-section-line"><RadzenIcon Icon="location_on" /><span>@UiStrings.Customers.Address</span></div>
        <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.AddressLine1</label><div class="cuf-input-wrap"><RadzenIcon Icon="home" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.AddressLine1" class="cuf-control cuf-control-icon" MaxLength="200" Placeholder="Building, street and district" /></div></div>
        <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.AddressLine2</label><div class="cuf-input-wrap"><RadzenIcon Icon="home" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.AddressLine2" class="cuf-control cuf-control-icon" MaxLength="200" Placeholder="Suite, floor or additional details" /></div></div>
        <div class="cuf-grid-2">
            <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.City</label><div class="cuf-input-wrap"><RadzenIcon Icon="location_city" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.AddressCity" class="cuf-control cuf-control-icon" MaxLength="100" Placeholder="e.g. Riyadh" /></div></div>
            <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.Region</label><div class="cuf-input-wrap"><RadzenIcon Icon="map" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.AddressRegion" class="cuf-control cuf-control-icon" MaxLength="100" Placeholder="e.g. Riyadh Province" /></div></div>
        </div>
        <div class="cuf-field-block"><label class="cuf-label">@UiStrings.Customers.PostalCode</label><div class="cuf-input-wrap"><RadzenIcon Icon="local_post_office" class="cuf-field-icon" /><RadzenTextBox @bind-Value="model.AddressPostalCode" class="cuf-control cuf-control-icon" MaxLength="20" Placeholder="e.g. 12345" /></div></div>
    </section>;

    private RenderFragment ContactsSection() =>@<section class="cuf-step-content">
        <div class="cuf-section-line cuf-section-line-action">
            <RadzenIcon Icon="contacts" /><span>@UiStrings.Customers.Contacts</span>
            <div class="cuf-section-actions">
                <RadzenButton Text="@UiStrings.Customers.AddContact" Icon="person_add" ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small" Click="@AddContact" />
            </div>
        </div>

        @if (contacts.Count(c => !c.Removed) == 0)
        {
            <div class="cuf-empty"><RadzenIcon Icon="person_add" /><span>@UiStrings.Customers.ContactsEmpty</span></div>
        }
        else
        {
            <div class="cuf-contacts">
                @foreach (var contact in contacts.Where(c => !c.Removed))
                {
                    <div class="cuf-contact" @key="contact">
                        <RadzenTextBox @bind-Value="contact.Name" Placeholder="@UiStrings.Customers.ContactName" class="cuf-control" MaxLength="150" />
                        <RadzenTextBox @bind-Value="contact.Email" Placeholder="@UiStrings.Customers.ContactEmail" class="cuf-control" MaxLength="256" />
                        <RadzenTextBox @bind-Value="contact.JobTitle" Placeholder="@UiStrings.Customers.ContactJobTitle" class="cuf-control" MaxLength="100" />
                        <RadzenTextBox @bind-Value="contact.Phone" Placeholder="@UiStrings.Customers.ContactPhone" class="cuf-control" MaxLength="30" />
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small" Click="@(() => RemoveContact(contact))" />
                    </div>
                }
            </div>
        }
        <DismissibleDialogMessage AlertStyle="AlertStyle.Info" Title="@UiStrings.Customers.Contacts">
            <p>@UiStrings.Customers.ContactsEmpty</p>
        </DismissibleDialogMessage>
    </section>;

    private RenderFragment ReviewSection() =>@<section class="cuf-step-content">
        <div class="cuf-review-intro"><h3>@UiStrings.Customers.StepReview</h3><p>@string.Format(UiStrings.Customers.ReviewSummary, Display(model.IataCode), model.Name, contacts.Count(c => !c.Removed))</p></div>
        <div class="cuf-review-card"><div class="cuf-review-head"><h4>@UiStrings.Common.Details</h4><button type="button" @onclick="@(() => step = 0)"><RadzenIcon Icon="edit" />@UiStrings.Common.Edit</button></div>
            <dl class="cuf-review-grid"><div><dt>@UiStrings.Customers.IataCode</dt><dd>@Display(model.IataCode)</dd></div><div><dt>@UiStrings.Customers.IcaoCode</dt><dd>@Display(model.IcaoCode)</dd></div><div><dt>@UiStrings.Customers.Name</dt><dd>@model.Name</dd></div><div><dt>@UiStrings.Customers.Country</dt><dd>@CountryName</dd></div><div><dt>@UiStrings.Customers.OfficialEmail</dt><dd>@Display(model.OfficialEmail)</dd></div><div><dt>@UiStrings.Customers.OfficialPhone</dt><dd>@Display(model.OfficialPhone)</dd></div></dl>
        </div>
        <div class="cuf-review-card"><div class="cuf-review-head"><h4>@UiStrings.Customers.Address</h4><button type="button" @onclick="@(() => step = 1)"><RadzenIcon Icon="edit" />@UiStrings.Common.Edit</button></div>
            <dl class="cuf-review-grid"><div><dt>@UiStrings.Customers.AddressLine1</dt><dd>@Display(model.AddressLine1)</dd></div><div><dt>@UiStrings.Customers.City</dt><dd>@Display(model.AddressCity)</dd></div><div><dt>@UiStrings.Customers.Region</dt><dd>@Display(model.AddressRegion)</dd></div><div><dt>@UiStrings.Customers.PostalCode</dt><dd>@Display(model.AddressPostalCode)</dd></div></dl>
        </div>
        <DismissibleDialogMessage AlertStyle="AlertStyle.Info" Icon="lock">
            @UiStrings.Customers.StepReview
        </DismissibleDialogMessage>
    </section>;

    private RenderFragment ErrorBanner() =>@<text>
        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" Title="Please fix the following errors before continuing"
                                      StateKey="@errorMessage" OnDismiss="@(() => errorMessage = null)">
                <ul><li>@errorMessage</li></ul>
            </DismissibleDialogMessage>
        }
    </text>;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var countriesTask = MasterData.GetCountryOptionsAsync();
            Task<CustomerDetail?> detailTask = CustomerId is { } id
                ? GetCustomerForEditAsync(id)
                : Task.FromResult<CustomerDetail?>(null);

            await Task.WhenAll(countriesTask, detailTask);

            countries = await countriesTask;

            if (await detailTask is { } detail)
            {
                model = new CustomerModel
                {
                    IataCode = detail.IataCode,
                    IcaoCode = detail.IcaoCode,
                    Name = detail.Name,
                    CountryId = detail.CountryId,
                    OfficialEmail = detail.OfficialEmail,
                    OfficialPhone = detail.OfficialPhone,
                    AddressLine1 = detail.Address.Line1,
                    AddressLine2 = detail.Address.Line2,
                    AddressCity = detail.Address.City,
                    AddressRegion = detail.Address.Region,
                    AddressPostalCode = detail.Address.PostalCode
                };
                rowVersion = detail.RowVersion;

                if (!string.IsNullOrWhiteSpace(detail.LogoFileReference))
                {
                    try
                    {
                        var logo = await MasterData.GetCustomerLogoAsync(detail.Id);
                        existingLogoPreviewUrl = $"data:{logo.ContentType};base64,{logo.Base64}";
                        logoPreviewUrl = existingLogoPreviewUrl;
                    }
                    catch (ApiException)
                    {
                        // Keep the customer editable if an older logo file is unavailable.
                        existingLogoPreviewUrl = null;
                        logoPreviewUrl = null;
                    }
                }
            }
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
    }

    private async Task<CustomerDetail?> GetCustomerForEditAsync(Guid id) =>
        await MasterData.GetCustomerAsync(id);

    private void AddContact() => contacts.Add(new ContactRow());

    private async Task SelectLogoAsync(InputFileChangeEventArgs args)
    {
        errorMessage = null;
        var file = args.File;
        if (file.ContentType is not ("image/png" or "image/jpeg" or "image/webp" or "image/gif"))
        {
            errorMessage = "The logo must be a PNG, JPEG, WEBP, or GIF image.";
            return;
        }
        if (file.Size > 2 * 1024 * 1024)
        {
            errorMessage = "The logo file must be at most 2 MB.";
            return;
        }

        await using var stream = file.OpenReadStream(2 * 1024 * 1024);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);
        logoContent = memory.ToArray();
        logoFileName = file.Name;
        logoContentType = file.ContentType;
        logoPreviewUrl = $"data:{logoContentType};base64,{Convert.ToBase64String(logoContent)}";
    }

    private void ClearSelectedLogo()
    {
        logoContent = null;
        logoFileName = null;
        logoContentType = null;
        logoPreviewUrl = existingLogoPreviewUrl;
    }

    private void RemoveContact(ContactRow contact)
    {
        if (contact.Id is null)
            contacts.Remove(contact);
        else
            contact.Removed = true;
    }

    private void NextAsync()
    {
        errorMessage = null;
        if (step == 0 && !ValidateDetails())
            return;
        if (step == 1 && !ValidateAddress())
            return;
        if (step == 2 && !ValidateContacts())
            return;
        step = Math.Min(3, step + 1);
    }

    private bool ValidateDetails()
    {
        if (!string.IsNullOrWhiteSpace(model.IataCode) && model.IataCode.Trim().Length != 2) { errorMessage = UiStrings.Customers.IataRequired; return false; }
        if (!string.IsNullOrWhiteSpace(model.IcaoCode) && model.IcaoCode.Trim().Length != 3) { errorMessage = UiStrings.Customers.IcaoInvalid; return false; }
        if (string.IsNullOrWhiteSpace(model.Name)) { errorMessage = UiStrings.Customers.NameRequired; return false; }
        if (model.CountryId == Guid.Empty) { errorMessage = UiStrings.Customers.CountryRequired; return false; }
        return true;
    }

    private bool ValidateAddress()
    {
        return true;
    }

    private bool ValidateContacts()
    {
        var active = contacts.Where(c => !c.Removed).ToList();
        if (active.Any(c => string.IsNullOrWhiteSpace(c.Name))) { errorMessage = UiStrings.Customers.ContactNameRequired; return false; }
        if (active.Any(c => string.IsNullOrWhiteSpace(c.Email))) { errorMessage = UiStrings.Customers.ContactEmailRequired; return false; }
        if (active.GroupBy(c => c.Email!.Trim().ToLowerInvariant()).Any(g => g.Count() > 1)) { errorMessage = UiStrings.Customers.ContactEmailDuplicate; return false; }
        return true;
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;
        if (!ValidateDetails()) { step = 0; return; }
        if (!ValidateAddress()) { step = 1; return; }
        if (!ValidateContacts()) { step = 2; return; }

        isSubmitting = true;
        try
        {
            var activeContacts = contacts.Where(c => !c.Removed).ToList();
            var address = new AddressRequest(
                Trim(model.AddressLine1), Trim(model.AddressLine2), Trim(model.AddressCity),
                Trim(model.AddressRegion), Trim(model.AddressPostalCode));

            var iata = string.IsNullOrWhiteSpace(model.IataCode) ? null : model.IataCode.Trim().ToUpperInvariant();
            var icao = string.IsNullOrWhiteSpace(model.IcaoCode) ? null : model.IcaoCode!.Trim().ToUpperInvariant();
            var email = Trim(model.OfficialEmail);
            var phone = Trim(model.OfficialPhone);
            var name = model.Name!.Trim();

            Guid targetId;
            if (CustomerId is { } id)
            {
                // Customer update changes only customer fields; contacts are managed on the detail page.
                await MasterData.UpdateCustomerAsync(id,
                    new UpdateCustomerRequest(iata, icao, name, model.CountryId, email, phone, address),
                    rowVersion ?? string.Empty);
                targetId = id;
            }
            else
            {
                if (savedCustomerId is { } existingId)
                {
                    targetId = existingId;
                }
                else
                {
                    var contactRequests = activeContacts
                        .Select(c => new CustomerContactRequest(c.Id, c.Name!.Trim(), Trim(c.JobTitle), c.Email!.Trim(), Trim(c.Phone), null))
                        .ToList();
                    targetId = await MasterData.CreateCustomerAsync(
                        new CreateCustomerRequest(iata, icao, name, model.CountryId, email, phone, address, contactRequests));
                    savedCustomerId = targetId;
                }
            }

            if (logoContent is not null && logoFileName is not null && logoContentType is not null)
            {
                var refreshed = await MasterData.GetCustomerAsync(targetId);
                rowVersion = refreshed.RowVersion;
                await MasterData.UploadCustomerLogoAsync(targetId, logoContent, logoFileName, logoContentType, rowVersion);
            }

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
            if (IsCreate)
                step = 0;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private static string? Trim(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    private string CountryName => countries.FirstOrDefault(c => c.Id == model.CountryId)?.Name ?? UiStrings.Common.None;
    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? UiStrings.Common.None : value;
    private static string FormatFileSize(long bytes) => bytes < 1024 * 1024
        ? $"{Math.Max(1, bytes / 1024)} KB"
        : $"{bytes / 1024d / 1024d:0.0} MB";

    private sealed class CustomerModel
    {
        public string? IataCode { get; set; }
        public string? IcaoCode { get; set; }
        public string? Name { get; set; }
        public Guid CountryId { get; set; }
        public string? OfficialEmail { get; set; }
        public string? OfficialPhone { get; set; }
        public string? AddressLine1 { get; set; }
        public string? AddressLine2 { get; set; }
        public string? AddressCity { get; set; }
        public string? AddressRegion { get; set; }
        public string? AddressPostalCode { get; set; }
    }

    private sealed class ContactRow
    {
        public Guid? Id { get; set; }
        public string? Name { get; set; }
        public string? JobTitle { get; set; }
        public string? Email { get; set; }
        public string? Phone { get; set; }
        public bool Removed { get; set; }
    }
}
