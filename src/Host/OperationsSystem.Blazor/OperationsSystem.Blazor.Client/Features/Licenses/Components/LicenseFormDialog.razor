@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="LicenseModel" Data="@model" Submit="@SubmitAsync">
    <div class="lcf-form">
        <p class="lcf-intro os-muted">@UiStrings.Licenses.FormIntro</p>

        <div class="lcf-section-line"><RadzenIcon Icon="badge" /><span>@UiStrings.Common.Details</span></div>
        <div class="lcf-grid-2">
            <div class="lcf-field-block"><label class="lcf-label">@UiStrings.Licenses.Code <span>*</span></label><div class="lcf-input-wrap"><RadzenIcon Icon="tag" class="lcf-field-icon" /><RadzenTextBox @bind-Value="model.Code" Name="code" class="lcf-control lcf-control-icon" MaxLength="10" Disabled="@(LicenseId is not null)" Placeholder="e.g. GSE" /></div></div>
            <div class="lcf-field-block"><label class="lcf-label">@UiStrings.Licenses.Name <span>*</span></label><div class="lcf-input-wrap"><RadzenIcon Icon="badge" class="lcf-field-icon" /><RadzenTextBox @bind-Value="model.Name" Name="name" class="lcf-control lcf-control-icon" MaxLength="100" Placeholder="e.g. Ground Support Equipment" /></div></div>
        </div>
        <div class="lcf-field-block"><label class="lcf-label">@UiStrings.Licenses.LicenseDescription</label><RadzenTextArea @bind-Value="model.Description" Name="description" Rows="4" class="lcf-control" MaxLength="500" Placeholder="Describe what this license authorizes" /></div>
        <div class="lcf-callout"><RadzenIcon Icon="info" /><div><strong>@UiStrings.Licenses.Code</strong><p>@(LicenseId is null ? "Choose the short code carefully; it cannot be changed after creation." : UiStrings.Licenses.CodeImmutable)</p></div></div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="lcf-error-panel" role="alert"><RadzenIcon Icon="error_outline" /><div><strong>Please fix the following errors before continuing</strong><ul><li>@errorMessage</li></ul></div></div>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="lcf-actions">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(LicenseId is null ? UiStrings.Common.Create : UiStrings.Common.Save)"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
        </RadzenStack>
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid? LicenseId { get; set; }

    private LicenseModel model = new();
    private string? rowVersion;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (LicenseId is { } id)
        {
            try
            {
                var detail = await MasterData.GetLicenseAsync(id);
                model = new LicenseModel { Code = detail.Code, Name = detail.Name, Description = detail.Description };
                rowVersion = detail.RowVersion;
            }
            catch (ApiException ex)
            {
                errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
            }
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (LicenseId is null && (string.IsNullOrWhiteSpace(model.Code) || model.Code.Trim().Length < 2))
        {
            errorMessage = UiStrings.Licenses.CodeRequired;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorMessage = UiStrings.Licenses.NameRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            var name = model.Name.Trim();
            var description = string.IsNullOrWhiteSpace(model.Description) ? null : model.Description.Trim();

            if (LicenseId is { } id)
                await MasterData.UpdateLicenseAsync(id, new UpdateLicenseRequest(name, description), rowVersion ?? string.Empty);
            else
                await MasterData.CreateLicenseAsync(new CreateLicenseRequest(model.Code.Trim().ToUpperInvariant(), name, description));

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class LicenseModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}
