@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="LicenseModel" Data="@model" Submit="@SubmitAsync">
    <RadzenStack Gap="1rem">
        <RadzenFormField Text="@UiStrings.Licenses.Code" Variant="Variant.Outlined">
            <RadzenTextBox @bind-Value="model.Code" Name="code" Style="width: 100%;" MaxLength="10" Disabled="@(LicenseId is not null)" />
        </RadzenFormField>
        @if (LicenseId is not null)
        {
            <p class="os-muted">@UiStrings.Licenses.CodeImmutable</p>
        }

        <RadzenFormField Text="@UiStrings.Licenses.Name" Variant="Variant.Outlined">
            <RadzenTextBox @bind-Value="model.Name" Name="name" Style="width: 100%;" MaxLength="100" />
        </RadzenFormField>

        <RadzenFormField Text="@UiStrings.Licenses.LicenseDescription" Variant="Variant.Outlined">
            <RadzenTextArea @bind-Value="model.Description" Name="description" Rows="3" Style="width: 100%;" MaxLength="500" />
        </RadzenFormField>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">@errorMessage</RadzenAlert>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(LicenseId is null ? UiStrings.Common.Create : UiStrings.Common.Save)"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid? LicenseId { get; set; }

    private LicenseModel model = new();
    private string? rowVersion;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (LicenseId is { } id)
        {
            try
            {
                var detail = await MasterData.GetLicenseAsync(id);
                model = new LicenseModel { Code = detail.Code, Name = detail.Name, Description = detail.Description };
                rowVersion = detail.RowVersion;
            }
            catch (ApiException ex)
            {
                errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
            }
        }
    }

    private async Task SubmitAsync()
    {
        errorMessage = null;

        if (LicenseId is null && (string.IsNullOrWhiteSpace(model.Code) || model.Code.Trim().Length < 2))
        {
            errorMessage = UiStrings.Licenses.CodeRequired;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorMessage = UiStrings.Licenses.NameRequired;
            return;
        }

        isSubmitting = true;

        try
        {
            var name = model.Name.Trim();
            var description = string.IsNullOrWhiteSpace(model.Description) ? null : model.Description.Trim();

            if (LicenseId is { } id)
                await MasterData.UpdateLicenseAsync(id, new UpdateLicenseRequest(name, description), rowVersion ?? string.Empty);
            else
                await MasterData.CreateLicenseAsync(new CreateLicenseRequest(model.Code.Trim().ToUpperInvariant(), name, description));

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class LicenseModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
    }
}
