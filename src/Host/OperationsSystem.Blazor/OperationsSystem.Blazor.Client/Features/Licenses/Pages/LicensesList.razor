@page "/master-data/licenses"
@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject GridPreferences GridPrefs

<PageTitle>@UiStrings.Licenses.Title</PageTitle>

<RequirePermission Permission="@MasterDataPermissions.LicensesView">
    <div class="os-list-page">
        <PageHeader Title="@UiStrings.Licenses.Title" Description="@UiStrings.Licenses.Description">
            <Actions>
                <AuthorizeView Context="create">
                    @if (create.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.LicensesCreate))
                    {
                        <RadzenButton Text="@UiStrings.Licenses.Create" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@OpenCreateAsync" />
                    }
                </AuthorizeView>
            </Actions>
        </PageHeader>

        <DataListCard @ref="list" TItem="LicenseListItem" Data="@items" Count="@totalCount" IsLoading="@isLoading"
                      HasError="@loadError" OnRetry="@ReloadAsync" LoadData="@LoadDataAsync"
                      PageSize="@currentPageSize" PageSizeChanged="@OnPageSizeChangedAsync"
                      SearchValue="@searchTerm" SearchValueChanged="@(v => searchTerm = v)" OnSearch="@ReloadAsync"
                      SearchPlaceholder="@UiStrings.Licenses.SearchPlaceholder"
                      CountLabel="@UiStrings.Licenses.CountLabel" EmptyText="@UiStrings.Licenses.Empty">
            <Filters>
                <DataListFilter TValue="bool?" Placeholder="@UiStrings.Licenses.AllStatuses"
                                Data="@statusOptions" Value="@activeFilter" ValueChanged="@OnStatusFilterChangedAsync" />
            </Filters>
            <Columns>
                <RadzenDataGridColumn TItem="LicenseListItem" Property="Code" Title="@UiStrings.Licenses.Code" Width="140px">
                    <Template Context="item">
                        <strong>@item.Code</strong>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="LicenseListItem" Property="Name" Title="@UiStrings.Licenses.Name" />
                <RadzenDataGridColumn TItem="LicenseListItem" Title="@UiStrings.Licenses.Status" Sortable="false" Width="140px">
                    <Template Context="item">
                        @if (item.IsActive)
                        {
                            <StatusBadge Label="@UiStrings.Licenses.Active" Tone="success" />
                        }
                        else
                        {
                            <StatusBadge Label="@UiStrings.Licenses.Inactive" Tone="neutral" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
            <RowActions Context="item">
                <RowActionMenu>
                    <RowAction Text="@UiStrings.Common.Open" Icon="visibility" OnClick="@(() => Open(item.Id))" />
                    <RowAction Text="@UiStrings.Common.Edit" Icon="edit" Permission="@MasterDataPermissions.LicensesUpdate"
                               OnClick="@(() => OpenEditAsync(item))" />
                    <RowAction Separator="true" />
                    <RowAction Text="@UiStrings.Licenses.Activate" Icon="check_circle" Permission="@MasterDataPermissions.LicensesActivate"
                               Visible="@(!item.IsActive)" OnClick="@(() => ActivateAsync(item))" />
                    <RowAction Text="@UiStrings.Licenses.Deactivate" Icon="cancel" Danger="true"
                               Permission="@MasterDataPermissions.LicensesDeactivate"
                               Visible="@item.IsActive" OnClick="@(() => DeactivateAsync(item))" />
                </RowActionMenu>
            </RowActions>
        </DataListCard>
    </div>
</RequirePermission>

@code {
    private const string GridKey = "licenses";
    private static readonly int[] PageSizes = [10, 25, 50, 100];

    private DataListCard<LicenseListItem>? list;
    private IReadOnlyList<LicenseListItem> items = [];
    private int totalCount;
    private int currentPage = 1;
    private int currentPageSize = 10;
    private bool isLoading;
    private bool loadError;

    private string searchTerm = string.Empty;
    private bool? activeFilter;
    private string? currentSort;

    private readonly List<StatusOption> statusOptions =
    [
        new(UiStrings.Licenses.Active, true),
        new(UiStrings.Licenses.Inactive, false)
    ];

    protected override async Task OnInitializedAsync()
    {
        currentPageSize = await GridPrefs.GetPageSizeAsync(GridKey, currentPageSize, PageSizes);
        await FetchAsync();
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        currentPageSize = pageSize;
        await GridPrefs.SetPageSizeAsync(GridKey, pageSize);
    }

    private async Task OnStatusFilterChangedAsync(bool? value)
    {
        activeFilter = value;
        await ReloadAsync();
    }

    private async Task LoadDataAsync(LoadDataArgs args)
    {
        currentPageSize = args.Top ?? currentPageSize;
        currentPage = ((args.Skip ?? 0) / Math.Max(currentPageSize, 1)) + 1;
        currentSort = SortBuilder.From(args);
        await FetchAsync();
    }

    private async Task FetchAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            var result = await MasterData.GetLicensesAsync(currentPage, currentPageSize,
                string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm, activeFilter, currentSort);
            items = result.Items;
            totalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadAsync()
    {
        currentPage = 1;
        if (list is not null)
            await list.ReloadAsync();
        else
            await FetchAsync();
    }

    private async Task OpenCreateAsync()
    {
        var result = await DialogService.OpenAsync<LicenseFormDialog>(UiStrings.Licenses.CreateTitle);
        if (result is true)
            await ReloadAsync();
    }

    private void Open(Guid id) => Navigation.NavigateTo($"/master-data/licenses/{id}");

    private async Task OpenEditAsync(LicenseListItem item)
    {
        var result = await DialogService.OpenAsync<LicenseFormDialog>(UiStrings.Licenses.EditTitle,
            new Dictionary<string, object?> { [nameof(LicenseFormDialog.LicenseId)] = item.Id });

        if (result is true)
            await ReloadAsync();
    }

    private Task ActivateAsync(LicenseListItem item) =>
        RunAsync(item.Id, (rv, ct) => MasterData.ActivateLicenseAsync(item.Id, rv, ct), UiStrings.Licenses.Activated);

    private async Task DeactivateAsync(LicenseListItem item)
    {
        var confirmed = await DialogService.Confirm(UiStrings.Licenses.ConfirmDeactivate, UiStrings.Licenses.Deactivate,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        await RunAsync(item.Id, (rv, ct) => MasterData.DeactivateLicenseAsync(item.Id, rv, ct), UiStrings.Licenses.Deactivated);
    }

    private async Task RunAsync(Guid id, Func<string, CancellationToken, Task> action, string successMessage)
    {
        try
        {
            var detail = await MasterData.GetLicenseAsync(id);
            await action(detail.RowVersion, CancellationToken.None);
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private sealed record StatusOption(string Label, bool? Value);
}
