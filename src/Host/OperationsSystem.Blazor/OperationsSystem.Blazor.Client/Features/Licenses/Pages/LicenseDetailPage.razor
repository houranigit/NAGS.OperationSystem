@page "/master-data/licenses/{Id:guid}"
@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject AuditApiClient AuditApi

<PageTitle>@(item?.Name ?? UiStrings.Licenses.Title)</PageTitle>

<RequirePermission Permission="@MasterDataPermissions.LicensesView">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (loadError)
    {
        <ErrorState Message="@errorMessage" OnRetry="@LoadAsync" />
    }
    else if (item is { } l)
    {
        <div class="lc-workspace">
            <section class="lc-profile @ProfileClass(l)">
                <div class="lc-hero">
                    <div class="lc-avatar @AvatarClass(l)">
                        <RadzenIcon Icon="badge" />
                        <span class="lc-avatar-dot @DotClass(l)"></span>
                    </div>

                    <div class="lc-identity">
                        <div class="lc-identity-headline">
                            <h1 class="lc-name">@l.Name</h1>
                            @if (l.IsActive)
                            {
                                <StatusBadge Label="@UiStrings.Licenses.Active" Tone="success" />
                            }
                            else
                            {
                                <StatusBadge Label="@UiStrings.Licenses.Inactive" Tone="neutral" />
                            }
                            <span class="lc-info-badge"><RadzenIcon Icon="tag" />@l.Code</span>
                        </div>

                        <div class="lc-meta-row">
                            <RadzenIcon Icon="tag" />
                            <span>@l.Code</span>

                            <RadzenIcon Icon="id_card" />
                            <span>@ShortId(l.Id)</span>
                            <button type="button" class="lc-copy" title="@UiStrings.Users.CopyId"
                                    aria-label="@UiStrings.Users.CopyId" @onclick="@(() => CopyAsync(l.Id.ToString()))">
                                <RadzenIcon Icon="content_copy" />
                            </button>
                        </div>
                    </div>

                    <div class="lc-hero-actions">
                        @if (Auth.HasPermission(MasterDataPermissions.LicensesUpdate))
                        {
                            <RadzenButton Text="@UiStrings.Common.Edit" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                        }
                        @if (HasMoreActions(l))
                        {
                            <RowActionMenu Label="@UiStrings.Common.MoreActions" ShowLabel="true">
                                <RowAction Text="@UiStrings.Licenses.Activate" Icon="check_circle"
                                           Permission="@MasterDataPermissions.LicensesActivate"
                                           Visible="@(!l.IsActive)" OnClick="@ActivateAsync" />
                                <RowAction Text="@UiStrings.Licenses.Deactivate" Icon="cancel" Danger="true"
                                           Permission="@MasterDataPermissions.LicensesDeactivate"
                                           Visible="@l.IsActive" OnClick="@DeactivateAsync" />
                            </RowActionMenu>
                        }
                    </div>
                </div>

                <nav class="lc-tabs" role="tablist">
                    @foreach (var tab in Tabs())
                    {
                        <button type="button" role="tab" class="lc-tab @(activeTab == tab.Key ? "lc-tab--active" : "")"
                                aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                            <RadzenIcon Icon="@tab.Icon" />
                            <span>@tab.Label</span>
                        </button>
                    }
                </nav>
            </section>

            <div class="lc-tab-body" role="tabpanel">
                @(activeTab switch
                {
                    LicenseTab.History => HistoryTab(l),
                    _ => OverviewTab(l)
                })
            </div>
        </div>
    }
</RequirePermission>

@code {
    private RenderFragment OverviewTab(LicenseDetail l) =>@<text>
        <div class="lc-stack">
            <div class="lc-overview-grid">
                <RadzenCard class="lc-card">
                    <div class="lc-card-head"><RadzenIcon Icon="toggle_on" /><h3>@UiStrings.Licenses.Status</h3></div>
                    <div class="lc-lead">
                        <span class="lc-lead-dot lc-lead-dot--@StatusToneColor(l)"></span>
                        <div>
                            <p class="lc-lead-title">@(l.IsActive ? UiStrings.Licenses.Active : UiStrings.Licenses.Inactive)</p>
                            <p class="os-muted lc-lead-desc">@StatusDescription(l)</p>
                        </div>
                    </div>
                    <dl class="lc-metrics">
                        <div class="lc-metric">
                            <dt>@UiStrings.Licenses.Created</dt>
                            <dd>@l.CreatedAtUtc.ToLocalTime().ToString("d")</dd>
                        </div>
                        <div class="lc-metric">
                            <dt>@UiStrings.Licenses.Updated</dt>
                            <dd>@(l.UpdatedAtUtc is { } updated ? updated.ToLocalTime().ToString("g") : UiStrings.Common.None)</dd>
                        </div>
                    </dl>
                </RadzenCard>

                <RadzenCard class="lc-card">
                    <div class="lc-card-head"><RadzenIcon Icon="badge" /><h3>@UiStrings.Common.Details</h3></div>
                    <div class="lc-lead">
                        <span class="lc-lead-icon lc-lead-icon--blue"><RadzenIcon Icon="badge" /></span>
                        <div>
                            <p class="lc-lead-title">@l.Name</p>
                            <p class="os-muted lc-lead-desc">@l.Code</p>
                        </div>
                    </div>
                    <dl class="lc-metrics lc-metrics--tall">
                        <div class="lc-metric">
                            <dt>@UiStrings.Licenses.Code</dt>
                            <dd>@l.Code</dd>
                        </div>
                        <div class="lc-metric">
                            <dt>@UiStrings.Licenses.Name</dt>
                            <dd>@l.Name</dd>
                        </div>
                        <div class="lc-metric">
                            <dt>@UiStrings.Licenses.LicenseDescription</dt>
                            <dd>@(string.IsNullOrWhiteSpace(l.Description) ? UiStrings.Licenses.NoDescription : l.Description)</dd>
                        </div>
                        <div class="lc-metric">
                            <dt>@UiStrings.Licenses.Status</dt>
                            <dd>@(l.IsActive ? UiStrings.Licenses.Active : UiStrings.Licenses.Inactive)</dd>
                        </div>
                    </dl>
                </RadzenCard>
            </div>

            @if (CanViewAudit)
            {
                <RadzenCard class="lc-card">
                    <div class="lc-card-head">
                        <RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3>
                        @if (history.Count > 0)
                        {
                            <button type="button" class="lc-link" @onclick="@(() => activeTab = LicenseTab.History)">@UiStrings.Common.ViewAll</button>
                        }
                    </div>
                    <p class="os-muted">@UiStrings.Audit.Description</p>
                    @HistoryTimeline(OverviewHistoryPreviewCount)
                </RadzenCard>
            }
        </div>
    </text>;

    private RenderFragment HistoryTab(LicenseDetail l) =>@<text>
        <RadzenCard class="lc-card">
            <div class="lc-card-head"><RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3></div>
            <p class="os-muted">@UiStrings.Audit.Description</p>
            @HistoryTimeline()
        </RadzenCard>
    </text>;

    private RenderFragment HistoryTimeline(int? maxItems = null) =>@<text>
        @if (history.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="lc-timeline">
                @foreach (var entry in maxItems is { } take ? history.Take(take) : history)
                {
                    var visual = TimelineVisual(entry.Action);
                    <li class="lc-timeline-row" @key="entry.Id">
                        <span class="lc-timeline-icon lc-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="lc-timeline-content">
                            <p class="lc-timeline-title">@entry.Action</p>
                            <p class="os-muted lc-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="lc-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                        <RadzenButton Text="@UiStrings.Audit.ViewDetails" Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      class="lc-timeline-view" Click="@(() => OpenAuditDetailAsync(entry.Id))" />
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment TimelineEmpty() =>@<text>
        <div class="lc-timeline-empty">
            <span class="lc-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="lc-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted">@UiStrings.Audit.Empty</p>
            </div>
        </div>
    </text>;
}

@code {
    [Parameter] public Guid Id { get; set; }

    private LicenseDetail? item;
    private IReadOnlyList<AuditTrailListItem> history = [];
    private bool isLoading = true;
    private bool loadError;
    private string errorMessage = UiStrings.Errors.LoadFailed;
    private LicenseTab activeTab = LicenseTab.Overview;

    private const int OverviewHistoryPreviewCount = 4;

    private enum LicenseTab { Overview, History }

    private sealed record TabDef(LicenseTab Key, string Label, string Icon);

    private bool CanViewAudit => Auth.HasPermission(AuditPermissions.TrailsView);

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(LicenseTab.Overview, UiStrings.Common.Overview, "dashboard");
        if (CanViewAudit)
            yield return new TabDef(LicenseTab.History, UiStrings.Audit.HistoryTitle, "manage_history");
    }

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        var historyTask = LoadHistoryAsync();

        try
        {
            item = await MasterData.GetLicenseAsync(Id);
            history = await historyTask;
        }
        catch (ApiException ex)
        {
            loadError = true;
            errorMessage = ex.IsNotFound ? UiStrings.Errors.NotFound : ex.ToDisplayMessage(UiStrings.Errors.LoadFailed);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task<IReadOnlyList<OperationsSystem.Blazor.Client.Api.AuditTrailListItem>> LoadHistoryAsync()
    {
        if (!CanViewAudit)
            return [];

        try
        {
            var trails = await AuditApi.GetTrailsAsync(entityType: "License", entityId: Id, pageSize: 25);
            return trails.Items;
        }
        catch (ApiException)
        {
            return [];
        }
    }

    private async Task OpenEditAsync()
    {
        var result = await DialogService.OpenAsync<LicenseFormDialog>(UiStrings.Licenses.EditTitle,
            new Dictionary<string, object?> { [nameof(LicenseFormDialog.LicenseId)] = Id });

        if (result is true)
            await LoadAsync();
    }

    private async Task ActivateAsync()
    {
        if (item is not { } l)
            return;

        await RunAsync((rv, ct) => MasterData.ActivateLicenseAsync(Id, rv, ct), UiStrings.Licenses.Activated, l.RowVersion);
    }

    private async Task DeactivateAsync()
    {
        if (item is not { } l)
            return;

        var confirmed = await DialogService.Confirm(UiStrings.Licenses.ConfirmDeactivate, UiStrings.Licenses.Deactivate,
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;

        if (!confirmed)
            return;

        await RunAsync((rv, ct) => MasterData.DeactivateLicenseAsync(Id, rv, ct), UiStrings.Licenses.Deactivated, l.RowVersion);
    }

    private async Task RunAsync(Func<string, CancellationToken, Task> action, string successMessage, string rowVersion)
    {
        try
        {
            await action(rowVersion, CancellationToken.None);
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private async Task OpenAuditDetailAsync(Guid trailId)
    {
        await DialogService.OpenAsync<AuditTrailDetailDialog>(
            UiStrings.Audit.DetailsTitle,
            new Dictionary<string, object?> { [nameof(AuditTrailDetailDialog.TrailId)] = trailId },
            new DialogOptions { Width = "760px" });
    }

    private bool HasMoreActions(LicenseDetail l) =>
        (!l.IsActive && Auth.HasPermission(MasterDataPermissions.LicensesActivate))
        || (l.IsActive && Auth.HasPermission(MasterDataPermissions.LicensesDeactivate));

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable (e.g. insecure context); fail silently.
        }
    }

    private static string ProfileClass(LicenseDetail l) =>
        l.IsActive ? "lc-profile--active" : "lc-profile--inactive";

    private static string AvatarClass(LicenseDetail l) =>
        l.IsActive ? "lc-avatar--active" : "lc-avatar--inactive";

    private static string DotClass(LicenseDetail l) =>
        l.IsActive ? "lc-avatar-dot--active" : "lc-avatar-dot--inactive";

    private static string StatusToneColor(LicenseDetail l) =>
        l.IsActive ? "success" : "neutral";

    private static string StatusDescription(LicenseDetail l) =>
        l.IsActive ? UiStrings.Licenses.FormIntro : UiStrings.Licenses.ConfirmDeactivate;

    private static string ShortId(Guid id) => "#" + id.ToString("N")[..8].ToUpperInvariant();

    private static string RelativeTime(DateTimeOffset value)
    {
        var delta = DateTimeOffset.UtcNow - value.ToUniversalTime();
        if (delta < TimeSpan.Zero)
            delta = TimeSpan.Zero;

        if (delta.TotalMinutes < 1)
            return UiStrings.Common.JustNow;
        if (delta.TotalHours < 1)
            return string.Format(UiStrings.Common.MinutesAgo, (int)delta.TotalMinutes);
        if (delta.TotalDays < 1)
            return string.Format(UiStrings.Common.HoursAgo, (int)delta.TotalHours);
        if (delta.TotalDays < 30)
            return string.Format(UiStrings.Common.DaysAgo, (int)delta.TotalDays);

        return value.ToLocalTime().ToString("d");
    }

    private static (string Icon, string Tone) TimelineVisual(string action)
    {
        var a = action.ToLowerInvariant();
        if (a.Contains("activ"))
            return ("check_circle", "green");
        if (a.Contains("deactiv"))
            return ("cancel", "red");
        if (a.Contains("delet"))
            return ("delete", "red");
        if (a.Contains("creat"))
            return ("add", "green");
        if (a.Contains("updat") || a.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }
}
