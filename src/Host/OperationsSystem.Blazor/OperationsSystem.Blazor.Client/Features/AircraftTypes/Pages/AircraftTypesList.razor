@page "/master-data/aircraft-types"
@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject GridPreferences GridPrefs

<PageTitle>Aircraft types</PageTitle>

<RequirePermission Permission="@MasterDataPermissions.AircraftTypesView">
    <div class="os-list-page">
        <PageHeader Title="Aircraft types" Description="Manage aircraft manufacturer and model reference data.">
            <Actions>
                <AuthorizeView Context="create">
                    @if (create.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, MasterDataPermissions.AircraftTypesCreate))
                    {
                        <RadzenButton Text="New aircraft type" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@OpenCreateAsync" />
                    }
                </AuthorizeView>
            </Actions>
        </PageHeader>

        <DataListCard @ref="list" TItem="AircraftTypeListItem" Data="@items" Count="@totalCount" IsLoading="@isLoading"
                      HasError="@loadError" OnRetry="@ReloadAsync" LoadData="@LoadDataAsync"
                      PageSize="@currentPageSize" PageSizeChanged="@OnPageSizeChangedAsync"
                      SearchValue="@searchTerm" SearchValueChanged="@(v => searchTerm = v)" OnSearch="@ReloadAsync"
                      SearchPlaceholder="Search by model" CountLabel="aircraft types" EmptyText="No aircraft types match your filters.">
            <Filters>
                <DataListFilter TValue="bool?" Placeholder="All statuses" Data="@statusOptions" Value="@activeFilter" ValueChanged="@OnStatusFilterChangedAsync" />
            </Filters>
            <Columns>
                <RadzenDataGridColumn TItem="AircraftTypeListItem" Property="Model" Title="Model">
                    <Template Context="item">
                        <div class="os-role-cell">
                            <span class="os-role-cell-icon"><RadzenIcon Icon="flight" /></span>
                            <strong>@item.Model</strong>
                        </div>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AircraftTypeListItem" Property="Manufacturer" Title="Manufacturer" />
                <RadzenDataGridColumn TItem="AircraftTypeListItem" Property="Notes" Title="Notes" Sortable="false">
                    <Template Context="item">@(string.IsNullOrWhiteSpace(item.Notes) ? UiStrings.Common.None : item.Notes)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="AircraftTypeListItem" Title="Status" Sortable="false" Width="140px">
                    <Template Context="item">
                        @if (item.IsActive)
                        {
                            <StatusBadge Label="Active" Tone="success" />
                        }
                        else
                        {
                            <StatusBadge Label="Inactive" Tone="neutral" />
                        }
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
            <RowActions Context="item">
                <RowActionMenu>
                    <RowAction Text="@UiStrings.Common.Open" Icon="visibility" OnClick="@(() => Open(item.Id))" />
                    <RowAction Text="@UiStrings.Common.Edit" Icon="edit" Permission="@MasterDataPermissions.AircraftTypesUpdate" OnClick="@(() => OpenEditAsync(item.Id))" />
                    <RowAction Separator="true" />
                    <RowAction Text="Activate" Icon="check_circle" Permission="@MasterDataPermissions.AircraftTypesActivate" Visible="@(!item.IsActive)" OnClick="@(() => ActivateAsync(item.Id))" />
                    <RowAction Text="Deactivate" Icon="cancel" Danger="true" Permission="@MasterDataPermissions.AircraftTypesDeactivate" Visible="@item.IsActive" OnClick="@(() => DeactivateAsync(item.Id))" />
                </RowActionMenu>
            </RowActions>
        </DataListCard>
    </div>
</RequirePermission>

@code {
    private const string GridKey = "aircraft-types";
    private static readonly int[] PageSizes = [10, 25, 50, 100];
    private DataListCard<AircraftTypeListItem>? list;
    private IReadOnlyList<AircraftTypeListItem> items = [];
    private int totalCount;
    private int currentPage = 1;
    private int currentPageSize = 10;
    private bool isLoading;
    private bool loadError;
    private string searchTerm = string.Empty;
    private bool? activeFilter;
    private string? currentSort;
    private readonly List<StatusOption> statusOptions = [new("Active", true), new("Inactive", false)];

    protected override async Task OnInitializedAsync()
    {
        currentPageSize = await GridPrefs.GetPageSizeAsync(GridKey, currentPageSize, PageSizes);
        await FetchAsync();
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        currentPageSize = pageSize;
        await GridPrefs.SetPageSizeAsync(GridKey, pageSize);
    }

    private async Task OnStatusFilterChangedAsync(bool? value)
    {
        activeFilter = value;
        await ReloadAsync();
    }

    private async Task LoadDataAsync(LoadDataArgs args)
    {
        currentPageSize = args.Top ?? currentPageSize;
        currentPage = ((args.Skip ?? 0) / Math.Max(currentPageSize, 1)) + 1;
        currentSort = SortBuilder.From(args);
        await FetchAsync();
    }

    private async Task FetchAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            var result = await MasterData.GetAircraftTypesAsync(currentPage, currentPageSize,
                string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm, activeFilter, currentSort);
            items = result.Items;
            totalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadAsync()
    {
        currentPage = 1;
        if (list is not null)
            await list.ReloadAsync();
        else
            await FetchAsync();
    }

    private async Task OpenCreateAsync()
    {
        var result = await DialogService.OpenAsync<AircraftTypeFormDialog>("Create aircraft type", null, new DialogOptions { Width = "760px" });
        if (result is true)
            await ReloadAsync();
    }

    private void Open(Guid id) => Navigation.NavigateTo($"/master-data/aircraft-types/{id}");

    private async Task OpenEditAsync(Guid id)
    {
        var result = await DialogService.OpenAsync<AircraftTypeFormDialog>("Edit aircraft type",
            new Dictionary<string, object?> { [nameof(AircraftTypeFormDialog.AircraftTypeId)] = id },
            new DialogOptions { Width = "760px" });
        if (result is true)
            await ReloadAsync();
    }

    private Task ActivateAsync(Guid id) => RunAsync(id, (rv, ct) => MasterData.ActivateAircraftTypeAsync(id, rv, ct), "Aircraft type activated.");

    private async Task DeactivateAsync(Guid id)
    {
        var confirmed = await DialogService.Confirm("Deactivate this aircraft type?", "Deactivate",
            new ConfirmOptions { OkButtonText = UiStrings.Common.Yes, CancelButtonText = UiStrings.Common.No }) ?? false;
        if (confirmed)
            await RunAsync(id, (rv, ct) => MasterData.DeactivateAircraftTypeAsync(id, rv, ct), "Aircraft type deactivated.");
    }

    private async Task RunAsync(Guid id, Func<string, CancellationToken, Task> action, string successMessage)
    {
        try
        {
            var detail = await MasterData.GetAircraftTypeAsync(id);
            await action(detail.RowVersion, CancellationToken.None);
            Notifications.Notify(NotificationSeverity.Success, successMessage);
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong));
        }
    }

    private sealed record StatusOption(string Label, bool? Value);
}
