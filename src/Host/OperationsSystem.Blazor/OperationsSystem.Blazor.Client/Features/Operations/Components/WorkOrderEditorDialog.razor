@inject OperationsApiClient Operations
@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<div class="owo-form">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (flight is null)
    {
        <ErrorState Message="Could not load the work order." OnRetry="@LoadAsync" />
    }
    else
    {
        @FlightSummary()

        @if (IsCompletion)
        {
            @WizardStepper()

            <div class="owo-wizard-body">
                @if (step == 0)
                {
                    @CompletionDetailsStep()
                }
                else if (step == 1)
                {
                    @ServiceLinesStep()
                }
                else
                {
                    @TasksStep()
                }
            </div>
        }
        else
        {
            @CancellationDetailsStep()
        }

        @if (validationMessages.Count > 0)
        {
            <div class="owo-error-panel" role="alert">
                <RadzenIcon Icon="error_outline" class="owo-message-icon" />
                <div>
                    <strong>Please fix the following errors before continuing</strong>
                    <ul>
                        @foreach (var message in validationMessages)
                        {
                            <li>@message</li>
                        }
                    </ul>
                </div>
                <button type="button" class="owo-message-close" aria-label="Dismiss validation message" @onclick="DismissValidationMessages">
                    <RadzenIcon Icon="close" />
                </button>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" StateKey="@errorMessage" OnDismiss="@(() => errorMessage = null)">
                @errorMessage
            </DismissibleDialogMessage>
        }

        @DialogActions()
    }
</div>

@code {
    [Parameter] public Guid? FlightId { get; set; }
    [Parameter] public Guid? WorkOrderId { get; set; }
    [Parameter] public string Type { get; set; } = "Completion";
    [Parameter] public bool ViewOnly { get; set; }

    private FlightDetail? flight;
    private WorkOrderDetail? workOrder;
    private WorkOrderFormModel model = new();
    private IReadOnlyList<ServiceOption> serviceOptions = [];
    private IReadOnlyList<AircraftTypeOption> aircraftTypes = [];
    private IReadOnlyList<StaffMemberOption> staffOptions = [];
    private IReadOnlyList<ToolOption> toolOptions = [];
    private IReadOnlyList<MaterialOption> materialOptions = [];
    private IReadOnlyList<GeneralSupportOption> supportOptions = [];
    private bool isLoading = true;
    private bool isSubmitting;
    private bool isAttachmentBusy;
    private string? errorMessage;
    private List<string> validationMessages = [];
    private string? signatureDownloadUrl;
    private int step;

    private readonly IReadOnlyList<SelectOption> taskTypeOptions = [new("Major", "Major"), new("Minor", "Minor")];

    private bool IsCompletion => model.Type == "Completion";
    private bool IsCancellation => model.Type == "Cancellation";
    private int LastStep => IsCompletion ? 2 : 0;
    private string SubmitText => WorkOrderId is null ? "Create" : "Update";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;
        validationMessages = [];
        step = 0;

        try
        {
            if (WorkOrderId is { } workOrderId)
            {
                workOrder = await Operations.GetWorkOrderAsync(workOrderId);
                flight = await Operations.GetFlightAsync(workOrder.FlightId);
                model = FromWorkOrder(workOrder);
                if (!string.IsNullOrWhiteSpace(Type) && !ViewOnly)
                    model.Type = Type;
            }
            else if (FlightId is { } flightId)
            {
                flight = await Operations.GetFlightAsync(flightId);
                model = NewModel(flight, Type);
            }

            if (flight is not null)
                await LoadOptionsAsync(flight.StationId);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not load the work order.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadOptionsAsync(Guid stationId)
    {
        var servicesTask = MasterData.GetServiceOptionsAsync();
        var aircraftTask = MasterData.GetAircraftTypeOptionsAsync();
        var staffTask = MasterData.GetStaffMemberOptionsAsync(stationId);
        var toolsTask = MasterData.GetToolOptionsAsync();
        var materialsTask = MasterData.GetMaterialOptionsAsync();
        var supportsTask = MasterData.GetGeneralSupportOptionsAsync();

        await Task.WhenAll(servicesTask, aircraftTask, staffTask, toolsTask, materialsTask, supportsTask);

        serviceOptions = servicesTask.Result.Where(s => !s.IsAircraftPerLanding).ToList();
        aircraftTypes = aircraftTask.Result;
        staffOptions = staffTask.Result;
        toolOptions = toolsTask.Result;
        materialOptions = materialsTask.Result;
        supportOptions = supportsTask.Result;
    }

    private RenderFragment FlightSummary() => @<div class="owo-summary">
        <div class="owo-summary-icon">
            <RadzenIcon Icon="flight" />
            <span class="owo-summary-dot @StatusDotClass(flight!.Status)"></span>
        </div>
        <div class="owo-summary-main">
            <div class="owo-summary-heading">
                <h2>@DisplayFlightNumber(flight!)</h2>
                <StatusBadge Label="@flight!.Status" Tone="@FlightStatusTone(flight.Status)" />
                <span class="owo-operation-badge"><RadzenIcon Icon="settings" />@flight.OperationTypeName</span>
            </div>
            <div class="owo-summary-meta">
                <span><RadzenIcon Icon="business" />@flight.CustomerName</span>
                <span><RadzenIcon Icon="flight_takeoff" />@flight.StationIata</span>
            </div>
        </div>
    </div>;

    private RenderFragment WizardStepper() => @<div class="owo-stepper" aria-label="Work order steps">
        @for (var i = 0; i <= LastStep; i++)
        {
            var index = i;
            <div class="@StepClass(index)">
                <button type="button" class="owo-step-button" disabled="@(index > step)" @onclick="@(() => MoveToStep(index))">
                    <span class="owo-step-node">
                        @if (index < step)
                        {
                            <RadzenIcon Icon="check" />
                        }
                        else
                        {
                            @(index + 1)
                        }
                    </span>
                    <span class="owo-step-label">@StepLabel(index)</span>
                </button>
            </div>
        }
    </div>;

    private RenderFragment CompletionDetailsStep() => @<section class="owo-step-content">
        <div class="owo-section-line"><RadzenIcon Icon="fact_check" /><span>Details</span></div>
        <div class="owo-grid-1">
            <div class="owo-field-block">
                <label class="owo-label">Flight number <span class="owo-required">*</span></label>
                <div class="owo-input-wrap">
                    <span class="owo-flight-prefix">
                        <span>@CustomerIataPrefix</span>
                        @if (ShowCustomerFlightPrefixDivider)
                        {
                            <span class="owo-flight-prefix-divider">-</span>
                        }
                    </span>
                    <RadzenTextBox @bind-Value="model.ActualFlightNumber" Immediate="true" MaxLength="12"
                                   Disabled="@ViewOnly" class="owo-control owo-control-icon owo-flight-number-control" />
                </div>
            </div>
        </div>
        <div class="owo-grid-2">
            <div class="owo-field-block">
                <label class="owo-label">Aircraft type <span class="owo-required">*</span></label>
                <div class="owo-input-wrap">
                    <span class="owo-field-icon"><RadzenIcon Icon="flight" /></span>
                    <RadzenDropDown TValue="Guid?" @bind-Value="model.AircraftTypeId" Data="@aircraftTypes" TextProperty="Model" ValueProperty="Id"
                                    AllowClear="true" AllowFiltering="true" Disabled="@ViewOnly" class="owo-control owo-control-icon" />
                </div>
            </div>
            <div class="owo-field-block">
                <label class="owo-label">Tail number</label>
                <div class="owo-input-wrap">
                    <span class="owo-field-icon"><RadzenIcon Icon="confirmation_number" /></span>
                    <RadzenTextBox @bind-Value="model.AircraftTailNumber" Immediate="true" MaxLength="20" Disabled="@ViewOnly" class="owo-control owo-control-icon" />
                </div>
            </div>
        </div>
        <div class="owo-grid-2">
            <div class="owo-field-block">
                <label class="owo-label">ATA (UTC) <span class="owo-required">*</span></label>
                <div class="owo-input-wrap">
                    <span class="owo-field-icon"><RadzenIcon Icon="flight_land" /></span>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="model.ActualArrivalUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true"
                                      Disabled="@ViewOnly" class="owo-control owo-control-icon" />
                </div>
            </div>
            <div class="owo-field-block">
                <label class="owo-label">ATD (UTC) <span class="owo-required">*</span></label>
                <div class="owo-input-wrap">
                    <span class="owo-field-icon"><RadzenIcon Icon="flight_takeoff" /></span>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="model.ActualDepartureUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true"
                                      Disabled="@ViewOnly" class="owo-control owo-control-icon" />
                </div>
            </div>
        </div>
        <div class="owo-field-block owo-full">
            <label class="owo-label">Remarks</label>
            <RadzenTextArea @bind-Value="model.Remarks" Rows="4" MaxLength="2000" Disabled="@ViewOnly" class="owo-control" />
        </div>
        @CustomerSignatureSection()
    </section>;

    private RenderFragment CancellationDetailsStep() => @<section class="owo-step-content">
        <div class="owo-section-line"><RadzenIcon Icon="event_busy" /><span>Cancellation</span></div>
        <div class="owo-grid-2">
            <div class="owo-field-block">
                <label class="owo-label">Cancellation date/time (UTC)</label>
                <div class="owo-input-wrap">
                    <span class="owo-field-icon"><RadzenIcon Icon="event_busy" /></span>
                    <RadzenDatePicker TValue="DateTime?" @bind-Value="model.CanceledAtUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true"
                                      Disabled="@ViewOnly" class="owo-control owo-control-icon" />
                </div>
            </div>
            <div class="owo-field-block owo-full">
                <label class="owo-label">Cancellation reason</label>
                <RadzenTextArea @bind-Value="model.CancellationReason" Immediate="true" Rows="4" MaxLength="1000" Disabled="@ViewOnly" class="owo-control" />
            </div>
        </div>
    </section>;

    private RenderFragment ServiceLinesStep() => @<section class="owo-step-content">
        <div class="owo-step-toolbar">
            <div class="owo-section-line"><RadzenIcon Icon="checklist" /><span>Service lines</span></div>
            @if (!ViewOnly)
            {
                <RadzenButton Text="Add line" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              ButtonType="ButtonType.Button" Click="@AddServiceLine" />
            }
        </div>

        @if (model.ServiceLines.Count == 0)
        {
            <div class="owo-empty-row"><RadzenIcon Icon="checklist" />No service lines</div>
        }
        @foreach (var line in model.ServiceLines)
        {
            <div @key="line.Key" class="owo-row-panel">
                <div class="owo-grid-2">
                    <div class="owo-field-block">
                        <label class="owo-label">Service <span class="owo-required">*</span></label>
                        <RadzenDropDown TValue="Guid?" @bind-Value="line.ServiceId" Data="@serviceOptions" TextProperty="Name" ValueProperty="Id"
                                        AllowFiltering="true" Disabled="@ViewOnly" class="owo-control" />
                    </div>
                    <div class="owo-field-block">
                        <label class="owo-label">Performed by <span class="owo-required">*</span></label>
                        <RadzenDropDown TValue="Guid?" @bind-Value="line.PerformedByStaffMemberId" Data="@staffOptions" TextProperty="FullName" ValueProperty="Id"
                                        AllowFiltering="true" Disabled="@ViewOnly" class="owo-control" />
                    </div>
                    <div class="owo-field-block">
                        <label class="owo-label">From (UTC) <span class="owo-required">*</span></label>
                        <RadzenDatePicker TValue="DateTime?" @bind-Value="line.FromUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true"
                                          Disabled="@ViewOnly" class="owo-control" />
                    </div>
                    <div class="owo-field-block">
                        <label class="owo-label">To (UTC) <span class="owo-required">*</span></label>
                        <RadzenDatePicker TValue="DateTime?" @bind-Value="line.ToUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true"
                                          Disabled="@ViewOnly" class="owo-control" />
                    </div>
                </div>
                <div class="owo-row-actions">
                    <RadzenTextBox @bind-Value="line.Description" MaxLength="2000" Placeholder="Description" Disabled="@ViewOnly" class="owo-control" />
                    @if (!ViewOnly)
                    {
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => RemoveServiceLine(line))" />
                    }
                </div>
            </div>
        }
    </section>;

    private RenderFragment TasksStep() => @<section class="owo-step-content">
        <div class="owo-step-toolbar">
            <div class="owo-section-line"><RadzenIcon Icon="task_alt" /><span>Tasks</span></div>
            @if (!ViewOnly)
            {
                <RadzenButton Text="Add task" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                              ButtonType="ButtonType.Button" Click="@AddTask" />
            }
        </div>

        @if (model.Tasks.Count == 0)
        {
            <div class="owo-empty-row"><RadzenIcon Icon="task_alt" />No tasks</div>
        }
        @foreach (var task in model.Tasks)
        {
            <div @key="task.Key" class="owo-row-panel">
                <div class="owo-grid-2">
                    <div class="owo-field-block">
                        <label class="owo-label">Task type <span class="owo-required">*</span></label>
                        <RadzenDropDown @bind-Value="task.TaskType" Data="@taskTypeOptions" TextProperty="Label" ValueProperty="Value"
                                        Disabled="@ViewOnly" class="owo-control" />
                    </div>
                    <div class="owo-field-block">
                        <label class="owo-label">Employees <span class="owo-required">*</span></label>
                        <RadzenDropDown TValue="IEnumerable<Guid>" @bind-Value="task.EmployeeIds" Data="@staffOptions" TextProperty="FullName" ValueProperty="Id"
                                        Multiple="true" AllowFiltering="true" Disabled="@ViewOnly" class="owo-control" />
                    </div>
                    <div class="owo-field-block">
                        <label class="owo-label">From (UTC) <span class="owo-required">*</span></label>
                        <RadzenDatePicker TValue="DateTime?" @bind-Value="task.FromUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true"
                                          Disabled="@ViewOnly" class="owo-control" />
                    </div>
                    <div class="owo-field-block">
                        <label class="owo-label">To (UTC) <span class="owo-required">*</span></label>
                        <RadzenDatePicker TValue="DateTime?" @bind-Value="task.ToUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true"
                                          Disabled="@ViewOnly" class="owo-control" />
                    </div>
                </div>
                <div class="owo-row-actions">
                    <RadzenTextBox @bind-Value="task.Description" MaxLength="2000" Placeholder="Description" Disabled="@ViewOnly" class="owo-control" />
                    @if (!ViewOnly)
                    {
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => RemoveTask(task))" />
                    }
                </div>

                @TaskResourceRows(task)
                @TaskAttachments(task)
            </div>
        }
    </section>;

    private RenderFragment DialogActions() => @<div class="owo-actions">
        <div>
            @if (IsCompletion && step > 0)
            {
                <RadzenButton Text="Previous" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@PreviousStep" />
            }
            else
            {
                <RadzenButton Text="Close" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => DialogService.Close(false))" />
            }
        </div>
        <div class="owo-actions-end">
            @if (IsCompletion && step > 0)
            {
                <RadzenButton Text="Close" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => DialogService.Close(false))" />
            }
            @if (IsCompletion && step < LastStep)
            {
                <RadzenButton Text="Next" Icon="arrow_forward" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@NextAsync" />
            }
            else if (!ViewOnly)
            {
                <RadzenButton Text="@SubmitText" Icon="check" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting"
                              ButtonType="ButtonType.Button" Click="@SubmitAsync" />
            }
        </div>
    </div>;

    private RenderFragment TaskResourceRows(TaskForm task) => @<div class="owo-resource-grid">
        @ResourceBlock("Tools", "build", task.Tools, toolOptions, AddTool, RemoveTool)
        @ResourceBlock("Materials", "category", task.Materials, materialOptions, AddMaterial, RemoveMaterial)
        @ResourceBlock("General support", "headset_mic", task.GeneralSupports, supportOptions, AddSupport, RemoveSupport)
    </div>;

    private RenderFragment CustomerSignatureSection() => @<div class="owo-signature">
        <div class="owo-signature-head">
            <span><RadzenIcon Icon="draw" />Customer signature</span>
            @if (!ViewOnly)
            {
                @if (CanEditSignature)
                {
                    <label class="owo-signature-upload"><RadzenIcon Icon="upload" /><span>@(workOrder?.CustomerSignature is null ? "Upload PNG" : "Replace PNG")</span><InputFile OnChange="@UploadSignatureAsync" accept="image/png" /></label>
                }
                else
                {
                    <span class="owo-attachment-hint">Save the work order before capturing a signature.</span>
                }
            }
        </div>
        @if (workOrder?.CustomerSignature is { } signature)
        {
            <div class="owo-signature-row">
                <span class="owo-attachment-icon"><RadzenIcon Icon="draw" /></span>
                <span class="owo-attachment-main">
                    <strong>@signature.FileName</strong>
                    <small>@FormatFileSize(signature.Size) · @DateDisplay(signature.SignedAtUtc) UTC</small>
                </span>
                @if (!string.IsNullOrWhiteSpace(signatureDownloadUrl))
                {
                    <a class="owo-attachment-link" href="@signatureDownloadUrl" download="@signature.FileName">Open</a>
                }
                <RadzenButton Icon="download" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button"
                              Disabled="@isAttachmentBusy" Click="@DownloadSignatureAsync" />
                @if (!ViewOnly)
                {
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button"
                                  Disabled="@isAttachmentBusy" Click="@DeleteSignatureAsync" />
                }
            </div>
        }
        else
        {
            <div class="owo-attachment-empty">No customer signature</div>
        }
    </div>;

    private RenderFragment TaskAttachments(TaskForm task) => @<div class="owo-attachments">
        <div class="owo-attachments-head">
            <span><RadzenIcon Icon="attach_file" />Attachments</span>
            @if (!ViewOnly)
            {
                @if (CanUploadAttachments(task))
                {
                    <div class="owo-attachment-upload">
                        <label><RadzenIcon Icon="image" /><span>Image</span><InputFile OnChange="@((args) => UploadAttachmentAsync(task, "Image", args))" accept="image/png,image/jpeg,image/webp" /></label>
                        <label><RadzenIcon Icon="graphic_eq" /><span>Voice</span><InputFile OnChange="@((args) => UploadAttachmentAsync(task, "Voice", args))" accept="audio/mp4,audio/m4a,audio/mpeg,audio/mp3,audio/ogg,audio/webm" /></label>
                        <label><RadzenIcon Icon="description" /><span>PDF</span><InputFile OnChange="@((args) => UploadAttachmentAsync(task, "Document", args))" accept="application/pdf" /></label>
                    </div>
                }
                else
                {
                    <span class="owo-attachment-hint">Save the work order before adding files.</span>
                }
            }
        </div>

        @if (task.Attachments.Count == 0)
        {
            <div class="owo-attachment-empty">No attachments</div>
        }
        else
        {
            <div class="owo-attachment-list">
                @foreach (var attachment in task.Attachments)
                {
                    <div @key="attachment.Id" class="owo-attachment-row">
                        <span class="owo-attachment-icon"><RadzenIcon Icon="@AttachmentIcon(attachment.Kind)" /></span>
                        <span class="owo-attachment-main">
                            <strong>@attachment.OriginalFileName</strong>
                            <small>@attachment.Kind · @FormatFileSize(attachment.Size)</small>
                        </span>
                        @if (!string.IsNullOrWhiteSpace(attachment.DownloadUrl))
                        {
                            <a class="owo-attachment-link" href="@attachment.DownloadUrl" download="@attachment.OriginalFileName">Open</a>
                        }
                        <RadzenButton Icon="download" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button"
                                      Disabled="@isAttachmentBusy" Click="@(() => DownloadAttachmentAsync(task, attachment))" />
                        @if (!ViewOnly)
                        {
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button"
                                          Disabled="@isAttachmentBusy" Click="@(() => DeleteAttachmentAsync(task, attachment))" />
                        }
                    </div>
                }
            </div>
        }
    </div>;

    private RenderFragment ResourceBlock<TOption>(
        string title,
        string icon,
        List<ResourceForm> rows,
        IReadOnlyList<TOption> options,
        Action<TaskForm> add,
        Action<TaskForm, ResourceForm> remove) => @<div class="owo-resource-block">
            <div class="owo-resource-head">
                <span><RadzenIcon Icon="@icon" />@title</span>
                @if (!ViewOnly)
                {
                    <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  ButtonType="ButtonType.Button" Click="@(() => add(CurrentTaskFor(rows)))" />
                }
            </div>
            @foreach (var row in rows)
            {
                <div @key="row.Key" class="owo-resource-row">
                    <RadzenDropDown TValue="Guid?" @bind-Value="row.ItemId" Data="@options" TextProperty="Name" ValueProperty="Id"
                                    AllowFiltering="true" Disabled="@ViewOnly" class="owo-control" />
                    <RadzenNumeric @bind-Value="row.Quantity" Min="0.01m" Step="0.25m" Disabled="@ViewOnly" class="owo-qty" />
                    @if (!ViewOnly)
                    {
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      ButtonType="ButtonType.Button" Click="@(() => remove(CurrentTaskFor(rows), row))" />
                    }
                </div>
            }
            @if (rows.Count == 0)
            {
                <div class="owo-resource-empty">@NoResourceText(title)</div>
            }
        </div>;

    private TaskForm CurrentTaskFor(List<ResourceForm> rows) => model.Tasks.First(t => ReferenceEquals(t.Tools, rows) || ReferenceEquals(t.Materials, rows) || ReferenceEquals(t.GeneralSupports, rows));

    private void AddServiceLine() => model.ServiceLines.Add(new ServiceLineForm { FromUtc = DateTime.UtcNow, ToUtc = DateTime.UtcNow.AddHours(1) });
    private void RemoveServiceLine(ServiceLineForm line) => model.ServiceLines.Remove(line);

    private void AddTask() => model.Tasks.Add(new TaskForm { FromUtc = DateTime.UtcNow, ToUtc = DateTime.UtcNow.AddHours(1) });
    private void RemoveTask(TaskForm task) => model.Tasks.Remove(task);

    private static void AddTool(TaskForm task) => task.Tools.Add(new ResourceForm());
    private static void RemoveTool(TaskForm task, ResourceForm row) => task.Tools.Remove(row);
    private static void AddMaterial(TaskForm task) => task.Materials.Add(new ResourceForm());
    private static void RemoveMaterial(TaskForm task, ResourceForm row) => task.Materials.Remove(row);
    private static void AddSupport(TaskForm task) => task.GeneralSupports.Add(new ResourceForm());
    private static void RemoveSupport(TaskForm task, ResourceForm row) => task.GeneralSupports.Remove(row);

    private bool CanUploadAttachments(TaskForm task) =>
        WorkOrderId is not null && workOrder is not null && task.Id is not null && workOrder.Status is "Submitted" or "Returned";

    private bool CanEditSignature =>
        WorkOrderId is not null && workOrder is not null && workOrder.Status is "Submitted" or "Returned" && workOrder.Type == "Completion";

    private async Task UploadSignatureAsync(InputFileChangeEventArgs args)
    {
        if (WorkOrderId is not { } workOrderId || workOrder is null)
        {
            errorMessage = "Save the work order before capturing a signature.";
            return;
        }

        var file = args.File;
        if (file.ContentType != "image/png" && !file.Name.EndsWith(".png", StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "Customer signature must be a PNG image.";
            return;
        }
        if (file.Size > 2 * 1024 * 1024)
        {
            errorMessage = "Customer signature must be at most 2 MB.";
            return;
        }

        isAttachmentBusy = true;
        errorMessage = null;
        try
        {
            await using var stream = file.OpenReadStream(2 * 1024 * 1024);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            await Operations.UploadWorkOrderSignatureAsync(workOrderId, memory.ToArray(), file.Name, file.ContentType, workOrder.RowVersion);
            signatureDownloadUrl = null;
            await ReloadWorkOrderAsync(workOrderId);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not upload the customer signature.");
        }
        finally
        {
            isAttachmentBusy = false;
        }
    }

    private async Task DownloadSignatureAsync()
    {
        if (WorkOrderId is not { } workOrderId)
            return;

        isAttachmentBusy = true;
        errorMessage = null;
        try
        {
            var file = await Operations.DownloadWorkOrderSignatureAsync(workOrderId);
            signatureDownloadUrl = $"data:{file.ContentType};base64,{file.Base64}";
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not download the customer signature.");
        }
        finally
        {
            isAttachmentBusy = false;
        }
    }

    private async Task DeleteSignatureAsync()
    {
        if (WorkOrderId is not { } workOrderId || workOrder is null)
            return;

        isAttachmentBusy = true;
        errorMessage = null;
        try
        {
            await Operations.DeleteWorkOrderSignatureAsync(workOrderId, workOrder.RowVersion);
            signatureDownloadUrl = null;
            await ReloadWorkOrderAsync(workOrderId);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not delete the customer signature.");
        }
        finally
        {
            isAttachmentBusy = false;
        }
    }

    private async Task UploadAttachmentAsync(TaskForm task, string kind, InputFileChangeEventArgs args)
    {
        if (WorkOrderId is not { } workOrderId || workOrder is null || task.Id is not { } taskId)
        {
            errorMessage = "Save the work order before adding files.";
            return;
        }

        var file = args.File;
        var maxBytes = MaxAttachmentBytes(kind);
        if (file.Size > maxBytes)
        {
            errorMessage = $"{kind} attachments must be at most {FormatFileSize(maxBytes)}.";
            return;
        }

        isAttachmentBusy = true;
        errorMessage = null;
        try
        {
            await using var stream = file.OpenReadStream(maxBytes);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            await Operations.UploadWorkOrderAttachmentAsync(workOrderId, taskId, kind, memory.ToArray(), file.Name, file.ContentType, workOrder.RowVersion);
            await ReloadWorkOrderAsync(workOrderId);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not upload the attachment.");
        }
        finally
        {
            isAttachmentBusy = false;
        }
    }

    private async Task DownloadAttachmentAsync(TaskForm task, AttachmentForm attachment)
    {
        if (WorkOrderId is not { } workOrderId || task.Id is not { } taskId)
            return;

        isAttachmentBusy = true;
        errorMessage = null;
        try
        {
            var file = await Operations.DownloadWorkOrderAttachmentAsync(workOrderId, taskId, attachment.Id);
            attachment.DownloadUrl = $"data:{file.ContentType};base64,{file.Base64}";
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not download the attachment.");
        }
        finally
        {
            isAttachmentBusy = false;
        }
    }

    private async Task DeleteAttachmentAsync(TaskForm task, AttachmentForm attachment)
    {
        if (WorkOrderId is not { } workOrderId || workOrder is null || task.Id is not { } taskId)
