@inject OperationsApiClient Operations
@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="WorkOrderEditModel" Data="@model" Submit="@SubmitAsync">
    <div class="owe-form">
        @if (isLoading)
        {
            <LoadingCard />
        }
        else if (workOrder is null)
        {
            <ErrorState Message="Could not load the work order." OnRetry="@LoadAsync" />
        }
        else
        {
            <div class="owe-summary">
                <div>
                    <p class="os-eyebrow">@workOrder.Type work order</p>
                    <h2>@workOrder.FlightNumber</h2>
                    <p class="os-muted">@workOrder.CustomerName · @workOrder.StationIata</p>
                </div>
                <StatusBadge Label="@workOrder.Status" Tone="@StatusTone(workOrder.Status)" />
            </div>

            @WizardStepper()

            <div class="owe-wizard-body">
                @if (step == 0)
                {
                    @ActualsStep()
                }
                else if (step == 1)
                {
                    @ServiceLinesStep()
                }
                else
                {
                    @TasksStep()
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" StateKey="@errorMessage"
                                          OnDismiss="@(() => errorMessage = null)">
                    @errorMessage
                </DismissibleDialogMessage>
            }

            <div class="owe-actions">
                @if (step == 0)
                {
                    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => DialogService.Close(false))" />
                }
                else
                {
                    <RadzenButton Text="Previous" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@Previous" />
                }
                <div class="owe-actions-end">
                    @if (step > 0)
                    {
                        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => DialogService.Close(false))" />
                    }
                    @if (step < LastStep)
                    {
                        <RadzenButton Text="Next" Icon="arrow_forward" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@NextAsync" />
                    }
                    else
                    {
                        <RadzenButton ButtonType="ButtonType.Submit" Text="Save work order" Icon="check" ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
                    }
                </div>
            </div>
        }
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid WorkOrderId { get; set; }

    private WorkOrderDetail? workOrder;
    private WorkOrderEditModel model = new();
    private IReadOnlyList<ServiceOption> services = [];
    private IReadOnlyList<AircraftTypeOption> aircraftTypes = [];
    private IReadOnlyList<StaffMemberOption> staff = [];
    private IReadOnlyList<ToolOption> tools = [];
    private IReadOnlyList<MaterialOption> materials = [];
    private IReadOnlyList<GeneralSupportOption> generalSupports = [];
    private readonly WorkOrderServiceLineOriginModel[] serviceOrigins = Enum.GetValues<WorkOrderServiceLineOriginModel>();
    private readonly WorkOrderTaskTypeModel[] taskTypes = Enum.GetValues<WorkOrderTaskTypeModel>();
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private int step;
    private const int LastStep = 2;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            workOrder = await Operations.GetWorkOrderAsync(WorkOrderId);
            var servicesTask = MasterData.GetServiceOptionsAsync();
            var aircraftTypesTask = MasterData.GetAircraftTypeOptionsAsync();
            var staffTask = MasterData.GetStaffMemberOptionsAsync();
            var toolsTask = MasterData.GetToolOptionsAsync();
            var materialsTask = MasterData.GetMaterialOptionsAsync();
            var generalSupportsTask = MasterData.GetGeneralSupportOptionsAsync();

            await Task.WhenAll(servicesTask, aircraftTypesTask, staffTask, toolsTask, materialsTask, generalSupportsTask);

            services = await servicesTask;
            aircraftTypes = await aircraftTypesTask;
            staff = await staffTask;
            tools = await toolsTask;
            materials = await materialsTask;
            generalSupports = await generalSupportsTask;
            model = FromDetail(workOrder);
        }
        catch (ApiException ex)
        {
            // A 403 after the work order itself loaded means the reference lookups were denied.
            errorMessage = ex.IsForbidden && workOrder is not null
                ? UiStrings.Errors.ReferenceLookupsForbidden
                : ex.ToDisplayMessage("Could not load the work order.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private RenderFragment WizardStepper() => @<div class="owe-stepper" aria-label="Work order steps">
        @for (var i = 0; i <= LastStep; i++)
        {
            var index = i;
            <div class="@StepClass(index)">
                <button type="button" class="owe-step-button" disabled="@(index > step)" @onclick="@(() => MoveToStep(index))">
                    <span class="owe-step-node">
                        @if (index < step)
                        {
                            <RadzenIcon Icon="check" />
                        }
                        else
                        {
                            @((index + 1).ToString())
                        }
                    </span>
                    <span class="owe-step-label">@StepLabel(index)</span>
                </button>
            </div>
        }
    </div>;

    private RenderFragment ActualsStep() => @<section class="owe-step-content">
        <div class="owe-section-line"><RadzenIcon Icon="schedule" /><span>Actuals</span></div>

        <div class="owe-grid-2">
            <div class="owe-field-block">
                <label class="owe-label">Actual flight #</label>
                <div class="owe-input-wrap">
                    <RadzenIcon Icon="tag" class="owe-field-icon" />
                    <RadzenTextBox @bind-Value="model.ActualFlightNumber" MaxLength="12" class="owe-control owe-control-icon" />
                </div>
            </div>
            <div class="owe-field-block">
                <label class="owe-label">Actual aircraft type</label>
                <div class="owe-input-wrap">
                    <RadzenIcon Icon="airplanemode_active" class="owe-field-icon" />
                    <RadzenDropDown @bind-Value="model.ActualAircraftTypeId" Data="@aircraftTypes" TextProperty="Model" ValueProperty="Id"
                                    AllowClear="true" AllowFiltering="true" class="owe-control owe-control-icon" Placeholder="Aircraft type" />
                </div>
            </div>
        </div>

        <div class="owe-grid-2">
            <div class="owe-field-block">
                <label class="owe-label">Actual arrival (UTC)</label>
                <div class="owe-input-wrap">
                    <RadzenIcon Icon="flight_land" class="owe-field-icon" />
                    <RadzenDatePicker @bind-Value="model.ActualArrivalUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="owe-control owe-control-icon" />
                </div>
            </div>
            <div class="owe-field-block">
                <label class="owe-label">Actual departure (UTC)</label>
                <div class="owe-input-wrap">
                    <RadzenIcon Icon="flight_takeoff" class="owe-field-icon" />
                    <RadzenDatePicker @bind-Value="model.ActualDepartureUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="owe-control owe-control-icon" />
                </div>
            </div>
        </div>

        <div class="owe-grid-2">
            <div class="owe-field-block">
                <label class="owe-label">Aircraft tail</label>
                <div class="owe-input-wrap">
                    <RadzenIcon Icon="airplane_ticket" class="owe-field-icon" />
                    <RadzenTextBox @bind-Value="model.AircraftTailNumber" MaxLength="30" class="owe-control owe-control-icon" />
                </div>
            </div>
            <div class="owe-field-block">
                <label class="owe-label">Signature reference</label>
                <div class="owe-input-wrap">
                    <RadzenIcon Icon="draw" class="owe-field-icon" />
                    <RadzenTextBox @bind-Value="model.CustomerSignatureReference" MaxLength="500" class="owe-control owe-control-icon" />
                </div>
            </div>
        </div>

        <div class="owe-field-block">
            <label class="owe-label">Remarks</label>
            <RadzenTextArea @bind-Value="model.Remarks" Rows="3" MaxLength="2000" class="owe-control" />
        </div>
    </section>;

    private RenderFragment ServiceLinesStep() => @<section class="owe-step-content">
        <div class="owe-section-head">
            <div class="owe-section-line"><RadzenIcon Icon="settings" /><span>Service lines</span></div>
            <RadzenButton Text="Add service" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button" Click="@AddServiceLine" />
        </div>

        @if (model.ServiceLines.Count == 0)
        {
            <div class="owe-empty">No service lines have been added.</div>
        }
        else
        {
            <div class="owe-row-list">
                @foreach (var line in model.ServiceLines)
                {
                    <section @key="line.Key" class="owe-row-card">
                        <div class="owe-row-head">
                            <strong>Service line</strong>
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                          ButtonType="ButtonType.Button" Click="@(() => RemoveServiceLine(line))" />
                        </div>
                        <div class="owe-grid-2">
                            <RadzenDropDown @bind-Value="line.ServiceId" Data="@services" TextProperty="Name" ValueProperty="Id"
                                            AllowFiltering="true" class="owe-control" Placeholder="Service" />
                            <RadzenDropDown @bind-Value="line.Origin" Data="@serviceOrigins" class="owe-control" />
                        </div>
                        <div class="owe-grid-2">
                            <RadzenDatePicker @bind-Value="line.FromUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="owe-control" />
                            <RadzenDatePicker @bind-Value="line.ToUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="owe-control" />
                        </div>
                        <RadzenTextBox @bind-Value="line.Description" MaxLength="500" class="owe-control" Placeholder="Description" />
                        <div class="owe-inline-check">
                            <RadzenCheckBox @bind-Value="line.ReturnToRamp" Name="@($"line-ramp-{line.Key}")" />
                            <RadzenLabel Text="Return to ramp" Component="@($"line-ramp-{line.Key}")" />
                        </div>
                        @EmployeePicker(line.EmployeeIds)
                    </section>
                }
            </div>
        }
    </section>;

    private RenderFragment TasksStep() => @<section class="owe-step-content">
        <div class="owe-section-head">
            <div class="owe-section-line"><RadzenIcon Icon="checklist" /><span>Tasks</span></div>
            <RadzenButton Text="Add task" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button" Click="@AddTask" />
        </div>

        @if (model.Tasks.Count == 0)
        {
            <div class="owe-empty">No task rows have been added.</div>
        }
        else
        {
            <div class="owe-row-list">
                @foreach (var task in model.Tasks)
                {
                    <section @key="task.Key" class="owe-row-card">
                        <div class="owe-row-head">
                            <strong>@task.TaskType task</strong>
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                                          ButtonType="ButtonType.Button" Click="@(() => RemoveTask(task))" />
                        </div>
                        <div class="owe-grid-2">
                            <RadzenDropDown @bind-Value="task.TaskType" Data="@taskTypes" class="owe-control" />
                            <RadzenTextBox @bind-Value="task.Description" MaxLength="1000" class="owe-control" Placeholder="Task description" />
                        </div>
                        <div class="owe-grid-2">
                            <RadzenDatePicker @bind-Value="task.FromUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="owe-control" />
                            <RadzenDatePicker @bind-Value="task.ToUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="owe-control" />
                        </div>
                        <div class="owe-inline-check">
                            <RadzenCheckBox @bind-Value="task.ReturnToRamp" Name="@($"task-ramp-{task.Key}")" />
                            <RadzenLabel Text="Return to ramp" Component="@($"task-ramp-{task.Key}")" />
                        </div>
                        @EmployeePicker(task.EmployeeIds)
                        @ResourceEditor("Tools", task.Tools, tools, "build")
                        @ResourceEditor("Materials", task.Materials, materials, "category")
                        @ResourceEditor("General support", task.GeneralSupports, generalSupports, "headset_mic")
                    </section>
                }
            </div>
        }
    </section>;

    private RenderFragment EmployeePicker(HashSet<Guid> selected) => @<div class="owe-employee-picker">
        <span class="owe-sub-label">Employees</span>
        <div class="owe-chip-list">
            @foreach (var member in staff)
            {
                <button type="button" @key="member.Id" class="@ChipClass(selected.Contains(member.Id))"
                        @onclick="@(() => Toggle(selected, member.Id))">
                    <RadzenIcon Icon="person" />
                    <span>@member.FullName</span>
                </button>
            }
        </div>
    </div>;

    private RenderFragment ResourceEditor<TOption>(string title, List<ResourceEditRow> rows, IReadOnlyList<TOption> options, string icon)
        where TOption : notnull => @<div class="owe-resource-editor">
        <div class="owe-resource-title">
            <span><RadzenIcon Icon="@icon" /> @title</span>
            <RadzenButton Text="Add" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          ButtonType="ButtonType.Button" Click="@(() => rows.Add(new ResourceEditRow()))" />
        </div>
        @foreach (var row in rows)
        {
            <div @key="row.Key" class="owe-resource-row">
                <RadzenDropDown @bind-Value="row.Id" Data="@options" TextProperty="Name" ValueProperty="Id"
                                AllowFiltering="true" class="owe-control" Placeholder="@title" />
                <RadzenNumeric @bind-Value="row.Quantity" Min="0.01m" Step="0.25m" class="owe-qty" />
                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text" Size="ButtonSize.Small"
                              ButtonType="ButtonType.Button" Click="@(() => rows.Remove(row))" />
            </div>
        }
    </div>;

    private static string ChipClass(bool selected) => selected ? "owe-chip owe-chip-selected" : "owe-chip";

    private static void Toggle(HashSet<Guid> set, Guid id)
    {
        if (!set.Add(id))
            set.Remove(id);
    }

    private void AddServiceLine()
    {
        var from = model.ActualArrivalUtc ?? workOrder?.ScheduledArrivalUtc.UtcDateTime ?? DateTime.UtcNow;
        var to = model.ActualDepartureUtc ?? workOrder?.ScheduledDepartureUtc.UtcDateTime ?? from.AddHours(1);
        model.ServiceLines.Add(new ServiceLineEditRow { FromUtc = from, ToUtc = to });
    }

    private void AddTask()
    {
        var from = model.ActualArrivalUtc ?? workOrder?.ScheduledArrivalUtc.UtcDateTime ?? DateTime.UtcNow;
        var to = model.ActualDepartureUtc ?? workOrder?.ScheduledDepartureUtc.UtcDateTime ?? from.AddMinutes(30);
        model.Tasks.Add(new TaskEditRow { FromUtc = from, ToUtc = to });
    }

    private void RemoveServiceLine(ServiceLineEditRow row) => model.ServiceLines.Remove(row);

    private void RemoveTask(TaskEditRow row) => model.Tasks.Remove(row);

    private static string StepLabel(int index) => index switch
    {
        0 => "Actuals",
        1 => "Services",
        _ => "Tasks"
    };

    private string StepClass(int index)
    {
        var state = index < step ? "complete" : index == step ? "active" : "pending";
        return $"owe-step owe-step-{state}";
    }

    private void MoveToStep(int index)
    {
        if (index > step)
            return;

        errorMessage = null;
        step = index;
    }

    private void Previous()
    {
        errorMessage = null;
        step = Math.Max(0, step - 1);
    }

    private Task NextAsync()
    {
        errorMessage = step switch
        {
            0 => ValidateActuals(),
            1 => ValidateServiceLines(),
            _ => null
        };

        if (errorMessage is null)
            step = Math.Min(LastStep, step + 1);

        return Task.CompletedTask;
    }

    private async Task SubmitAsync()
    {
        errorMessage = Validate();
        if (errorMessage is not null || workOrder is null)
            return;

        isSubmitting = true;
        try
        {
            await Operations.UpdateWorkOrderAsync(WorkOrderId, new UpdateWorkOrderRequestModel(
                model.ServiceLines.Select(ToRequest).ToList(),
                model.Tasks.Select(ToRequest).ToList(),
                TrimToNull(model.ActualFlightNumber),
                model.ActualAircraftTypeId,
                model.ActualArrivalUtc is null ? null : ToUtc(model.ActualArrivalUtc.Value),
                model.ActualDepartureUtc is null ? null : ToUtc(model.ActualDepartureUtc.Value),
                TrimToNull(model.AircraftTailNumber),
                TrimToNull(model.Remarks),
                TrimToNull(model.CustomerSignatureReference)),
                workOrder.RowVersion);

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not save the work order.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private string? Validate()
    {
        return ValidateActuals() ?? ValidateServiceLines() ?? ValidateTasks();
    }

    private string? ValidateActuals()
    {
        if (model.ActualArrivalUtc is not null && model.ActualDepartureUtc is not null && model.ActualDepartureUtc <= model.ActualArrivalUtc)
            return "Actual departure must be after actual arrival.";

        return null;
    }

    private string? ValidateServiceLines()
    {
        foreach (var line in model.ServiceLines)
        {
            if (line.ServiceId == Guid.Empty)
                return "Every service line must have a service.";
            if (line.FromUtc is null || line.ToUtc is null || line.ToUtc <= line.FromUtc)
                return "Every service line must have a valid time window.";
        }

        return null;
    }

    private string? ValidateTasks()
    {
        foreach (var task in model.Tasks)
        {
            if (task.FromUtc is null || task.ToUtc is null || task.ToUtc <= task.FromUtc)
                return "Every task must have a valid time window.";
            if (task.Tools.Concat(task.Materials).Concat(task.GeneralSupports).Any(r => r.Id == Guid.Empty || r.Quantity <= 0))
                return "Every resource row must have a resource and quantity above zero.";
        }

        return null;
    }

    private static string StatusTone(string status) => status switch
    {
        "Approved" => "success",
        "Submitted" => "warning",
        "Draft" => "neutral",
        _ => "neutral"
    };

    private static WorkOrderEditModel FromDetail(WorkOrderDetail detail) => new()
    {
        ActualFlightNumber = detail.FlightNumber,
        ActualAircraftTypeId = detail.AircraftTypeId,
        ActualArrivalUtc = detail.ActualArrivalUtc?.UtcDateTime,
        ActualDepartureUtc = detail.ActualDepartureUtc?.UtcDateTime,
        AircraftTailNumber = detail.AircraftTailNumber,
        Remarks = detail.Remarks,
        CustomerSignatureReference = detail.CustomerSignatureReference,
        ServiceLines = detail.ServiceLines.Select(line => new ServiceLineEditRow
        {
            ServiceId = line.ServiceId,
            Origin = Enum.TryParse<WorkOrderServiceLineOriginModel>(line.Origin, out var origin) ? origin : WorkOrderServiceLineOriginModel.Planned,
            FromUtc = line.FromUtc.UtcDateTime,
            ToUtc = line.ToUtc.UtcDateTime,
            Description = line.Description,
            ReturnToRamp = line.ReturnToRamp,
            EmployeeIds = line.Employees.Select(x => x.StaffMemberId).ToHashSet()
        }).ToList(),
        Tasks = detail.Tasks.Select(task => new TaskEditRow
        {
            TaskType = Enum.TryParse<WorkOrderTaskTypeModel>(task.TaskType, out var taskType) ? taskType : WorkOrderTaskTypeModel.Minor,
            Description = task.Description,
            FromUtc = task.FromUtc.UtcDateTime,
            ToUtc = task.ToUtc.UtcDateTime,
            ReturnToRamp = task.ReturnToRamp,
            EmployeeIds = task.Employees.Select(x => x.StaffMemberId).ToHashSet(),
            Tools = task.Tools.Select(ToResourceRow).ToList(),
            Materials = task.Materials.Select(ToResourceRow).ToList(),
            GeneralSupports = task.GeneralSupports.Select(ToResourceRow).ToList()
        }).ToList()
    };

    private static ResourceEditRow ToResourceRow(WorkOrderResourceModel resource) => new()
    {
        Id = resource.Id,
        Quantity = resource.Quantity
    };

    private static ServiceLineRequestModel ToRequest(ServiceLineEditRow row) => new(
        row.ServiceId,
        row.Origin,
        ToUtc(row.FromUtc!.Value),
        ToUtc(row.ToUtc!.Value),
        TrimToNull(row.Description),
        row.ReturnToRamp,
        row.EmployeeIds.ToList());

    private static TaskRequestModel ToRequest(TaskEditRow row) => new(
        row.TaskType,
        TrimToNull(row.Description),
        ToUtc(row.FromUtc!.Value),
        ToUtc(row.ToUtc!.Value),
        row.ReturnToRamp,
        row.EmployeeIds.ToList(),
        row.Tools.Select(ToRequest).ToList(),
        row.Materials.Select(ToRequest).ToList(),
        row.GeneralSupports.Select(ToRequest).ToList(),
        []);

    private static ResourceUsageRequestModel ToRequest(ResourceEditRow row) => new(row.Id, row.Quantity);

    private static DateTimeOffset ToUtc(DateTime value)
    {
        var utc = value.Kind == DateTimeKind.Utc ? value : DateTime.SpecifyKind(value, DateTimeKind.Utc);
        return new DateTimeOffset(utc);
    }

    private static string? TrimToNull(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class WorkOrderEditModel
    {
        public string? ActualFlightNumber { get; set; }
        public Guid? ActualAircraftTypeId { get; set; }
        public DateTime? ActualArrivalUtc { get; set; }
        public DateTime? ActualDepartureUtc { get; set; }
        public string? AircraftTailNumber { get; set; }
        public string? Remarks { get; set; }
        public string? CustomerSignatureReference { get; set; }
        public List<ServiceLineEditRow> ServiceLines { get; set; } = [];
        public List<TaskEditRow> Tasks { get; set; } = [];
    }

    private sealed class ServiceLineEditRow
    {
        public Guid Key { get; } = Guid.NewGuid();
        public Guid ServiceId { get; set; }
        public WorkOrderServiceLineOriginModel Origin { get; set; } = WorkOrderServiceLineOriginModel.Planned;
        public DateTime? FromUtc { get; set; }
        public DateTime? ToUtc { get; set; }
        public string? Description { get; set; }
        public bool ReturnToRamp { get; set; }
        public HashSet<Guid> EmployeeIds { get; set; } = [];
    }

    private sealed class TaskEditRow
    {
        public Guid Key { get; } = Guid.NewGuid();
        public WorkOrderTaskTypeModel TaskType { get; set; } = WorkOrderTaskTypeModel.Minor;
        public string? Description { get; set; }
        public DateTime? FromUtc { get; set; }
        public DateTime? ToUtc { get; set; }
        public bool ReturnToRamp { get; set; }
        public HashSet<Guid> EmployeeIds { get; set; } = [];
        public List<ResourceEditRow> Tools { get; set; } = [];
        public List<ResourceEditRow> Materials { get; set; } = [];
        public List<ResourceEditRow> GeneralSupports { get; set; } = [];
    }

    private sealed class ResourceEditRow
    {
        public Guid Key { get; } = Guid.NewGuid();
        public Guid Id { get; set; }
        public decimal Quantity { get; set; } = 1;
    }
}
