    }

    private async Task ReloadWorkOrderAsync(Guid workOrderId)
    {
        workOrder = await Operations.GetWorkOrderAsync(workOrderId);
        model = FromWorkOrder(workOrder);
    }

    private void PreviousStep()
    {
        errorMessage = null;
        validationMessages = [];
        step = Math.Max(0, step - 1);
    }

    private Task NextAsync()
    {
        if (!IsCompletion || step >= LastStep)
            return Task.CompletedTask;

        var validation = ValidateCurrentStep();
        if (validation.Count > 0)
        {
            validationMessages = validation;
            errorMessage = null;
            return Task.CompletedTask;
        }

        validationMessages = [];
        errorMessage = null;
        step++;
        return Task.CompletedTask;
    }

    private void MoveToStep(int index)
    {
        if (index < 0 || index > LastStep || index > step)
            return;

        errorMessage = null;
        validationMessages = [];
        step = index;
    }

    private async Task SubmitAsync()
    {
        if (flight is null)
            return;

        var validation = Validate();
        if (validation.Count > 0)
        {
            validationMessages = validation;
            errorMessage = null;
            return;
        }

        isSubmitting = true;
        validationMessages = [];
        errorMessage = null;
        try
        {
            var request = BuildRequest();
            if (WorkOrderId is { } workOrderId && workOrder is not null)
                await Operations.UpdateWorkOrderAsync(workOrderId, request, workOrder.RowVersion);
            else
                await Operations.SubmitWorkOrderAsync(flight.Id, request);

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not save the work order.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void DismissValidationMessages() => validationMessages = [];

    private List<string> ValidateCurrentStep()
    {
        if (!IsCompletion)
            return [];

        return step switch
        {
            0 => ValidateDetailsStep(),
            1 => ValidateServiceLinesStep(),
            _ => ValidateTasksStep()
        };
    }

    private List<string> Validate()
    {
        if (IsCancellation)
        {
            var cancellationMessages = new List<string>();
            if (IsMissing(model.CanceledAtUtc))
                cancellationMessages.Add("Cancellation work orders require a cancellation time.");
            if (string.IsNullOrWhiteSpace(model.CancellationReason))
                cancellationMessages.Add("Cancellation work orders require a reason.");
            return cancellationMessages;
        }

        var messages = ValidateDetailsStep();
        messages.AddRange(ValidateServiceLinesStep());
        messages.AddRange(ValidateTasksStep());
        return messages;
    }

    private List<string> ValidateDetailsStep()
    {
        var messages = new List<string>();
        if (string.IsNullOrWhiteSpace(model.ActualFlightNumber))
            messages.Add("Flight number is required.");
        else if (model.ActualFlightNumber.Trim().Length > 12)
            messages.Add("Flight number must be at most 12 characters.");
        if (model.AircraftTypeId is null)
            messages.Add("Aircraft type is required.");
        if (!string.IsNullOrWhiteSpace(model.AircraftTailNumber) && model.AircraftTailNumber.Trim().Length > 20)
            messages.Add("Tail number must be at most 20 characters.");
        if (IsMissing(model.ActualArrivalUtc))
            messages.Add("ATA is required.");
        if (IsMissing(model.ActualDepartureUtc))
            messages.Add("ATD is required.");
        if (!IsMissing(model.ActualArrivalUtc) && !IsMissing(model.ActualDepartureUtc) && model.ActualDepartureUtc < model.ActualArrivalUtc)
            messages.Add("ATD cannot be before ATA.");
        return messages;
    }

    private List<string> ValidateServiceLinesStep()
    {
        var messages = new List<string>();
        if (model.ServiceLines.Any(l => l.ServiceId is null || l.PerformedByStaffMemberId is null || IsMissing(l.FromUtc) || IsMissing(l.ToUtc)))
            messages.Add("Every service line needs a service, performer, From, and To time.");
        if (model.ServiceLines.Any(l => !IsMissing(l.FromUtc) && !IsMissing(l.ToUtc) && l.ToUtc < l.FromUtc))
            messages.Add("Service line To time cannot be before From time.");
        return messages;
    }

    private List<string> ValidateTasksStep()
    {
        var messages = new List<string>();
        if (model.Tasks.Any(t => string.IsNullOrWhiteSpace(t.TaskType)))
            messages.Add("Every task needs a task type.");
        if (model.Tasks.Any(t => t.EmployeeIds is null || !t.EmployeeIds.Any()))
            messages.Add("Every task needs at least one employee.");
        if (model.Tasks.Any(t => IsMissing(t.FromUtc) || IsMissing(t.ToUtc)))
            messages.Add("Every task needs a From and To time.");
        if (model.Tasks.Any(t => !IsMissing(t.FromUtc) && !IsMissing(t.ToUtc) && t.ToUtc < t.FromUtc))
            messages.Add("Task To time cannot be before From time.");

        AddResourceValidation(messages, model.Tasks.SelectMany(t => t.Tools), "tool");
        AddResourceValidation(messages, model.Tasks.SelectMany(t => t.Materials), "material");
        AddResourceValidation(messages, model.Tasks.SelectMany(t => t.GeneralSupports), "general support");
        return messages;
    }

    private static void AddResourceValidation(List<string> messages, IEnumerable<ResourceForm> rows, string label)
    {
        var list = rows.ToList();
        if (list.Any(r => r.ItemId is null))
            messages.Add($"Every {label} row needs an item.");
        if (list.Any(r => r.Quantity <= 0))
            messages.Add($"{ToTitle(label)} quantities must be greater than zero.");
    }

    private static bool IsMissing(DateTime? value) => value is null || value.Value == default;

    private static string ToTitle(string value) =>
        string.IsNullOrWhiteSpace(value) ? value : char.ToUpperInvariant(value[0]) + value[1..];

    private static string NoResourceText(string title) => $"No {title.ToLowerInvariant()} added";

    private WorkOrderRequestModel BuildRequest()
    {
        var completion = IsCompletion;
        var cancellation = IsCancellation;

        return new WorkOrderRequestModel(
            model.Type,
            model.ActualFlightNumber,
            completion ? model.AircraftTypeId : null,
            completion ? model.AircraftTailNumber : null,
            completion ? ToOffset(model.ActualArrivalUtc) : null,
            completion ? ToOffset(model.ActualDepartureUtc) : null,
            cancellation ? ToOffset(model.CanceledAtUtc) : null,
            cancellation ? model.CancellationReason : null,
            completion ? model.Remarks : null,
            completion
                ? model.ServiceLines.Select(l => new WorkOrderServiceLineRequestModel(
                    l.ServiceId!.Value,
                    l.PerformedByStaffMemberId!.Value,
                    ToOffset(l.FromUtc)!.Value,
                    ToOffset(l.ToUtc)!.Value,
                    l.Description)).ToList()
                : [],
            completion
                ? model.Tasks.Select(t => new WorkOrderTaskRequestModel(
                    t.Id,
                    t.TaskType,
                    t.Description,
                    ToOffset(t.FromUtc)!.Value,
                    ToOffset(t.ToUtc)!.Value,
                    t.EmployeeIds.ToList(),
                    t.Tools.Where(r => r.ItemId.HasValue).Select(r => new WorkOrderTaskToolRequestModel(r.ItemId!.Value, r.Quantity)).ToList(),
                    t.Materials.Where(r => r.ItemId.HasValue).Select(r => new WorkOrderTaskMaterialRequestModel(r.ItemId!.Value, r.Quantity)).ToList(),
                    t.GeneralSupports.Where(r => r.ItemId.HasValue).Select(r => new WorkOrderTaskGeneralSupportRequestModel(r.ItemId!.Value, r.Quantity)).ToList())).ToList()
                : []);
    }

    private string StepClass(int index) =>
        index == step ? "owo-step owo-step-active" : index < step ? "owo-step owo-step-complete" : "owo-step";

    private static string StepLabel(int index) => index switch
    {
        0 => "Details",
        1 => "Service lines",
        _ => "Tasks"
    };

    private static DateTimeOffset? ToOffset(DateTime? value) =>
        value is null ? null : new DateTimeOffset(DateTime.SpecifyKind(value.Value, DateTimeKind.Utc));

    private static WorkOrderFormModel NewModel(FlightDetail flight, string type) => new()
    {
        Type = string.IsNullOrWhiteSpace(type) ? "Completion" : type,
        ActualFlightNumber = flight.FlightNumber,
        AircraftTypeId = flight.AircraftTypeId,
        ActualArrivalUtc = flight.ScheduledArrivalUtc.UtcDateTime,
        ActualDepartureUtc = flight.ScheduledDepartureUtc.UtcDateTime,
        CanceledAtUtc = flight.ScheduledArrivalUtc.UtcDateTime
    };

    private static WorkOrderFormModel FromWorkOrder(WorkOrderDetail workOrder) => new()
    {
        Type = workOrder.Type,
        ActualFlightNumber = workOrder.ActualFlightNumber,
        AircraftTypeId = workOrder.AircraftTypeId,
        AircraftTailNumber = workOrder.AircraftTailNumber,
        ActualArrivalUtc = workOrder.ActualArrivalUtc?.UtcDateTime,
        ActualDepartureUtc = workOrder.ActualDepartureUtc?.UtcDateTime,
        CanceledAtUtc = workOrder.CanceledAtUtc?.UtcDateTime,
        CancellationReason = workOrder.CancellationReason,
        Remarks = workOrder.Remarks,
        ServiceLines = workOrder.ServiceLines.Select(l => new ServiceLineForm
        {
            Id = l.Id,
            ServiceId = l.ServiceId,
            PerformedByStaffMemberId = l.PerformedByStaffMemberId,
            FromUtc = l.FromUtc.UtcDateTime,
            ToUtc = l.ToUtc.UtcDateTime,
            Description = l.Description
        }).ToList(),
        Tasks = workOrder.Tasks.Select(t => new TaskForm
        {
            Id = t.Id,
            TaskType = t.TaskType,
            Description = t.Description,
            FromUtc = t.FromUtc.UtcDateTime,
            ToUtc = t.ToUtc.UtcDateTime,
            EmployeeIds = t.Employees.Select(e => e.StaffMemberId).ToList(),
            Tools = t.Tools.Select(x => new ResourceForm { ItemId = x.ToolId, Quantity = x.Quantity }).ToList(),
            Materials = t.Materials.Select(x => new ResourceForm { ItemId = x.MaterialId, Quantity = x.Quantity }).ToList(),
            GeneralSupports = t.GeneralSupports.Select(x => new ResourceForm { ItemId = x.GeneralSupportId, Quantity = x.Quantity }).ToList(),
            Attachments = t.Attachments.Select(a => new AttachmentForm
            {
                Id = a.Id,
                Kind = a.Kind,
                OriginalFileName = a.OriginalFileName,
                ContentType = a.ContentType,
                Size = a.Size
            }).ToList()
        }).ToList()
    };

    private bool HasCustomerIataPrefix =>
        !string.IsNullOrWhiteSpace(flight?.CustomerIataCode);

    private bool ShowCustomerFlightPrefixDivider =>
        flight is not null;

    private string CustomerIataPrefix =>
        flight is null
            ? "-"
            : HasCustomerIataPrefix
                ? flight.CustomerIataCode!.Trim().ToUpperInvariant()
                : "N/A";

    private static string DisplayFlightNumber(FlightDetail f) =>
        string.IsNullOrWhiteSpace(f.CustomerIataCode) ? f.FlightNumber : $"{f.CustomerIataCode.Trim().ToUpperInvariant()}-{f.FlightNumber}";

    private static string DateDisplay(DateTimeOffset value) => value.UtcDateTime.ToString("yyyy-MM-dd HH:mm");

    private static long MaxAttachmentBytes(string kind) => kind switch
    {
        "Image" => 10 * 1024 * 1024,
        "Voice" => 25 * 1024 * 1024,
        _ => 20 * 1024 * 1024
    };

    private static string FormatFileSize(long bytes)
    {
        if (bytes >= 1024 * 1024)
            return $"{bytes / 1024m / 1024m:0.#} MB";
        if (bytes >= 1024)
            return $"{bytes / 1024m:0.#} KB";
        return $"{bytes} B";
    }

    private static string AttachmentIcon(string kind) => kind switch
    {
        "Image" => "image",
        "Voice" => "graphic_eq",
        "Document" => "description",
        _ => "attach_file"
    };

    private static string FlightStatusTone(string status) => status switch
    {
        "Completed" => "success",
        "Canceled" or "Merged" => "danger",
        "InProgress" => "warning",
        _ => "neutral"
    };

    private static string StatusDotClass(string status) => status switch
    {
        "InProgress" => "owo-summary-dot--warning",
        "Completed" => "owo-summary-dot--success",
        "Canceled" or "Merged" => "owo-summary-dot--danger",
        _ => "owo-summary-dot--active"
    };

