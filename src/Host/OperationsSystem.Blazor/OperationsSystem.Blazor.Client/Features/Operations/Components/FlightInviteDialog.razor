@inject OperationsApiClient Operations
@inject DialogService DialogService

<div class="ofi-form">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (flight is null)
    {
        <ErrorState Message="Could not load the flight." OnRetry="@LoadAsync" />
    }
    else
    {
        <div class="ofi-summary">
            <div class="ofi-summary-icon">
                <RadzenIcon Icon="flight" />
                <span class="ofi-summary-dot @StatusDotClass(flight.Status)"></span>
            </div>
            <div class="ofi-summary-main">
                <div class="ofi-summary-heading">
                    <h2>@DisplayFlightNumber(flight)</h2>
                    <StatusBadge Label="@flight.Status" Tone="@FlightStatusTone(flight.Status)" />
                    <span class="ofi-operation-badge"><RadzenIcon Icon="settings" />@flight.OperationTypeName</span>
                </div>
                <div class="ofi-summary-meta">
                    <span><RadzenIcon Icon="business" />@flight.CustomerName</span>
                    <span><RadzenIcon Icon="flight_takeoff" />@flight.StationIata</span>
                </div>
            </div>
        </div>

        <div class="ofi-section-line"><RadzenIcon Icon="groups" /><span>Eligible employees</span></div>

        var filteredStaff = FilteredStaff().ToList();
        var assignedStaff = flight.AssignedEmployees;

        <div class="ofi-step-toolbar">
            <div class="ofi-search-box">
                <span class="ofi-search-icon"><RadzenIcon Icon="search" /></span>
                <input type="search" value="@searchTerm" @oninput="@OnSearchInput" placeholder="Search staff" aria-label="Search staff" disabled="@(eligibleStaff.Count == 0)" />
                @if (!string.IsNullOrWhiteSpace(searchTerm))
                {
                    <button type="button" class="ofi-search-clear" title="Clear search" aria-label="Clear search" @onclick="@ClearSearch">
                        <RadzenIcon Icon="close" />
                    </button>
                }
            </div>
            <div class="ofi-toolbar-actions">
                <RadzenButton Text="@SelectAllStaffText" Icon="@SelectAllStaffIcon" ButtonStyle="ButtonStyle.Light"
                              Size="ButtonSize.Small" ButtonType="ButtonType.Button" Click="@ToggleAllStaff"
                              Disabled="@(eligibleStaff.Count == 0)" />
                <span class="ofi-selection-count">@SelectedCountText</span>
            </div>
        </div>

        <div class="ofi-staff-layout">
            <div class="ofi-selection-panel ofi-selection-panel-scroll" aria-label="Eligible employees">
                @if (filteredStaff.Count == 0)
                {
                    <div class="ofi-empty-row">
                        <RadzenIcon Icon="@(eligibleStaff.Count == 0 ? "groups" : "search_off")" />
                        @(eligibleStaff.Count == 0 ? "No employees available to invite." : "No employees match your search.")
                    </div>
                }
                else
                {
                    <div class="ofi-chip-list">
                        @foreach (var member in filteredStaff)
                        {
                            <button type="button" @key="member.StaffMemberId" class="@ChipClass(selectedStaffIds.Contains(member.StaffMemberId))"
                                    @onclick="@(() => Toggle(member.StaffMemberId))">
                                <RadzenIcon Icon="person" />
                                <span>@member.FullName</span>
                                <small>@flight.StationIata</small>
                            </button>
                        }
                    </div>
                }
            </div>

            <aside class="ofi-assigned-panel" aria-label="Already assigned employees">
                <div class="ofi-assigned-head">
                    <span><RadzenIcon Icon="person_check" />Already assigned</span>
                    <small>@assignedStaff.Count</small>
                </div>
                @if (assignedStaff.Count == 0)
                {
                    <div class="ofi-assigned-empty">No one assigned yet.</div>
                }
                else
                {
                    <div class="ofi-assigned-list">
                        @foreach (var member in assignedStaff)
                        {
                            <div class="ofi-assigned-item" @key="member.StaffMemberId">
                                <RadzenIcon Icon="person" />
                                <span>@member.FullName</span>
                            </div>
                        }
                    </div>
                }
            </aside>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" StateKey="@errorMessage"
                                      OnDismiss="@(() => errorMessage = null)">
                @errorMessage
            </DismissibleDialogMessage>
        }

        <div class="ofi-actions">
            <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton Text="Invite" Icon="person_add" ButtonStyle="ButtonStyle.Primary"
                          Disabled="@(isSubmitting || selectedStaffIds.Count == 0)"
                          Click="@SubmitAsync" />
        </div>
    }
</div>

@code {
    [Parameter] public Guid FlightId { get; set; }

    private FlightDetail? flight;
    private IReadOnlyList<AssignedEmployeeModel> eligibleStaff = [];
    private readonly HashSet<Guid> selectedStaffIds = [];
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private string searchTerm = string.Empty;

    private bool AllEligibleStaffSelected
    {
        get
        {
            var ids = eligibleStaff.Select(member => member.StaffMemberId).ToList();
            return ids.Count > 0 && ids.All(selectedStaffIds.Contains);
        }
    }

    private string SelectAllStaffText => AllEligibleStaffSelected ? "Clear all" : "Select all";
    private string SelectAllStaffIcon => AllEligibleStaffSelected ? "clear_all" : "select_all";
    private string SelectedCountText => selectedStaffIds.Count == 1 ? "1 selected" : $"{selectedStaffIds.Count} selected";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;
        selectedStaffIds.Clear();

        try
        {
            flight = await Operations.GetFlightAsync(FlightId);
            if (flight.IsPerLanding)
            {
                errorMessage = "Per Landing flights cannot have assigned staff because they are available station-wide.";
                eligibleStaff = [];
                return;
            }

            eligibleStaff = await Operations.GetFlightInviteOptionsAsync(flight.Id);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not load eligible employees.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private IEnumerable<AssignedEmployeeModel> FilteredStaff()
    {
        if (string.IsNullOrWhiteSpace(searchTerm))
            return eligibleStaff;

        var term = searchTerm.Trim();
        return eligibleStaff.Where(member =>
            member.FullName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
            member.EmployeeId.Contains(term, StringComparison.OrdinalIgnoreCase));
    }

    private void Toggle(Guid id)
    {
        if (!selectedStaffIds.Add(id))
            selectedStaffIds.Remove(id);
    }

    private void ToggleAllStaff()
    {
        var ids = eligibleStaff.Select(member => member.StaffMemberId).ToList();
        if (ids.Count == 0)
            return;

        if (ids.All(selectedStaffIds.Contains))
        {
            selectedStaffIds.ExceptWith(ids);
            return;
        }

        foreach (var id in ids)
            selectedStaffIds.Add(id);
    }

    private void OnSearchInput(ChangeEventArgs args) => searchTerm = args.Value?.ToString() ?? string.Empty;

    private void ClearSearch() => searchTerm = string.Empty;

    private async Task SubmitAsync()
    {
        if (flight is null || selectedStaffIds.Count == 0)
            return;

        isSubmitting = true;
        errorMessage = null;
        try
        {
            await Operations.InviteEmployeesAsync(
                flight.Id,
                new AssignEmployeesRequestModel(selectedStaffIds.ToList()),
                flight.RowVersion);
            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not invite the selected employees.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private static string DisplayFlightNumber(FlightDetail flight)
    {
        if (string.IsNullOrWhiteSpace(flight.CustomerIataCode))
            return flight.FlightNumber;

        return $"{flight.CustomerIataCode.Trim().ToUpperInvariant()}-{flight.FlightNumber}";
    }

    private static string FlightStatusTone(string status) => status switch
    {
        "InProgress" => "warning",
        "Completed" => "success",
        "Canceled" or "Merged" => "danger",
        _ => "neutral"
    };

    private static string StatusDotClass(string status) => status switch
    {
        "InProgress" => "ofi-summary-dot--warning",
        "Completed" => "ofi-summary-dot--success",
        "Canceled" or "Merged" => "ofi-summary-dot--danger",
        _ => "ofi-summary-dot--active"
    };

    private static string ChipClass(bool selected) => selected ? "ofi-chip ofi-chip-selected" : "ofi-chip";
}
