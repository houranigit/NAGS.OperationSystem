@inject OperationsApiClient Operations
@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="FlightFormModel" Data="@model" Submit="@SubmitAsync">
    <div class="opf-form">
        @if (isLoading)
        {
            <LoadingCard />
        }
        else
        {
            @WizardStepper()

            <div class="opf-wizard-body">
                @(step switch
                {
                    0 => IsBulkCreate ? BulkFlightDetailsStep() : FlightDetailsStep(),
                    1 => IsBulkCreate ? CalendarStep() : ServicesStep(),
                    2 => IsBulkCreate ? ServicesStep() : StaffStep(),
                    _ => StaffStep()
                })
            </div>

            @if (HasCurrentDuplicateCheck && duplicates.Count > 0)
            {
                <div class="opf-warning-panel" role="status">
                    <RadzenIcon Icon="warning_amber" class="opf-message-icon" />
                    <div>
                        <strong>Potential duplicates found.</strong>
                        <div class="opf-duplicates">
                            @foreach (var duplicate in duplicates)
                            {
                                <a @key="duplicate.FlightId" class="opf-duplicate-link" href="@FlightUrl(duplicate.FlightId)" target="_blank" rel="noopener noreferrer">
                                    @duplicate.FlightNumber · @duplicate.CustomerName · @duplicate.StationIata
                                </a>
                            }
                        </div>
                    </div>
                    <button type="button" class="opf-message-close" aria-label="Dismiss duplicate message" @onclick="DismissDuplicateMessage">
                        <RadzenIcon Icon="close" />
                    </button>
                </div>
            }
            else if (HasCurrentDuplicateCheck)
            {
                <div class="opf-success-panel" role="status">
                    <RadzenIcon Icon="task_alt" class="opf-message-icon" />
                    <div>
                        <strong>No duplicates found.</strong>
                        <p>No other flight matches this customer, station, scheduled arrival, and scheduled departure.</p>
                    </div>
                    <button type="button" class="opf-message-close" aria-label="Dismiss duplicate message" @onclick="DismissDuplicateMessage">
                        <RadzenIcon Icon="close" />
                    </button>
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="opf-error-panel" role="alert">
                    <RadzenIcon Icon="error_outline" class="opf-message-icon" />
                    <div>
                        <strong>Please fix the following errors before continuing</strong>
                        <ul>
                            <li>@errorMessage</li>
                        </ul>
                    </div>
                    <button type="button" class="opf-message-close" aria-label="Dismiss validation message" @onclick="DismissErrorMessage">
                        <RadzenIcon Icon="close" />
                    </button>
                </div>
            }

            <div class="opf-actions">
                @if (step == 0)
                {
                    <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                }
                else
                {
                    <RadzenButton Text="Previous" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@Previous" />
                }
                <div class="opf-actions-end">
                    @if (step > 0)
                    {
                        <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => DialogService.Close(false))" />
                    }
                    @if (step < LastStep)
                    {
                        <RadzenButton Text="Next" Icon="arrow_forward" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button" Click="@NextAsync" />
                    }
                    else
                    {
                        <RadzenButton ButtonType="ButtonType.Submit" Icon="check" Text="@SubmitButtonText"
                                      ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
                    }
                </div>
            </div>
        }
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid? FlightId { get; set; }
    [Parameter] public bool BulkMode { get; set; }

    private FlightFormModel model = new();
    private IReadOnlyList<CustomerOption> customers = [];
    private IReadOnlyList<StationOption> stations = [];
    private IReadOnlyList<OperationTypeOption> operationTypes = [];
    private IReadOnlyList<AircraftTypeOption> aircraftTypes = [];
    private IReadOnlyList<ServiceOption> services = [];
    private IReadOnlyList<StaffMemberListItem> staff = [];
    private IReadOnlyList<DuplicateCandidate> duplicates = [];
    private FlightDetail? original;
    private string? rowVersion;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;
    private int step;
    private string serviceSearchTerm = string.Empty;
    private string staffSearchTerm = string.Empty;
    private string? duplicateCheckSignature;
    private Guid? staffLoadedForStationId;

    private static readonly IReadOnlyList<WeekdayOption> WeekdayOptions =
    [
        new(DayOfWeek.Monday, "Mon"),
        new(DayOfWeek.Tuesday, "Tue"),
        new(DayOfWeek.Wednesday, "Wed"),
        new(DayOfWeek.Thursday, "Thu"),
        new(DayOfWeek.Friday, "Fri"),
        new(DayOfWeek.Saturday, "Sat"),
        new(DayOfWeek.Sunday, "Sun")
    ];

    private bool IsBulkCreate => BulkMode && FlightId is null;
    private int LastStep => IsBulkCreate ? 3 : 2;
    private string SubmitButtonText => FlightId is null
        ? (IsBulkCreate ? "Schedule flights" : "Schedule flight")
        : "Save changes";

    private RenderFragment WizardStepper() => @<div class="@($"opf-stepper opf-stepper-{LastStep + 1}")" aria-label="Schedule flight steps">
        @for (var i = 0; i <= LastStep; i++)
        {
            var index = i;
            <div class="@StepClass(index)">
                <button type="button" class="opf-step-button" disabled="@(index > step)" @onclick="@(() => MoveToStep(index))">
                    <span class="opf-step-node">
                        @if (index < step)
                        {
                            <RadzenIcon Icon="check" />
                        }
                        else
                        {
                            @((index + 1).ToString())
                        }
                    </span>
                    <span class="opf-step-label">@StepLabel(index)</span>
                </button>
            </div>
        }
    </div>;

    private RenderFragment CustomerFlightNumberFields(string flightNumberName) => @<text>
        <div class="opf-grid-2">
            <div class="opf-field-block">
                <label class="opf-label">Customer <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="business" class="opf-field-icon" />
                    <RadzenDropDown @bind-Value="model.CustomerId" Data="@customers" TextProperty="Name" ValueProperty="Id"
                                    AllowFiltering="true" class="opf-control opf-control-icon" Placeholder="Select customer" />
                </div>
            </div>
            <div class="opf-field-block">
                <label class="opf-label">Flight number <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <span class="opf-flight-prefix">
                        <span>@CustomerIataPrefix</span>
                        @if (ShowCustomerFlightPrefixDivider)
                        {
                            <span class="opf-flight-prefix-divider">-</span>
                        }
                    </span>
                    <RadzenTextBox @bind-Value="model.FlightNumber" Name="@flightNumberName" MaxLength="12"
                                   class="opf-control opf-control-icon opf-flight-number-control" Placeholder="e.g. NGS104" />
                </div>
            </div>
        </div>
    </text>;

    private RenderFragment StationOperationFields() => @<text>
        <div class="opf-grid-2">
            <div class="opf-field-block">
                <label class="opf-label">Station <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="flight_takeoff" class="opf-field-icon" />
                    <RadzenDropDown @bind-Value="model.StationId" Data="@stations" TextProperty="IataCode" ValueProperty="Id"
                                    AllowFiltering="true" class="opf-control opf-control-icon" Placeholder="Select station" />
                </div>
            </div>
            <div class="opf-field-block">
                <label class="opf-label">Operation type <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="settings" class="opf-field-icon" />
                    <RadzenDropDown @bind-Value="model.OperationTypeId" Data="@operationTypes" TextProperty="Name" ValueProperty="Id"
                                    AllowFiltering="true" class="opf-control opf-control-icon" Placeholder="Select operation" />
                </div>
            </div>
        </div>
    </text>;

    private RenderFragment AircraftTypeField() => @<div class="opf-field-block">
        <label class="opf-label">Aircraft type</label>
        <div class="opf-input-wrap">
            <RadzenIcon Icon="flight" class="opf-field-icon" />
            <RadzenDropDown @bind-Value="model.AircraftTypeId" Data="@aircraftTypes" TextProperty="Model" ValueProperty="Id"
                            AllowClear="true" AllowFiltering="true" class="opf-control opf-control-icon" Placeholder="Optional aircraft type" />
        </div>
    </div>;

    private RenderFragment FlightDetailsStep() => @<section class="opf-step-content">
        <div class="opf-section-line"><RadzenIcon Icon="flight_takeoff" /><span>Flight details</span></div>

        @CustomerFlightNumberFields("flightNumber")
        @StationOperationFields()
        <div class="opf-grid-2">
            <div class="opf-field-block">
                <label class="opf-label">Scheduled arrival (UTC) <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="flight_land" class="opf-field-icon" />
                    <RadzenDatePicker @bind-Value="model.ScheduledArrivalUtc" DateFormat="yyyy-MM-dd HH:mm"
                                      ShowTime="true" class="opf-control opf-control-icon" />
                </div>
            </div>
            <div class="opf-field-block">
                <label class="opf-label">Scheduled departure (UTC) <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="flight_takeoff" class="opf-field-icon" />
                    <RadzenDatePicker @bind-Value="model.ScheduledDepartureUtc" DateFormat="yyyy-MM-dd HH:mm"
                                      ShowTime="true" class="opf-control opf-control-icon" />
                </div>
            </div>
        </div>

        @AircraftTypeField()
        <div class="opf-details-actions">
            <RadzenButton Text="Check duplicates" Icon="manage_search" ButtonStyle="ButtonStyle.Secondary"
                          ButtonType="ButtonType.Button" Click="@CheckDuplicatesAsync" Disabled="@isSubmitting" />
        </div>
    </section>;

    private RenderFragment BulkFlightDetailsStep() => @<section class="opf-step-content">
        <div class="opf-section-line"><RadzenIcon Icon="flight_takeoff" /><span>Flight details</span></div>

        @CustomerFlightNumberFields("bulkFlightNumber")
        @StationOperationFields()
        <div class="opf-grid-2">
            <div class="opf-field-block">
                <label class="opf-label">Period start date <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="event" class="opf-field-icon" />
                    <RadzenDatePicker @bind-Value="model.PeriodStartDate" DateFormat="yyyy-MM-dd" ShowTime="false"
                                      class="opf-control opf-control-icon" />
                </div>
            </div>
            <div class="opf-field-block">
                <label class="opf-label">Period end date <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="event_available" class="opf-field-icon" />
                    <RadzenDatePicker @bind-Value="model.PeriodEndDate" DateFormat="yyyy-MM-dd" ShowTime="false"
                                      class="opf-control opf-control-icon" />
                </div>
            </div>
        </div>

        <div class="opf-grid-2">
            <div class="opf-field-block">
                <label class="opf-label">STA time (UTC) <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="schedule" class="opf-field-icon" />
                    <RadzenDatePicker @bind-Value="model.ScheduledArrivalTimeUtc" DateFormat="HH:mm" ShowTime="true"
                                      ShowSeconds="false" class="opf-control opf-control-icon" />
                </div>
            </div>
            <div class="opf-field-block">
                <label class="opf-label">STD time (UTC) <span class="opf-required">*</span></label>
                <div class="opf-input-wrap">
                    <RadzenIcon Icon="schedule" class="opf-field-icon" />
                    <RadzenDatePicker @bind-Value="model.ScheduledDepartureTimeUtc" DateFormat="HH:mm" ShowTime="true"
                                      ShowSeconds="false" class="opf-control opf-control-icon" />
                </div>
            </div>
        </div>

        @AircraftTypeField()
        <div class="opf-field-block">
            <label class="opf-label">Weekdays <span class="opf-required">*</span></label>
            <div class="opf-weekday-list">
                @foreach (var option in WeekdayOptions)
                {
                    <label @key="option.Day" class="@WeekdayClass(option.Day)">
                        <RadzenCheckBox TValue="bool" Value="@model.Weekdays.Contains(option.Day)"
                                        Change="@(value => SetWeekday(option.Day, value))" />
                        <span>@option.Label</span>
                    </label>
                }
            </div>
        </div>
    </section>;

    private RenderFragment CalendarStep() => @<section class="opf-step-content">
        <div class="opf-section-line"><RadzenIcon Icon="calendar_month" /><span>Calendar</span></div>
        <div class="opf-step-toolbar">
            <span class="opf-selection-count">@model.SelectedScheduleDates.Count selected</span>
            <RadzenButton Text="Reset weekdays" Icon="restart_alt" ButtonStyle="ButtonStyle.Light"
                          Size="ButtonSize.Small" ButtonType="ButtonType.Button"
                          Click="@ResetSelectedDatesFromWeekdays" Disabled="@(!CanSeedSelectedDates)" />
        </div>
        <div class="opf-selection-panel">
            <ScheduleFlightCalendarStep PeriodStartDate="@BulkPeriodStartDate"
                                        PeriodEndDate="@BulkPeriodEndDate"
                                        SelectedDates="@SelectedScheduleDates"
                                        DateToggled="@ToggleScheduleDate" />
        </div>
    </section>;

    private RenderFragment ServicesStep() => @<section class="opf-step-content">
        <div class="opf-section-line"><RadzenIcon Icon="settings" /><span>Planned services</span></div>
        <div class="opf-step-toolbar">
            @SearchBox(serviceSearchTerm, "Search services", OnServiceSearchInput, ClearServiceSearch)
            <span class="opf-selection-count">@model.PlannedServiceIds.Count selected</span>
        </div>
        <div class="opf-selection-panel">
            @if (!FilteredServices().Any())
            {
                <div class="opf-empty-row">
                    <RadzenIcon Icon="search_off" />
                    <span>No services match your search.</span>
                </div>
            }
            else
            {
                <div class="opf-chip-list">
                    @foreach (var service in FilteredServices())
                    {
                        <button type="button" @key="service.Id" class="@ChipClass(model.PlannedServiceIds.Contains(service.Id))"
                                @onclick="@(() => TogglePlannedService(service))">
                            <RadzenIcon Icon="task_alt" />
                            <span>@service.Name</span>
                        </button>
                    }
                </div>
            }
        </div>
    </section>;

    private RenderFragment StaffStep() => @<section class="opf-step-content">
        <div class="opf-section-line"><RadzenIcon Icon="groups" /><span>Assigned staff</span></div>
        @if (IsPerLandingSelected)
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Info" Title="Per landing flight">
                <p>This flight is per landing and does not need staff assignment because all station staff can reach the flight.</p>
            </DismissibleDialogMessage>
        }
        else
        {
            <div class="opf-step-toolbar">
                @SearchBox(staffSearchTerm, "Search staff", OnStaffSearchInput, ClearStaffSearch)
                <div class="opf-toolbar-actions">
                    <RadzenButton Text="@SelectAllStaffText" Icon="@SelectAllStaffIcon" ButtonStyle="ButtonStyle.Light"
                                  Size="ButtonSize.Small" ButtonType="ButtonType.Button" Click="@ToggleAllStaff"
                                  Disabled="@(!HasAvailableStaff)" />
                    <span class="opf-selection-count">@model.AssignedStaffMemberIds.Count selected</span>
                </div>
            </div>
            @if (staff.Count == 0)
            {
                <div class="opf-empty-row">
                    <RadzenIcon Icon="group_add" />
                    <span>No active staff members are available for this station.</span>
                </div>
            }
            else
            {
                <div class="opf-selection-panel opf-selection-panel-scroll">
                    @if (!FilteredStaff().Any())
                    {
                        <div class="opf-empty-row">
                            <RadzenIcon Icon="search_off" />
                            <span>No staff members match your search.</span>
                        </div>
                    }
                    else
                    {
                        <div class="opf-chip-list opf-chip-list-staff">
                            @foreach (var member in FilteredStaff())
                            {
                                <button type="button" @key="member.Id" class="@ChipClass(model.AssignedStaffMemberIds.Contains(member.Id))"
                                        @onclick="@(() => ToggleStaff(member))">
                                    <RadzenIcon Icon="person" />
                                    <span>@member.FullName</span>
                                    <small>@member.StationCode</small>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        }
    </section>;

    private RenderFragment SearchBox(string value, string placeholder, Action<ChangeEventArgs> onInput, Action onClear) => @<div class="opf-search-box">
        <span class="opf-search-icon"><RadzenIcon Icon="search" /></span>
        <input type="search" value="@value" @oninput="@onInput" placeholder="@placeholder" aria-label="@placeholder" />
        @if (!string.IsNullOrWhiteSpace(value))
        {
            <button type="button" class="opf-search-clear" aria-label="Clear search" @onclick="@onClear">
                <RadzenIcon Icon="close" />
            </button>
        }
    </div>;

    private string StepLabel(int index) => index switch
    {
        0 => "Details",
        1 => IsBulkCreate ? "Calendar" : "Services",
        2 => IsBulkCreate ? "Services" : "Staff",
        _ => "Staff"
    };

    private string StepClass(int index)
    {
        var state = index < step ? "complete" : index == step ? "active" : "pending";
        return $"opf-step opf-step-{state}";
    }

    private void MoveToStep(int index)
    {
        if (index > step)
            return;

        errorMessage = null;
        step = index;
    }

    private void Previous()
    {
        errorMessage = null;
        step = Math.Max(0, step - 1);
    }

    private async Task NextAsync()
    {
        errorMessage = step switch
        {
            0 => ValidateDetails(),
            1 when IsBulkCreate => ValidateCalendar(),
            1 => ValidateServices(),
            2 when IsBulkCreate => ValidateServices(),
            _ => null
        };

        if (errorMessage is not null)
            return;

        if (step == 0)
        {
            await LoadStaffForSelectedStationAsync();
            if (errorMessage is not null)
                return;
        }

        if (IsBulkCreate && step == 0)
            SeedSelectedDatesFromWeekdaysIfNeeded();

        step = Math.Min(LastStep, step + 1);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var customersTask = MasterData.GetCustomerOptionsAsync();
            var stationsTask = MasterData.GetStationOptionsAsync();
            var operationTypesTask = MasterData.GetOperationTypeOptionsAsync();
            var aircraftTypesTask = MasterData.GetAircraftTypeOptionsAsync();
            var servicesTask = MasterData.GetServiceOptionsAsync();
            Task<FlightDetail?> detailTask = FlightId is { } id ? LoadFlightOrNullAsync(id) : Task.FromResult<FlightDetail?>(null);

            await Task.WhenAll(customersTask, stationsTask, operationTypesTask, aircraftTypesTask, servicesTask, detailTask);

            customers = await customersTask;
            stations = await stationsTask;
            operationTypes = await operationTypesTask;
            aircraftTypes = await aircraftTypesTask;
            services = await servicesTask;

            if (await detailTask is { } detail)
            {
                original = detail;
                rowVersion = detail.RowVersion;
                model = new FlightFormModel
                {
                    FlightNumber = detail.FlightNumber,
                    CustomerId = detail.CustomerId,
                    StationId = detail.StationId,
                    OperationTypeId = detail.OperationTypeId,
                    AircraftTypeId = detail.AircraftTypeId,
                    ScheduledArrivalUtc = detail.ScheduledArrivalUtc.UtcDateTime,
                    ScheduledDepartureUtc = detail.ScheduledDepartureUtc.UtcDateTime,
                    PlannedServiceIds = detail.PlannedServices.Select(x => x.ServiceId).ToHashSet(),
                    AssignedStaffMemberIds = detail.AssignedEmployees.Select(x => x.StaffMemberId).ToHashSet()
                };
            }
            else
            {
                var now = DateTime.UtcNow;
                if (IsBulkCreate)
                {
                    var today = now.Date;
                    model.PeriodStartDate = today;
                    model.PeriodEndDate = today;
                    model.ScheduledArrivalTimeUtc = today.AddHours(10);
                    model.ScheduledDepartureTimeUtc = today.AddHours(12);
                }
                else
                {
                    model.ScheduledArrivalUtc = new DateTime(now.Year, now.Month, now.Day, now.Hour, 0, 0, DateTimeKind.Utc).AddHours(1);
                    model.ScheduledDepartureUtc = model.ScheduledArrivalUtc.Value.AddHours(2);
                }
            }

            if (model.StationId != Guid.Empty)
                await LoadStaffForSelectedStationAsync();

            SyncPerLandingAssignmentState();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not load the flight form.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<FlightDetail?> LoadFlightOrNullAsync(Guid id) => await Operations.GetFlightAsync(id);

    private static string ChipClass(bool selected) => selected ? "opf-chip opf-chip-selected" : "opf-chip";

    private static void Toggle(HashSet<Guid> set, Guid id)
    {
        if (!set.Add(id))
            set.Remove(id);
    }

    private static string WeekdayClass(bool selected) =>
        selected ? "opf-weekday opf-weekday-selected" : "opf-weekday";

    private string WeekdayClass(DayOfWeek day) => WeekdayClass(model.Weekdays.Contains(day));

    private void SetWeekday(DayOfWeek day, bool selected)
    {
        if (selected)
            model.Weekdays.Add(day);
        else
            model.Weekdays.Remove(day);
    }

    private DateOnly? BulkPeriodStartDate =>
        model.PeriodStartDate is { } date ? DateOnly.FromDateTime(date.Date) : null;

    private DateOnly? BulkPeriodEndDate =>
        model.PeriodEndDate is { } date ? DateOnly.FromDateTime(date.Date) : null;

    private IReadOnlyList<DateOnly> SelectedScheduleDates =>
        model.SelectedScheduleDates.OrderBy(date => date).ToList();

    private bool CanSeedSelectedDates =>
        BulkPeriodStartDate is { } start &&
        BulkPeriodEndDate is { } end &&
        end >= start &&
        model.Weekdays.Count > 0;

    private string? BulkDatePatternSignature =>
        BulkPeriodStartDate is { } start && BulkPeriodEndDate is { } end
            ? $"{start:yyyy-MM-dd}|{end:yyyy-MM-dd}|{string.Join(',', model.Weekdays.OrderBy(day => (int)day).Select(day => (int)day))}"
            : null;

    private void SeedSelectedDatesFromWeekdaysIfNeeded()
    {
        var signature = BulkDatePatternSignature;
        if (signature is null || string.Equals(signature, model.SelectedScheduleDatesPattern, StringComparison.Ordinal))
            return;

        ResetSelectedDatesFromWeekdays();
    }

    private void ResetSelectedDatesFromWeekdays()
    {
        if (BulkPeriodStartDate is not { } start || BulkPeriodEndDate is not { } end || end < start)
            return;

        model.SelectedScheduleDates = ExpandWeekdaysToDates(start, end, model.Weekdays);
        model.SelectedScheduleDatesPattern = BulkDatePatternSignature;
    }

    private void ToggleScheduleDate(DateOnly date)
    {
        if (BulkPeriodStartDate is not { } start || BulkPeriodEndDate is not { } end || date < start || date > end)
            return;

        if (!model.SelectedScheduleDates.Add(date))
            model.SelectedScheduleDates.Remove(date);
    }

    private static HashSet<DateOnly> ExpandWeekdaysToDates(DateOnly start, DateOnly end, IReadOnlySet<DayOfWeek> weekdays)
    {
        var dates = new HashSet<DateOnly>();
        if (weekdays.Count == 0)
            return dates;

        for (var date = start; date <= end; date = date.AddDays(1))
        {
            if (weekdays.Contains(date.DayOfWeek))
                dates.Add(date);
        }

        return dates;
    }

    private bool IsPerLandingSelected =>
        services.Any(service => service.IsAircraftPerLanding && model.PlannedServiceIds.Contains(service.Id));

    private CustomerOption? SelectedCustomer =>
        customers.FirstOrDefault(customer => customer.Id == model.CustomerId);

    private bool HasCustomerIataPrefix =>
        !string.IsNullOrWhiteSpace(SelectedCustomer?.IataCode);

    private bool ShowCustomerFlightPrefixDivider =>
        SelectedCustomer is not null;

    private string CustomerIataPrefix =>
        SelectedCustomer is null
            ? "-"
            : HasCustomerIataPrefix
                ? SelectedCustomer.IataCode!.Trim().ToUpperInvariant()
                : "N/A";

    private void TogglePlannedService(ServiceOption service)
    {
        Toggle(model.PlannedServiceIds, service.Id);
        SyncPerLandingAssignmentState();
    }

    private void ToggleStaff(StaffMemberListItem member)
    {
        if (member.StationId != model.StationId)
            return;

        Toggle(model.AssignedStaffMemberIds, member.Id);
    }

    private IEnumerable<StaffMemberListItem> AvailableStaff() =>
        staffLoadedForStationId == model.StationId
            ? staff.Where(member => member.StationId == model.StationId)
            : [];

    private bool HasAvailableStaff => AvailableStaff().Any();

    private bool AllAvailableStaffSelected
    {
        get
        {
            var ids = AvailableStaff().Select(member => member.Id).ToList();
            return ids.Count > 0 && ids.All(model.AssignedStaffMemberIds.Contains);
        }
    }

    private string SelectAllStaffText => AllAvailableStaffSelected ? "Clear all" : "Select all";

    private string SelectAllStaffIcon => AllAvailableStaffSelected ? "clear_all" : "select_all";

    private void ToggleAllStaff()
    {
        var ids = AvailableStaff().Select(member => member.Id).ToList();
        if (ids.Count == 0)
            return;

        if (ids.All(model.AssignedStaffMemberIds.Contains))
        {
            model.AssignedStaffMemberIds.ExceptWith(ids);
            return;
        }

        foreach (var id in ids)
            model.AssignedStaffMemberIds.Add(id);
    }

    private void SyncPerLandingAssignmentState()
    {
        if (!IsPerLandingSelected)
            return;

        model.AssignedStaffMemberIds.Clear();
        staffSearchTerm = string.Empty;
    }

    private IEnumerable<ServiceOption> FilteredServices()
    {
        if (string.IsNullOrWhiteSpace(serviceSearchTerm))
            return services;

        var term = serviceSearchTerm.Trim();
        return services.Where(service => service.Name.Contains(term, StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<StaffMemberListItem> FilteredStaff()
    {
        var stationStaff = AvailableStaff();

        if (string.IsNullOrWhiteSpace(staffSearchTerm))
            return stationStaff;

        var term = staffSearchTerm.Trim();
        return stationStaff.Where(member =>
            member.FullName.Contains(term, StringComparison.OrdinalIgnoreCase) ||
            member.EmployeeId.Contains(term, StringComparison.OrdinalIgnoreCase) ||
            member.StationCode.Contains(term, StringComparison.OrdinalIgnoreCase) ||
            member.ManpowerTypeName.Contains(term, StringComparison.OrdinalIgnoreCase));
    }

    private async Task LoadStaffForSelectedStationAsync()
    {
        if (model.StationId == Guid.Empty)
        {
            staff = [];
            staffLoadedForStationId = null;
            model.AssignedStaffMemberIds.Clear();
            return;
        }

        if (staffLoadedForStationId == model.StationId)
            return;

        try
        {
            var result = await MasterData.GetStaffMembersAsync(1, 250, null, true, model.StationId);
            staff = result.Items;
            staffLoadedForStationId = model.StationId;
            staffSearchTerm = string.Empty;

            var stationStaffIds = staff.Select(member => member.Id).ToHashSet();
            model.AssignedStaffMemberIds.RemoveWhere(id => !stationStaffIds.Contains(id));
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not load staff for the selected station.");
        }
    }

    private void OnServiceSearchInput(ChangeEventArgs args) =>
        serviceSearchTerm = args.Value?.ToString() ?? string.Empty;

    private void OnStaffSearchInput(ChangeEventArgs args) =>
        staffSearchTerm = args.Value?.ToString() ?? string.Empty;

    private void ClearServiceSearch() => serviceSearchTerm = string.Empty;

    private void ClearStaffSearch() => staffSearchTerm = string.Empty;

    private bool HasCurrentDuplicateCheck =>
        duplicateCheckSignature is not null && duplicateCheckSignature == DuplicateSignature();

    private string DuplicateSignature() =>
        $"{model.CustomerId:N}|{model.StationId:N}|{model.ScheduledArrivalUtc?.Ticks}|{model.ScheduledDepartureUtc?.Ticks}";

    private void DismissDuplicateMessage()
    {
        duplicates = [];
        duplicateCheckSignature = null;
    }

    private void DismissErrorMessage() => errorMessage = null;

    private async Task CheckDuplicatesAsync()
    {
        errorMessage = null;
        duplicates = [];
        duplicateCheckSignature = null;

        if (model.CustomerId == Guid.Empty || model.StationId == Guid.Empty || model.ScheduledArrivalUtc is null || model.ScheduledDepartureUtc is null)
        {
            errorMessage = "Select customer, station, scheduled arrival, and scheduled departure before checking duplicates.";
            return;
        }

        try
        {
            duplicates = await Operations.GetDuplicateCandidatesAsync(
                model.CustomerId,
                ToUtc(model.ScheduledArrivalUtc.Value),
                ToUtc(model.ScheduledDepartureUtc.Value),
                model.StationId,
                FlightId);
            duplicateCheckSignature = DuplicateSignature();
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not check duplicate candidates.");
        }
    }

    private static string FlightUrl(Guid flightId) => $"/operations/flights/{flightId}";

    private async Task SubmitAsync()
    {
        errorMessage = Validate();
        if (errorMessage is not null)
            return;

        isSubmitting = true;
        try
        {
            object closeResult = true;
            if (FlightId is { } id)
            {
                await UpdateAsync(id);
            }
            else if (IsBulkCreate)
            {
                closeResult = await CreateBulkAsync();
            }
            else
            {
                await CreateAsync();
            }

            DialogService.Close(closeResult);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not save the flight.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task CreateAsync()
    {
        await Operations.ScheduleFlightAsync(new ScheduleFlightRequestModel(
            model.CustomerId,
            model.StationId,
            model.OperationTypeId,
            model.FlightNumber.Trim().ToUpperInvariant(),
            ToUtc(model.ScheduledArrivalUtc!.Value),
            ToUtc(model.ScheduledDepartureUtc!.Value),
            model.AircraftTypeId,
            model.PlannedServiceIds.ToList(),
            AssignmentIdsForSave()));
    }

    private async Task<int> CreateBulkAsync()
    {
        var ids = await Operations.ScheduleFlightsAsync(new ScheduleFlightsRequestModel(
            model.CustomerId,
            model.StationId,
            model.OperationTypeId,
            model.FlightNumber.Trim().ToUpperInvariant(),
            TimeOnly.FromDateTime(model.ScheduledArrivalTimeUtc!.Value),
            TimeOnly.FromDateTime(model.ScheduledDepartureTimeUtc!.Value),
            SelectedScheduleDates,
            model.AircraftTypeId,
            model.PlannedServiceIds.ToList(),
            AssignmentIdsForSave()));

        return ids.Count;
    }

    private async Task UpdateAsync(Guid id)
    {
        var version = rowVersion ?? string.Empty;

        if (original is not null && !string.Equals(original.FlightNumber, model.FlightNumber.Trim(), StringComparison.OrdinalIgnoreCase))
        {
            await Operations.ChangeFlightNumberAsync(id, new ChangeFlightNumberRequestModel(model.FlightNumber.Trim().ToUpperInvariant()), version);
            var refreshed = await Operations.GetFlightAsync(id);
            version = refreshed.RowVersion;
        }

        await Operations.UpdateFlightAsync(id, new UpdateScheduledFlightRequestModel(
            model.CustomerId,
            model.StationId,
            model.OperationTypeId,
            ToUtc(model.ScheduledArrivalUtc!.Value),
            ToUtc(model.ScheduledDepartureUtc!.Value),
            model.AircraftTypeId,
            model.PlannedServiceIds.ToList()), version);

        var assignmentIds = AssignmentIdsForSave();
        if (AssignmentsChanged(assignmentIds))
        {
            var refreshed = await Operations.GetFlightAsync(id);
            await Operations.AssignEmployeesAsync(id, new AssignEmployeesRequestModel(assignmentIds), refreshed.RowVersion);
        }
    }

    private IReadOnlyList<Guid> AssignmentIdsForSave() =>
        IsPerLandingSelected ? [] : model.AssignedStaffMemberIds.ToList();

    private bool AssignmentsChanged(IReadOnlyList<Guid> next)
    {
        if (original is null)
            return next.Count > 0;

        var current = original.AssignedEmployees.Select(employee => employee.StaffMemberId).ToHashSet();
        return current.Count != next.Count || next.Any(id => !current.Contains(id));
    }

    private string? Validate()
    {
        return IsBulkCreate
            ? ValidateDetails() ?? ValidateCalendar() ?? ValidateServices() ?? ValidateAssignments()
            : ValidateDetails() ?? ValidateServices() ?? ValidateAssignments();
    }

    private string? ValidateDetails()
    {
        if (string.IsNullOrWhiteSpace(model.FlightNumber))
            return "Flight number is required.";
        if (model.CustomerId == Guid.Empty)
            return "Customer is required.";
        if (model.StationId == Guid.Empty)
            return "Station is required.";
        if (model.OperationTypeId == Guid.Empty)
            return "Operation type is required.";
        if (IsBulkCreate)
        {
            if (model.PeriodStartDate is null || model.PeriodEndDate is null)
                return "Period start and end dates are required.";
            if (model.PeriodEndDate.Value.Date < model.PeriodStartDate.Value.Date)
                return "Period end date must be on or after period start date.";
            if (model.ScheduledArrivalTimeUtc is null || model.ScheduledDepartureTimeUtc is null)
                return "STA and STD times are required.";
            if (model.Weekdays.Count == 0)
                return "Select at least one weekday.";
            return null;
        }
        if (model.ScheduledArrivalUtc is null || model.ScheduledDepartureUtc is null)
            return "Scheduled arrival and departure are required.";
        if (model.ScheduledDepartureUtc <= model.ScheduledArrivalUtc)
            return "Scheduled departure must be after scheduled arrival.";
        return null;
    }

    private string? ValidateCalendar()
    {
        if (!IsBulkCreate)
            return null;

        if (model.SelectedScheduleDates.Count == 0)
            return "Select at least one calendar date.";

        if (BulkPeriodStartDate is not { } start || BulkPeriodEndDate is not { } end)
            return "Period start and end dates are required.";

        return model.SelectedScheduleDates.Any(date => date < start || date > end)
            ? "Selected calendar dates must be inside the selected period."
            : null;
    }

    private string? ValidateServices()
    {
        if (model.PlannedServiceIds.Count == 0)
            return "At least one planned service is required.";
        return null;
    }

    private string? ValidateAssignments()
    {
        if (IsPerLandingSelected || model.AssignedStaffMemberIds.Count == 0)
            return null;

        if (staffLoadedForStationId != model.StationId)
            return "Load the selected station staff before assigning employees.";

        var stationStaffIds = staff.Where(member => member.StationId == model.StationId).Select(member => member.Id).ToHashSet();
        return model.AssignedStaffMemberIds.Any(id => !stationStaffIds.Contains(id))
            ? "Assigned staff must belong to the selected station."
            : null;
    }

    private static DateTimeOffset ToUtc(DateTime value)
    {
        var utc = value.Kind == DateTimeKind.Utc ? value : DateTime.SpecifyKind(value, DateTimeKind.Utc);
        return new DateTimeOffset(utc);
    }

