        public string? Description { get; set; }
        public DateTime? FromUtc { get; set; }
        public DateTime? ToUtc { get; set; }
        public IEnumerable<Guid> EmployeeIds { get; set; } = [];
        public List<ResourceForm> Tools { get; } = [];
        public List<ResourceForm> Materials { get; } = [];
        public List<ResourceForm> GeneralSupports { get; } = [];
        public List<AttachmentForm> Attachments { get; } = [];
