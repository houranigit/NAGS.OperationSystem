@inject OperationsApiClient Operations
@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="AdHocFormModel" Data="@model" Submit="@SubmitAsync">
    <div class="oah-form">
        @if (isLoading)
        {
            <LoadingCard />
        }
        else
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Info">
                Creates a new flight together with your work order. The flight appears on the calendar and list immediately;
                submit the work order when the work is done.
            </DismissibleDialogMessage>

            <div class="oah-section-line"><RadzenIcon Icon="flight" /><span>Flight details</span></div>
            <div class="oah-grid-2">
                <div class="oah-field-block">
                    <label class="oah-label">Flight number <span class="oah-required">*</span></label>
                    <RadzenTextBox @bind-Value="model.FlightNumber" MaxLength="12" class="oah-control" Placeholder="e.g. NGS104" />
                </div>
                <div class="oah-field-block">
                    <label class="oah-label">Customer <span class="oah-required">*</span></label>
                    <RadzenDropDown @bind-Value="model.CustomerId" Data="@customers" TextProperty="Name" ValueProperty="Id"
                                    AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" class="oah-control" Placeholder="Select customer" />
                </div>
            </div>
            <div class="oah-grid-2">
                <div class="oah-field-block">
                    <label class="oah-label">Operation type <span class="oah-required">*</span></label>
                    <RadzenDropDown @bind-Value="model.OperationTypeId" Data="@operationTypes" TextProperty="Name" ValueProperty="Id"
                                    AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" class="oah-control" Placeholder="Select operation" />
                </div>
                <div class="oah-field-block">
                    <label class="oah-label">Scheduled aircraft type</label>
                    <RadzenDropDown @bind-Value="model.AircraftTypeId" Data="@aircraftTypes" TextProperty="Model" ValueProperty="Id"
                                    AllowClear="true" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" class="oah-control" Placeholder="Optional aircraft type" />
                </div>
            </div>
            <div class="oah-grid-2">
                <div class="oah-field-block">
                    <label class="oah-label">STA (UTC) <span class="oah-required">*</span></label>
                    <RadzenDatePicker @bind-Value="model.ScheduledArrivalUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="oah-control" />
                </div>
                <div class="oah-field-block">
                    <label class="oah-label">STD (UTC) <span class="oah-required">*</span></label>
                    <RadzenDatePicker @bind-Value="model.ScheduledDepartureUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="oah-control" />
                </div>
            </div>

            <div class="oah-section-line"><RadzenIcon Icon="settings" /><span>Planned services @(model.IsCancellation ? "" : "*")</span></div>
            <div class="oah-chip-list">
                @foreach (var service in services)
                {
                    <button type="button" @key="service.Id" class="@ChipClass(model.PlannedServiceIds.Contains(service.Id))"
                            @onclick="@(() => Toggle(model.PlannedServiceIds, service.Id))">
                        <RadzenIcon Icon="task_alt" />
                        <span>@service.Name</span>
                    </button>
                }
            </div>

            <div class="oah-section-line"><RadzenIcon Icon="assignment" /><span>Work order</span></div>
            <div class="oah-inline-check">
                <RadzenCheckBox @bind-Value="model.IsCancellation" Name="adhoc-cancel" />
                <RadzenLabel Text="This is a cancellation (the customer canceled the flight)" Component="adhoc-cancel" />
            </div>

            @if (model.IsCancellation)
            {
                <div class="oah-grid-2">
                    <div class="oah-field-block">
                        <label class="oah-label">Canceled at (UTC) <span class="oah-required">*</span></label>
                        <RadzenDatePicker @bind-Value="model.CancellationAtUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="oah-control" />
                    </div>
                    <div class="oah-field-block">
                        <label class="oah-label">Cancellation reason</label>
                        <RadzenTextBox @bind-Value="model.CancellationReason" MaxLength="1000" class="oah-control" />
                    </div>
                </div>
            }
            else
            {
                <div class="oah-grid-2">
                    <div class="oah-field-block">
                        <label class="oah-label">Actual flight #</label>
                        <RadzenTextBox @bind-Value="model.ActualFlightNumber" MaxLength="12" class="oah-control" Placeholder="Defaults to flight number" />
                    </div>
                    <div class="oah-field-block">
                        <label class="oah-label">Actual aircraft type</label>
                        <RadzenDropDown @bind-Value="model.ActualAircraftTypeId" Data="@aircraftTypes" TextProperty="Model" ValueProperty="Id"
                                        AllowClear="true" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" class="oah-control" Placeholder="Optional" />
                    </div>
                </div>
                <div class="oah-grid-2">
                    <div class="oah-field-block">
                        <label class="oah-label">ATA (UTC)</label>
                        <RadzenDatePicker @bind-Value="model.ActualArrivalUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="oah-control" />
                    </div>
                    <div class="oah-field-block">
                        <label class="oah-label">ATD (UTC)</label>
                        <RadzenDatePicker @bind-Value="model.ActualDepartureUtc" DateFormat="yyyy-MM-dd HH:mm" ShowTime="true" class="oah-control" />
                    </div>
                </div>
                <div class="oah-grid-2">
                    <div class="oah-field-block">
                        <label class="oah-label">Aircraft tail</label>
                        <RadzenTextBox @bind-Value="model.AircraftTailNumber" MaxLength="30" class="oah-control" />
                    </div>
                    <div class="oah-field-block">
                        <label class="oah-label">Signature reference</label>
                        <RadzenTextBox @bind-Value="model.CustomerSignatureReference" MaxLength="500" class="oah-control" />
                    </div>
                </div>
                <div class="oah-field-block">
                    <label class="oah-label">Remarks</label>
                    <RadzenTextArea @bind-Value="model.Remarks" Rows="2" MaxLength="2000" class="oah-control" />
                </div>
                <p class="os-muted">Actual services and tasks can be added in the work order editor after creation.</p>
            }

            @if (duplicates.Count > 0)
            {
                <DismissibleDialogMessage AlertStyle="AlertStyle.Warning" Title="Potential duplicates found. Saving again will create the flight anyway."
                                          StateKey="@duplicates.Count" OnDismiss="@DismissDuplicateMessage">
                    <div class="oah-duplicates">
                        @foreach (var duplicate in duplicates)
                        {
                            <a @key="duplicate.FlightId" class="oah-duplicate-link" href="@FlightUrl(duplicate.FlightId)" target="_blank" rel="noopener noreferrer">
                                @duplicate.FlightNumber · @duplicate.CustomerName · @duplicate.StationIata
                            </a>
                        }
                    </div>
                </DismissibleDialogMessage>
            }

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" StateKey="@errorMessage"
                                          OnDismiss="@(() => errorMessage = null)">
                    @errorMessage
                </DismissibleDialogMessage>
            }

            <div class="oah-actions">
                <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="Create flight + work order" Icon="check"
                              ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
            </div>
        }
    </div>
</RadzenTemplateForm>

@code {
    private AdHocFormModel model = new();
    private IReadOnlyList<CustomerOption> customers = [];
    private IReadOnlyList<OperationTypeOption> operationTypes = [];
    private IReadOnlyList<AircraftTypeOption> aircraftTypes = [];
    private IReadOnlyList<ServiceOption> services = [];
    private IReadOnlyList<DuplicateCandidate> duplicates = [];
    private bool acknowledgeDuplicates;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var customersTask = MasterData.GetCustomerOptionsAsync();
            var operationTypesTask = MasterData.GetOperationTypeOptionsAsync();
            var aircraftTypesTask = MasterData.GetAircraftTypeOptionsAsync();
            var servicesTask = MasterData.GetServiceOptionsAsync();

            await Task.WhenAll(customersTask, operationTypesTask, aircraftTypesTask, servicesTask);

            customers = await customersTask;
            operationTypes = await operationTypesTask;
            aircraftTypes = await aircraftTypesTask;
            services = await servicesTask;

            var now = DateTime.UtcNow;
            model.ScheduledArrivalUtc = new DateTime(now.Year, now.Month, now.Day, now.Hour, 0, 0, DateTimeKind.Utc);
            model.ScheduledDepartureUtc = model.ScheduledArrivalUtc.Value.AddHours(2);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.IsForbidden
                ? UiStrings.Errors.ReferenceLookupsForbidden
                : ex.ToDisplayMessage("Could not load the form.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string ChipClass(bool selected) => selected ? "oah-chip oah-chip-selected" : "oah-chip";

    private static void Toggle(HashSet<Guid> set, Guid id)
    {
        if (!set.Add(id))
            set.Remove(id);
    }

    private void DismissDuplicateMessage()
    {
        duplicates = [];
        acknowledgeDuplicates = false;
    }

    private async Task SubmitAsync()
    {
        errorMessage = Validate();
        if (errorMessage is not null)
            return;

        isSubmitting = true;
        try
        {
            var result = await Operations.CreateAdHocFlightAsync(new CreateAdHocFlightRequestModel(
                model.CustomerId,
                model.OperationTypeId,
                model.FlightNumber.Trim().ToUpperInvariant(),
                ToUtc(model.ScheduledArrivalUtc!.Value),
                ToUtc(model.ScheduledDepartureUtc!.Value),
                model.AircraftTypeId,
                model.PlannedServiceIds.ToList(),
                acknowledgeDuplicates,
                model.IsCancellation,
                model.CancellationAtUtc is null ? null : ToUtc(model.CancellationAtUtc.Value),
                TrimToNull(model.CancellationReason),
                TrimToNull(model.ActualFlightNumber),
                model.ActualAircraftTypeId,
                TrimToNull(model.AircraftTailNumber),
                model.ActualArrivalUtc is null ? null : ToUtc(model.ActualArrivalUtc.Value),
                model.ActualDepartureUtc is null ? null : ToUtc(model.ActualDepartureUtc.Value),
                [],
                [],
                TrimToNull(model.Remarks),
                TrimToNull(model.CustomerSignatureReference)));

            duplicates = result.DuplicateCandidates;
            DialogService.Close(true);

            if (!model.IsCancellation)
            {
                await DialogService.OpenAsync<WorkOrderEditorDialog>("Work order",
                    new Dictionary<string, object?> { [nameof(WorkOrderEditorDialog.WorkOrderId)] = result.WorkOrderId },
                    new DialogOptions { Width = "760px" });
            }
        }
        catch (ApiException ex)
        {
            // A strong duplicate match returns a conflict; surface the candidates and let the user confirm.
            errorMessage = ex.ToDisplayMessage("Could not create the flight and work order.");
            if (!acknowledgeDuplicates)
            {
                try
                {
                    duplicates = await Operations.GetDuplicateCandidatesAsync(
                        model.CustomerId,
                        ToUtc(model.ScheduledArrivalUtc!.Value),
                        ToUtc(model.ScheduledDepartureUtc!.Value));
                }
                catch (ApiException)
                {
                    // Keep the original error; candidates are advisory only.
                }
                acknowledgeDuplicates = duplicates.Count > 0;
            }
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(model.FlightNumber))
            return "Flight number is required.";
        if (model.CustomerId == Guid.Empty)
            return "Customer is required.";
        if (model.OperationTypeId == Guid.Empty)
            return "Operation type is required.";
        if (model.ScheduledArrivalUtc is null || model.ScheduledDepartureUtc is null)
            return "STA and STD are required.";
        if (model.ScheduledDepartureUtc <= model.ScheduledArrivalUtc)
            return "STD must be after STA.";
        if (!model.IsCancellation && model.PlannedServiceIds.Count == 0)
            return "At least one planned service is required.";
        if (model.IsCancellation && model.CancellationAtUtc is null)
            return "The cancellation date/time is required.";
        if (model.ActualArrivalUtc is not null && model.ActualDepartureUtc is not null && model.ActualDepartureUtc <= model.ActualArrivalUtc)
            return "ATD must be after ATA.";
        return null;
    }

    private static DateTimeOffset ToUtc(DateTime value)
    {
        var utc = value.Kind == DateTimeKind.Utc ? value : DateTime.SpecifyKind(value, DateTimeKind.Utc);
        return new DateTimeOffset(utc);
    }

    private static string? TrimToNull(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string FlightUrl(Guid flightId) => $"/operations/flights/{flightId}";

    private sealed class AdHocFormModel
    {
        public string FlightNumber { get; set; } = string.Empty;
        public Guid CustomerId { get; set; }
        public Guid OperationTypeId { get; set; }
        public Guid? AircraftTypeId { get; set; }
        public DateTime? ScheduledArrivalUtc { get; set; }
        public DateTime? ScheduledDepartureUtc { get; set; }
        public HashSet<Guid> PlannedServiceIds { get; set; } = [];
        public bool IsCancellation { get; set; }
        public DateTime? CancellationAtUtc { get; set; }
        public string? CancellationReason { get; set; }
        public string? ActualFlightNumber { get; set; }
        public Guid? ActualAircraftTypeId { get; set; }
        public string? AircraftTailNumber { get; set; }
        public DateTime? ActualArrivalUtc { get; set; }
        public DateTime? ActualDepartureUtc { get; set; }
        public string? Remarks { get; set; }
        public string? CustomerSignatureReference { get; set; }
    }
}
