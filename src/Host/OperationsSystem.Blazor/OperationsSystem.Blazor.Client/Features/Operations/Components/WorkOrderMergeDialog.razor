@inject OperationsApiClient Operations
@inject DialogService DialogService

<div class="owm-form">
    @if (isLoading)
    {
        <LoadingCard />
    }
    else if (flight is null)
    {
        <ErrorState Message="Could not load work orders." OnRetry="@LoadAsync" />
    }
    else
    {
        <div class="owm-summary">
            <div class="owm-summary-icon">
                <RadzenIcon Icon="flight" />
                <span class="owm-summary-dot @StatusDotClass(flight.Status)"></span>
            </div>
            <div class="owm-summary-main">
                <div class="owm-summary-heading">
                    <h2>@DisplayFlightNumber(flight)</h2>
                    <StatusBadge Label="@flight.Status" Tone="@FlightStatusTone(flight.Status)" />
                    <span class="owm-operation-badge"><RadzenIcon Icon="settings" />@flight.OperationTypeName</span>
                </div>
                <div class="owm-summary-meta">
                    <span><RadzenIcon Icon="business" />@flight.CustomerName</span>
                    <span><RadzenIcon Icon="flight_takeoff" />@flight.StationIata</span>
                    <span><RadzenIcon Icon="flight_land" />STA @DateDisplay(flight.ScheduledArrivalUtc) UTC</span>
                </div>
            </div>
        </div>

        @if (sources.Count < 2)
        {
            <div class="owm-empty">
                <RadzenIcon Icon="merge_type" />
                <span>At least two submitted or returned work orders are required.</span>
            </div>
        }
        else
        {
            <section class="owm-section">
                <div class="owm-section-line"><RadzenIcon Icon="checklist" /><span>Source work orders</span></div>
                <div class="owm-toolbar">
                    <RadzenButton Text="Select all" Icon="select_all" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  ButtonType="ButtonType.Button" Click="@SelectAll" />
                    <RadzenButton Text="Clear" Icon="clear_all" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                  ButtonType="ButtonType.Button" Click="@ClearSelection" />
                    <span class="owm-selection-count">@SelectedCountText</span>
                </div>

                <div class="owm-source-list">
                    @foreach (var source in sources)
                    {
                        var selected = selectedSourceIds.Contains(source.Id);
                        var disabled = !CanSelectSource(source);
                        <label @key="source.Id" class="owm-source-row @(selected ? "owm-source-row--selected" : string.Empty) @(disabled ? "owm-source-row--disabled" : string.Empty)">
                            <RadzenCheckBox TValue="bool" Value="@selected" Disabled="@disabled" Change="@((bool value) => ToggleSource(source.Id, value))" />
                            <span class="owm-source-icon"><RadzenIcon Icon="@(source.Type == "Cancellation" ? "cancel" : "task_alt")" /></span>
                            <span class="owm-source-main">
                                <strong>@DisplayWorkOrder(source)</strong>
                                <small>@source.Type · @None(source.OwnerName)</small>
                            </span>
                            <StatusBadge Label="@source.Status" Tone="@WorkOrderStatusTone(source.Status)" />
                        </label>
                    }
                </div>
            </section>

            <section class="owm-section">
                <div class="owm-section-line"><RadzenIcon Icon="rule" /><span>Merged work order</span></div>
                <div class="owm-field-selectors">
                    @ValueSourceField("Actual flight #", "tag", actualFlightSourceId, id => actualFlightSourceId = id, source => source.ActualFlightNumber)
                    @if (IsMergedCompletion)
                    {
                        @ValueSourceField("Aircraft type", "flight", aircraftSourceId, id => aircraftSourceId = id, source => source.AircraftTypeModel)
                        @ValueSourceField("Tail number", "confirmation_number", tailSourceId, id => tailSourceId = id, source => source.AircraftTailNumber)
                        @ValueSourceField("ATA / ATD", "flight_land", actualTimesSourceId, id => actualTimesSourceId = id, ActualTimesValue)
                        @ValueSourceField("Remarks", "notes", remarksSourceId, id => remarksSourceId = id, source => source.Remarks)
                    }
                    else
                    {
                        @ValueSourceField("Cancellation", "event_busy", cancellationSourceId, id => cancellationSourceId = id, CancellationValue)
                    }
                    <label class="owm-toggle-row">
                        <RadzenCheckBox TValue="bool" @bind-Value="approveImmediately" />
                        <span>Approve immediately</span>
                    </label>
                </div>

                @if (TypeSource is { } typeSource)
                {
                    <div class="owm-preview">
                        <div>
                            <span>Type</span>
                            <strong>@typeSource.Type</strong>
                        </div>
                        <div>
                            <span>Actual flight #</span>
                            <strong>@(SourceOrFallback(actualFlightSourceId, typeSource).ActualFlightNumber)</strong>
                        </div>
                        <div>
                            <span>Service lines</span>
                            <strong>@MergeServiceLineCount</strong>
                        </div>
                        <div>
                            <span>Tasks</span>
                            <strong>@MergeTaskCount</strong>
                        </div>
                    </div>
                }

                @if (IsMergedCompletion)
                {
                    <div class="owm-include-grid">
                        <div class="owm-include-panel">
                            <div class="owm-include-head">
                                <span><RadzenIcon Icon="fact_check" />Service lines</span>
                                <div>
                                    <RadzenButton Text="All" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button" Click="@SelectAllServiceLines" />
                                    <RadzenButton Text="None" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button" Click="@ClearServiceLines" />
                                </div>
                            </div>
                            @if (AvailableServiceLines.Count == 0)
                            {
                                <div class="owm-empty-mini">No source service lines</div>
                            }
                            @foreach (var item in AvailableServiceLines)
                            {
                                var selected = selectedServiceLineKeys.Contains(item.Key);
                                <label @key="item.Key" class="owm-include-row @(selected ? "owm-include-row--selected" : string.Empty)">
                                    <RadzenCheckBox TValue="bool" Value="@selected" Change="@((bool value) => ToggleServiceLine(item.Key, value))" />
                                    <span><strong>@item.Line.ServiceName</strong><small>@DisplayWorkOrder(item.Source)</small></span>
                                </label>
                            }
                        </div>
                        <div class="owm-include-panel">
                            <div class="owm-include-head">
                                <span><RadzenIcon Icon="task_alt" />Tasks</span>
                                <div>
                                    <RadzenButton Text="All" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button" Click="@SelectAllTasks" />
                                    <RadzenButton Text="None" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" ButtonType="ButtonType.Button" Click="@ClearTasks" />
                                </div>
                            </div>
                            @if (AvailableTasks.Count == 0)
                            {
                                <div class="owm-empty-mini">No source tasks</div>
                            }
                            @foreach (var item in AvailableTasks)
                            {
                                var selected = selectedTaskKeys.Contains(item.Key);
                                <label @key="item.Key" class="owm-include-row @(selected ? "owm-include-row--selected" : string.Empty)">
                                    <RadzenCheckBox TValue="bool" Value="@selected" Change="@((bool value) => ToggleTask(item.Key, value))" />
                                    <span><strong>@item.Task.TaskType</strong><small>@DisplayWorkOrder(item.Source) · @None(item.Task.Description)</small></span>
                                </label>
                            }
                        </div>
                    </div>
                }
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" StateKey="@errorMessage" OnDismiss="@(() => errorMessage = null)">
                @errorMessage
            </DismissibleDialogMessage>
        }

        <div class="owm-actions">
            <RadzenButton Text="Close" ButtonStyle="ButtonStyle.Light" ButtonType="ButtonType.Button" Click="@(() => DialogService.Close(false))" />
            <RadzenButton Text="Merge" Icon="merge_type" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Button"
                          Disabled="@(!CanMerge || isSubmitting)" Click="@MergeAsync" />
        </div>
    }
</div>

@code {
    [Parameter] public Guid FlightId { get; set; }

    private FlightDetail? flight;
    private List<WorkOrderDetail> sources = [];
    private HashSet<Guid> selectedSourceIds = [];
    private HashSet<string> selectedServiceLineKeys = [];
    private HashSet<string> selectedTaskKeys = [];
    private Guid? actualFlightSourceId;
    private Guid? aircraftSourceId;
    private Guid? tailSourceId;
    private Guid? actualTimesSourceId;
    private Guid? remarksSourceId;
    private Guid? cancellationSourceId;
    private bool approveImmediately;
    private bool isLoading = true;
    private bool isSubmitting;
    private string? errorMessage;

    private WorkOrderDetail? TypeSource =>
        SelectedSources.FirstOrDefault();

    private bool IsMergedCompletion => TypeSource?.Type != "Cancellation";

    private IReadOnlyList<WorkOrderDetail> SelectedSources =>
        sources.Where(source => selectedSourceIds.Contains(source.Id)).ToList();

    private string? SelectedMergeType => TypeSource?.Type;

    private IReadOnlyList<ServiceLineSelection> AvailableServiceLines =>
        SelectedSources
            .SelectMany(source => source.ServiceLines.Select(line => new ServiceLineSelection(source, line, LineKey(source.Id, line.Id))))
            .ToList();

    private IReadOnlyList<TaskSelection> AvailableTasks =>
        SelectedSources
            .SelectMany(source => source.Tasks.Select(task => new TaskSelection(source, task, TaskKey(source.Id, task.Id))))
            .ToList();

    private bool CanMerge =>
        selectedSourceIds.Count >= 2
        && TypeSource is not null
        && SelectedSources.All(source => source.Type == TypeSource.Type);
    private string SelectedCountText => selectedSourceIds.Count == 1 ? "1 selected" : $"{selectedSourceIds.Count} selected";
    private int MergeServiceLineCount => IsMergedCompletion ? selectedServiceLineKeys.Count : 0;
    private int MergeTaskCount => IsMergedCompletion ? selectedTaskKeys.Count : 0;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            flight = await Operations.GetFlightAsync(FlightId);
            var eligible = flight.WorkOrders
                .Where(summary => summary.Status is "Submitted" or "Returned")
                .ToList();

            var loaded = new List<WorkOrderDetail>(eligible.Count);
            foreach (var summary in eligible)
            {
                var detail = await Operations.GetWorkOrderAsync(summary.Id);
                if (!detail.IsMergeGenerated && detail.MergedIntoWorkOrderId is null)
                    loaded.Add(detail);
            }

            sources = loaded
                .OrderBy(source => source.Type)
                .ThenBy(source => source.OwnerName)
                .ThenBy(source => source.CreatedAtUtc)
                .ToList();
            selectedSourceIds = sources
                .GroupBy(source => source.Type)
                .FirstOrDefault(group => group.Count() >= 2)?
                .Take(2)
                .Select(source => source.Id)
                .ToHashSet() ?? [];
            SyncMergeSelections(selectMissingLinesAndTasks: true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not load merge candidates.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleSource(Guid id, bool selected)
    {
        var source = sources.FirstOrDefault(item => item.Id == id);
        if (source is null || (selected && !CanSelectSource(source)))
            return;

        if (selected)
            selectedSourceIds.Add(id);
        else
            selectedSourceIds.Remove(id);

        SyncMergeSelections(selectMissingLinesAndTasks: selected);
    }

    private void SelectAll()
    {
        var type = SelectedMergeType
            ?? sources.GroupBy(source => source.Type).FirstOrDefault(group => group.Count() >= 2)?.Key;
        selectedSourceIds = string.IsNullOrWhiteSpace(type)
            ? []
            : sources.Where(source => source.Type == type).Select(source => source.Id).ToHashSet();
        SyncMergeSelections(selectMissingLinesAndTasks: true);
    }

    private void ClearSelection()
    {
        selectedSourceIds.Clear();
        selectedServiceLineKeys.Clear();
        selectedTaskKeys.Clear();
        actualFlightSourceId = null;
        aircraftSourceId = null;
        tailSourceId = null;
        actualTimesSourceId = null;
        remarksSourceId = null;
        cancellationSourceId = null;
    }

    private void SyncMergeSelections(bool selectMissingLinesAndTasks)
    {
        EnsureFieldSource(ref actualFlightSourceId);
        EnsureFieldSource(ref aircraftSourceId);
        EnsureFieldSource(ref tailSourceId);
        EnsureFieldSource(ref actualTimesSourceId);
        EnsureFieldSource(ref remarksSourceId);
        EnsureFieldSource(ref cancellationSourceId);

        var availableLineKeys = AvailableServiceLines.Select(item => item.Key).ToHashSet(StringComparer.Ordinal);
        var availableTaskKeys = AvailableTasks.Select(item => item.Key).ToHashSet(StringComparer.Ordinal);
        selectedServiceLineKeys.IntersectWith(availableLineKeys);
        selectedTaskKeys.IntersectWith(availableTaskKeys);

        if (selectMissingLinesAndTasks)
        {
            selectedServiceLineKeys.UnionWith(availableLineKeys);
            selectedTaskKeys.UnionWith(availableTaskKeys);
        }
    }

    private void EnsureFieldSource(ref Guid? fieldSourceId)
    {
        if (fieldSourceId is { } id && selectedSourceIds.Contains(id))
            return;

        fieldSourceId = SelectedSources.FirstOrDefault()?.Id;
    }

    private bool CanSelectSource(WorkOrderDetail source) =>
        selectedSourceIds.Contains(source.Id)
        || SelectedMergeType is null
        || source.Type == SelectedMergeType;

    private RenderFragment ValueSourceField(
        string label,
        string icon,
        Guid? selectedId,
        Action<Guid> select,
        Func<WorkOrderDetail, string?> valueSelector) => @<div class="owm-field-block">
            <label class="owm-label">@label</label>
            <div class="owm-value-options">
                @if (SelectedSources.Count == 0)
                {
                    <div class="owm-empty-mini">Select source work orders</div>
                }
                @foreach (var source in SelectedSources)
                {
                    var active = selectedId == source.Id;
                    <button @key="source.Id" type="button" class="owm-value-option @(active ? "owm-value-option--selected" : string.Empty)"
                            @onclick="@(() => select(source.Id))">
                        <span class="owm-value-icon"><RadzenIcon Icon="@icon" /></span>
                        <span class="owm-value-main">
                            <strong>@None(valueSelector(source))</strong>
                            <small>@SourceValueMeta(source)</small>
                        </span>
                    </button>
                }
            </div>
        </div>;

    private void ToggleServiceLine(string key, bool selected)
    {
        if (selected)
            selectedServiceLineKeys.Add(key);
        else
            selectedServiceLineKeys.Remove(key);
    }

    private void ToggleTask(string key, bool selected)
    {
        if (selected)
            selectedTaskKeys.Add(key);
        else
            selectedTaskKeys.Remove(key);
    }

    private void SelectAllServiceLines() => selectedServiceLineKeys = AvailableServiceLines.Select(item => item.Key).ToHashSet(StringComparer.Ordinal);
    private void ClearServiceLines() => selectedServiceLineKeys.Clear();
    private void SelectAllTasks() => selectedTaskKeys = AvailableTasks.Select(item => item.Key).ToHashSet(StringComparer.Ordinal);
    private void ClearTasks() => selectedTaskKeys.Clear();

    private async Task MergeAsync()
    {
        if (flight is null || TypeSource is not { } typeSource)
            return;

        if (selectedSourceIds.Count < 2)
        {
            errorMessage = "Select at least two work orders to merge.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        try
        {
            var request = new MergeWorkOrdersRequestModel(
                selectedSourceIds.ToList(),
                BuildMergedWorkOrder(typeSource),
                approveImmediately);
            await Operations.MergeWorkOrdersAsync(flight.Id, request);
            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage("Could not merge work orders.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private WorkOrderRequestModel BuildMergedWorkOrder(WorkOrderDetail baseWorkOrder)
    {
        var completion = baseWorkOrder.Type == "Completion";
        var actualFlightSource = SourceOrFallback(actualFlightSourceId, baseWorkOrder);
        var aircraftSource = SourceOrFallback(aircraftSourceId, baseWorkOrder);
        var tailSource = SourceOrFallback(tailSourceId, baseWorkOrder);
        var actualTimesSource = SourceOrFallback(actualTimesSourceId, baseWorkOrder);
        var remarksSource = SourceOrFallback(remarksSourceId, baseWorkOrder);
        var cancellationSource = SourceOrFallback(cancellationSourceId, baseWorkOrder);
        var selectedLines = AvailableServiceLines.Where(item => selectedServiceLineKeys.Contains(item.Key)).ToList();
        var selectedTasks = AvailableTasks.Where(item => selectedTaskKeys.Contains(item.Key)).ToList();

        return new WorkOrderRequestModel(
            baseWorkOrder.Type,
            actualFlightSource.ActualFlightNumber,
            completion ? aircraftSource.AircraftTypeId : null,
            completion ? tailSource.AircraftTailNumber : null,
            completion ? actualTimesSource.ActualArrivalUtc : null,
            completion ? actualTimesSource.ActualDepartureUtc : null,
            completion ? null : cancellationSource.CanceledAtUtc,
            completion ? null : cancellationSource.CancellationReason,
            completion ? remarksSource.Remarks : null,
            completion ? selectedLines.Select(item => new WorkOrderServiceLineRequestModel(
                item.Line.ServiceId,
                item.Line.PerformedByStaffMemberId,
                item.Line.FromUtc,
                item.Line.ToUtc,
                item.Line.Description)).ToList() : [],
            completion ? selectedTasks.Select(item => new WorkOrderTaskRequestModel(
                null,
                item.Task.TaskType,
                item.Task.Description,
                item.Task.FromUtc,
                item.Task.ToUtc,
                item.Task.Employees.Select(employee => employee.StaffMemberId).ToList(),
                item.Task.Tools.Select(tool => new WorkOrderTaskToolRequestModel(tool.ToolId, tool.Quantity)).ToList(),
                item.Task.Materials.Select(material => new WorkOrderTaskMaterialRequestModel(material.MaterialId, material.Quantity)).ToList(),
                item.Task.GeneralSupports.Select(support => new WorkOrderTaskGeneralSupportRequestModel(support.GeneralSupportId, support.Quantity)).ToList())).ToList() : []);
    }

    private WorkOrderDetail? SourceOrNull(Guid? id) =>
        id is { } value && selectedSourceIds.Contains(value)
            ? sources.FirstOrDefault(source => source.Id == value)
            : null;

    private WorkOrderDetail SourceOrFallback(Guid? id, WorkOrderDetail fallback) =>
        SourceOrNull(id) ?? fallback;

    private static string DisplayFlightNumber(FlightDetail flight) =>
        string.IsNullOrWhiteSpace(flight.CustomerIataCode)
            ? flight.FlightNumber
            : $"{flight.CustomerIataCode.Trim().ToUpperInvariant()}-{flight.FlightNumber}";

    private static string DisplayWorkOrder(WorkOrderDetail workOrder) =>
        string.IsNullOrWhiteSpace(workOrder.ApprovalNumber) ? ShortId(workOrder.Id) : workOrder.ApprovalNumber;

    private static string DateDisplay(DateTimeOffset value) => value.UtcDateTime.ToString("yyyy-MM-dd HH:mm");
    private static string DateDisplay(DateTimeOffset? value) => value?.UtcDateTime.ToString("yyyy-MM-dd HH:mm") ?? "None";
    private static string None(string? value) => string.IsNullOrWhiteSpace(value) ? "None" : value;
    private static string ShortId(Guid id) => id.ToString("N")[..8].ToUpperInvariant();
    private static string LineKey(Guid sourceId, Guid lineId) => $"{sourceId:N}:{lineId:N}";
    private static string TaskKey(Guid sourceId, Guid taskId) => $"{sourceId:N}:{taskId:N}";

    private static string SourceValueMeta(WorkOrderDetail source) =>
        $"Owner {None(source.OwnerName)}";

    private static string ActualTimesValue(WorkOrderDetail source) =>
        $"ATA {DateDisplay(source.ActualArrivalUtc)} · ATD {DateDisplay(source.ActualDepartureUtc)}";

    private static string CancellationValue(WorkOrderDetail source) =>
        $"{DateDisplay(source.CanceledAtUtc)} · {None(source.CancellationReason)}";

    private static string StatusDotClass(string status) => status switch
    {
        "Completed" => "owm-summary-dot--success",
        "Canceled" or "Merged" => "owm-summary-dot--danger",
        "InProgress" => "owm-summary-dot--warning",
        _ => "owm-summary-dot--active"
    };

    private static string FlightStatusTone(string status) => status switch
    {
        "Completed" => "success",
        "Canceled" or "Merged" => "danger",
        "InProgress" => "warning",
        _ => "neutral"
    };

    private static string WorkOrderStatusTone(string status) => status switch
    {
        "Approved" => "success",
        "Merged" => "danger",
        "Submitted" => "warning",
        _ => "neutral"
    };

    private sealed record ServiceLineSelection(WorkOrderDetail Source, WorkOrderServiceLineModel Line, string Key);
    private sealed record TaskSelection(WorkOrderDetail Source, WorkOrderTaskModel Task, string Key);
}
