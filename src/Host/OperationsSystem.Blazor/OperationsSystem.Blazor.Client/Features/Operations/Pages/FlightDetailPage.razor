    private static string DateTimeDisplay(DateTimeOffset? value) =>
        value?.UtcDateTime.ToString("yyyy-MM-dd HH:mm") ?? "None";

    private static string None(string? value) => string.IsNullOrWhiteSpace(value) ? "None" : value;

    private static string DisplayFlightNumber(FlightDetail flight) =>
        string.IsNullOrWhiteSpace(flight.CustomerIataCode)
            ? flight.FlightNumber
            : $"{flight.CustomerIataCode.Trim().ToUpperInvariant()}-{flight.FlightNumber}";

    private static string ShortId(Guid id) => id.ToString("N")[..8].ToUpperInvariant();

    private async Task CopyAsync(string value)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", value);
            Notifications.Notify(NotificationSeverity.Success, UiStrings.Common.Copied);
        }
        catch (JSException)
        {
            // Clipboard may be unavailable in some browser contexts.
        }
    }

    private bool HasMoreActions(FlightDetail f) =>
        (CanInvite(f) && Auth.HasPermission(OperationsPermissions.FlightsInvite))
        || (CanMerge(f) && Auth.HasPermission(OperationsPermissions.FlightsMerge));

    private bool HasPotentialDuplicate(FlightDetail f) =>
        EffectiveDuplicateFlightId(f) is not null;

    private Guid? EffectiveDuplicateFlightId(FlightDetail f) =>
        PrimaryDuplicateCandidate(f)?.FlightId;

    private DuplicateCandidate? PrimaryDuplicateCandidate(FlightDetail f) =>
        duplicateCandidates.FirstOrDefault(x => x.FlightId != f.Id);

    private string PotentialDuplicateDisplay(FlightDetail f)
    {
        var candidate = PrimaryDuplicateCandidate(f);
        if (candidate is null)
            return "No";

        return $"{candidate.FlightNumber} · {candidate.Score}%";
    }

    private static bool CanEdit(FlightDetail f) => f.Status is "Scheduled";

    private static bool CanInvite(FlightDetail f) => f is { Status: "Scheduled", IsPerLanding: false };

    private static bool CanMerge(FlightDetail f) => f.Status is not "Completed" and not "Canceled" and not "Merged";
    private static bool CanAuthorWorkOrder(FlightDetail f) => f.Status is "Scheduled" or "InProgress";
    private static bool CanEditWorkOrder(WorkOrderSummaryModel workOrder) => workOrder.Status is "Submitted" or "Returned";
    private static bool CanApproveWorkOrder(WorkOrderSummaryModel workOrder) => workOrder.Status is "Submitted" or "Returned";
    private static bool CanReturnWorkOrder(WorkOrderSummaryModel workOrder) => workOrder.Status is "Approved";

    private static string DisplayWorkOrder(WorkOrderSummaryModel workOrder) =>
        string.IsNullOrWhiteSpace(workOrder.ApprovalNumber) ? ShortId(workOrder.Id) : workOrder.ApprovalNumber;

