@page "/operations/flights/{Id:guid}"
@inject OperationsApiClient Operations
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject AuthSession Auth
@inject IJSRuntime JS
@inject AuditApiClient AuditApi

<PageTitle>@(flight is null ? "Flight" : DisplayFlightNumber(flight))</PageTitle>

<RequirePermission Permission="@OperationsPermissions.FlightsView">
    <div class="os-detail-page">
        @if (isLoading)
        {
            <LoadingCard />
        }
        else if (loadError)
        {
            <ErrorState Message="Could not load the flight." OnRetry="@LoadAsync" />
        }
        else if (flight is not null)
        {
            <div class="ofd-workspace">
                <section class="ofd-profile @ProfileClass(flight)">
                    <div class="ofd-hero">
                        <div class="ofd-avatar @AvatarClass(flight)">
                            <RadzenIcon Icon="flight" />
                            <span class="ofd-avatar-dot @DotClass(flight.Status)"></span>
                        </div>

                        <div class="ofd-identity">
                            <div class="ofd-identity-headline">
                                <h1 class="ofd-name">@DisplayFlightNumber(flight)</h1>
                                <StatusBadge Label="@flight.Status" Tone="@FlightStatusTone(flight.Status)" />
                                @if (flight.IsPerLanding)
                                {
                                    <StatusBadge Label="Per landing" Tone="warning" />
                                }
                                @if (HasPotentialDuplicate(flight))
                                {
                                    <StatusBadge Label="Potential duplicate" Tone="warning" />
                                }
                                <span class="ofd-info-badge"><RadzenIcon Icon="settings" />@flight.OperationTypeName</span>
                            </div>

                            <div class="ofd-meta-row">
                                <span class="ofd-meta-pair"><RadzenIcon Icon="business" /><span>@flight.CustomerName</span></span>
                                <span class="ofd-meta-pair"><RadzenIcon Icon="flight_takeoff" /><span>@flight.StationIata</span></span>
                                <span class="ofd-meta-pair"><RadzenIcon Icon="schedule" /><span>@DateTimeDisplay(flight.ScheduledArrivalUtc) UTC</span></span>
                                <span class="ofd-meta-pair">
                                    <RadzenIcon Icon="id_card" />
                                    <span>@ShortId(flight.Id)</span>
                                    <button type="button" class="ofd-copy" title="Copy flight ID"
                                            aria-label="Copy flight ID" @onclick="@(() => CopyAsync(flight.Id.ToString()))">
                                        <RadzenIcon Icon="content_copy" />
                                    </button>
                                </span>
                            </div>
                        </div>

                        <div class="ofd-hero-actions">
                            <RadzenButton Text="Back" Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Click="@Back" />
                            @if (CanAuthorWorkOrder(flight) && Auth.HasPermission(OperationsPermissions.WorkOrdersAuthor))
                            {
                                <RadzenButton Text="Open work order" Icon="task_alt" ButtonStyle="ButtonStyle.Secondary" Click="@OpenCompletionWorkOrderAsync" />
                                <RadzenButton Text="Cancel flight" Icon="cancel" ButtonStyle="ButtonStyle.Light" Click="@OpenCancellationWorkOrderAsync" />
                            }
                            @if (CanEdit(flight) && Auth.HasPermission(OperationsPermissions.FlightsUpdate))
                            {
                                <RadzenButton Text="Edit flight" Icon="edit" ButtonStyle="ButtonStyle.Primary" Click="@OpenEditAsync" />
                            }
                            @if (HasMoreActions(flight))
                            {
                                <RowActionMenu ShowLabel="true" Label="Actions">
                                    <RowAction Text="Invite employee" Icon="person_add" Permission="@OperationsPermissions.FlightsInvite"
                                               Visible="@CanInvite(flight)" OnClick="@OpenInviteAsync" />
                                    <RowAction Text="Resolve duplicate" Icon="merge_type" Permission="@OperationsPermissions.FlightsMerge"
                                               Visible="@CanMerge(flight)" OnClick="@OpenMergeAsync" />
                                </RowActionMenu>
                            }
                        </div>
                    </div>

                    <nav class="ofd-tabs" role="tablist">
                        @foreach (var tab in Tabs())
                        {
                            <button type="button" role="tab" class="ofd-tab @(activeTab == tab.Key ? "ofd-tab--active" : "")"
                                    aria-selected="@(activeTab == tab.Key)" @onclick="@(() => activeTab = tab.Key)">
                                <RadzenIcon Icon="@tab.Icon" />
                                <span>@tab.Label</span>
                            </button>
                        }
                    </nav>
                </section>

                @if (EffectiveDuplicateFlightId(flight) is { } duplicateId)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Flat" ShowIcon="true" AllowClose="false" class="ofd-alert">
                        This flight has a likely duplicate candidate.
                        <RadzenButton Text="Resolve now" Icon="merge_type" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small"
                                      Click="@(() => OpenMergeAsync(duplicateId))" />
                    </RadzenAlert>
                }

                <div class="ofd-tab-body" role="tabpanel">
                    @(activeTab switch
                    {
                        FlightTab.Overview => OverviewTab(flight),
                        FlightTab.Services => ServicesTab(flight),
                        FlightTab.WorkOrders => WorkOrdersTab(flight),
                        FlightTab.Timeline => TimelineTab(),
                        FlightTab.History => HistoryTab(),
                        _ => OverviewTab(flight)
                    })
                </div>
            </div>
        }
    </div>
</RequirePermission>

@code {
    [Parameter] public Guid Id { get; set; }

    private FlightDetail? flight;
    private IReadOnlyList<FlightTimelineEntryModel> timeline = [];
    private IReadOnlyList<AuditTrailListItem> history = [];
    private IReadOnlyList<DuplicateCandidate> duplicateCandidates = [];
    private bool isLoading = true;
    private bool loadError;
    private FlightTab activeTab = FlightTab.Overview;

    private const int OverviewTimelinePreviewCount = 4;
    private const int OverviewHistoryPreviewCount = 4;

    private bool CanEditFlight => flight is { } f && CanEdit(f);
    private bool CanInviteFlight => flight is { } f && CanInvite(f);
    private bool CanMergeFlight => flight is { } f && CanMerge(f);
    private bool CanViewAudit => Auth.HasPermission(AuditPermissions.TrailsView);

    private enum FlightTab { Overview, Services, WorkOrders, Timeline, History }

    private sealed record TabDef(FlightTab Key, string Label, string Icon);

    private IEnumerable<TabDef> Tabs()
    {
        yield return new TabDef(FlightTab.Overview, "Overview", "dashboard");
        yield return new TabDef(FlightTab.Services, "Services & staff", "groups");
        if (Auth.HasPermission(OperationsPermissions.WorkOrdersView))
            yield return new TabDef(FlightTab.WorkOrders, "Work orders", "fact_check");
        yield return new TabDef(FlightTab.Timeline, "Timeline", "history");
        if (CanViewAudit)
            yield return new TabDef(FlightTab.History, UiStrings.Audit.HistoryTitle, "manage_history");
    }

    private RenderFragment OverviewTab(FlightDetail f) => @<text>
        <div class="ofd-stack">
            <div class="ofd-overview-grid">
                <RadzenCard class="ofd-card">
                    <div class="ofd-card-head"><RadzenIcon Icon="schedule" /><h3>Schedule</h3></div>
                    <div class="ofd-lead">
                        <span class="ofd-lead-icon"><RadzenIcon Icon="flight_land" /></span>
                        <div>
                            <p class="ofd-lead-title">@DateTimeDisplay(f.ScheduledArrivalUtc) UTC</p>
                            <p class="os-muted ofd-lead-desc">STA to STD @DateTimeDisplay(f.ScheduledDepartureUtc) UTC</p>
                        </div>
                    </div>
                    <dl class="ofd-metrics">
                        <div class="ofd-metric"><dt>Original flight #</dt><dd>@f.OriginalFlightNumber</dd></div>
                        <div class="ofd-metric"><dt>STA (UTC)</dt><dd>@DateTimeDisplay(f.ScheduledArrivalUtc)</dd></div>
                        <div class="ofd-metric"><dt>STD (UTC)</dt><dd>@DateTimeDisplay(f.ScheduledDepartureUtc)</dd></div>
                        <div class="ofd-metric"><dt>Aircraft type</dt><dd>@None(f.AircraftTypeModel)</dd></div>
                        <div class="ofd-metric"><dt>Contract</dt><dd>@None(f.ContractNumber)</dd></div>
                        <div class="ofd-metric"><dt>Updated</dt><dd>@DateTimeDisplay(f.UpdatedAtUtc)</dd></div>
                    </dl>
                </RadzenCard>

                <RadzenCard class="ofd-card">
                    <div class="ofd-card-head"><RadzenIcon Icon="settings" /><h3>Work scope</h3></div>
                    <div class="ofd-lead">
                        <span class="ofd-lead-icon"><RadzenIcon Icon="task_alt" /></span>
                        <div>
                            <p class="ofd-lead-title">@f.PlannedServices.Count planned service(s)</p>
                            <p class="os-muted ofd-lead-desc">@f.AssignedEmployees.Count assigned staff member(s)</p>
                        </div>
                    </div>
                    <dl class="ofd-metrics">
                        <div class="ofd-metric"><dt>Customer</dt><dd>@f.CustomerName</dd></div>
                        <div class="ofd-metric"><dt>Station</dt><dd>@f.StationIata</dd></div>
                        <div class="ofd-metric"><dt>Operation</dt><dd>@f.OperationTypeName</dd></div>
                        <div class="ofd-metric"><dt>Per landing</dt><dd>@(f.IsPerLanding ? "Yes" : "No")</dd></div>
                    </dl>
                    <button type="button" class="ofd-card-link" @onclick="@(() => activeTab = FlightTab.Services)">
                        <span>Open</span><RadzenIcon Icon="chevron_right" />
                    </button>
                </RadzenCard>

                <RadzenCard class="ofd-card">
                    <div class="ofd-card-head"><RadzenIcon Icon="info" /><h3>Flight state</h3></div>
                    <div class="ofd-lead">
                        <span class="ofd-lead-dot ofd-lead-dot--@FlightStatusTone(f.Status)"></span>
                        <div>
                            <p class="ofd-lead-title">@f.Status</p>
                            <p class="os-muted ofd-lead-desc">@FlightStatusDescription(f)</p>
                        </div>
                    </div>
                    <dl class="ofd-metrics">
                        <div class="ofd-metric"><dt>Potential duplicate</dt><dd>@PotentialDuplicateDisplay(f)</dd></div>
                        <div class="ofd-metric"><dt>Assigned staff</dt><dd>@f.AssignedEmployees.Count</dd></div>
                        <div class="ofd-metric"><dt>Planned services</dt><dd>@f.PlannedServices.Count</dd></div>
                        <div class="ofd-metric"><dt>Created</dt><dd>@DateTimeDisplay(f.CreatedAtUtc)</dd></div>
                    </dl>
                </RadzenCard>
            </div>

            <RadzenCard class="ofd-card">
                <div class="ofd-card-head">
                    <RadzenIcon Icon="history" /><h3>Timeline</h3>
                    @if (timeline.Count > 0)
                    {
                        <button type="button" class="ofd-link" @onclick="@(() => activeTab = FlightTab.Timeline)">View all</button>
                    }
                </div>
                <p class="os-muted ofd-card-intro">Operational lifecycle events for this flight.</p>
                @TimelineList(OverviewTimelinePreviewCount)
            </RadzenCard>

            @if (CanViewAudit)
            {
                <RadzenCard class="ofd-card">
                    <div class="ofd-card-head">
                        <RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3>
                        @if (history.Count > 0)
                        {
                            <button type="button" class="ofd-link" @onclick="@(() => activeTab = FlightTab.History)">@UiStrings.Common.ViewAll</button>
                        }
                    </div>
                    <p class="os-muted ofd-card-intro">@UiStrings.Audit.Description</p>
                    @HistoryList(OverviewHistoryPreviewCount)
                </RadzenCard>
            }
        </div>
    </text>;

    private RenderFragment ServicesTab(FlightDetail f) => @<text>
        <div class="ofd-grid-2">
            <RadzenCard class="ofd-card">
                <div class="ofd-card-head">
                    <RadzenIcon Icon="settings" /><h3>Planned services</h3>
                    <span class="ofd-count">@f.PlannedServices.Count</span>
                </div>
                @if (f.PlannedServices.Count == 0)
                {
                    <EmptyState Title="No planned services" Icon="settings" />
                }
                else
                {
                    <div class="ofd-list">
                        @foreach (var service in f.PlannedServices)
                        {
                            <div @key="service.ServiceId" class="ofd-list-row">
                                <span class="ofd-list-icon ofd-list-icon--blue"><RadzenIcon Icon="task_alt" /></span>
                                <div class="ofd-list-main">
                                    <p class="ofd-list-title">@service.Name</p>
                                    <p class="os-muted ofd-list-sub">@(service.IsAircraftPerLanding ? "Aircraft per landing" : "Scheduled service")</p>
                                </div>
                                @if (service.IsAircraftPerLanding)
                                {
                                    <StatusBadge Label="Per landing" Tone="warning" />
                                }
                            </div>
                        }
                    </div>
                }
            </RadzenCard>

            <RadzenCard class="ofd-card">
                <div class="ofd-card-head">
                    <RadzenIcon Icon="groups" /><h3>Assigned staff</h3>
                    <span class="ofd-count">@f.AssignedEmployees.Count</span>
                </div>
                @if (f.AssignedEmployees.Count == 0)
                {
                    <EmptyState Title="No assigned staff" Icon="groups" />
                }
                else
                {
                    <div class="ofd-list">
                        @foreach (var employee in f.AssignedEmployees)
                        {
                            <div @key="employee.StaffMemberId" class="ofd-list-row">
                                <span class="ofd-list-icon ofd-list-icon--green"><RadzenIcon Icon="badge" /></span>
                                <div class="ofd-list-main">
                                    <p class="ofd-list-title">@employee.FullName</p>
                                    <p class="os-muted ofd-list-sub">@employee.EmployeeId</p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </RadzenCard>
        </div>
    </text>;

    private RenderFragment TimelineTab() => @<text>
        <RadzenCard class="ofd-card">
            <div class="ofd-card-head"><RadzenIcon Icon="history" /><h3>Timeline</h3></div>
            <p class="os-muted ofd-card-intro">Operational lifecycle events for this flight.</p>
            @TimelineList()
        </RadzenCard>
    </text>;

    private RenderFragment WorkOrdersTab(FlightDetail f) => @<text>
        <RadzenCard class="ofd-card">
            <div class="ofd-card-head">
                <RadzenIcon Icon="fact_check" /><h3>Work orders</h3>
                <span class="ofd-count">@f.WorkOrders.Count</span>
            </div>
            @if (f.WorkOrders.Count == 0)
            {
                <EmptyState Title="No work orders" Icon="fact_check" />
            }
            else
            {
                <div class="ofd-list">
                    @foreach (var workOrder in f.WorkOrders)
                    {
                        <div @key="workOrder.Id" class="ofd-list-row">
                            <span class="ofd-list-icon @(workOrder.Type == "Cancellation" ? "ofd-list-icon--red" : "ofd-list-icon--green")">
                                <RadzenIcon Icon="@(workOrder.Type == "Cancellation" ? "cancel" : "task_alt")" />
                            </span>
                            <div class="ofd-list-main">
                                <p class="ofd-list-title">@DisplayWorkOrder(workOrder)</p>
                                <p class="os-muted ofd-list-sub">@workOrder.Type · @None(workOrder.OwnerName)</p>
                            </div>
                            <StatusBadge Label="@workOrder.Status" Tone="@WorkOrderStatusTone(workOrder.Status)" />
                            <RowActionMenu>
                                <RowAction Text="View" Icon="visibility" OnClick="@(() => OpenWorkOrderSummaryAsync(workOrder, true))" />
                                <RowAction Text="Edit" Icon="edit" Permission="@OperationsPermissions.WorkOrdersAuthor"
                                           Visible="@CanEditWorkOrder(workOrder)" OnClick="@(() => OpenWorkOrderSummaryAsync(workOrder, false))" />
                                <RowAction Text="Approve" Icon="task_alt" Permission="@OperationsPermissions.WorkOrdersApprove"
                                           Visible="@CanApproveWorkOrder(workOrder)" OnClick="@(() => ApproveWorkOrderAsync(workOrder))" />
                                <RowAction Text="Return" Icon="undo" Permission="@OperationsPermissions.WorkOrdersApprove"
                                           Visible="@CanReturnWorkOrder(workOrder)" OnClick="@(() => ReturnWorkOrderAsync(workOrder))" />
                            </RowActionMenu>
                        </div>
                    }
                </div>
            }
        </RadzenCard>
    </text>;

    private RenderFragment HistoryTab() => @<text>
        <RadzenCard class="ofd-card">
            <div class="ofd-card-head"><RadzenIcon Icon="manage_history" /><h3>@UiStrings.Audit.HistoryTitle</h3></div>
            <p class="os-muted ofd-card-intro">@UiStrings.Audit.Description</p>
            @HistoryList()
        </RadzenCard>
    </text>;

    private RenderFragment HistoryList(int? maxItems = null) => @<text>
        @if (history.Count == 0)
        {
            @HistoryEmpty()
        }
        else
        {
            <ol class="ofd-timeline">
                @foreach (var entry in maxItems is { } take ? history.Take(take) : history)
                {
                    var visual = HistoryVisual(entry.Action);
                    <li @key="entry.Id" class="ofd-timeline-item ofd-timeline-item--action">
                        <span class="ofd-timeline-icon ofd-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="ofd-timeline-text">
                            <p class="ofd-timeline-title">@entry.Action</p>
                            <p class="os-muted ofd-timeline-sub">
                                <span title="@entry.OccurredOnUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredOnUtc)</span>
                                <span class="ofd-dot-sep">&middot;</span>
                                @(entry.IsSystemActor ? UiStrings.Audit.System : (entry.ActorDisplayName ?? UiStrings.Common.None))
                            </p>
                        </div>
                        <RadzenButton Text="@UiStrings.Audit.ViewDetails" Icon="visibility"
                                      ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                      class="ofd-timeline-view" Click="@(() => OpenAuditDetailAsync(entry.Id))" />
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment TimelineList(int? maxItems = null) => @<text>
        @if (timeline.Count == 0)
        {
            @TimelineEmpty()
        }
        else
        {
            <ol class="ofd-timeline">
                @foreach (var entry in maxItems is { } take ? timeline.Take(take) : timeline)
                {
                    var visual = TimelineVisual(entry.EventType);
                    <li @key="entry.Id" class="ofd-timeline-item">
                        <span class="ofd-timeline-icon ofd-timeline-icon--@visual.Tone"><RadzenIcon Icon="@visual.Icon" /></span>
                        <div class="ofd-timeline-text">
                            <p class="ofd-timeline-title">@TimelineLabel(entry)</p>
                            <p class="os-muted ofd-timeline-sub">
                                <span title="@entry.OccurredAtUtc.ToLocalTime().ToString("F")">@RelativeTime(entry.OccurredAtUtc)</span>
                                <span class="ofd-dot-sep">&middot;</span>
                                @(entry.ActorName ?? "Administrator/System")
                            </p>
                        </div>
                    </li>
                }
            </ol>
        }
    </text>;

    private RenderFragment HistoryEmpty() => @<text>
        <div class="ofd-timeline-empty">
            <span class="ofd-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="ofd-timeline-title">@UiStrings.Common.NoData</p>
                <p class="os-muted ofd-timeline-sub">@UiStrings.Audit.Empty</p>
            </div>
        </div>
    </text>;

    private RenderFragment TimelineEmpty() => @<text>
        <div class="ofd-timeline-empty">
            <span class="ofd-timeline-icon"><RadzenIcon Icon="history_toggle_off" /></span>
            <div>
                <p class="ofd-timeline-title">No timeline events</p>
                <p class="os-muted ofd-timeline-sub">Flight activity will appear here as work progresses.</p>
            </div>
        </div>
    </text>;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        duplicateCandidates = [];
        history = [];
        try
        {
            var historyTask = LoadHistoryAsync();
            var loadedFlight = await Operations.GetFlightAsync(Id);
            var timelineTask = Operations.GetFlightTimelineAsync(Id);
            var duplicateTask = LoadDuplicateCandidatesAsync(loadedFlight);

            flight = loadedFlight;
            timeline = await timelineTask;
            duplicateCandidates = await duplicateTask;
            history = await historyTask;
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<IReadOnlyList<AuditTrailListItem>> LoadHistoryAsync()
    {
        if (!CanViewAudit)
            return [];

        try
        {
            var trails = await AuditApi.GetTrailsAsync(subjectType: "Flight", subjectId: Id, pageSize: 25);
            return trails.Items;
        }
        catch (ApiException)
        {
            return [];
        }
    }

    private async Task<IReadOnlyList<DuplicateCandidate>> LoadDuplicateCandidatesAsync(FlightDetail loadedFlight)
    {
        try
        {
            return await Operations.GetDuplicateCandidatesAsync(
                loadedFlight.CustomerId,
                loadedFlight.ScheduledArrivalUtc,
                loadedFlight.ScheduledDepartureUtc,
                loadedFlight.StationId,
                loadedFlight.Id);
        }
        catch (ApiException)
        {
            return [];
        }
    }

    private static string TimelineLabel(FlightTimelineEntryModel entry)
    {
        var label = entry.EventType switch
        {
            "FlightScheduled" => "Flight scheduled",
            "FlightUpdated" => "Flight updated",
            "FlightCompleted" => "Flight completed",
            "FlightCanceled" => "Flight canceled",
            "FlightReopened" => "Flight reopened",
            "WorkOrderSubmitted" => "Work order submitted",
            "FlightMerged" => "Flight merged",
            "EmployeeAssigned" => "Employee assigned",
            "EmployeeInvited" => "Employee invited",
            _ => HumanizeEventType(entry.EventType)
        };

        return string.IsNullOrWhiteSpace(entry.Details) ? label : $"{label}: {entry.Details}";
    }

    private static (string Icon, string Tone) TimelineVisual(string eventType)
    {
        var value = eventType.ToLowerInvariant();
        if (value.Contains("assign") || value.Contains("invite"))
            return ("person_add", "blue");
        if (value.Contains("schedule"))
            return ("flight", "green");
        if (value.Contains("complete"))
            return ("task_alt", "green");
        if (value.Contains("cancel"))
            return ("cancel", "red");
        if (value.Contains("merge") || value.Contains("duplicate"))
            return ("merge_type", "amber");
        if (value.Contains("update") || value.Contains("edit"))
            return ("edit", "neutral");
        return ("history", "neutral");
    }

    private static (string Icon, string Tone) HistoryVisual(string action)
    {
        var value = action.ToLowerInvariant();
        if (value.Contains("creat"))
            return ("flight", "green");
        if (value.Contains("updat") || value.Contains("edit"))
            return ("edit", "neutral");
        if (value.Contains("merge") || value.Contains("duplicate"))
            return ("merge_type", "amber");
        if (value.Contains("cancel"))
            return ("cancel", "red");
        if (value.Contains("complete"))
            return ("task_alt", "green");
        return ("manage_history", "neutral");
    }

    private void Back() => Navigation.NavigateTo("/operations/flights");

    private async Task OpenEditAsync()
    {
        if (!CanEditFlight)
            return;

        var result = await DialogService.OpenAsync<ScheduleFlightDialog>("Edit flight",
            new Dictionary<string, object?> { [nameof(ScheduleFlightDialog.FlightId)] = Id },
            new DialogOptions { Width = "760px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, "Flight updated");
            await LoadAsync();
        }
    }

    private async Task OpenInviteAsync()
    {
        if (!CanInviteFlight)
            return;

        var result = await DialogService.OpenAsync<FlightInviteDialog>("Invite employee",
            new Dictionary<string, object?> { [nameof(FlightInviteDialog.FlightId)] = Id },
            new DialogOptions { Width = "760px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, "Employee invited");
            await LoadAsync();
        }
    }

    private Task OpenCompletionWorkOrderAsync() => OpenWorkOrderAsync("Completion");
    private Task OpenCancellationWorkOrderAsync() => OpenWorkOrderAsync("Cancellation");

    private async Task OpenWorkOrderAsync(string type)
    {
        if (flight is null)
            return;

        try
        {
            var mine = await Operations.GetMyWorkOrderForFlightAsync(flight.Id);
            var viewOnly = mine?.Status == "Approved";
            if (mine is not null && mine.Type != type && !viewOnly)
            {
                var confirmed = await DialogService.Confirm(
                    $"You already have a {mine.Type} work order for this flight. Convert it to {type}?",
                    "Convert work order",
                    new ConfirmOptions { OkButtonText = "Convert", CancelButtonText = "Cancel" });
                if (confirmed is not true)
                    return;
            }

            var result = await DialogService.OpenAsync<WorkOrderEditorDialog>(
                viewOnly ? "Work order" : $"{type} work order",
                new Dictionary<string, object?>
                {
                    [nameof(WorkOrderEditorDialog.FlightId)] = flight.Id,
                    [nameof(WorkOrderEditorDialog.WorkOrderId)] = mine?.Id,
                    [nameof(WorkOrderEditorDialog.Type)] = type,
                    [nameof(WorkOrderEditorDialog.ViewOnly)] = viewOnly
                },
                new DialogOptions { Width = "980px" });

            if (result is true)
            {
                Notifications.Notify(NotificationSeverity.Success, "Work order saved");
                await LoadAsync();
            }
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, "Work order unavailable", ex.ToDisplayMessage("Could not open the work order."));
        }
    }

    private async Task OpenWorkOrderSummaryAsync(WorkOrderSummaryModel summary, bool viewOnly)
    {
        var result = await DialogService.OpenAsync<WorkOrderEditorDialog>(
            viewOnly ? "Work order" : "Edit work order",
            new Dictionary<string, object?>
            {
                [nameof(WorkOrderEditorDialog.WorkOrderId)] = summary.Id,
                [nameof(WorkOrderEditorDialog.Type)] = summary.Type,
                [nameof(WorkOrderEditorDialog.ViewOnly)] = viewOnly
            },
            new DialogOptions { Width = "980px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, "Work order updated");
            await LoadAsync();
        }
    }

    private async Task ApproveWorkOrderAsync(WorkOrderSummaryModel summary)
    {
        try
        {
            await Operations.ApproveWorkOrderAsync(summary.Id, summary.RowVersion);
            Notifications.Notify(NotificationSeverity.Success, "Work order approved");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, "Approval failed", ex.ToDisplayMessage("Could not approve the work order."));
        }
    }

    private async Task ReturnWorkOrderAsync(WorkOrderSummaryModel summary)
    {
        var reason = await DialogService.OpenAsync<WorkOrderReturnDialog>(
            "Return work order",
            null,
            new DialogOptions { Width = "520px" });
        if (reason is not string value || string.IsNullOrWhiteSpace(value))
            return;

        try
        {
            await Operations.ReturnWorkOrderAsync(summary.Id, new ReturnWorkOrderRequestModel(value), summary.RowVersion);
            Notifications.Notify(NotificationSeverity.Success, "Work order returned");
            await LoadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, "Return failed", ex.ToDisplayMessage("Could not return the work order."));
        }
    }

