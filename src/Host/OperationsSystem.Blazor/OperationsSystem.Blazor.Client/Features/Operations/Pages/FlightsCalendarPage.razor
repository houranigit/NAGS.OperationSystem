@page "/operations/calendar"
@inject OperationsApiClient Operations
@inject MasterDataApiClient MasterData
@inject NavigationManager Navigation
@inject NotificationService Notifications
@inject AuthSession Auth
@using OperationsSystem.Blazor.Client.Features.Operations

<PageTitle>Flight calendar</PageTitle>

<RequirePermission Permission="@OperationsPermissions.FlightsView">
    <div class="os-list-page">
        <PageHeader Title="Flight calendar" Description="Scheduled flights in your scope. Click a flight to open it.">
            <Actions>
                <div class="ofc-filters">
                    <RadzenDropDown TValue="string" Data="@statusOptions" TextProperty="Label" ValueProperty="Value"
                                    Value="@statusFilter" ValueChanged="@OnStatusFilterChangedAsync"
                                    AllowClear="true" Placeholder="All statuses" class="ofc-filter" />
                    <RadzenDropDown TValue="Guid?" Data="@stationOptions" TextProperty="Label" ValueProperty="Value"
                                    Value="@stationFilter" ValueChanged="@OnStationFilterChangedAsync"
                                    AllowClear="true" Placeholder="All stations" class="ofc-filter" />
                    <RadzenDropDown TValue="Guid?" Data="@customerOptions" TextProperty="Label" ValueProperty="Value"
                                    Value="@customerFilter" ValueChanged="@OnCustomerFilterChangedAsync"
                                    AllowClear="true" AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    Placeholder="All customers" class="ofc-filter" />
                </div>
            </Actions>
        </PageHeader>

        @if (loadError)
        {
            <ErrorState Message="Could not load the calendar." OnRetry="@ReloadAsync" />
        }
        else
        {
            <RadzenCard class="ofc-card">
                <div class="ofc-calendar-toolbar">
                    <div class="ofc-calendar-nav">
                        <button type="button" class="ofc-icon-button" @onclick="@(() => MoveRangeAsync(-1))">
                            <RadzenIcon Icon="chevron_left" />
                        </button>
                        <button type="button" class="ofc-icon-button" @onclick="@(() => MoveRangeAsync(1))">
                            <RadzenIcon Icon="chevron_right" />
                        </button>
                        <button type="button" class="ofc-today-button" @onclick="@GoTodayAsync">Today</button>
                    </div>
                    <strong class="ofc-range-label">@CalendarRangeLabel</strong>
                    <div class="ofc-view-tabs">
                        <button type="button" class="@ViewButtonClass(CalendarViewMode.Agenda)" @onclick="@(() => SelectViewAsync(CalendarViewMode.Agenda))">
                            <RadzenIcon Icon="view_agenda" />
                            <span>Agenda</span>
                        </button>
                        <button type="button" class="@ViewButtonClass(CalendarViewMode.Day)" @onclick="@(() => SelectViewAsync(CalendarViewMode.Day))">
                            <RadzenIcon Icon="calendar_view_day" />
                            <span>Day</span>
                        </button>
                        <button type="button" class="@ViewButtonClass(CalendarViewMode.Month)" @onclick="@(() => SelectViewAsync(CalendarViewMode.Month))">
                            <RadzenIcon Icon="calendar_month" />
                            <span>Month</span>
                        </button>
                    </div>
                </div>

                @if (activeView is CalendarViewMode.Agenda or CalendarViewMode.Day)
                {
                    <div class="@CalendarListClass">
                        @if (items.Count == 0)
                        {
                            <div class="ofc-agenda-empty">
                                <RadzenIcon Icon="event_busy" />
                                <strong>@CalendarEmptyMessage</strong>
                            </div>
                        }
                        else
                        {
                            @foreach (var group in CalendarGroups)
                            {
                                <section class="@CalendarDayClass" @key="group.Key">
                                    <div class="ofc-agenda-date">
                                        <strong>@group.Key.ToString("dd")</strong>
                                        <span>@group.Key.ToString("ddd")</span>
                                    </div>
                                    <div class="ofc-agenda-items">
                                        @foreach (var item in group)
                                        {
                                            <button type="button"
                                                    class="ofc-agenda-action"
                                                    data-ofc-status="@StatusTone(item.Status)"
                                                    @key="item.FlightId"
                                                    @onclick="@(() => OpenFlight(item.FlightId))">
                                                @RenderAppointment(item)
                                            </button>
                                        }
                                    </div>
                                </section>
                            }
                        }
                    </div>
                }
                else
                {
                    <RadzenScheduler @key="activeView" TItem="CalendarItem" Data="@items" class="ofc-scheduler"
                                     StartProperty="Start" EndProperty="End" TextProperty="Text"
                                     Date="@visibleDate" ShowHeader="false"
                                     LoadData="@OnLoadDataAsync"
                                     AppointmentSelect="@OnAppointmentSelect" AppointmentRender="@OnAppointmentRender">
                        <Template Context="item">
                            @RenderAppointment(item)
                        </Template>
                        <ChildContent>
                            <RadzenMonthView />
                        </ChildContent>
                    </RadzenScheduler>
                }

                <div class="ofc-legend">
                    <span class="ofc-legend-item"><span class="ofc-dot ofc-dot-scheduled"></span> Scheduled</span>
                    <span class="ofc-legend-item"><span class="ofc-dot ofc-dot-inprogress"></span> In progress</span>
                    <span class="ofc-legend-item"><span class="ofc-dot ofc-dot-completed"></span> Completed</span>
                    <span class="ofc-legend-item"><span class="ofc-dot ofc-dot-canceled"></span> Canceled</span>
                </div>
            </RadzenCard>
        }
    </div>
</RequirePermission>

@code {
    private IReadOnlyList<CalendarItem> items = [];
    private IReadOnlyList<StationFilterOption> stationOptions = [];
    private IReadOnlyList<CustomerFilterOption> customerOptions = [];
    private Guid? stationFilter;
    private Guid? customerFilter;
    private string? statusFilter;
    private CalendarViewMode activeView = CalendarViewMode.Agenda;
    private DateTime visibleDate = DateTime.UtcNow.Date;
    private DateTime rangeStart = DateTime.UtcNow.Date;
    private DateTime rangeEnd = DateTime.UtcNow.Date.AddDays(7);
    private bool loadError;
    private readonly IReadOnlyList<StatusFilterOption> statusOptions =
    [
        new("Scheduled", "Scheduled"),
        new("In progress", "InProgress"),
        new("Completed", "Completed"),
        new("Canceled", "Canceled")
    ];

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(
            LoadStationOptionsAsync(),
            LoadCustomerOptionsAsync());

        SetRangeForCurrentView();
        await FetchAsync();
    }

    private IEnumerable<IGrouping<DateTime, CalendarItem>> CalendarGroups =>
        items.OrderBy(x => x.Start).GroupBy(x => activeView == CalendarViewMode.Day ? visibleDate.Date : x.Start.Date);

    private string CalendarListClass =>
        activeView == CalendarViewMode.Day ? "ofc-agenda ofc-day-list" : "ofc-agenda";

    private string CalendarDayClass =>
        activeView == CalendarViewMode.Day ? "ofc-agenda-day ofc-agenda-day-single" : "ofc-agenda-day";

    private string CalendarEmptyMessage =>
        activeView == CalendarViewMode.Day ? "No flights scheduled for this day." : "No flights match your filters.";

    private string CalendarRangeLabel
    {
        get
        {
            var (start, endExclusive) = GetRange(activeView, visibleDate);
            if (activeView == CalendarViewMode.Day)
                return start.ToString("M/d/yyyy");

            if (activeView == CalendarViewMode.Month)
                return start.ToString("MMMM yyyy");

            return $"{start:M/d/yyyy} - {endExclusive.AddDays(-1):M/d/yyyy}";
        }
    }

    private bool CanLoadLookup(string resourceViewPermission) =>
        Auth.HasPermission(MasterDataPermissions.ReferenceViewOptions) || Auth.HasPermission(resourceViewPermission);

    private async Task LoadStationOptionsAsync()
    {
        if (!CanLoadLookup(MasterDataPermissions.StationsView))
            return;

        try
        {
            stationOptions = (await MasterData.GetStationOptionsAsync())
                .Select(x => new StationFilterOption($"{x.IataCode} · {x.Name}", x.Id))
                .ToList();
        }
        catch (ApiException)
        {
            stationOptions = [];
        }
    }

    private async Task LoadCustomerOptionsAsync()
    {
        if (!CanLoadLookup(MasterDataPermissions.CustomersView))
            return;

        try
        {
            customerOptions = (await MasterData.GetCustomerOptionsAsync())
                .Select(x => new CustomerFilterOption(CustomerFilterLabel(x), x.Id))
                .ToList();
        }
        catch (ApiException)
        {
            customerOptions = [];
        }
    }

    private async Task OnLoadDataAsync(SchedulerLoadDataEventArgs args)
    {
        rangeStart = args.Start;
        rangeEnd = args.End;
        await FetchAsync();
    }

    private async Task SelectViewAsync(CalendarViewMode view)
    {
        if (activeView == view)
            return;

        activeView = view;
        await RefreshCurrentViewAsync();
    }

    private async Task MoveRangeAsync(int direction)
    {
        visibleDate = activeView switch
        {
            CalendarViewMode.Day => visibleDate.AddDays(direction),
            CalendarViewMode.Month => visibleDate.AddMonths(direction),
            _ => visibleDate.AddDays(direction * 7)
        };

        await RefreshCurrentViewAsync();
    }

    private async Task GoTodayAsync()
    {
        visibleDate = DateTime.UtcNow.Date;
        await RefreshCurrentViewAsync();
    }

    private async Task OnStationFilterChangedAsync(Guid? value)
    {
        stationFilter = value;
        await FetchAsync();
    }

    private async Task OnCustomerFilterChangedAsync(Guid? value)
    {
        customerFilter = value;
        await FetchAsync();
    }

    private async Task OnStatusFilterChangedAsync(string? value)
    {
        statusFilter = value;
        await FetchAsync();
    }

    private async Task ReloadAsync() => await FetchAsync();

    private async Task RefreshCurrentViewAsync()
    {
        SetRangeForCurrentView();
        await FetchAsync();
    }

    private void SetRangeForCurrentView() => (rangeStart, rangeEnd) = GetRange(activeView, visibleDate);

    private static (DateTime Start, DateTime End) GetRange(CalendarViewMode view, DateTime date)
    {
        var day = date.Date;
        return view switch
        {
            CalendarViewMode.Day => (day, day.AddDays(1)),
            CalendarViewMode.Month => (new DateTime(day.Year, day.Month, 1), new DateTime(day.Year, day.Month, 1).AddMonths(1)),
            _ => (StartOfWeek(day), StartOfWeek(day).AddDays(7))
        };
    }

    private static DateTime StartOfWeek(DateTime date) => date.Date.AddDays(-(int)date.DayOfWeek);

    private async Task FetchAsync()
    {
        loadError = false;
        try
        {
            var flights = await Operations.GetCalendarAsync(
                new DateTimeOffset(DateTime.SpecifyKind(rangeStart, DateTimeKind.Utc)),
                new DateTimeOffset(DateTime.SpecifyKind(rangeEnd, DateTimeKind.Utc)),
                stationFilter,
                customerFilter,
                statusFilter);

            items = flights.Select(ToCalendarItem).ToList();
        }
        catch (ApiException)
        {
            loadError = true;
        }

        StateHasChanged();
    }

    private void OnAppointmentSelect(SchedulerAppointmentSelectEventArgs<CalendarItem> args)
    {
        if (args.Data is { } item)
            OpenFlight(item.FlightId);
    }

    private void OpenFlight(Guid flightId) => Navigation.NavigateTo($"/operations/flights/{flightId}");

    private void OnAppointmentRender(SchedulerAppointmentRenderEventArgs<CalendarItem> args)
    {
        if (args.Data is not { } item)
            return;

        args.Attributes["data-ofc-status"] = StatusTone(item.Status);
    }

    private static CalendarItem ToCalendarItem(CalendarFlight flight)
    {
        var flightNumber = DisplayFlightNumber(flight);
        var start = flight.ScheduledArrivalUtc.UtcDateTime;
        var end = flight.ScheduledDepartureUtc.UtcDateTime;
        var text = $"{flightNumber} · {StationLine(flight.StationName, flight.IsPerLanding, flight.IsOnCall)}";
        return new CalendarItem(flight.Id, text, flightNumber, flight.CustomerName, flight.StationName, start, end, flight.Status, flight.IsPerLanding, flight.IsOnCall);
    }

    private static string DisplayFlightNumber(CalendarFlight flight) =>
        string.IsNullOrWhiteSpace(flight.CustomerIataCode)
            ? flight.FlightNumber
            : $"{flight.CustomerIataCode.Trim().ToUpperInvariant()}-{flight.FlightNumber}";

    private static string CustomerFilterLabel(CustomerOption customer) =>
        string.IsNullOrWhiteSpace(customer.IataCode)
            ? customer.Name
            : $"{customer.IataCode.Trim().ToUpperInvariant()} · {customer.Name}";

    private static string StationLine(string stationName, bool isPerLanding, bool isOnCall) =>
        FlightServicePresentation.Badge(isPerLanding, isOnCall) is { } serviceBadge
            ? $"{stationName} · {serviceBadge.Label}"
            : stationName;

    private static string TimeDisplay(DateTime value) => value.ToString("h:mm tt");

    private static string StatusLabel(string status) => status switch
    {
        "Scheduled" => "Scheduled",
        "InProgress" => "In progress",
        "Completed" => "Completed",
        "Canceled" => "Canceled",
        "Merged" => "Merged",
        _ when !string.IsNullOrWhiteSpace(status) => status,
        _ => "Scheduled"
    };

    private static string StatusTone(string status) => status switch
    {
        "InProgress" => "inprogress",
        "Completed" => "completed",
        "Canceled" or "Merged" => "canceled",
        _ => "scheduled"
    };

    private string ViewButtonClass(CalendarViewMode view) =>
        activeView == view ? "ofc-view-tab ofc-view-tab-active" : "ofc-view-tab";

    private RenderFragment RenderAppointment(CalendarItem item) => @<div class="ofc-appointment">
        <span class="ofc-flight-icon"><RadzenIcon Icon="flight" /></span>
        <div class="ofc-flight-main">
            <div class="ofc-flight-heading">
                <strong>@item.FlightNumberDisplay</strong>
                @if (FlightServicePresentation.Badge(item.IsPerLanding, item.IsOnCall) is { } serviceBadge)
                {
                    <span class="ofc-heading-sep">•</span>
                    <span class="ofc-per-landing">@serviceBadge.Label</span>
                }
            </div>
            <span class="ofc-station-name">@item.StationName</span>
        </div>
        <div class="ofc-time-cell">
            <span>From</span>
            <strong>@TimeDisplay(item.Start)</strong>
        </div>
        <div class="ofc-time-cell">
            <span>To</span>
            <strong>@TimeDisplay(item.End)</strong>
        </div>
        <span class="ofc-status-pill ofc-status-pill--@StatusTone(item.Status)">
            <span class="ofc-status-dot"></span>
            @StatusLabel(item.Status)
        </span>
        <span class="ofc-agenda-more"><RadzenIcon Icon="more_vert" /></span>
    </div>;

    private enum CalendarViewMode
    {
        Agenda,
        Day,
        Month
    }

    private sealed record CalendarItem(
        Guid FlightId,
        string Text,
        string FlightNumberDisplay,
        string CustomerName,
        string StationName,
        DateTime Start,
        DateTime End,
        string Status,
        bool IsPerLanding,
        bool IsOnCall);

    private sealed record StatusFilterOption(string Label, string Value);
    private sealed record StationFilterOption(string Label, Guid? Value);
    private sealed record CustomerFilterOption(string Label, Guid? Value);
}
