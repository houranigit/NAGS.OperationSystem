@page "/operations/staff-allocation"

<PageTitle>Staff allocation</PageTitle>

<RequirePermission Permission="@MasterDataPermissions.StaffAllocationView">
    <div class="os-list-page sa-page">
        <PageHeader Eyebrow="Resource planning"
                    Title="Staff allocation"
                    Description="Compare capability coverage across stations and permanently reassign staff where they are needed.">
            <Actions>
                <RadzenButton Text="Refresh data" Icon="refresh" ButtonStyle="ButtonStyle.Light"
                              Disabled="@(isLoading || isMoving)" Click="@ReloadAsync" />
            </Actions>
        </PageHeader>

        @if (!Auth.HasGlobalReadScope)
        {
            <ErrorState Message="Staff allocation across stations requires global read access." />
        }
        else if (isLoading && overview is null)
        {
            <LoadingCard Message="Loading station coverage and staff qualifications..." />
        }
        else if (loadError && overview is null)
        {
            <ErrorState Message="Could not load staff allocation data." OnRetry="@ReloadAsync" />
        }
        else if (overview is { } allocation)
        {
            @if (!CanReassignStaff)
            {
                <div class="sa-inline-alert sa-inline-alert--info">
                    <RadzenIcon Icon="visibility" />
                    <span>You have read-only allocation access. The reassign permission is required to move an employee.</span>
                </div>
            }

            @if (loadError)
            {
                <div class="sa-inline-alert sa-inline-alert--danger">
                    <RadzenIcon Icon="error_outline" />
                    <span>Coverage could not be refreshed. The last successful view is still shown.</span>
                    <button type="button" @onclick="ReloadAsync">Try again</button>
                </div>
            }

            <section class="sa-summary-grid" aria-label="Allocation summary">
                <article class="sa-summary-card sa-summary-card--primary">
                    <span class="sa-summary-icon"><RadzenIcon Icon="flight_takeoff" /></span>
                    <div>
                        <span>Active stations</span>
                        <strong>@allocation.Stations.Count</strong>
                        <small>Available destinations</small>
                    </div>
                </article>
                <article class="sa-summary-card sa-summary-card--blue">
                    <span class="sa-summary-icon"><RadzenIcon Icon="groups" /></span>
                    <div>
                        <span>Active staff</span>
                        <strong>@allocation.StaffMembers.Count</strong>
                        <small>Across all stations</small>
                    </div>
                </article>
                <article class="sa-summary-card sa-summary-card--green">
                    <span class="sa-summary-icon"><RadzenIcon Icon="engineering" /></span>
                    <div>
                        <span>Manpower types</span>
                        <strong>@TotalManpowerTypes</strong>
                        <small>Capabilities represented</small>
                    </div>
                </article>
                <article class="sa-summary-card sa-summary-card--amber">
                    <span class="sa-summary-icon"><RadzenIcon Icon="workspace_premium" /></span>
                    <div>
                        <span>License types</span>
                        <strong>@TotalLicenseTypes</strong>
                        <small>Qualifications represented</small>
                    </div>
                </article>
            </section>

            <section class="sa-coverage-card">
                <div class="sa-section-head">
                    <div>
                        <p class="sa-kicker">Coverage explorer</p>
                        <h2>Find the capability you need</h2>
                        <p>Filter by manpower or license to see where qualified employees are currently based.</p>
                    </div>
                    @if (HasFilters)
                    {
                        <button type="button" class="sa-clear-button" @onclick="ClearFilters">
                            <RadzenIcon Icon="filter_alt_off" />
                            Clear filters
                        </button>
                    }
                </div>

                <div class="sa-filter-bar">
                    <label class="sa-search-field">
                        <RadzenIcon Icon="search" />
                        <input type="search" placeholder="Search name, employee ID, or qualification"
                               @bind="searchTerm" @bind:event="oninput" />
                    </label>
                    <RadzenDropDown TValue="Guid?" Data="@ManpowerOptions" TextProperty="Label" ValueProperty="Value"
                                    @bind-Value="manpowerFilter" AllowClear="true" AllowFiltering="true"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    Placeholder="All manpower types" class="sa-filter" />
                    <RadzenDropDown TValue="Guid?" Data="@LicenseOptions" TextProperty="Label" ValueProperty="Value"
                                    @bind-Value="licenseFilter" AllowClear="true" AllowFiltering="true"
                                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                    Placeholder="All licenses" class="sa-filter" />
                </div>

                @if (allocation.Stations.Count == 0)
                {
                    <EmptyState Icon="flight_takeoff" Title="No active stations"
                                Description="Activate a station before allocating staff." />
                }
                else
                {
                    <div class="sa-station-grid">
                        @foreach (var station in allocation.Stations)
                        {
                            var staffCount = StationStaff(station.Id).Count;
                            var matchCount = StationMatchingStaff(station.Id).Count;
                            <button type="button" class="@StationCardClass(station.Id)" @key="station.Id"
                                    @onclick="@(() => SelectStation(station.Id))">
                                <span class="sa-station-card-head">
                                    <span class="sa-station-code">@station.IataCode</span>
                                    @if (selectedStationId == station.Id)
                                    {
                                        <span class="sa-selected-label"><RadzenIcon Icon="check" /> Selected</span>
                                    }
                                    else
                                    {
                                        <RadzenIcon Icon="arrow_forward" class="sa-station-arrow" />
                                    }
                                </span>
                                <span class="sa-station-name">@station.Name</span>
                                @if (!string.IsNullOrWhiteSpace(station.City))
                                {
                                    <span class="sa-station-city">@station.City</span>
                                }
                                <span class="sa-station-focus">
                                    <strong>@(HasFilters ? matchCount : staffCount)</strong>
                                    <span>@(HasFilters ? "matching staff" : "active employees")</span>
                                </span>
                                <span class="sa-station-facts">
                                    <span title="Manpower types"><RadzenIcon Icon="engineering" /> @StationManpowerCount(station.Id)</span>
                                    <span title="License types"><RadzenIcon Icon="workspace_premium" /> @StationLicenseCount(station.Id)</span>
                                </span>
                                <span class="sa-capability-row">
                                    @foreach (var item in TopManpower(station.Id))
                                    {
                                        <span class="sa-capability-chip" @key="item.Name">@item.Name <strong>@item.Count</strong></span>
                                    }
                                    @if (staffCount == 0)
                                    {
                                        <span class="sa-capability-empty">No staff assigned</span>
                                    }
                                </span>
                            </button>
                        }
                    </div>
                }
            </section>

            @if (SelectedStation is { } sourceStation)
            {
                <section class="sa-workspace">
                    <div class="sa-candidates-card">
                        <div class="sa-workspace-head">
                            <div class="sa-station-identity">
                                <span class="sa-code-tile">@sourceStation.IataCode</span>
                                <div>
                                    <p class="sa-kicker">Source station</p>
                                    <h2>@sourceStation.Name</h2>
                                    <p>@CandidateSummary</p>
                                </div>
                            </div>
                            <span class="sa-roster-count">@FilteredCandidates.Count() shown</span>
                        </div>

                        @if (!FilteredCandidates.Any())
                        {
                            <div class="sa-local-empty">
                                <span><RadzenIcon Icon="person_search" /></span>
                                <strong>No matching staff at @sourceStation.IataCode</strong>
                                <p>Try another station or clear the qualification filters.</p>
                                @if (HasFilters)
                                {
                                    <button type="button" class="sa-secondary-button" @onclick="ClearFilters">Clear filters</button>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="sa-candidate-list">
                                @foreach (var member in FilteredCandidates)
                                {
                                    <button type="button" class="@CandidateCardClass(member.Id)" @key="member.Id"
                                            @onclick="@(() => SelectMember(member.Id))">
                                        <span class="sa-person-avatar">@Initials(member.FullName)</span>
                                        <span class="sa-person-main">
                                            <span class="sa-person-heading">
                                                <strong>@member.FullName</strong>
                                                <span class="sa-employee-id">@member.EmployeeId</span>
                                            </span>
                                            <span class="sa-person-skills">
                                                <span class="sa-manpower-chip"><RadzenIcon Icon="engineering" /> @member.ManpowerTypeName</span>
                                                @foreach (var license in member.Licenses.Take(3))
                                                {
                                                    <span class="sa-license-chip" title="@($"{license.Name} · {license.LicenseNumber}")" @key="license.LicenseId">
                                                        @license.Code
                                                    </span>
                                                }
                                                @if (member.Licenses.Count > 3)
                                                {
                                                    <span class="sa-more-chip">+@(member.Licenses.Count - 3)</span>
                                                }
                                                @if (member.Licenses.Count == 0)
                                                {
                                                    <span class="sa-no-license">No licenses recorded</span>
                                                }
                                            </span>
                                        </span>
                                        <span class="sa-select-action">
                                            <span>@(selectedMemberId == member.Id ? "Selected" : "Plan move")</span>
                                            <RadzenIcon Icon="arrow_forward" />
                                        </span>
                                    </button>
                                }
                            </div>
                        }
                    </div>

                    <aside class="sa-planner-card">
                        @if (SelectedMember is not { } selectedMember)
                        {
                            <div class="sa-planner-empty">
                                <span class="sa-planner-empty-icon"><RadzenIcon Icon="move_up" /></span>
                                <p class="sa-kicker">Transfer planner</p>
                                <h2>Select an employee</h2>
                                <p>Choose a staff member to compare station coverage before confirming a move.</p>
                                <ol>
                                    <li><span>1</span> Select a source station</li>
                                    <li><span>2</span> Choose an employee</li>
                                    <li><span>3</span> Review the destination impact</li>
                                </ol>
                            </div>
                        }
                        else
                        {
                            <div class="sa-planner-head">
                                <div>
                                    <p class="sa-kicker">Transfer planner</p>
                                    <h2>Plan reassignment</h2>
                                </div>
                                <span class="sa-permanent-badge"><RadzenIcon Icon="info" /> Permanent move</span>
                            </div>

                            <div class="sa-selected-person">
                                <span class="sa-person-avatar sa-person-avatar--large">@Initials(selectedMember.FullName)</span>
                                <div>
                                    <strong>@selectedMember.FullName</strong>
                                    <span>@selectedMember.EmployeeId · @selectedMember.ManpowerTypeName</span>
                                </div>
                            </div>

                            <div class="sa-route-picker">
                                <div class="sa-route-stop">
                                    <span>From</span>
                                    <strong>@sourceStation.IataCode</strong>
                                    <small>@sourceStation.Name</small>
                                </div>
                                <span class="sa-route-arrow"><RadzenIcon Icon="arrow_forward" /></span>
                                <div class="sa-route-stop sa-route-stop--destination">
                                    <label for="staff-allocation-destination">To station</label>
                                    <RadzenDropDown TValue="Guid?" Data="@DestinationOptions" TextProperty="Label" ValueProperty="Value"
                                                    @bind-Value="destinationStationId" Placeholder="Select destination"
                                                    AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                                    InputAttributes="@(new Dictionary<string, object> { ["id"] = "staff-allocation-destination" })"
                                                    class="sa-destination-select" />
                                </div>
                            </div>

                            <div class="sa-qualification-block">
                                <span>Qualifications moving with employee</span>
                                <div>
                                    <span class="sa-manpower-chip"><RadzenIcon Icon="engineering" /> @selectedMember.ManpowerTypeName</span>
                                    @foreach (var license in selectedMember.Licenses)
                                    {
                                        <span class="sa-license-chip" title="@license.Name" @key="license.LicenseId">@license.Code</span>
                                    }
                                    @if (selectedMember.Licenses.Count == 0)
                                    {
                                        <span class="sa-no-license">No licenses recorded</span>
                                    }
                                </div>
                            </div>

                            @if (SelectedDestination is { } destination)
                            {
                                <div class="sa-impact-block">
                                    <div class="sa-impact-head">
                                        <div>
                                            <span>Coverage impact</span>
                                            <small>Projected immediately after reassignment</small>
                                        </div>
                                        <RadzenIcon Icon="analytics" />
                                    </div>

                                    <div class="sa-impact-grid">
                                        <div>
                                            <span>@sourceStation.IataCode headcount</span>
                                            <p><strong>@StationStaff(sourceStation.Id).Count</strong><RadzenIcon Icon="arrow_forward" /><strong>@(StationStaff(sourceStation.Id).Count - 1)</strong></p>
                                        </div>
                                        <div class="sa-impact-gain">
                                            <span>@destination.IataCode headcount</span>
                                            <p><strong>@StationStaff(destination.Id).Count</strong><RadzenIcon Icon="arrow_forward" /><strong>@(StationStaff(destination.Id).Count + 1)</strong></p>
                                        </div>
                                        <div>
                                            <span>@sourceStation.IataCode · @selectedMember.ManpowerTypeName</span>
                                            <p><strong>@ManpowerHolderCount(sourceStation.Id, selectedMember.ManpowerTypeId)</strong><RadzenIcon Icon="arrow_forward" /><strong>@(ManpowerHolderCount(sourceStation.Id, selectedMember.ManpowerTypeId) - 1)</strong></p>
                                        </div>
                                        <div class="sa-impact-gain">
                                            <span>@destination.IataCode · @selectedMember.ManpowerTypeName</span>
                                            <p><strong>@ManpowerHolderCount(destination.Id, selectedMember.ManpowerTypeId)</strong><RadzenIcon Icon="arrow_forward" /><strong>@(ManpowerHolderCount(destination.Id, selectedMember.ManpowerTypeId) + 1)</strong></p>
                                        </div>
                                    </div>

                                    @if (SourceCoverageWarnings.Count > 0)
                                    {
                                        <div class="sa-risk-alert">
                                            <RadzenIcon Icon="warning_amber" />
                                            <div>
                                                <strong>Single-holder coverage risk</strong>
                                                <p>Moving @selectedMember.FullName will leave @sourceStation.IataCode with no coverage for @string.Join(", ", SourceCoverageWarnings).</p>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="sa-safe-alert">
                                            <RadzenIcon Icon="verified" />
                                            <span>@sourceStation.IataCode retains another holder for this manpower type and every listed license.</span>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="sa-planner-hint">
                                    <RadzenIcon Icon="touch_app" />
                                    <span>Select a destination to preview the headcount and capability impact.</span>
                                </div>
                            }

                            @if (CanReassignStaff)
                            {
                                <button type="button" class="sa-primary-action"
                                        disabled="@(SelectedDestination is null || isMoving)"
                                        @onclick="ReviewAndMoveAsync">
                                    @if (isMoving)
                                    {
                                        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                                                   Size="ProgressBarCircularSize.Small" />
                                        <span>Moving employee...</span>
                                    }
                                    else
                                    {
                                        <RadzenIcon Icon="swap_horiz" />
                                        <span>Review reassignment</span>
                                    }
                                </button>
                                <p class="sa-action-note">This updates the employee's primary station. Their manpower type, licenses, schedule, and account remain unchanged.</p>
                            }
                            else
                            {
                                <div class="sa-readonly-note">
                                    <RadzenIcon Icon="lock" />
                                    <span>Reassignment is locked for this role.</span>
                                </div>
                            }
                        }
                    </aside>
                </section>
            }
        }
    </div>
</RequirePermission>
