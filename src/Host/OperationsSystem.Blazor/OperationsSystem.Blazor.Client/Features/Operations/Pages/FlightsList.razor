@page "/operations/flights"
@inject OperationsApiClient Operations
@inject MasterDataApiClient MasterData
@inject DialogService DialogService
@inject NotificationService Notifications
@inject NavigationManager Navigation
@inject GridPreferences GridPrefs
@inject AuthSession Auth

<PageTitle>Flights</PageTitle>

<RequirePermission Permission="@OperationsPermissions.FlightsView">
    <div class="os-list-page">
        <PageHeader Title="Flights" Description="Scheduled, in-progress, review, and settled flights within your scope.">
            <Actions>
                <AuthorizeView Context="adhoc">
                    @if (adhoc.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, OperationsPermissions.WorkOrdersAuthor))
                    {
                        <RadzenButton Text="Work order from scratch" Icon="assignment_add" ButtonStyle="ButtonStyle.Secondary" Click="@OpenAdHocAsync" />
                    }
                </AuthorizeView>
                <AuthorizeView Context="schedule">
                    @if (schedule.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, OperationsPermissions.FlightsSchedule))
                    {
                        <RadzenButton Text="Schedule flights" Icon="event_repeat" ButtonStyle="ButtonStyle.Secondary" Click="@OpenBulkScheduleAsync" />
                        <RadzenButton Text="Schedule flight" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="@OpenScheduleAsync" />
                    }
                </AuthorizeView>
            </Actions>
        </PageHeader>

        <DataListCard @ref="list" TItem="FlightListItem" Data="@items" Count="@totalCount" IsLoading="@isLoading"
                      HasError="@loadError" OnRetry="@ReloadAsync" LoadData="@LoadDataAsync"
                      PageSize="@currentPageSize" PageSizeChanged="@OnPageSizeChangedAsync"
                      SearchValue="@searchTerm" SearchValueChanged="@(v => searchTerm = v)" OnSearch="@ReloadAsync"
                      SearchPlaceholder="Search flight number or customer" CountLabel="flights" EmptyText="No flights match your filters.">
            <Filters>
                <DataListFilter TValue="Guid?" Placeholder="All stations" Data="@stationOptions" Value="@stationFilter" ValueChanged="@OnStationFilterChangedAsync" />
                <DataListFilter TValue="Guid?" Placeholder="All customers" Data="@customerOptions" Value="@customerFilter" ValueChanged="@OnCustomerFilterChangedAsync" />
                <DataListFilter TValue="string" Placeholder="All statuses" Data="@statusOptions" Value="@statusFilter" ValueChanged="@OnStatusFilterChangedAsync" />
                <DataListFilter TValue="Guid?" Placeholder="All operations" Data="@operationTypeOptions" Value="@operationTypeFilter" ValueChanged="@OnOperationTypeFilterChangedAsync" />
                <div class="ofl-date-range">
                    <RadzenDatePicker TValue="DateTime?" Value="@fromFilter" Change="@OnFromFilterChangedAsync"
                                      DateFormat="yyyy-MM-dd" ShowTime="false" AllowClear="true"
                                      Placeholder="From date" class="ofl-date-filter" />
                    <RadzenDatePicker TValue="DateTime?" Value="@toFilter" Change="@OnToFilterChangedAsync"
                                      DateFormat="yyyy-MM-dd" ShowTime="false" AllowClear="true"
                                      Placeholder="To date" class="ofl-date-filter" />
                </div>
            </Filters>
            <Columns>
                <RadzenDataGridColumn TItem="FlightListItem" Property="FlightNumber" Title="Flight #">
                    <Template Context="flight">
                        <div class="os-role-cell">
                            <span class="os-role-cell-icon"><RadzenIcon Icon="flight" /></span>
                            <div class="os-role-cell-text">
                                <strong>@DisplayFlightNumber(flight)</strong>
                                <span>@flight.CustomerName</span>
                            </div>
                        </div>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FlightListItem" Property="StationIata" Title="Station" Width="110px" />
                <RadzenDataGridColumn TItem="FlightListItem" Property="OperationTypeName" Title="Operation" />
                <RadzenDataGridColumn TItem="FlightListItem" Title="STA (UTC)" Width="170px">
                    <Template Context="flight">@DateTimeDisplay(flight.ScheduledArrivalUtc)</Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FlightListItem" Title="Status" Sortable="false" Width="150px">
                    <Template Context="flight"><StatusBadge Label="@flight.Status" Tone="@FlightStatusTone(flight.Status)" /></Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FlightListItem" Title="Per landing" Sortable="false" Width="120px">
                    <Template Context="flight">@(flight.IsPerLanding ? "Yes" : "No")</Template>
                </RadzenDataGridColumn>
            </Columns>
            <RowActions Context="flight">
                <RowActionMenu>
                    <RowAction Text="Open" Icon="visibility" OnClick="@(() => OpenFlight(flight.Id))" />
                    <RowAction Text="Edit schedule" Icon="edit" Permission="@OperationsPermissions.FlightsUpdate"
                               Visible="@CanEditFlight(flight)" OnClick="@(() => OpenEditAsync(flight.Id))" />
                    <RowAction Text="Open work order" Icon="assignment_add" Permission="@OperationsPermissions.WorkOrdersAuthor"
                               Visible="@CanOpenWorkOrder(flight)" OnClick="@(() => OpenWorkOrderAsync(flight))" />
                    <RowAction Separator="true" />
                    <RowAction Text="Resolve duplicates" Icon="merge_type" Permission="@OperationsPermissions.FlightsMerge"
                               Visible="@CanMergeFlight(flight)" OnClick="@(() => OpenMergeAsync(flight.Id))" />
                    <RowAction Text="Cancel flight" Icon="cancel" Danger="true" Permission="@OperationsPermissions.FlightsCancel"
                               Visible="@CanCancelFlight(flight)" OnClick="@(() => OpenCancelAsync(flight))" />
                </RowActionMenu>
            </RowActions>
        </DataListCard>
    </div>
</RequirePermission>

@code {
    private const string GridKey = "operations-flights";
    private static readonly int[] PageSizes = [10, 25, 50, 100];

    private DataListCard<FlightListItem>? list;
    private IReadOnlyList<FlightListItem> items = [];
    private int totalCount;
    private bool isLoading;
    private bool loadError;
    private string searchTerm = string.Empty;
    private string? statusFilter;
    private Guid? stationFilter;
    private Guid? customerFilter;
    private Guid? operationTypeFilter;
    private DateTime? fromFilter;
    private DateTime? toFilter;
    private int currentPage = 1;
    private int currentPageSize = 10;
    private string? currentSort;
    private IReadOnlyList<StationFilterOption> stationOptions = [];
    private IReadOnlyList<CustomerFilterOption> customerOptions = [];
    private IReadOnlyList<OperationTypeFilterOption> operationTypeOptions = [];
    private readonly IReadOnlyList<StatusFilterOption> statusOptions =
    [
        new("Scheduled", "Scheduled"),
        new("In progress", "InProgress"),
        new("Completed", "Completed"),
        new("Canceled", "Canceled")
    ];

    protected override async Task OnInitializedAsync()
    {
        currentPageSize = await GridPrefs.GetPageSizeAsync(GridKey, currentPageSize, PageSizes);
        await Task.WhenAll(
            LoadStationOptionsAsync(),
            LoadCustomerOptionsAsync(),
            LoadOperationTypeOptionsAsync());

        await FetchAsync();
    }

    private async Task LoadStationOptionsAsync()
    {
        try
        {
            stationOptions = (await MasterData.GetStationOptionsAsync())
                .Select(x => new StationFilterOption($"{x.IataCode} · {x.Name}", x.Id))
                .ToList();
        }
        catch (ApiException)
        {
            stationOptions = [];
        }
    }

    private async Task LoadCustomerOptionsAsync()
    {
        try
        {
            customerOptions = (await MasterData.GetCustomerOptionsAsync())
                .Select(x => new CustomerFilterOption(CustomerFilterLabel(x), x.Id))
                .ToList();
        }
        catch (ApiException)
        {
            customerOptions = [];
        }
    }

    private async Task LoadOperationTypeOptionsAsync()
    {
        try
        {
            operationTypeOptions = (await MasterData.GetOperationTypeOptionsAsync())
                .Select(x => new OperationTypeFilterOption(x.Name, x.Id))
                .ToList();
        }
        catch (ApiException)
        {
            operationTypeOptions = [];
        }
    }

    private async Task OnPageSizeChangedAsync(int pageSize)
    {
        currentPageSize = pageSize;
        await GridPrefs.SetPageSizeAsync(GridKey, pageSize);
    }

    private async Task OnStationFilterChangedAsync(Guid? value)
    {
        stationFilter = value;
        await ReloadAsync();
    }

    private async Task OnCustomerFilterChangedAsync(Guid? value)
    {
        customerFilter = value;
        await ReloadAsync();
    }

    private async Task OnStatusFilterChangedAsync(string? value)
    {
        statusFilter = value;
        await ReloadAsync();
    }

    private async Task OnOperationTypeFilterChangedAsync(Guid? value)
    {
        operationTypeFilter = value;
        await ReloadAsync();
    }

    private async Task OnFromFilterChangedAsync(DateTime? value)
    {
        fromFilter = value;
        await ReloadAsync();
    }

    private async Task OnToFilterChangedAsync(DateTime? value)
    {
        toFilter = value;
        await ReloadAsync();
    }

    private async Task LoadDataAsync(LoadDataArgs args)
    {
        currentPageSize = args.Top ?? currentPageSize;
        currentPage = ((args.Skip ?? 0) / Math.Max(currentPageSize, 1)) + 1;
        currentSort = SortBuilder.From(args);
        await FetchAsync();
    }

    private async Task ReloadAsync()
    {
        currentPage = 1;
        if (list is not null)
            await list.ReloadAsync();
        else
            await FetchAsync();
    }

    private async Task FetchAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();

        try
        {
            var result = await Operations.GetFlightsAsync(currentPage, currentPageSize,
                string.IsNullOrWhiteSpace(searchTerm) ? null : searchTerm, stationFilter, customerFilter, operationTypeFilter,
                statusFilter, DateBoundaryUtc(fromFilter, false), DateBoundaryUtc(toFilter, true), currentSort);
            items = result.Items;
            totalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task OpenScheduleAsync()
    {
        var result = await DialogService.OpenAsync<ScheduleFlightDialog>("Schedule flight", null, new DialogOptions { Width = "760px" });
        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, "Flight scheduled");
            await ReloadAsync();
        }
    }

    private async Task OpenBulkScheduleAsync()
    {
        var result = await DialogService.OpenAsync<ScheduleFlightDialog>("Schedule flights",
            new Dictionary<string, object?> { [nameof(ScheduleFlightDialog.BulkMode)] = true },
            new DialogOptions { Width = "760px" });

        if (result is int count)
        {
            Notifications.Notify(NotificationSeverity.Success, "Flights scheduled", $"Created {count} flight(s).");
            await ReloadAsync();
        }
    }

    private async Task OpenAdHocAsync()
    {
        var result = await DialogService.OpenAsync<AdHocWorkOrderDialog>("Work order from scratch", null, new DialogOptions { Width = "1040px" });
        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, "Ad-hoc flight created", "The flight and its work order were created.");
            await ReloadAsync();
        }
    }

    private void OpenFlight(Guid id) => Navigation.NavigateTo($"/operations/flights/{id}");

    private async Task OpenEditAsync(Guid id)
    {
        var result = await DialogService.OpenAsync<ScheduleFlightDialog>("Edit flight",
            new Dictionary<string, object?> { [nameof(ScheduleFlightDialog.FlightId)] = id },
            new DialogOptions { Width = "760px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, "Flight updated");
            await ReloadAsync();
        }
    }

    private async Task OpenWorkOrderAsync(FlightListItem flight)
    {
        try
        {
            var id = await Operations.OpenWorkOrderAsync(flight.Id);
            var result = await DialogService.OpenAsync<WorkOrderEditorDialog>("Work order",
                new Dictionary<string, object?> { [nameof(WorkOrderEditorDialog.WorkOrderId)] = id },
                new DialogOptions { Width = "1040px" });

            if (result is true)
                Notifications.Notify(NotificationSeverity.Success, "Work order saved");

            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, "Work order", ex.ToDisplayMessage("Could not open a work order."));
        }
    }

    private async Task OpenCancelAsync(FlightListItem flight)
    {
        var result = await DialogService.OpenAsync<CancelFlightDialog>("Cancel flight",
            new Dictionary<string, object?> { [nameof(CancelFlightDialog.FlightId)] = flight.Id },
            new DialogOptions { Width = "640px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, "Cancellation created", $"Cancellation work order for {flight.FlightNumber} is in review.");
            await ReloadAsync();
        }
    }

    private async Task OpenMergeAsync(Guid flightId)
    {
        var result = await DialogService.OpenAsync<FlightMergeDialog>("Resolve duplicate flights",
            new Dictionary<string, object?> { [nameof(FlightMergeDialog.PrimaryFlightId)] = flightId },
            new DialogOptions { Width = "980px" });

        if (result is true)
        {
            Notifications.Notify(NotificationSeverity.Success, "Flights merged");
            await ReloadAsync();
        }
    }

    private static bool CanEditFlight(FlightListItem flight) => flight.Status is "Scheduled" or "InProgress";
    private static bool CanOpenWorkOrder(FlightListItem flight) => flight.Status is "Scheduled" or "InProgress";
    private static bool CanCancelFlight(FlightListItem flight) => flight.Status is "Scheduled" or "InProgress";
    private static bool CanMergeFlight(FlightListItem flight) => flight.Status is not "Completed" and not "Canceled" and not "Merged";

    private static string DateTimeDisplay(DateTimeOffset value) => value.UtcDateTime.ToString("yyyy-MM-dd HH:mm");

    private static DateTimeOffset? DateBoundaryUtc(DateTime? value, bool endOfDay)
    {
        if (value is not { } date)
            return null;

        var boundary = endOfDay ? date.Date.AddDays(1).AddTicks(-1) : date.Date;
        return new DateTimeOffset(DateTime.SpecifyKind(boundary, DateTimeKind.Utc));
    }

    private static string DisplayFlightNumber(FlightListItem flight) =>
        string.IsNullOrWhiteSpace(flight.CustomerIataCode)
            ? flight.FlightNumber
            : $"{flight.CustomerIataCode.Trim().ToUpperInvariant()}-{flight.FlightNumber}";

    private static string CustomerFilterLabel(CustomerOption customer) =>
        string.IsNullOrWhiteSpace(customer.IataCode)
            ? customer.Name
            : $"{customer.IataCode.Trim().ToUpperInvariant()} · {customer.Name}";

    private static string FlightStatusTone(string status) => status switch
    {
        "Completed" => "success",
        "Canceled" or "Merged" => "danger",
        "InProgress" => "warning",
        _ => "neutral"
    };

    private sealed record StatusFilterOption(string Label, string Value);
    private sealed record StationFilterOption(string Label, Guid? Value);
    private sealed record CustomerFilterOption(string Label, Guid? Value);
    private sealed record OperationTypeFilterOption(string Label, Guid? Value);
}
