@page "/operations/review-queue"
@inject OperationsApiClient Operations
@inject NotificationService Notifications

<PageTitle>Work order review</PageTitle>

<RequirePermission Permission="@OperationsPermissions.WorkOrdersView">
    <div class="os-list-page">
        <PageHeader Title="Work order review" Description="Submitted work orders awaiting approval. Approving locks the work order and hands it to billing." />

        <RadzenCard class="rz-mt-4">
            @if (loadError)
            {
                <ErrorState Message="Could not load the review queue." />
            }
            else
            {
                <RadzenDataGrid @ref="grid" Data="@items" Count="@totalCount" LoadData="@LoadDataAsync"
                                AllowPaging="true" PageSize="20" IsLoading="@isLoading" TItem="ReviewQueueItem"
                                AllowSorting="false" EmptyText="Nothing awaiting review.">
                    <Columns>
                        <RadzenDataGridColumn TItem="ReviewQueueItem" Property="FlightNumber" Title="Flight #" />
                        <RadzenDataGridColumn TItem="ReviewQueueItem" Property="CustomerName" Title="Customer" />
                        <RadzenDataGridColumn TItem="ReviewQueueItem" Property="StationIata" Title="Station" />
                        <RadzenDataGridColumn TItem="ReviewQueueItem" Property="Type" Title="Type" />
                        <RadzenDataGridColumn TItem="ReviewQueueItem" Title="Submitted (UTC)">
                            <Template Context="item">@item.CreatedAtUtc.UtcDateTime.ToString("yyyy-MM-dd HH:mm")</Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="ReviewQueueItem" Title="Actions" Sortable="false">
                            <Template Context="item">
                                <AuthorizeView Context="approve">
                                    @if (approve.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, OperationsPermissions.WorkOrdersApprove))
                                    {
                                        <RadzenButton Text="Approve" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small"
                                                      Click="@(() => ApproveAsync(item))" class="rz-mr-2" />
                                    }
                                </AuthorizeView>
                                <AuthorizeView Context="reject">
                                    @if (reject.User.HasClaim(PortalAuthStateProvider.PermissionClaimType, OperationsPermissions.WorkOrdersReject))
                                    {
                                        <RadzenButton Text="Reject" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                                      Click="@(() => RejectAsync(item))" />
                                    }
                                </AuthorizeView>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </RadzenCard>
    </div>
</RequirePermission>

@code {
    private RadzenDataGrid<ReviewQueueItem>? grid;
    private IReadOnlyList<ReviewQueueItem> items = [];
    private int totalCount;
    private bool isLoading;
    private bool loadError;
    private int currentPage = 1;
    private int currentPageSize = 20;

    private async Task LoadDataAsync(LoadDataArgs args)
    {
        currentPageSize = args.Top ?? 20;
        currentPage = ((args.Skip ?? 0) / currentPageSize) + 1;
        await FetchAsync();
    }

    private async Task FetchAsync()
    {
        isLoading = true;
        loadError = false;
        StateHasChanged();
        try
        {
            var result = await Operations.GetReviewQueueAsync(currentPage, currentPageSize);
            items = result.Items;
            totalCount = (int)result.TotalCount;
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ApproveAsync(ReviewQueueItem item)
    {
        try
        {
            await Operations.ApproveWorkOrderAsync(item.WorkOrderId, item.RowVersion);
            Notifications.Notify(NotificationSeverity.Success, "Approved", $"Work order for {item.FlightNumber} approved and sent to billing.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, "Approval failed", ex.ToDisplayMessage("Could not approve the work order."));
        }
    }

    private async Task RejectAsync(ReviewQueueItem item)
    {
        try
        {
            await Operations.RejectWorkOrderAsync(item.WorkOrderId, item.RowVersion);
            Notifications.Notify(NotificationSeverity.Success, "Rejected", $"Work order for {item.FlightNumber} returned to the field.");
            await ReloadAsync();
        }
        catch (ApiException ex)
        {
            Notifications.Notify(NotificationSeverity.Error, "Reject failed", ex.ToDisplayMessage("Could not reject the work order."));
        }
    }

    private async Task ReloadAsync()
    {
        if (grid is not null)
            await grid.Reload();
        else
            await FetchAsync();
    }
}
