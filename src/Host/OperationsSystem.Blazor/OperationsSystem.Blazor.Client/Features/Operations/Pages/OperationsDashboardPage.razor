@page "/operations/dashboard"
@inject OperationsApiClient Operations
@inject NavigationManager Navigation

<PageTitle>Operations dashboard</PageTitle>

<RequirePermission Permission="@OperationsPermissions.DashboardView">
    <div class="os-list-page">
        <PageHeader Title="Operations" Description="Flight scheduling activity across your scope.">
            <Actions>
                <RadzenButton Text="Flights" Icon="flight" ButtonStyle="ButtonStyle.Primary" Click="@OpenFlights" />
            </Actions>
        </PageHeader>

        @if (isLoading)
        {
            <LoadingCard />
        }
        else if (loadError)
        {
            <ErrorState Message="Could not load the dashboard." OnRetry="@LoadAsync" />
        }
        else if (data is not null)
        {
            <div class="opd-kpis">
                @Kpi("Scheduled flights", data.ScheduledFlights, "flight_takeoff", "neutral")
                @Kpi("In progress", data.InProgressFlights, "engineering", "warning")
                @Kpi("Completed flights", data.CompletedFlights, "verified", "success")
                @Kpi("Canceled flights", data.CanceledFlights, "cancel", "danger")
            </div>

            <div class="opd-panels">
                <section class="opd-panel">
                    <div>
                        <p class="os-eyebrow">Flight control</p>
                        <h2>Operations flight list</h2>
                        <p class="os-muted">Search flights, edit schedules, assign employees, and resolve duplicate candidates.</p>
                    </div>
                    <RadzenButton Text="Open flights" Icon="flight" ButtonStyle="ButtonStyle.Secondary"
                                  Click="@OpenFlights" />
                </section>
            </div>
        }
    </div>
</RequirePermission>

@code {
    private OperationsDashboard? data;
    private bool isLoading = true;
    private bool loadError;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private void OpenFlights() => Navigation.NavigateTo("/operations/flights");

    private async Task LoadAsync()
    {
        isLoading = true;
        loadError = false;
        try
        {
            data = await Operations.GetDashboardAsync();
        }
        catch (ApiException)
        {
            loadError = true;
        }
        finally
        {
            isLoading = false;
        }
    }

    private static RenderFragment Kpi(string label, int value, string icon, string tone) => @<section class="@($"opd-kpi opd-kpi-{tone}")">
        <span class="opd-kpi-icon"><RadzenIcon Icon="@icon" /></span>
        <div>
            <span>@label</span>
            <strong>@value.ToString("N0")</strong>
        </div>
    </section>;
}
