@inject MasterDataApiClient MasterData
@inject DialogService DialogService

<RadzenTemplateForm TItem="ToolModel" Data="@model" Submit="@SubmitAsync">
    <div class="mtf-form">
        <p class="mtf-intro os-muted">Define the tool and optional equipment rows attached to it.</p>
        <div class="mtf-section-line"><RadzenIcon Icon="build" /><span>@UiStrings.Common.Details</span></div>

        <div class="mtf-field-block">
            <label class="mtf-label">Name <span>*</span></label>
            <div class="mtf-input-wrap">
                <RadzenIcon Icon="build" class="mtf-field-icon" />
                <RadzenTextBox @bind-Value="model.Name" Name="name" class="mtf-control mtf-control-icon" MaxLength="100" />
            </div>
        </div>
        <div class="mtf-field-block">
            <label class="mtf-label">Description</label>
            <RadzenTextArea @bind-Value="model.Description" Name="description" Rows="4" class="mtf-control" MaxLength="500" />
        </div>

        <div class="mtf-section-line"><RadzenIcon Icon="memory" /><span>Equipment</span></div>
        <RadzenStack Gap="0.75rem">
            @foreach (var equipment in model.Equipments)
            {
                <div class="mtf-callout" @key="equipment.Key">
                    <RadzenIcon Icon="tag" />
                    <div class="mtf-equipment-grid">
                        <RadzenTextBox @bind-Value="equipment.FactoryId" Placeholder="Factory id" MaxLength="100" class="mtf-control" />
                        <RadzenTextBox @bind-Value="equipment.SerialId" Placeholder="Serial id" MaxLength="100" class="mtf-control" />
                        <RadzenDatePicker @bind-Value="equipment.CalibrationDate" DateFormat="yyyy-MM-dd" ShowTime="false" Placeholder="Calibration date" class="mtf-control" />
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Light" Click="@(() => RemoveEquipment(equipment))" />
                    </div>
                </div>
            }
            <RadzenButton Text="Add equipment" Icon="add" ButtonStyle="ButtonStyle.Light" Click="@AddEquipment" />
        </RadzenStack>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <DismissibleDialogMessage AlertStyle="AlertStyle.Danger" Title="Please fix the following errors before continuing"
                                      StateKey="@errorMessage" OnDismiss="@(() => errorMessage = null)">
                <ul><li>@errorMessage</li></ul>
            </DismissibleDialogMessage>
        }

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Gap="0.5rem" class="mtf-actions">
            <RadzenButton Text="@UiStrings.Common.Cancel" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="@(ToolId is null ? UiStrings.Common.Create : UiStrings.Common.Save)"
                          ButtonStyle="ButtonStyle.Primary" Disabled="@isSubmitting" />
        </RadzenStack>
    </div>
</RadzenTemplateForm>

@code {
    [Parameter] public Guid? ToolId { get; set; }

    private ToolModel model = new();
    private string? rowVersion;
    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (ToolId is not { } id)
            return;

        try
        {
            var detail = await MasterData.GetToolAsync(id);
            model = new ToolModel
            {
                Name = detail.Name,
                Description = detail.Description,
                Equipments = detail.Equipments
                    .Select(e => new ToolEquipmentModelState
                    {
                        Id = e.Id,
                        FactoryId = e.FactoryId,
                        SerialId = e.SerialId,
                        CalibrationDate = e.CalibrationDate?.ToDateTime(TimeOnly.MinValue)
                    })
                    .ToList()
            };
            rowVersion = detail.RowVersion;
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
    }

    private void AddEquipment() => model.Equipments.Add(new ToolEquipmentModelState());

    private void RemoveEquipment(ToolEquipmentModelState equipment) => model.Equipments.Remove(equipment);

    private async Task SubmitAsync()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(model.Name))
        {
            errorMessage = "A name is required.";
            return;
        }

        if (model.Equipments.Any(e => string.IsNullOrWhiteSpace(e.FactoryId) || string.IsNullOrWhiteSpace(e.SerialId)))
        {
            errorMessage = "Each equipment row needs a factory id and serial id.";
            return;
        }

        isSubmitting = true;
        try
        {
            var requestRows = model.Equipments
                .Select(e => new ToolEquipmentRequest(
                    e.Id,
                    e.FactoryId.Trim(),
                    e.SerialId.Trim(),
                    e.CalibrationDate is { } date ? DateOnly.FromDateTime(date) : null))
                .ToList();

            var name = model.Name.Trim();
            var description = string.IsNullOrWhiteSpace(model.Description) ? null : model.Description.Trim();

            if (ToolId is { } id)
                await MasterData.UpdateToolAsync(id, new UpdateToolRequest(name, description, requestRows), rowVersion ?? string.Empty);
            else
                await MasterData.CreateToolAsync(new CreateToolRequest(name, description, requestRows));

            DialogService.Close(true);
        }
        catch (ApiException ex)
        {
            errorMessage = ex.ToDisplayMessage(UiStrings.Common.SomethingWentWrong);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private sealed class ToolModel
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public List<ToolEquipmentModelState> Equipments { get; set; } = [];
    }

    private sealed class ToolEquipmentModelState
    {
        public Guid Key { get; } = Guid.NewGuid();
        public Guid? Id { get; set; }
        public string FactoryId { get; set; } = string.Empty;
        public string SerialId { get; set; } = string.Empty;
        public DateTime? CalibrationDate { get; set; }
    }
}
