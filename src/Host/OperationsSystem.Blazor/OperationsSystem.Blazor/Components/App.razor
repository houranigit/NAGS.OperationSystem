@using Microsoft.AspNetCore.Components.Web
<!DOCTYPE html>
<html lang="en" dir="ltr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script>
        (function () {
            try {
                var lang = localStorage.getItem("operations-system.language") || "en";
                var rtl = lang === "ar";
                document.documentElement.setAttribute("lang", lang);
                document.documentElement.setAttribute("dir", rtl ? "rtl" : "ltr");
            } catch (_) { /* ignore */ }
        })();
    </script>
    <base href="/" />
    <link rel="icon" type="image/png" href="favicon.png" sizes="64x64" />
    <link rel="icon" type="image/png" href="favicon-32.png" sizes="32x32" />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="favicon.png" />
    <ResourcePreloader />
    <RadzenTheme Theme="default" />
    <link rel="stylesheet" href="@Assets["tokens.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["OperationsSystem.Blazor.styles.css"]" />
    <ImportMap />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <Routes @rendermode="PageRenderMode" />
    <ReconnectModal />
    <script src="@Assets["_content/Radzen.Blazor/Radzen.Blazor.js"]"></script>
    <script src="@Assets["js/api-client.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    // Global Interactive Auto. Prerender is disabled so the in-memory access token / refresh-cookie
    // auth flow (which relies on JS interop) runs only in the interactive runtime, and protected
    // content never flashes during a static prerender.
    private static readonly IComponentRenderMode PageRenderMode = new InteractiveAutoRenderMode(prerender: false);
}
