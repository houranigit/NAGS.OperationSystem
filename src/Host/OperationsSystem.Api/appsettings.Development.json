  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Messaging": {
    "OutboxDispatchEnabled": true
  },
  "Operations": {
    "AutoWorkOrder": {
      "Enabled": true,
      "DelayMinutes": 60,
      "PollIntervalSeconds": 300,
      "BatchSize": 25
    },
    "FlightReminders": {
      "Enabled": true,
      "PollIntervalSeconds": 60,
      "EnrollmentLookaheadHours": 13,
      "EnrollmentLatenessToleranceMinutes": 5,
      "EnrollmentBatchSize": 500,
      "DispatchBatchSize": 500,
      "TerminalRetentionDays": 30,
      "CleanupBatchSize": 500
    }
  },
  "Notifications": {
    "Fcm": {
      "Enabled": true,
      "Required": false,
      "ProjectId": "nags-operations-system",
      "ServiceAccountJsonPath": "App_Data/firebase-admin.json"
    }
  },
  "Identity": {
    "Jwt": {
      "Issuer": "operations-system",
      "Audience": "operations-system",
      "SigningKey": "dev-only-super-secret-signing-key-change-me-32+chars!!"
    },
    "Admin": {
      "Email": "admin@nags.sa",
      "DisplayName": "System Administrator",
      "Password": "Admin#12345"
    },
    "DemoData": {
      "Enabled": false,
      "RoleCount": 55,
      "UserCount": 55
    },
    "ActivationUrlBase": "http://localhost:5158/activate",
    "PasswordResetUrlBase": "http://localhost:5158/reset-password",
    "EmailChangeConfirmUrlBase": "http://localhost:5158/confirm-email-change"
