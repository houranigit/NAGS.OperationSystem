{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "UseSerilog": false
  },
  "ConnectionStrings": {
    // Local SQL Server (Docker) — uncomment to switch back
    // "Default": "Server=localhost,1433;Database=OperationsSystem;User Id=sa;Password=Your_strong_Pass123;TrustServerCertificate=True;Encrypt=False",

    // Remote test server (performance / network latency)
    "Default": "Data Source=80.209.234.61,1433;Initial Catalog=OperationsSystemV3;Persist Security Info=True;User ID=app;Password=P@ssw0rd!;Pooling=True;Min Pool Size=5;Max Pool Size=100;Connect Timeout=15;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Application Name=OperationsSystem"
