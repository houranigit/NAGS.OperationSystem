{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "operations-system-api"
  },
  "DataProtection": {
    "ApplicationName": "operations-system"
  },
  "Operations": {
    "AutoWorkOrder": {
      "Enabled": true,
      "DelayMinutes": 60,
      "PollIntervalSeconds": 300,
      "BatchSize": 25
    }
  },
  "Notifications": {
    "Fcm": {
      "Enabled": false,
      "Required": false,
      "ProjectId": "nags-operations-system"
    }
  },
  "Identity": {
    "Jwt": {
      "Issuer": "operations-system",
      "Audience": "operations-system"
    },
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14,
    "MaxFailedSignInAttempts": 5,
    "LockoutMinutes": 15,
    "InvitationExpiryHours": 72,
    "Admin": {
      "Email": "admin@nags.sa",
      "DisplayName": "System Administrator"
    }
  }
}
