{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "operations-system-api"
  },
  "Identity": {
    "Jwt": {
      "Issuer": "operations-system",
      "Audience": "operations-system"
    },
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14,
    "MaxFailedSignInAttempts": 5,
    "LockoutMinutes": 15,
    "InvitationExpiryHours": 72,
    "Admin": {
      "Email": "admin@nags.sa",
      "DisplayName": "System Administrator"
    }
  }
}
