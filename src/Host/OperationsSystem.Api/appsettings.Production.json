{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "UseSerilog": true
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "Enabled": true,
    "ServiceName": "operations-system-api"
  },
  "ConnectionStrings": {
    "Default": "Data Source=80.209.234.61,1433;Initial Catalog=OperationsSystemV3;Persist Security Info=True;User ID=app;Password=P@ssw0rd!;Pooling=True;Min Pool Size=5;Max Pool Size=100;Connect Timeout=15;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Application Name=OperationsSystem"
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Messaging": {
    "OutboxDispatchEnabled": true
  },
  "DataProtection": {
    "ApplicationName": "operations-system",
    "KeyRingPath": "App_Data/data-protection-keys",
    "RequirePersistedKeyRingInProduction": true
  },
  "FileStorage": {
    "RootPath": "App_Data/storage"
  },
  "Security": {
    "RateLimit": {
      "AnonymousAuthPermitLimit": 20,
      "AnonymousAuthWindowSeconds": 60
    }
  },
  "Operations": {
    "AutoWorkOrder": {
      "Enabled": true,
      "DelayMinutes": 60,
      "PollIntervalSeconds": 300,
      "BatchSize": 25
    }
  },
  "Notifications": {
    "Fcm": {
      "Enabled": true,
      "Required": true,
      "ProjectId": "nags-operations-system",
      "ServiceAccountJsonPath": "App_Data/firebase-admin.json"
    }
  },
  "Identity": {
    "Jwt": {
      "Issuer": "operations-system",
      "Audience": "operations-system",
      "SigningKey": "dev-only-super-secret-signing-key-change-me-32+chars!!"
    },
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 14,
    "MaxFailedSignInAttempts": 5,
    "LockoutMinutes": 15,
    "InvitationExpiryHours": 72,
    "PasswordResetExpiryHours": 2,
    "EmailChangeExpiryHours": 72,
    "Admin": {
      "Email": "admin@nags.sa",
      "DisplayName": "System Administrator",
      "Password": "Admin#12345"
    },
    "DemoData": {
      "Enabled": false
    },
    "ActivationUrlBase": "http://operation.nags-ksa.com/activate",
    "PasswordResetUrlBase": "http://operation.nags-ksa.com/reset-password",
    "EmailChangeConfirmUrlBase": "http://operation.nags-ksa.com/confirm-email-change"
  },
  "EmailSettings": {
    "EnableEmailNotifications": true,
    "Host": "smtp.office365.com",
    "Port": 587,
    "UseSsl": true,
    "Username": "Reminder@nfs-ksa.com",
    "Password": "Nfs@123456*",
    "FromEmail": "Reminder@nfs-ksa.com",
    "FromName": "NAGS Operations"
  }
}
