<?xml version="1.0" encoding="utf-8"?>
<!-- Dev: allow HTTP to the emulator host (10.0.2.2), LAN IPs (VM), etc.
     Tighten for release builds once the API is reachable over HTTPS. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
