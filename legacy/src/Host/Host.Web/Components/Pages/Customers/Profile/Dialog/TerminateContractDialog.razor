@*
  Terminate-contract dialog. Sends TerminateContractCommand for the supplied contract and
  closes with `true` on success so the host can refresh the card list.

  UX notes (mirrors CancelFlightDialog's destructive shell):
   - Red hero + emphatic copy because termination is a one-way trip — the contract cannot
     be revoked back to Active once committed (see Contract.Terminate domain rule).
   - Reason textarea (1-500 chars) matches TerminateContractCommandValidator.
   - "I understand" acknowledgement gates the submit button so accidental clicks bounce.
*@
@using Contracts.Application.Features.Contract.Commands.TerminateContract
@using Contracts.Contracts.Contract
@using Host.Web.Services
@using Radzen
@inject DialogService DialogService
@inject IScopedMediator ScopedMediator
@inject NotificationService NotificationService

<div class="settings-wizard-host terminate-contract-host">
    <div class="settings-wizard">
        <section class="settings-wizard__content">
            <div class="settings-wizard__main">
                <div class="settings-wizard__panel">

                    <header class="terminate-contract__hero" role="banner">
                        <span class="terminate-contract__hero-icon" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        </span>
                        <div class="terminate-contract__hero-body">
                            <span class="terminate-contract__hero-eyebrow">Terminate contract</span>
                            <h2 class="terminate-contract__hero-title">#@Contract.ContractNo · @Contract.Customer.Name</h2>
                            <p class="terminate-contract__hero-sub">
                                Termination is <strong>permanent</strong> — once committed the contract
                                cannot be revoked, edited, or used for new operations. You can still
                                duplicate it as a starting point for a new contract.
                            </p>
                        </div>
                    </header>

                    <section class="terminate-contract__context" aria-label="Contract summary">
                        <div class="terminate-contract__context-cell">
                            <span class="terminate-contract__context-label">Customer</span>
                            <span class="terminate-contract__context-value">@Contract.Customer.IataCode · @Contract.Customer.Name</span>
                        </div>
                        <div class="terminate-contract__context-cell">
                            <span class="terminate-contract__context-label">Currency</span>
                            <span class="terminate-contract__context-value">@Contract.Currency.Code</span>
                        </div>
                        <div class="terminate-contract__context-cell">
                            <span class="terminate-contract__context-label">Period</span>
                            <span class="terminate-contract__context-value">@FormatPeriod()</span>
                        </div>
                    </section>

                    <h3 class="terminate-contract__section-title">Why is the contract being terminated?</h3>

                    <div class="settings-field terminate-contract__reason">
                        <label class="settings-field__label" for="@_reasonId">Reason *</label>
                        <textarea id="@_reasonId"
                                  class="terminate-contract__reason-input"
                                  rows="4"
                                  maxlength="500"
                                  placeholder="Required for the audit log (max 500 characters)…"
                                  disabled="@_busy"
                                  @bind="_reason"
                                  @bind:event="oninput"></textarea>
                        <div class="terminate-contract__reason-meta">
                            <span class="terminate-contract__reason-counter">@(_reason?.Length ?? 0) / 500</span>
                        </div>
                    </div>

                    <label class="terminate-contract__ack">
                        <input type="checkbox"
                               class="terminate-contract__ack-input"
                               checked="@_acknowledged"
                               disabled="@_busy"
                               @onchange="@OnAckChanged" />
                        <span class="terminate-contract__ack-text">
                            I understand this action is <strong>permanent</strong>. Contract
                            <strong>#@Contract.ContractNo</strong> will lock as <strong>Terminated</strong>
                            and cannot be brought back.
                        </span>
                    </label>

                    @if (_error is not null)
                    {
                        <p class="terminate-contract-dialog__error" role="alert">@_error</p>
                    }
                </div>
            </div>

            <footer class="settings-wizard__footer">
                <div class="settings-wizard__footer-actions">
                    <button type="button"
                            class="settings-wizard-btn settings-wizard-btn--secondary"
                            disabled="@_busy"
                            @onclick="CancelAsync">
                        Keep contract
                    </button>
                    <button type="button"
                            class="settings-wizard-btn settings-wizard-btn--danger"
                            disabled="@(_busy || !_acknowledged || !HasValidReason)"
                            @onclick="ConfirmAsync">
                        @if (_busy)
                        {
                            <span>Terminating…</span>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                            <span>Terminate contract</span>
                        }
                    </button>
                </div>
            </footer>
        </section>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ContractDto Contract { get; set; } = default!;

    private readonly string _reasonId = $"terminate-reason-{Guid.NewGuid():N}";
    private string? _reason;
    private bool _acknowledged;
    private bool _busy;
    private string? _error;

    private bool HasValidReason => !string.IsNullOrWhiteSpace(_reason);

    private string FormatPeriod() =>
        $"{Contract.Period.StartDate:dd MMM yyyy} → {Contract.Period.ExpiryDate:dd MMM yyyy}";

    private void OnAckChanged(ChangeEventArgs e)
    {
        _acknowledged = e.Value is bool b && b;
    }

    private async Task ConfirmAsync()
    {
        if (_busy || !_acknowledged || !HasValidReason) return;

        _error = null;
        _busy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var cmd = new TerminateContractCommand(Contract.Id, _reason!.Trim());
            var r = await ScopedMediator.Send(cmd);
            if (r.IsFailure)
            {
                _error = r.Error.Description;
                NotificationService.Notify(NotificationSeverity.Error, "Could not terminate contract", r.Error.Description);
                return;
            }

            NotificationService.Notify(NotificationSeverity.Success, "Contract terminated",
                "The contract is now permanently locked.");
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            NotificationService.Notify(NotificationSeverity.Error, "Unexpected error", ex.Message);
        }
        finally
        {
            _busy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task CancelAsync()
    {
        DialogService.Close(false);
        return Task.CompletedTask;
    }
}
