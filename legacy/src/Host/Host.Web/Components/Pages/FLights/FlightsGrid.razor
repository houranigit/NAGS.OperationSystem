@*
  Data page for flights: grid + expandable rows that show every linked work order.
  Mirrors ManpowerPricePlansGrid / ServicePricePlansGrid: header + RadzenDataGrid + expand template.
  Flight authoring lives in /scheduler — this grid only owns work-order CRUD on each flight
  (Add WO, Review WO with Accept/Reject/Revoke, Delete WO when not Approved).
*@
@using System.Globalization
@using Host.Web.Components.Pages.FLights.Dialog
@using Host.Web.Components.Shared.DataGrid
@using Host.Web.Services
@using Operations.Application.Features.Flight.Queries.GetPaginatedFlights
@using Operations.Application.Features.WorkOrder.Commands.DeleteWorkOrder
@using Operations.Contracts.Flight
@using Operations.Contracts.WorkOrder
@using Operations.Domain.Enumerations
@using Radzen
@inherits GridSettingsComponentBase<FlightDto>
@inject IScopedMediator ScopedMediator
@inject DialogService DialogService
@inject NotificationService NotificationService

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h4 mb-1">Flights</h1>
        <p class="text-secondary small mb-0">All scheduled flights with their linked work orders. Expand a row to add or review work orders.</p>
    </div>
</div>

@if (Data is null && !IsLoading)
{
    <TableSkeleton Rows="8" Columns="7" />
}
else
{
    <RadzenDataGrid @ref="Grid"
                    TItem="FlightDto"
                    Data="@Data"
                    Count="@Count"
                    LoadData="@HandleLoadDataAsync"
                    LoadSettings="@LoadSettings"
                    @bind-Settings="Settings"
                    PickedColumnsChanged="@OnPickedColumnsChanged"
                    IsLoading="@IsLoading"
                    Sort="@ShowLoadingAsync"
                    Page="@ShowLoadingAsync"
                    Filter="@ShowLoadingAsync"
                    ColumnWidth="140px"
                    Style="height: calc(100vh - 200px);"
                    Density="GridDefaults.Density"
                    FilterMode="GridDefaults.FilterMode"
                    AllowPaging="GridDefaults.AllowPaging"
                    PageSize="GridDefaults.DefaultPageSize"
                    AllowSorting="GridDefaults.AllowSorting"
                    AllowFiltering="GridDefaults.AllowFiltering"
                    AllowColumnResize="GridDefaults.AllowColumnResize"
                    AllowColumnPicking="GridDefaults.AllowColumnPicking"
                    AllowColumnReorder="GridDefaults.AllowColumnReorder"
                    AllowAlternatingRows="GridDefaults.AllowAlternatingRows"
                    LogicalFilterOperator="GridDefaults.LogicalFilterOperator"
                    FilterCaseSensitivity="GridDefaults.FilterCaseSensitivity"
                    AllowVirtualization="false"
                    ExpandMode="DataGridExpandMode.Multiple"
                    ShowExpandAll="true"
                    AllowRowSelectOnRowClick="false">
        <HeaderTemplate>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="10px">
                    <RadzenButton Icon="refresh"
                                  Text="@($"Refresh ({GetTitleText()})")"
                                  ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Filled"
                                  Shade="Shade.Light"
                                  Size="ButtonSize.Small"
                                  Click="@RefreshAsync"
                                  Disabled="@IsLoading" />
                </RadzenStack>
            </RadzenStack>
        </HeaderTemplate>
        <Columns>
            <RadzenDataGridColumn TItem="FlightDto" Property="FlightNumber" Title="Flight #" Width="120px">
                <Template Context="row">
                    <span class="fw-semibold">@row.FlightNumber</span>
                </Template>
            </RadzenDataGridColumn>
            @* Property MUST point at a primitive on the DTO (string/int/bool/...). Radzen
               cannot filter on a record type — pointing at a whole snapshot makes the column
               silently drop out of the filter string. The DTO path here is then rewritten to
               the entity path server-side via FilterPropertyMap below. *@
            <RadzenDataGridColumn TItem="FlightDto" Property="CustomerSnapshot.Name" Title="Customer">
                <Template Context="row">
                    <div class="flt-cell-stacked">
                        <span class="fw-semibold">@row.CustomerSnapshot.Name</span>
                        <span class="text-body-secondary small">@row.CustomerSnapshot.IataCode</span>
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Property="StationSnapshot.IataCode" Title="Station" Width="110px">
                <Template Context="row">
                    <div class="flt-cell-stacked">
                        <span class="fw-semibold">@row.StationSnapshot.IataCode</span>
                        <span class="text-body-secondary small">@row.StationSnapshot.Name</span>
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Property="OperationTypeSnapshot.Name" Title="Operation" Width="130px">
                <Template Context="row">@row.OperationTypeSnapshot.Name</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Property="ContractNumber" Title="Contract" Width="140px">
                <Template Context="row">
                    @if (!string.IsNullOrWhiteSpace(row.ContractNumber))
                    {
                        @row.ContractNumber
                    }
                    else
                    {
                        <span class="text-body-secondary small">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Title="Aircraft" Width="120px">
                <Template Context="row">
                    @if (row.AircraftTypeId is not null)
                    {
                        @row.AircraftTypeId.Model
                    }
                    else
                    {
                        <span class="text-body-secondary small">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Title="STA" Width="160px">
                <Template Context="row">@FormatDateTime(row.Sta)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Title="STD" Width="160px">
                <Template Context="row">@FormatDateTime(row.Std)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Property="Status" Title="Status" Width="120px">
                <Template Context="row">
                    <span class="@FlightStatusBadgeClass(row.Status)">@FlightStatusLabel(row.Status)</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Title="Work orders" Width="110px" Filterable="false" Sortable="false" Visible="false" TextAlign="TextAlign.Center">
                <Template Context="row">
                    <span class="flt-wo-count" title="Linked work orders">@row.AttachedWorkOrders.Count</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Title="Crew" Width="80px" Filterable="false" Sortable="false" Visible="false" TextAlign="TextAlign.Center">
                <Template Context="row">@row.AssignedEmployees.Count</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="FlightDto" Title="Actions" Width="130px" Filterable="false" Sortable="false" TextAlign="TextAlign.Center">
                <Template Context="row">
                    @if (row.AcceptedWorkOrderSnapshot is null && row.Status != FlightStatus.Canceled)
                    {
                        <button type="button"
                                class="flt-flight-action-cancel"
                                title="File a cancel work order against this flight"
                                @onclick="@(() => OpenCancelFlightAsync(row))">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg>
                            Cancel
                        </button>
                    }
                    else
                    {
                        <span class="text-body-secondary small">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>
        </Columns>
        <Template Context="flight">
            <div class="flt-workorders-detail">
                <div class="flt-workorders-detail__header">
                    <div class="flt-workorders-detail__heading">
                        <h6 class="flt-workorders-detail__title">Linked work orders</h6>
                        <span class="flt-workorders-detail__count">@flight.AttachedWorkOrders.Count total</span>
                    </div>
                    <div class="flt-workorders-detail__actions">
                        @if (flight.AcceptedWorkOrderSnapshot is not null)
                        {
                            <span class="flt-workorders-locked" title="Flight is settled by an accepted work order. Revoke it to add or modify work orders.">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                                Locked by @(flight.AcceptedWorkOrderSnapshot.WorkOrderNo ?? "approved WO")
                            </span>
                        }
                        else
                        {
                            <button type="button"
                                    class="flt-workorders-detail__add"
                                    @onclick="@(() => OpenAddWorkOrderAsync(flight))">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                                Add work order
                            </button>
                        }
                    </div>
                </div>
                @if (flight.AttachedWorkOrders.Count > 0)
                {
                    <div class="flt-wo-table">
                        <div class="flt-wo-header">
                            <span>Work order #</span>
                            <span>Status</span>
                            <span>STA / STD</span>
                            <span>ATA / ATD</span>
                            <span>Aircraft</span>
                            <span class="text-end">Actions</span>
                        </div>
                        @foreach (var wo in flight.AttachedWorkOrders)
                        {
                            <div class="flt-wo-row">
                                <span class="fw-semibold">@(wo.WorkOrderNo ?? "Pending")</span>
                                <span><span class="@WorkOrderStatusBadgeClass(wo.Status)">@WorkOrderStatusLabel(wo.Status)</span></span>
                                <span class="text-body-secondary small">
                                    @FormatDateTime(wo.Sta)
                                    <br />
                                    @FormatDateTime(wo.Std)
                                </span>
                                <span class="text-body-secondary small">
                                    @(wo.Ata is null ? "—" : FormatDateTime(wo.Ata.Value))
                                    <br />
                                    @(wo.Atd is null ? "—" : FormatDateTime(wo.Atd.Value))
                                </span>
                                <span>
                                    @if (wo.AircraftTypeId is not null)
                                    {
                                        @wo.AircraftTypeId.Model
                                        @if (!string.IsNullOrWhiteSpace(wo.AircraftTailNumber))
                                        {
                                            <span class="text-body-secondary small ms-1">@wo.AircraftTailNumber</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-body-secondary small">—</span>
                                    }
                                </span>
                                <span class="flt-wo-row__actions">
                                    <button type="button"
                                            class="flt-wo-action flt-wo-action--review"
                                            @onclick="@(() => OpenReviewWorkOrderAsync(wo))">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                        Review
                                    </button>
                                    <button type="button"
                                            class="flt-wo-action flt-wo-action--delete"
                                            disabled="@(wo.Status == WorkOrderStatus.Approved || wo.Status == WorkOrderStatus.Deleting)"
                                            title="@DeleteButtonTooltip(wo.Status)"
                                            @onclick="@(() => DeleteWorkOrderAsync(wo))">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/></svg>
                                        Delete
                                    </button>
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-body-secondary small ms-1 my-1">No work orders linked to this flight.</p>
                }
            </div>
        </Template>
    </RadzenDataGrid>
}

<ConfirmDialog @ref="_deleteConfirm" />

@code {
    private bool _expandRowsPending;
    private ConfirmDialog _deleteConfirm = default!;

    protected override string SettingsStorageKey => "FlightList-Settings";

    // FlightDto field names → Flight entity property paths. The grid base class rewrites
    // args.Filter / args.OrderBy with this map before the handler runs Where on IQueryable<Flight>.
    // FlightNumber on the DTO is a string; on the entity it's an OwnsOne VO whose underlying
    // column is reached via FlightNumber.Value (see FlightConfiguration).
    protected override IReadOnlyDictionary<string, string> FilterPropertyMap { get; } =
        new Dictionary<string, string>(StringComparer.Ordinal)
        {
            ["CustomerSnapshot"] = "Customer",
            ["StationSnapshot"] = "Station",
            ["OperationTypeSnapshot"] = "OperationType",
            ["AircraftTypeId"] = "AircraftType",
            ["AcceptedWorkOrderSnapshot"] = "AcceptedWorkOrder",
            ["FlightNumber"] = "FlightNumber.Value",
        };

    protected override async Task HandleLoadDataAsync(LoadDataArgs args)
    {
        await LoadDataAsync(args, LoadCore);
        _expandRowsPending = Data is { Count: > 0 } rows && rows.Any(f => f.AttachedWorkOrders.Count > 0);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (!_expandRowsPending || Grid is null || Data is null || Data.Count == 0)
            return;

        _expandRowsPending = false;
        await Grid.ExpandRows(Data.Where(f => f.AttachedWorkOrders.Count > 0));
    }

    private async Task LoadCore(LoadDataArgs a, int ps, int pn, IServiceProvider sp, CancellationToken ct)
    {
        var r = await ScopedMediator.Send(
            new GetPaginatedFlightsQuery(pn, ps, a.Filter, a.OrderBy, GetVisibleColumnPropertyNames()),
            ct);
        if (r.IsSuccess)
            SetGridResult(r.Value.Items, r.Value.TotalCount);
        else
            SetGridResult([], 0);
    }

    private string GetTitleText() => $"Total flights {Count:N0}";

    private async Task RefreshAsync()
    {
        await ShowLoadingAsync();
        Grid?.Reload();
    }

    private async Task OpenAddWorkOrderAsync(FlightDto flight)
    {
        var result = await DialogService.OpenAsync<WorkOrderAddDialog>(
            $"Add work order — flight {flight.FlightNumber}",
            new Dictionary<string, object?> { ["Flight"] = flight },
            new DialogOptions
            {
                Width = "920px",
                CloseDialogOnEsc = false,
                CloseDialogOnOverlayClick = false,
                ShowClose = true,
                Resizable = false
            });

        if (result is true)
            await RefreshAsync();
    }

    private async Task OpenReviewWorkOrderAsync(WorkOrderLightDto workOrder)
    {
        var label = workOrder.WorkOrderNo ?? "pending";
        var result = await DialogService.OpenAsync<WorkOrderReviewDialog>(
            $"Review work order — {label}",
            new Dictionary<string, object?> { ["WorkOrderId"] = workOrder.Id },
            new DialogOptions
            {
                Width = "880px",
                CloseDialogOnEsc = true,
                CloseDialogOnOverlayClick = false,
                ShowClose = true,
                Resizable = false
            });

        if (result is true)
            await RefreshAsync();
    }

    private async Task DeleteWorkOrderAsync(WorkOrderLightDto workOrder)
    {
        if (workOrder.Status is WorkOrderStatus.Approved or WorkOrderStatus.Deleting)
            return;

        var label = workOrder.WorkOrderNo ?? "pending work order";
        var confirmed = await _deleteConfirm.ShowAsync(
            title: "Delete work order?",
            message: $"This permanently removes {label}. The flight stays In progress so you can attach a different work order.",
            confirmText: "Delete",
            cancelText: "Cancel",
            style: ConfirmDialog.DialogStyle.Danger);
        if (!confirmed)
            return;

        try
        {
            var r = await ScopedMediator.Send(new DeleteWorkOrderCommand(workOrder.Id));
            if (r.IsFailure)
            {
                NotificationService.Notify(NotificationSeverity.Error, "Could not delete work order", r.Error.Description);
                return;
            }

            NotificationService.Notify(NotificationSeverity.Success, "Work order deleted", "");
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Unexpected error", ex.Message);
        }
    }

    private async Task OpenCancelFlightAsync(FlightDto flight)
    {
        var result = await DialogService.OpenAsync<CancelFlightDialog>(
            $"Cancel flight {flight.FlightNumber}",
            new Dictionary<string, object?> { ["Flight"] = flight },
            new DialogOptions
            {
                Width = "560px",
                CloseDialogOnEsc = true,
                CloseDialogOnOverlayClick = false,
                ShowClose = true,
                Resizable = false
            });

        if (result is true)
            await RefreshAsync();
    }

    private static string DeleteButtonTooltip(WorkOrderStatus status) => status switch
    {
        WorkOrderStatus.Approved => "Revoke approval before deleting.",
        WorkOrderStatus.Deleting => "This work order is pending automatic deletion.",
        _ => "Delete this work order"
    };

    private static string FormatDateTime(DateTimeOffset value) =>
        value.ToLocalTime().ToString("dd MMM yyyy HH:mm", CultureInfo.InvariantCulture);

    private static string FlightStatusLabel(FlightStatus status) => status switch
    {
        FlightStatus.Scheduled => "Scheduled",
        FlightStatus.InProgress => "In progress",
        FlightStatus.Completed => "Completed",
        FlightStatus.Canceled => "Canceled",
        _ => status.ToString()
    };

    private static string FlightStatusBadgeClass(FlightStatus status) => status switch
    {
        FlightStatus.Scheduled => "flt-status flt-status--scheduled",
        FlightStatus.InProgress => "flt-status flt-status--inprogress",
        FlightStatus.Completed => "flt-status flt-status--completed",
        FlightStatus.Canceled => "flt-status flt-status--canceled",
        _ => "flt-status"
    };

    private static string WorkOrderStatusLabel(WorkOrderStatus status) => status switch
    {
        WorkOrderStatus.UnderReview => "Under review",
        WorkOrderStatus.Approved => "Approved",
        WorkOrderStatus.Rejected => "Rejected",
        WorkOrderStatus.Deleting => "Deleting",
        _ => status.ToString()
    };

    private static string WorkOrderStatusBadgeClass(WorkOrderStatus status) => status switch
    {
        WorkOrderStatus.UnderReview => "flt-status flt-status--inprogress",
        WorkOrderStatus.Approved => "flt-status flt-status--completed",
        WorkOrderStatus.Rejected => "flt-status flt-status--canceled",
        WorkOrderStatus.Deleting => "flt-status flt-status--deleting",
        _ => "flt-status"
    };
}
