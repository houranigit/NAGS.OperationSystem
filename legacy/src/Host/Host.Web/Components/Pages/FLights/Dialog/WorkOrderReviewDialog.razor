    private static string FormatDateTime(DateTimeOffset value) =>
        value.ToLocalTime().ToString("dd MMM yyyy HH:mm", CultureInfo.InvariantCulture);

    private static string WorkOrderStatusLabel(WorkOrderStatus status) => status switch
    {
        WorkOrderStatus.UnderReview => "Under review",
        WorkOrderStatus.Approved => "Approved",
        WorkOrderStatus.Rejected => "Rejected",
        WorkOrderStatus.Deleting => "Deleting",
        _ => status.ToString()
    };

    private static string WorkOrderStatusBadgeClass(WorkOrderStatus status) => status switch
    {
        WorkOrderStatus.UnderReview => "wo-review__status wo-review__status--inprogress",
        WorkOrderStatus.Approved => "wo-review__status wo-review__status--completed",
        WorkOrderStatus.Rejected => "wo-review__status wo-review__status--canceled",
        WorkOrderStatus.Deleting => "wo-review__status wo-review__status--deleting",
        _ => "wo-review__status"
    };

    /// <summary>
    /// Lifecycle steps shown in the dialog header. Always three steps (Filed →
    /// Under review → Settled). The third step turns green for Approved, red for
    /// Rejected/Deleting, or stays inactive while the WO is still under review.
    /// </summary>
    private static IReadOnlyList<TimelineStep> BuildTimeline(WorkOrderDetailDto wo)
    {
        var filed = new TimelineStep(
            Title: "Filed",
            Subtitle: FormatDateTime(wo.CreatedAt),
            StateClass: "is-done",
            IsDone: true,
            Tooltip: $"Created {FormatDateTime(wo.CreatedAt)}");

        var review = wo.Status == WorkOrderStatus.UnderReview
            ? new TimelineStep("Under review", "Awaiting decision", "is-active", false, "Awaiting reviewer")
            : new TimelineStep("Reviewed", "Decision recorded", "is-done", true, "Reviewer acted on this work order");

        var settled = wo.Status switch
        {
            WorkOrderStatus.Approved => new TimelineStep(
                "Approved",
                "Flight settled",
                "is-done is-success",
                true,
                "Approval has settled the flight"),
            WorkOrderStatus.Rejected => new TimelineStep(
                "Rejected",
                "Stays attached to flight",
                "is-done is-danger",
                true,
                "Rejected work orders do not settle the flight"),
            WorkOrderStatus.Deleting => new TimelineStep(
                "Pending deletion",
                "Will be removed",
                "is-done is-danger",
                true,
                "Sibling approval marked this for deletion"),
            _ => new TimelineStep(
                "Settled",
                "Awaiting reviewer",
                "is-upcoming",
                false,
                "A reviewer must approve or reject")
        };

        return new[] { filed, review, settled };
    }

    private enum StepState { Upcoming, Active, Completed }

    private sealed record StepDescriptor(string Title, string Subtitle);

    private sealed record TimelineStep(string Title, string Subtitle, string StateClass, bool IsDone, string Tooltip);
