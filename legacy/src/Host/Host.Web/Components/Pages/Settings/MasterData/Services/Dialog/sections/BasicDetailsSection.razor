@*
  Wizard / update shared section — mirrors Currency / Company-style settings-field markup (Component Rules.md).
*@
@namespace Host.Web.Components.Pages.Settings.MasterData.Services.Dialog.Sections
@using Host.Web.Components.Pages.Settings.MasterData.Services.Dialog

<RadzenStack Gap="1rem">
    <div class="settings-field" style="position: relative;">
        <label class="settings-field__label" for="svc-name">Name</label>
        <RadzenTextBox id="svc-name"
                       Name="ServiceName"
                       @bind-Value="Model.Name"
                       MaxLength="100"
                       Placeholder="e.g. Headset"
                       Change="@OnFieldChangedAsync"
                       Style="width: 100%;" />
        <RadzenRequiredValidator Component="ServiceName"
                                 Text="Name is required."
                                 Popup="true"
                                 Style="position: absolute;" />
        <RadzenLengthValidator Component="ServiceName"
                               Max="100"
                               Text="Name must not exceed 100 characters."
                               Popup="true"
                               Style="position: absolute; top: 2.5rem;" />
    </div>
    <div class="settings-field">
        <label class="settings-field__label" for="svc-desc">Description</label>
        <RadzenTextArea id="svc-desc"
                        @bind-Value="Model.Description"
                        MaxLength="500"
                        Rows="3"
                        Placeholder="Optional notes"
                        Change="@OnFieldChangedAsync"
                        Style="width: 100%;" />
    </div>
    <div class="settings-field" style="position: relative;">
        <span class="settings-field__label" id="svc-status">Status</span>
        <RadzenSelectBar TValue="bool"
                         @bind-Value="Model.IsActive"
                         Change="@OnFieldChangedAsync"
                         Size="ButtonSize.Small"
                         aria-labelledby="svc-status">
            <Items>
                <RadzenSelectBarItem Text="Active" Value="true" />
                <RadzenSelectBarItem Text="Inactive" Value="false" />
            </Items>
        </RadzenSelectBar>
    </div>
</RadzenStack>

@code {
    [Parameter, EditorRequired] public ServiceFormModel Model { get; set; } = default!;

    [Parameter] public EventCallback OnModelChanged { get; set; }

    private Task OnFieldChangedAsync() => OnModelChanged.InvokeAsync();
}
