@*
  ADD = single-step wizard via the shared WizardShell. Section + form model unchanged;
  the shell now owns the chrome, error alert, dirty/save coupling and validator popups.
*@
@using Core.Application.Features.AircraftType.Commands.CreateAircraftType
@using Core.Contracts.Features.AircraftType
@using Host.Web.Components.Pages.Settings.MasterData.AircraftTypes.Dialog.Sections
@using Host.Web.Services
@using Radzen
@inject DialogService DialogService
@inject IScopedMediator ScopedMediator
@inject NotificationService NotificationService

<RadzenTemplateForm @ref="_form"
                    TItem="AircraftTypeFormModel"
                    Data="@_model"
                    Submit="@OnTemplateSubmitAsync"
                    InvalidSubmit="@OnTemplateInvalidSubmit">
    <WizardShell Steps="@_steps"
                 CurrentStep="_currentStep"
                 CurrentStepChanged="@(s => _currentStep = s)"
                 FurthestReached="_furthestReached"
                 FurthestReachedChanged="@(r => _furthestReached = r)"
                 Mode="WizardMode.Wizard"
                 IsBusy="_saving"
                 CanSave="@_hasChangedInAddMode"
                 SidebarAriaLabel="New aircraft type steps"
                 SaveLabel="Save"
                 SavingLabel="Saving…"
                 AlertTitle="Couldn't save the aircraft type"
                 ConfirmCancelOnDirty="@_hasChangedInAddMode"
                 ErrorMessages="@_errorMessages"
                 OnSave="OnSaveClickedAsync"
                 OnCancel="OnCancelAsync"
                 OnRequestStepValidationAsync="ValidateCurrentStepAsync"
                 OnDismissError="ClearErrors">
        <StepContent Context="step">
            @switch (step)
            {
                case 0:
                    <BasicDetailsSection Model="_model" OnModelChanged="OnFormFieldChangedAsync" />
                    break;
            }
        </StepContent>
    </WizardShell>
</RadzenTemplateForm>

@code {
    private readonly WizardStep[] _steps =
    [
        new("Basic details", "Manufacturer, model & notes", "plane", IsRequired: true, Validate: () => true)
    ];

    private RadzenTemplateForm<AircraftTypeFormModel>? _form;
    private int _currentStep;
    private int _furthestReached;
    private bool _saving;
    private bool _hasChangedInAddMode;
    private AircraftTypeFormModel _model = new() { IsActive = true };
    private List<string> _errorMessages = new();

    private void ClearErrors()
    {
        if (_errorMessages.Count == 0) return;
        _errorMessages = new List<string>();
        StateHasChanged();
    }

    private void SetCommandError(string description)
    {
        _errorMessages = description
            .Split([';', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(s => s.Length > 0).ToList();
        if (_errorMessages.Count == 0) _errorMessages.Add(description);
    }

    private Task OnFormFieldChangedAsync()
    {
        _hasChangedInAddMode = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task<bool> ValidateCurrentStepAsync(int _)
    {
        var ok = _form?.EditContext?.Validate() ?? true;
        if (ok) ClearErrors();
        return Task.FromResult(ok);
    }

    private void OnTemplateInvalidSubmit(FormInvalidSubmitEventArgs _) { }

    private async Task OnSaveClickedAsync()
    {
        if (_saving) return;
        if (!await ValidateAllStepsRenderedAsync())
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Cannot save", "Please fix the highlighted issues before saving.");
            return;
        }
        await OnTemplateSubmitAsync(_model);
    }

    private async Task<bool> ValidateAllStepsRenderedAsync()
    {
        var back = _currentStep;
        try
        {
            for (var s = 0; s < _steps.Length; s++)
            {
                _currentStep = s;
                await InvokeAsync(StateHasChanged);
                await Task.Yield();
                if (_form?.EditContext is null || !_form.EditContext.Validate())
                    return false;
            }
            return true;
        }
        finally
        {
            _currentStep = back;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnTemplateSubmitAsync(AircraftTypeFormModel _)
    {
        if (_saving) return;
        _saving = true;
        ClearErrors();
        await InvokeAsync(StateHasChanged);

        try
        {
            var r = await ScopedMediator.Send(new CreateAircraftTypeCommand(
                _model.Manufacturer,
                _model.Model.Trim(),
                string.IsNullOrWhiteSpace(_model.Notes) ? null : _model.Notes.Trim(),
                _model.IsActive));
            if (r.IsFailure)
            {
                SetCommandError(r.Error.Description);
                NotificationService.Notify(NotificationSeverity.Error, "Could not save aircraft type", r.Error.Description);
                return;
            }

            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            SetCommandError(ex.Message);
            NotificationService.Notify(NotificationSeverity.Error, "Unexpected error", ex.Message);
        }
        finally
        {
            _saving = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnCancelAsync()
    {
        DialogService.Close(false);
        await Task.CompletedTask;
    }
}
