@*
  Data page: grid + Add opens CountryAddDialog; row edit opens CountryUpdateDialog.
  See Component Rules.md — structure matches AircraftTypesGrid / CustomersGrid.
*@
@using Core.Application.Features.Country.Queries.GetPaginatedCountries
@using Core.Contracts.Features.Country
@using Host.Web.Components.Pages.Shared.Badges
@using Host.Web.Components.Shared.DataGrid
@using Host.Web.Services
@inherits GridSettingsComponentBase<CountryDto>
@inject IScopedMediator ScopedMediator
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject ILookupCache LookupCache

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h4 mb-1">Countries</h1>
        <p class="text-secondary small mb-0">ISO 3166-1 alpha-2 reference for stations and addresses.</p>
    </div>
    <button type="button"
            class="btn btn-sm settings-grid-add-btn"
            disabled="@IsLoading"
            @onclick="OpenAddDialogAsync">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
        Add New
    </button>
</div>

@if (Data is null && !IsLoading)
{
    <TableSkeleton Rows="10" Columns="5" />
}
else
{
    <RadzenDataGrid @ref="Grid"
                    TItem="CountryDto"
                    Data="@Data"
                    Count="@Count"
                    LoadData="@HandleLoadDataAsync"
                    LoadSettings="@LoadSettings"
                    @bind-Settings="Settings"
                    PickedColumnsChanged="@OnPickedColumnsChanged"
                    IsLoading="@IsLoading"
                    Sort="@ShowLoadingAsync"
                    Page="@ShowLoadingAsync"
                    Group="@ShowLoadingAsync"
                    Filter="@ShowLoadingAsync"
                    ColumnWidth="160px"
                    Style="height: calc(100vh - 200px);"
                    Density="GridDefaults.Density"
                    FilterMode="GridDefaults.FilterMode"
                    AllowPaging="GridDefaults.AllowPaging"
                    PageSize="GridDefaults.DefaultPageSize"
                    AllowSorting="GridDefaults.AllowSorting"
                    AllowFiltering="GridDefaults.AllowFiltering"
                    AllowColumnResize="GridDefaults.AllowColumnResize"
                    AllowColumnPicking="GridDefaults.AllowColumnPicking"
                    AllowColumnReorder="GridDefaults.AllowColumnReorder"
                    AllowAlternatingRows="GridDefaults.AllowAlternatingRows"
                    LogicalFilterOperator="GridDefaults.LogicalFilterOperator"
                    FilterCaseSensitivity="GridDefaults.FilterCaseSensitivity"
                    AllowVirtualization="GridDefaults.AllowVirtualization"
                    VirtualizationOverscanCount="GridDefaults.VirtualizationOverscanCount"
                    AllowRowSelectOnRowClick="true"
                    RowClick="@(() => Task.CompletedTask)">
        <HeaderTemplate>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="10px">
                    <RadzenButton Icon="refresh"
                                  Text="@($"Refresh ({GetTitleText()})")"
                                  ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Filled"
                                  Shade="Shade.Light"
                                  Size="ButtonSize.Small"
                                  Click="@RefreshAsync"
                                  Disabled="@IsLoading" />
                </RadzenStack>
            </RadzenStack>
        </HeaderTemplate>
        <Columns>
            <RadzenDataGridColumn TItem="CountryDto"
                                  Property="@nameof(CountryDto.IsActive)"
                                  Title="Active"
                                  Width="60px">
                <Template Context="row">
                    <Status IsActive="row.IsActive" />
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="CountryDto"
                                  Property="@nameof(CountryDto.Code)"
                                  FilterOperator="FilterOperator.Contains"
                                  Title="Code"
                                  Width="100px" />
            <RadzenDataGridColumn TItem="CountryDto"
                                  Property="@nameof(CountryDto.Name)"
                                  FilterOperator="FilterOperator.Contains"
                                  Title="Name"
                                  Width="240px" />
            <RadzenDataGridColumn TItem="CountryDto"
                                  Property="@nameof(CountryDto.CreatedAt)"
                                  Title="Created At"
                                  Visible="false" />
            <RadzenDataGridColumn TItem="CountryDto"
                                  Property="@nameof(CountryDto.UpdatedAt)"
                                  Title="Updated At"
                                  Visible="false" />
            <RadzenDataGridColumn TItem="CountryDto"
                                  Title="Actions"
                                  Frozen="true"
                                  FrozenPosition="FrozenColumnPosition.Right"
                                  Width="70px"
                                  Filterable="false"
                                  Sortable="false"
                                  Pickable="false"
                                  Resizable="false"
                                  Reorderable="false"
                                  TextAlign="TextAlign.Center">
                <Template Context="row">
                    <button type="button"
                            class="settings-grid-edit-btn"
                            disabled="@IsLoading"
                            @onclick="@(() => OpenEditDialogAsync(row))"
                            @onclick:stopPropagation="true"
                            title="Edit country">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" /><path d="m15 5 4 4" /></svg>
                        Edit
                    </button>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    protected override string SettingsStorageKey => "CountryList-Settings";

    // CountryDto.Code (string) → Country.Code.Value (entity has OwnsOne CountryCode VO).
    protected override IReadOnlyDictionary<string, string> FilterPropertyMap { get; } =
        new Dictionary<string, string>(StringComparer.Ordinal)
        {
            ["Code"] = "Code.Value",
        };

    protected override Task HandleLoadDataAsync(LoadDataArgs args) =>
        LoadDataAsync(args, LoadAsync);

    private async Task LoadAsync(
        LoadDataArgs args, int pageSize, int pageNumber, IServiceProvider sp, CancellationToken ct)
    {
        var visibleColumns = GetVisibleColumnPropertyNames();

        var result = await ScopedMediator.Send(
            new GetPaginatedCountriesQuery(
                pageNumber,
                pageSize,
                args.Filter,
                args.OrderBy,
                visibleColumns),
            ct);

        if (result.IsSuccess)
            SetGridResult(result.Value.Items, result.Value.TotalCount);
        else
            SetGridResult([], 0);
    }

    private string GetTitleText() => $"Total Items {Count:N0}";

    private async Task RefreshAsync()
    {
        await ShowLoadingAsync();
        Grid?.Reload();
    }

    private async Task OpenAddDialogAsync() => await OpenDialogAsync(null);

    private async Task OpenEditDialogAsync(CountryDto row) => await OpenDialogAsync(row);

    private async Task OpenDialogAsync(CountryDto? existing)
    {
        var title = existing is null ? "New country" : "Edit country";
        if (existing is null)
        {
            var resultAdd = await DialogService.OpenAsync<CountryAddDialog>(
                title,
                null,
                new DialogOptions
                {
                    Width = "min(56rem, 95vw)",
                    Resizable = false,
                    Draggable = false,
                    CloseDialogOnOverlayClick = false,
                    ShowClose = false,
                });

            if (resultAdd is true)
            {
                LookupCache.Invalidate<CountrySelectOption>();
                NotificationService.Notify(NotificationSeverity.Success, "Saved", "Country saved.");
                await ReloadAndResetAsync();
            }
        }
        else
        {
            var resultEdit = await DialogService.OpenAsync<CountryUpdateDialog>(
                title,
                new Dictionary<string, object?> { { nameof(CountryUpdateDialog.ExistingItem), existing } },
                new DialogOptions
                {
                    Width = "min(56rem, 95vw)",
                    Resizable = false,
                    Draggable = false,
                    CloseDialogOnOverlayClick = false,
                    ShowClose = false,
                });

            if (resultEdit is true)
            {
                LookupCache.Invalidate<CountrySelectOption>();
                NotificationService.Notify(NotificationSeverity.Success, "Saved", "Country saved.");
                await ReloadAndResetAsync();
            }
        }
    }
}
