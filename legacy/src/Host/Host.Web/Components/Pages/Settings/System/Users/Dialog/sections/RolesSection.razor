@*
    Roles slice — checkbox-list against the cached role lookup. Empty selection is allowed (admins
    can save the dialog without granting any role; the user simply has zero permissions until
    something is assigned later).
*@
@namespace Host.Web.Components.Pages.Settings.System.Users.Dialog.Sections
@using Host.Web.Components.Pages.Settings.System.Users.Dialog
@using Identity.Contracts.Features.Role

<RadzenStack Gap="1rem">
    <div class="settings-field">
        <label class="settings-field__label">Assigned roles</label>
        @if (RolesLoading)
        {
            <DropdownFieldSkeleton AriaLabel="Loading roles" />
        }
        else if (Roles.Count == 0)
        {
            <p class="text-secondary small mb-0">No roles defined yet — create them under <em>System → Roles</em>.</p>
        }
        else
        {
            <RadzenCheckBoxList TValue="Guid"
                                SelectedValues="@Model.RoleIds"
                                Data="@Roles"
                                TextProperty="@nameof(RoleSelectOption.Name)"
                                ValueProperty="@nameof(RoleSelectOption.Id)"
                                Orientation="Orientation.Horizontal"
                                Change="@OnRolesChanged"
                                Style="width:100%;" />
        }
    </div>

    @if (!RolesLoading && Roles.Count > 0)
    {
        <p class="text-secondary small mb-0" style="font-size: 0.7rem;">
            Tick every role this user should hold. The granted permissions are the union of all their roles' permissions.
        </p>
    }
</RadzenStack>

@code {
    [Parameter, EditorRequired] public UserFormModel Model { get; set; } = default!;

    [Parameter] public IReadOnlyList<RoleSelectOption> Roles { get; set; } = [];

    [Parameter] public bool RolesLoading { get; set; }

    [Parameter] public EventCallback OnModelChanged { get; set; }

    private async Task OnRolesChanged(IEnumerable<Guid> selectedRoleIds)
    {
        Model.RoleIds = selectedRoleIds.Distinct().ToList();
        await OnModelChanged.InvokeAsync();
    }
}
