@*
  Data page: grid + Add opens UserAddDialog; row edit opens UserUpdateDialog.
  See Component Rules.md — aligned with EmployeesGrid.
*@
@using Identity.Application.Queries.GetPaginatedUsers
@using Identity.Contracts.Features.User
@using Host.Web.Components.Pages.Shared.Badges
@using Host.Web.Components.Shared.DataGrid
@using Host.Web.Services
@inherits GridSettingsComponentBase<UserDto>
@inject IScopedMediator ScopedMediator
@inject NotificationService NotificationService
@inject DialogService DialogService

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h4 mb-1">Users</h1>
        <p class="text-secondary small mb-0">System accounts, roles, and invitation lifecycle.</p>
    </div>
    <button type="button"
            class="settings-grid-add-btn"
            disabled="@IsLoading"
            @onclick="OpenAddDialogAsync">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
        Add New
    </button>
</div>

@if (Data is null && !IsLoading)
{
    <TableSkeleton Rows="10" Columns="7" />
}
else
{
    <RadzenDataGrid @ref="Grid"
                    TItem="UserDto"
                    Data="@Data"
                    Count="@Count"
                    LoadData="@HandleLoadDataAsync"
                    LoadSettings="@LoadSettings"
                    @bind-Settings="Settings"
                    PickedColumnsChanged="@OnPickedColumnsChanged"
                    IsLoading="@IsLoading"
                    Sort="@ShowLoadingAsync"
                    Page="@ShowLoadingAsync"
                    Group="@ShowLoadingAsync"
                    Filter="@ShowLoadingAsync"
                    ColumnWidth="140px"
                    Style="height: calc(100vh - 200px);"
                    Density="GridDefaults.Density"
                    FilterMode="GridDefaults.FilterMode"
                    AllowPaging="GridDefaults.AllowPaging"
                    PageSize="GridDefaults.DefaultPageSize"
                    AllowSorting="GridDefaults.AllowSorting"
                    AllowFiltering="GridDefaults.AllowFiltering"
                    AllowColumnResize="GridDefaults.AllowColumnResize"
                    AllowColumnPicking="GridDefaults.AllowColumnPicking"
                    AllowColumnReorder="GridDefaults.AllowColumnReorder"
                    AllowAlternatingRows="GridDefaults.AllowAlternatingRows"
                    LogicalFilterOperator="GridDefaults.LogicalFilterOperator"
                    FilterCaseSensitivity="GridDefaults.FilterCaseSensitivity"
                    AllowVirtualization="GridDefaults.AllowVirtualization"
                    VirtualizationOverscanCount="GridDefaults.VirtualizationOverscanCount"
                    AllowRowSelectOnRowClick="true"
                    RowClick="@(() => Task.CompletedTask)">
        <HeaderTemplate>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="10px">
                    <RadzenButton Icon="refresh"
                                  Text="@($"Refresh ({GetTitleText()})")"
                                  ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Filled"
                                  Shade="Shade.Light"
                                  Size="ButtonSize.Small"
                                  Click="@RefreshAsync"
                                  Disabled="@IsLoading" />
                </RadzenStack>
            </RadzenStack>
        </HeaderTemplate>
        <Columns>
            @* IsActive is computed on the DTO from Status; the User entity Ignores it
               (see UserConfiguration), so it's not filterable on the entity side. *@
            <RadzenDataGridColumn TItem="UserDto" Property="@nameof(UserDto.IsActive)" Title="Active" Width="64px"
                                  Filterable="false" Sortable="false">
                <Template Context="row"><Status IsActive="row.IsActive" /></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="UserDto" Property="@nameof(UserDto.Username)" Title="Username" />
            <RadzenDataGridColumn TItem="UserDto" Property="@nameof(UserDto.Email)" Title="Email" />
            <RadzenDataGridColumn TItem="UserDto" Property="@nameof(UserDto.UserType)" Title="Type" Width="110px" />
            <RadzenDataGridColumn TItem="UserDto" Property="@nameof(UserDto.Status)" Title="Status" Width="140px">
                <Template Context="row"><span class="user-status-pill user-status-pill--@row.Status.ToLowerInvariant()">@FormatStatus(row.Status)</span></Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="UserDto" Title="Roles" Sortable="false" Filterable="false">
                <Template Context="row">
                    @if (row.Roles.Count == 0)
                    {
                        <span class="text-secondary small">—</span>
                    }
                    else
                    {
                        <div class="user-role-chips">
                            @foreach (var role in row.Roles)
                            {
                                <span class="user-role-chip" title="@role.Name">@role.Name</span>
                            }
                        </div>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="UserDto" Property="@nameof(UserDto.CreatedAt)" Title="Created" Width="160px" FormatString="{0:yyyy-MM-dd}" />
            <RadzenDataGridColumn TItem="UserDto" Title="Actions" Frozen="true" FrozenPosition="FrozenColumnPosition.Right" Width="70px"
                                  Filterable="false" Sortable="false" Pickable="false" Resizable="false" Reorderable="false" TextAlign="TextAlign.Center">
                <Template Context="row">
                    <button type="button" class="settings-grid-edit-btn" disabled="@IsLoading" @onclick="@(() => OpenEditDialogAsync(row))" @onclick:stopPropagation="true" title="Edit user">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" /><path d="m15 5 4 4" /></svg>
                        Edit
                    </button>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    protected override string SettingsStorageKey => "UserList-Settings";

    // DTO field name → User entity property path. Username / Email are OwnsOne VOs reached
    // via .Value (see UserConfiguration). UserType / Status are Enumeration objects whose
    // string label lives on .Name.
    protected override IReadOnlyDictionary<string, string> FilterPropertyMap { get; } =
        new Dictionary<string, string>(StringComparer.Ordinal)
        {
            ["Username"] = "Username.Value",
            ["Email"] = "Email.Value",
            ["UserType"] = "UserType.Name",
            ["Status"] = "Status.Name",
        };

    protected override Task HandleLoadDataAsync(LoadDataArgs args) =>
        LoadDataAsync(args, LoadAsync);

    private async Task LoadAsync(LoadDataArgs args, int pageSize, int pageNumber, IServiceProvider sp, CancellationToken ct)
    {
        var result = await ScopedMediator.Send(
            new GetPaginatedUsersQuery(pageNumber, pageSize, args.Filter, args.OrderBy, GetVisibleColumnPropertyNames()), ct);

        if (result.IsSuccess)
            SetGridResult(result.Value.Items, result.Value.TotalCount);
        else
            SetGridResult([], 0);
    }

    private string GetTitleText() => $"Total Items {Count:N0}";

    private static string FormatStatus(string status) => status switch
    {
        "PendingActivation" => "Pending invite",
        "Deactivated" => "Inactive",
        _ => status
    };

    private async Task RefreshAsync()
    {
        await ShowLoadingAsync();
        Grid?.Reload();
    }

    private async Task OpenAddDialogAsync() => await OpenDialogAsync(null);

    private async Task OpenEditDialogAsync(UserDto row) => await OpenDialogAsync(row);

    private async Task OpenDialogAsync(UserDto? existing)
    {
        var title = existing is null ? "Invite user" : "Edit user";
        if (existing is null)
        {
            var resultAdd = await DialogService.OpenAsync<UserAddDialog>(
                title,
                null,
                new DialogOptions { Width = "min(56rem, 95vw)", Resizable = false, Draggable = false, CloseDialogOnOverlayClick = false, ShowClose = false });

            if (resultAdd is true)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Invitation sent", "User invitation email dispatched.");
                await ReloadAndResetAsync();
            }
        }
        else
        {
            var resultEdit = await DialogService.OpenAsync<UserUpdateDialog>(
                title,
                new Dictionary<string, object?> { { nameof(UserUpdateDialog.ExistingItem), existing } },
                new DialogOptions { Width = "min(56rem, 95vw)", Resizable = false, Draggable = false, CloseDialogOnOverlayClick = false, ShowClose = false });

            if (resultEdit is true)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Saved", "User saved.");
                await ReloadAndResetAsync();
            }
        }
    }
}
