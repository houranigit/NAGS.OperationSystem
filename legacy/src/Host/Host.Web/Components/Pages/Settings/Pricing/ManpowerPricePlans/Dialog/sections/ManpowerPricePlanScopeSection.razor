@namespace Host.Web.Components.Pages.Settings.Pricing.ManpowerPricePlans.Dialog.Sections
@using Core.Contracts.Features.Currency
@using Core.Contracts.Features.ManpowerType
@using Core.Contracts.Features.OperationType
@using Core.Domain.Enumerations
@using Host.Web.Components.Pages.Settings.Pricing.ManpowerPricePlans.Dialog
@using Host.Web.Components.Pages.Settings.Pricing.Shared

@if (!string.IsNullOrWhiteSpace(LoadError))
{
    <p class="text-danger small mb-0">@LoadError</p>
}
else
{
    <RadzenStack Gap="1rem">
        <div class="settings-field__row2">
            <div class="settings-field" style="position: relative;">
                <label class="settings-field__label" for="mpp-manpower">Manpower type</label>
                @if (LoadingManpowerTypes)
                {
                    <DropdownFieldSkeleton AriaLabel="Loading manpower types"/>
                }
                else
                {
                    <RadzenDropDown TValue="Guid?"
                                    id="mpp-manpower"
                                    Name="MppManpowerType"
                                    @bind-Value="Model.ManpowerTypeId"
                                    Data="@ManpowerTypes"
                                    TextProperty="@nameof(ManpowerTypeSelectOption.Name)"
                                    ValueProperty="@nameof(ManpowerTypeSelectOption.Id)"
                                    AllowClear="false"
                                    Disabled="@FreezeManpowerScopeKeys"
                                    Placeholder="Select…"
                                    Change="@OnChg"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="MppManpowerType" Text="Required" Popup="true" Style="position:absolute;" />
                }
            </div>
            <div class="settings-field" style="position: relative;">
                <label class="settings-field__label" for="mpp-operation">Operation type</label>
                @if (LoadingOperationTypes)
                {
                    <DropdownFieldSkeleton AriaLabel="Loading operation types"/>
                }
                else
                {
                    <RadzenDropDown TValue="Guid?"
                                    id="mpp-operation"
                                    Name="MppOperationType"
                                    @bind-Value="Model.OperationTypeId"
                                    Data="@OperationTypes"
                                    TextProperty="@nameof(OperationTypeSelectOption.Name)"
                                    ValueProperty="@nameof(OperationTypeSelectOption.Id)"
                                    AllowClear="false"
                                    Disabled="@FreezeManpowerScopeKeys"
                                    Placeholder="Select…"
                                    Change="@OnChg"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="MppOperationType" Text="Required" Popup="true" Style="position:absolute;" />
                }
            </div>
        </div>
        <div class="settings-field__row2">
            <div class="settings-field" style="position: relative;">
                <label class="settings-field__label" for="mpp-currency">Currency</label>
                @if (LoadingCurrencies)
                {
                    <DropdownFieldSkeleton AriaLabel="Loading currencies"/>
                }
                else
                {
                    <RadzenDropDown TValue="Guid?"
                                    id="mpp-currency"
                                    Name="MppCurrency"
                                    @bind-Value="Model.CurrencyId"
                                    Data="@Currencies"
                                    TextProperty="@nameof(CurrencySelectOption.Code)"
                                    ValueProperty="@nameof(CurrencySelectOption.Id)"
                                    AllowClear="false"
                                    Placeholder="Select…"
                                    Change="@OnChg"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="MppCurrency" Text="Required" Popup="true" Style="position:absolute;" />
                }
            </div>
            <div class="settings-field">
                <label class="settings-field__label" for="mpp-basis">Pricing basis</label>
                <RadzenDropDown TValue="PricingBasis"
                                id="mpp-basis"
                                Name="MppBasis"
                                Value="@Model.Basis"
                                ValueChanged="@OnBasisChangedAsync"
                                Data="@PricePlanBasisOptions.All"
                                TextProperty="@nameof(PricePlanBasisOptions.Item.Label)"
                                ValueProperty="@nameof(PricePlanBasisOptions.Item.Value)"
                                Style="width:100%;" />
            </div>
        </div>
    </RadzenStack>
}

@code {
    [Parameter, EditorRequired] public ManpowerPricePlanScopeFormModel Model { get; set; } = default!;

    /// <summary>When true, manpower and operation dropdowns cannot be changed (pairs are invariant after creation).</summary>
    [Parameter] public bool FreezeManpowerScopeKeys { get; set; }

    [Parameter] public EventCallback OnModelChanged { get; set; }

    [Parameter] public string? LoadError { get; set; }

    [Parameter] public bool LoadingManpowerTypes { get; set; }

    [Parameter] public bool LoadingOperationTypes { get; set; }

    [Parameter] public bool LoadingCurrencies { get; set; }

    [Parameter] public IReadOnlyList<ManpowerTypeSelectOption> ManpowerTypes { get; set; } = [];

    [Parameter] public IReadOnlyList<OperationTypeSelectOption> OperationTypes { get; set; } = [];

    [Parameter] public IReadOnlyList<CurrencySelectOption> Currencies { get; set; } = [];

    [Parameter] public EventCallback<PricingBasis> BasisChanged { get; set; }

    private Task OnChg() => OnModelChanged.InvokeAsync();

    private async Task OnBasisChangedAsync(PricingBasis b)
    {
        Model.Basis = b;
        await BasisChanged.InvokeAsync(b);
        await OnModelChanged.InvokeAsync();
    }
}
