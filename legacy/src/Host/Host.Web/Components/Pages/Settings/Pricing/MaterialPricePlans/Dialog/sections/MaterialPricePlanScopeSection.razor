@*
  Scope step for material price-plan dialogs — Material / Currency / Basis.
*@
@namespace Host.Web.Components.Pages.Settings.Pricing.MaterialPricePlans.Dialog.Sections
@using Core.Contracts.Features.Currency
@using Core.Domain.Enumerations
@using Host.Web.Components.Pages.Settings.Pricing.MaterialPricePlans.Dialog
@using Host.Web.Components.Pages.Settings.Pricing.Shared
@using Store.Contracts.Features.Material

@if (!string.IsNullOrWhiteSpace(LoadError))
{
    <p class="text-danger small mb-0">@LoadError</p>
}
else
{
    <RadzenStack Gap="1rem">
        <div class="settings-field" style="position: relative;">
            <label class="settings-field__label" for="mtpp-material">Material</label>
            @if (LoadingMaterials)
            {
                <DropdownFieldSkeleton AriaLabel="Loading materials" />
            }
            else
            {
                <RadzenDropDown TValue="Guid?"
                                id="mtpp-material"
                                Name="MtppMaterial"
                                @bind-Value="Model.MaterialId"
                                Data="@Materials"
                                TextProperty="@nameof(MaterialSelectOption.Name)"
                                ValueProperty="@nameof(MaterialSelectOption.Id)"
                                AllowClear="false"
                                AllowFiltering="true"
                                FilterOperator="StringFilterOperator.Contains"
                                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                Disabled="@FreezeItemKey"
                                Placeholder="Select…"
                                Change="@OnChg"
                                Style="width: 100%;" />
                <RadzenRequiredValidator Component="MtppMaterial" Text="Required" Popup="true" Style="position:absolute;" />
            }
        </div>
        <div class="settings-field__row2">
            <div class="settings-field" style="position: relative;">
                <label class="settings-field__label" for="mtpp-currency">Currency</label>
                @if (LoadingCurrencies)
                {
                    <DropdownFieldSkeleton AriaLabel="Loading currencies" />
                }
                else
                {
                    <RadzenDropDown TValue="Guid?"
                                    id="mtpp-currency"
                                    Name="MtppCurrency"
                                    @bind-Value="Model.CurrencyId"
                                    Data="@Currencies"
                                    TextProperty="@nameof(CurrencySelectOption.Code)"
                                    ValueProperty="@nameof(CurrencySelectOption.Id)"
                                    AllowClear="false"
                                    Placeholder="Select…"
                                    Change="@OnChg"
                                    Style="width: 100%;" />
                    <RadzenRequiredValidator Component="MtppCurrency" Text="Required" Popup="true" Style="position:absolute;" />
                }
            </div>
            <div class="settings-field">
                <label class="settings-field__label" for="mtpp-basis">Pricing basis</label>
                <RadzenDropDown TValue="PricingBasis"
                                id="mtpp-basis"
                                Name="MtppBasis"
                                Value="@Model.Basis"
                                ValueChanged="@OnBasisChangedAsync"
                                Data="@PricePlanBasisOptions.All"
                                TextProperty="@nameof(PricePlanBasisOptions.Item.Label)"
                                ValueProperty="@nameof(PricePlanBasisOptions.Item.Value)"
                                Style="width: 100%;" />
            </div>
        </div>
    </RadzenStack>
}

@code {
    [Parameter, EditorRequired] public MaterialPricePlanScopeFormModel Model { get; set; } = default!;

    [Parameter] public bool FreezeItemKey { get; set; }

    [Parameter] public EventCallback OnModelChanged { get; set; }

    [Parameter] public string? LoadError { get; set; }

    [Parameter] public bool LoadingMaterials { get; set; }

    [Parameter] public bool LoadingCurrencies { get; set; }

    [Parameter] public IReadOnlyList<MaterialSelectOption> Materials { get; set; } = [];

    [Parameter] public IReadOnlyList<CurrencySelectOption> Currencies { get; set; } = [];

    [Parameter] public EventCallback<PricingBasis> BasisChanged { get; set; }

    private Task OnChg() => OnModelChanged.InvokeAsync();

    private async Task OnBasisChangedAsync(PricingBasis b)
    {
        Model.Basis = b;
        await BasisChanged.InvokeAsync(b);
        await OnModelChanged.InvokeAsync();
    }
}
