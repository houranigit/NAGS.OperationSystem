@*
  Data page: grid + Add opens Dialog/ServicePricePlanAddDialog; row edit opens Dialog/ServicePricePlanUpdateDialog.
  See Component Rules.md — mirrors CustomersGrid patterns.
*@
@using Core.Application.Features.ServicePricePlan.Queries.GetPaginatedServicePricePlans
@using Core.Contracts.Features.ServicePricePlan
@using Core.Domain.Enumerations
@using Host.Web.Components.Shared.DataGrid
@using Host.Web.Services
@inherits GridSettingsComponentBase<ServicePricePlanDto>
@inject IScopedMediator ScopedMediator
@inject NotificationService NotificationService
@inject DialogService DialogService

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1 class="h4 mb-1">Service price plans</h1>
        <p class="text-secondary small mb-0">Default rates by service, operation, and aircraft (with optional duration brackets).</p>
    </div>
    <button type="button"
            class="btn btn-sm settings-grid-add-btn"
            disabled="@IsLoading"
            @onclick="OpenAddDialogAsync">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
        Add New
    </button>
</div>

@if (Data is null && !IsLoading)
{
    <TableSkeleton Rows="6" Columns="6" />
}
else
{
    <RadzenDataGrid @ref="Grid"
                    TItem="ServicePricePlanDto"
                    Data="@Data"
                    Count="@Count"
                    LoadData="@HandleLoadDataAsync"
                    LoadSettings="@LoadSettings"
                    @bind-Settings="Settings"
                    PickedColumnsChanged="@OnPickedColumnsChanged"
                    IsLoading="@IsLoading"
                    Sort="@ShowLoadingAsync"
                    Page="@ShowLoadingAsync"
                    Filter="@ShowLoadingAsync"
                    ColumnWidth="140px"
                    Style="height: calc(100vh - 200px);"
                    Density="GridDefaults.Density"
                    FilterMode="GridDefaults.FilterMode"
                    AllowPaging="GridDefaults.AllowPaging"
                    PageSize="GridDefaults.DefaultPageSize"
                    AllowSorting="GridDefaults.AllowSorting"
                    AllowFiltering="GridDefaults.AllowFiltering"
                    AllowColumnResize="GridDefaults.AllowColumnResize"
                    AllowColumnPicking="GridDefaults.AllowColumnPicking"
                    AllowColumnReorder="GridDefaults.AllowColumnReorder"
                    AllowAlternatingRows="GridDefaults.AllowAlternatingRows"
                    LogicalFilterOperator="GridDefaults.LogicalFilterOperator"
                    FilterCaseSensitivity="GridDefaults.FilterCaseSensitivity"
                    AllowVirtualization="false"
                    ExpandMode="DataGridExpandMode.Multiple"
                    ShowExpandAll="true"
                    AllowRowSelectOnRowClick="false">
        <HeaderTemplate>
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="10px">
                    <RadzenButton Icon="refresh"
                                  Text="@($"Refresh ({GetTitleText()})")"
                                  ButtonStyle="ButtonStyle.Light"
                                  Variant="Variant.Filled"
                                  Shade="Shade.Light"
                                  Size="ButtonSize.Small"
                                  Click="@RefreshAsync"
                                  Disabled="@IsLoading" />
                </RadzenStack>
            </RadzenStack>
        </HeaderTemplate>
        <Columns>
            @* Property MUST be a primitive on the DTO. The map below rewrites these DTO
               paths to the anonymous-projection field names the handler joins into
               (see GetPaginatedServicePricePlansQueryHandler.Handle: { p, s, ot, curr, at }). *@
            <RadzenDataGridColumn TItem="ServicePricePlanDto" Property="ServiceTypeSnapshot.Name" Title="Service" Pickable="true">
                <Template Context="r">
                    <span class="fw-semibold">@r.ServiceTypeSnapshot.Name</span>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServicePricePlanDto" Property="OperationTypeSnapshot.Name" Title="Operation" Pickable="true">
                <Template Context="r">
                    <span class="fw-semibold">@r.OperationTypeSnapshot.Name</span>
                </Template>
            </RadzenDataGridColumn>
            @* AircraftTypeSnapshot is nullable on the DTO; the LEFT JOIN exposes a nullable at on
               the entity side. Filtering still works — Dynamic.Core emits a null guard for us. *@
            <RadzenDataGridColumn TItem="ServicePricePlanDto" Property="AircraftTypeSnapshot.Model" Title="Aircraft" Pickable="true">
                <Template Context="r">
                    @if (r.AircraftTypeSnapshot is not null)
                    {
                        <span class="badge bg-label-secondary">@r.AircraftTypeSnapshot.Model</span>
                    }
                    else
                    {
                        <span class="text-body-secondary small">All aircraft</span>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServicePricePlanDto" Property="CurrencySnapshot.Code" Title="Currency" Pickable="true">
                <Template Context="r">@r.CurrencySnapshot.Code</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServicePricePlanDto" Property="@nameof(ServicePricePlanDto.Basis)" Title="Basis" Pickable="true">
                <Template Context="r">@BasisLabel(r.Basis)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ServicePricePlanDto"
                                  Title="Actions"
                                  Width="70px"
                                  Filterable="false"
                                  Sortable="false"
                                  Pickable="false"
                                  Frozen="true"
                                  FrozenPosition="FrozenColumnPosition.Right"
                                  Resizable="false"
                                  Reorderable="false"
                                  TextAlign="TextAlign.Center">
                <Template Context="r">
                    <button type="button"
                            class="settings-grid-edit-btn"
                            disabled="@IsLoading"
                            title="Edit plan"
                            @onclick="@(() => OpenEditDialogAsync(r))"
                            @onclick:stopPropagation="true">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" /><path d="m15 5 4 4" /></svg>
                        Edit
                    </button>
                </Template>
            </RadzenDataGridColumn>
        </Columns>
        <Template Context="plan">
            <div class="ppp-brackets-detail">
                @if (plan.Basis == PricingBasis.Flat)
                {
                    @if (plan.Brackets.Count > 0)
                    {
                        <span class="ppp-flat-rate">
                            Flat rate: <strong>@plan.Brackets[0].Value.ToString("N2")</strong> @plan.CurrencySnapshot.Code per unit
                        </span>
                    }
                    else
                    {
                        <p class="text-body-secondary small ms-1 my-1">No rate defined.</p>
                    }
                }
                else
                {
                    @if (plan.Brackets.Count > 0)
                    {
                        <div class="ppp-bracket-table-ro">
                            <div class="ppp-bracket-header-ro">
                                <span>From (min)</span>
                                <span>To (min)</span>
                                <span>Block (min)</span>
                                <span>Rate (@plan.CurrencySnapshot.Code)</span>
                                <span>Billing mode</span>
                            </div>
                            @foreach (var b in plan.Brackets)
                            {
                                <div class="ppp-bracket-row-ro">
                                    <span>@b.MinMinutes</span>
                                    <span>@(b.MaxMinutes?.ToString() ?? "∞")</span>
                                    <span>@b.BlockSize</span>
                                    <span class="fw-semibold">@b.Value.ToString("N2")</span>
                                    <span>@BillingModeLabel(b.BillingMode)</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-body-secondary small ms-1 my-1">No brackets defined. Click <strong>Edit</strong> to add brackets.</p>
                    }
                }
            </div>
        </Template>
    </RadzenDataGrid>
}

@code {
    protected override string SettingsStorageKey => "ServicePricePlanList-Settings";

    // DTO snapshot path → joined anon-shape path inside the handler. The handler builds
    // its IQueryable as `from p ... join s ... join ot ... join curr ... join at ...
    // select new { p, s, ot, curr, at, Basis }`, so Where(filter) sees those identifiers.
    // Currency.Code is OwnsOne (.Value is the string); AircraftType.Model is a primitive.
    //
    // AircraftTypeSnapshot is nullable on the DTO — Radzen emits both
    // "x.AircraftTypeSnapshot.Model.Contains(...)" and "x.AircraftTypeSnapshot != null".
    // The longer dotted path is mapped first so it wins; the bare "AircraftTypeSnapshot"
    // entry catches the standalone null guard.
    protected override IReadOnlyDictionary<string, string> FilterPropertyMap { get; } =
        new Dictionary<string, string>(StringComparer.Ordinal)
        {
            ["ServiceTypeSnapshot.Name"] = "s.Name",
            ["OperationTypeSnapshot.Name"] = "ot.Name",
            ["AircraftTypeSnapshot.Model"] = "at.Model",
            ["CurrencySnapshot.Code"] = "curr.Code.Value",
            ["AircraftTypeSnapshot"] = "at",
        };

    private bool _expandRowsPending;

    protected override async Task HandleLoadDataAsync(LoadDataArgs a)
    {
        await LoadDataAsync(a, LoadCore);
        _expandRowsPending = Data is { Count: > 0 };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (!_expandRowsPending || Grid is null || Data is null || Data.Count == 0)
            return;

        _expandRowsPending = false;
        await Grid.ExpandRows(Data);
    }

    private async Task LoadCore(LoadDataArgs a, int ps, int pn, IServiceProvider sp, CancellationToken ct)
    {
        var r = await ScopedMediator.Send(new GetPaginatedServicePricePlansQuery(pn, ps, a.Filter, a.OrderBy, GetVisibleColumnPropertyNames()), ct);
        if (r.IsSuccess)
            SetGridResult(r.Value.Items, r.Value.TotalCount);
        else
            SetGridResult([], 0);
    }

    private string GetTitleText() => $"Total Items {Count:N0}";

    private async Task RefreshAsync()
    {
        await ShowLoadingAsync();
        Grid?.Reload();
    }

    private Task OpenAddDialogAsync() => OpenDialogAsync(null);

    private Task OpenEditDialogAsync(ServicePricePlanDto row) => OpenDialogAsync(row);

    private async Task OpenDialogAsync(ServicePricePlanDto? row)
    {
        if (row is null)
        {
            var addRes = await DialogService.OpenAsync<ServicePricePlanAddDialog>(
                "New service price plan",
                null,
                new DialogOptions { Width = "min(56rem, 95vw)", Resizable = false, Draggable = false, CloseDialogOnOverlayClick = false, ShowClose = false });
            if (addRes is true)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Saved", "Service price plan created.");
                await ReloadAndResetAsync();
            }

            return;
        }

        var res = await DialogService.OpenAsync<ServicePricePlanUpdateDialog>(
            "Edit service price plan",
            new Dictionary<string, object?> { { nameof(ServicePricePlanUpdateDialog.ExistingItem), row } },
            new DialogOptions { Width = "min(56rem, 95vw)", Resizable = false, Draggable = false, CloseDialogOnOverlayClick = false, ShowClose = false });
        if (res is true)
        {
            NotificationService.Notify(NotificationSeverity.Success, "Saved", "Service price plan updated.");
            await ReloadAndResetAsync();
        }
    }

    private static string BasisLabel(PricingBasis basis) => basis switch
    {
        PricingBasis.Flat => "Flat per unit",
        PricingBasis.Duration => "Duration brackets",
        _ => basis.ToString()
    };

    private static string BillingModeLabel(BracketBillingMode mode) => mode switch
    {
        BracketBillingMode.Floor => "Floor",
        BracketBillingMode.Ceiling => "Ceiling",
        BracketBillingMode.ProRated => "Pro-rated",
        _ => mode.ToString()
    };
}
