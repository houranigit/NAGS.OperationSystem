@namespace Host.Web.Components.Pages.Settings.Pricing.ServicePricePlans.Dialog.Sections
@using Core.Contracts.Features.AircraftType
@using Core.Contracts.Features.Currency
@using Core.Contracts.Features.OperationType
@using Core.Contracts.Features.Service
@using Core.Domain.Enumerations
@using Host.Web.Components.Pages.Settings.Pricing.ServicePricePlans.Dialog
@using Host.Web.Components.Pages.Settings.Pricing.Shared

@if (!string.IsNullOrWhiteSpace(LoadError))
{
    <p class="text-danger small mb-0">@LoadError</p>
}
else
{
    <RadzenStack Gap="1rem">
        <div class="settings-field__row2">
            <div class="settings-field" style="position: relative;">
                <label class="settings-field__label" for="svp-service">Service</label>
                @if (LoadingServices)
                {
                    <DropdownFieldSkeleton AriaLabel="Loading services"/>
                }
                else
                {
                    <RadzenDropDown TValue="Guid?"
                                    id="svp-service"
                                    Name="SvpService"
                                    @bind-Value="Model.ServiceId"
                                    Data="@Services"
                                    TextProperty="@nameof(ServiceSelectOption.Name)"
                                    ValueProperty="@nameof(ServiceSelectOption.Id)"
                                    AllowClear="false"
                                    Placeholder="Select…"
                                    Change="@OnChg"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="SvpService" Text="Required" Popup="true" Style="position:absolute;" />
                }
            </div>
            <div class="settings-field" style="position: relative;">
                <label class="settings-field__label" for="svp-operation">Operation type</label>
                @if (LoadingOperationTypes)
                {
                    <DropdownFieldSkeleton AriaLabel="Loading operation types"/>
                }
                else
                {
                    <RadzenDropDown TValue="Guid?"
                                    id="svp-operation"
                                    Name="SvpOperationType"
                                    @bind-Value="Model.OperationTypeId"
                                    Data="@OperationTypes"
                                    TextProperty="@nameof(OperationTypeSelectOption.Name)"
                                    ValueProperty="@nameof(OperationTypeSelectOption.Id)"
                                    AllowClear="false"
                                    Placeholder="Select…"
                                    Change="@OnChg"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="SvpOperationType" Text="Required" Popup="true" Style="position:absolute;" />
                }
            </div>
        </div>
        <div class="settings-field__row2">
            <div class="settings-field">
                <label class="settings-field__label" for="svp-aircraft">Aircraft type</label>
                @if (LoadingAircraftTypes)
                {
                    <DropdownFieldSkeleton AriaLabel="Loading aircraft types"/>
                }
                else
                {
                    <RadzenDropDown TValue="Guid?"
                                    id="svp-aircraft"
                                    Name="SvpAircraftType"
                                    @bind-Value="Model.AircraftTypeId"
                                    Data="@AircraftTypes"
                                    TextProperty="@nameof(AircraftTypeSelectOption.Model)"
                                    ValueProperty="@nameof(AircraftTypeSelectOption.Id)"
                                    AllowClear="true"
                                    Placeholder="All aircraft"
                                    Change="@OnChg"
                                    Style="width:100%;" />
                }
            </div>
            <div class="settings-field" style="position: relative;">
                <label class="settings-field__label" for="svp-currency">Currency</label>
                @if (LoadingCurrencies)
                {
                    <DropdownFieldSkeleton AriaLabel="Loading currencies"/>
                }
                else
                {
                    <RadzenDropDown TValue="Guid?"
                                    id="svp-currency"
                                    Name="SvpCurrency"
                                    @bind-Value="Model.CurrencyId"
                                    Data="@Currencies"
                                    TextProperty="@nameof(CurrencySelectOption.Code)"
                                    ValueProperty="@nameof(CurrencySelectOption.Id)"
                                    AllowClear="false"
                                    Placeholder="Select…"
                                    Change="@OnChg"
                                    Style="width:100%;" />
                    <RadzenRequiredValidator Component="SvpCurrency" Text="Required" Popup="true" Style="position:absolute;" />
                }
            </div>
        </div>
        <div class="settings-field">
            <label class="settings-field__label" for="svp-basis">Pricing basis</label>
            <RadzenDropDown TValue="PricingBasis"
                            id="svp-basis"
                            Name="SvpBasis"
                            Value="@Model.Basis"
                            ValueChanged="@OnBasisChangedAsync"
                            Data="@PricePlanBasisOptions.All"
                            TextProperty="@nameof(PricePlanBasisOptions.Item.Label)"
                            ValueProperty="@nameof(PricePlanBasisOptions.Item.Value)"
                            Style="width:100%;" />
        </div>
    </RadzenStack>
}

@code {
    [Parameter, EditorRequired] public ServicePricePlanScopeFormModel Model { get; set; } = default!;

    [Parameter] public EventCallback OnModelChanged { get; set; }

    [Parameter] public string? LoadError { get; set; }

    [Parameter] public bool LoadingServices { get; set; }

    [Parameter] public bool LoadingOperationTypes { get; set; }

    [Parameter] public bool LoadingAircraftTypes { get; set; }

    [Parameter] public bool LoadingCurrencies { get; set; }

    [Parameter] public IReadOnlyList<ServiceSelectOption> Services { get; set; } = [];

    [Parameter] public IReadOnlyList<OperationTypeSelectOption> OperationTypes { get; set; } = [];

    [Parameter] public IReadOnlyList<AircraftTypeSelectOption> AircraftTypes { get; set; } = [];

    [Parameter] public IReadOnlyList<CurrencySelectOption> Currencies { get; set; } = [];

    [Parameter] public EventCallback<PricingBasis> BasisChanged { get; set; }

    private Task OnChg() => OnModelChanged.InvokeAsync();

    private async Task OnBasisChangedAsync(PricingBasis b)
    {
        Model.Basis = b;
        await BasisChanged.InvokeAsync(b);
        await OnModelChanged.InvokeAsync();
    }
}
