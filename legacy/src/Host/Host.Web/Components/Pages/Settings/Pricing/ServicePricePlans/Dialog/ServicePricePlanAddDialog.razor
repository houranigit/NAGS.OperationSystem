@*
  ADD = wizard: Next validates scope; both sections stay in DOM (display) so scope validators work on Save (Component Rules.md — mirror CustomerAddDialog).
*@
@using Core.Application.Features.ServicePricePlan.Commands.CreateServicePricePlan
@using Core.Contracts.Features.Pricing
@using Core.Contracts.Features.AircraftType
@using Core.Contracts.Features.Currency
@using Core.Contracts.Features.OperationType
@using Core.Contracts.Features.Service
@using Core.Domain.Enumerations
@using Host.Web.Components.Pages.Settings.Pricing.ServicePricePlans.Dialog.Sections
@using Host.Web.Components.Pages.Settings.Pricing.Shared
@using Host.Web.Configuration
@using Host.Web.Services
@using Microsoft.Extensions.Options
@using Radzen
@inject DialogService DialogService
@inject IScopedMediator ScopedMediator
@inject ILookupCache LookupCache
@inject IOptions<PlatformSettings> PlatformOptions
@inject NotificationService NotificationService

<RadzenTemplateForm @ref="_form"
                    TItem="ServicePricePlanScopeFormModel"
                    Data="@_scopeModel"
                    Submit="@OnTemplateSubmitAsync"
                    InvalidSubmit="@OnTemplateInvalidSubmit">
    <WizardShell Steps="@_wizardSteps"
                 CurrentStep="_currentStep"
                 CurrentStepChanged="@(s => _currentStep = s)"
                 FurthestReached="_furthestReached"
                 FurthestReachedChanged="@(r => _furthestReached = r)"
                 Mode="WizardMode.Wizard"
                 IsBusy="_saving"
                 CanSave="@(_hasChangedInAddMode && !_scopeLookupsIncomplete && BracketsValid())"
                 SidebarAriaLabel="New service price plan steps"
                 SaveLabel="Save"
                 SavingLabel="Saving…"
                 AlertTitle="Couldn't save the price plan"
                 ConfirmCancelOnDirty="@_hasChangedInAddMode"
                 ErrorMessages="@_errorMessages"
                 OnSave="OnSaveClickedAsync"
                 OnCancel="OnCancelAsync"
                 OnRequestStepValidationAsync="ValidateCurrentStepAsync"
                 OnDismissError="ClearErrors">
        <StepContent Context="step">
            @switch (step)
            {
                case 0:
                    <ServicePricePlanScopeSection Model="@_scopeModel"
                                                  OnModelChanged="OnFormFieldChangedAsync"
                                                  LoadError="@_loadError"
                                                  LoadingServices="_loadingServices"
                                                  LoadingOperationTypes="_loadingOperationTypes"
                                                  LoadingAircraftTypes="_loadingAircraftTypes"
                                                  LoadingCurrencies="_loadingCurrencies"
                                                  Services="@_services"
                                                  OperationTypes="@_operationTypes"
                                                  AircraftTypes="@_aircraftTypes"
                                                  Currencies="@_currencies"
                                                  BasisChanged="@OnBasisChanged" />
                    break;
                case 1:
                    <PricePlanBracketsStepSection Basis="@_scopeModel.Basis"
                                                  CurrencyDisplay="@SelectedCurrencyCode"
                                                  Brackets="@_brackets"
                                                  SharedBlockMinutes="@_sharedBlock"
                                                  SharedBlockMinutesChanged="@OnSharedBlockChanged"
                                                  SharedBillingMode="@_sharedBilling"
                                                  SharedBillingModeChanged="@OnSharedBillingChanged"
                                                  OnChanged="@BracketsTouch"
                                                  BracketError="@_bracketError" />
                    break;
            }
        </StepContent>
    </WizardShell>
</RadzenTemplateForm>


@code {
    private readonly WizardStep[] _wizardSteps =
    [
        new("Plan", "Scopes & basis", "tools", IsRequired: true, Validate: () => true),
        new("Brackets", "Rates", "percent", IsRequired: true, Validate: () => true)
    ];

    private RadzenTemplateForm<ServicePricePlanScopeFormModel>? _form;
    private int _currentStep;
    private int _furthestReached;
    private bool _saving;
    private bool _hasChangedInAddMode;
    private bool _loadingServices = true;
    private bool _loadingOperationTypes = true;
    private bool _loadingAircraftTypes = true;
    private bool _loadingCurrencies = true;
    private string? _loadError;

    private List<ServiceSelectOption> _services = [];
    private List<OperationTypeSelectOption> _operationTypes = [];
    private List<AircraftTypeSelectOption> _aircraftTypes = [];
    private List<CurrencySelectOption> _currencies = [];

    private readonly ServicePricePlanScopeFormModel _scopeModel = new();

    private List<PriceBracketRowState> _brackets = [new() { MinMinutes = 0, MaxMinutes = null, Value = 0 }];
    private int _sharedBlock = 60;
    private BracketBillingMode _sharedBilling = BracketBillingMode.ProRated;
    private string? _bracketError;

    private List<string> _errorMessages = new();

    private void ClearErrors() { if (_errorMessages.Count > 0) { _errorMessages = new(); StateHasChanged(); } }
    private void SetCommandError(string d) { _errorMessages = d.Split([';', '\n'], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).Where(s => s.Length > 0).ToList(); if (_errorMessages.Count == 0) _errorMessages.Add(d); }

    private string PlatformCurrencyCode => PlatformOptions.Value.CurrencyCode?.Trim().ToUpperInvariant() ?? "SAR";

    private string SelectedCurrencyCode =>
        _currencies.FirstOrDefault(c => c.Id == _scopeModel.CurrencyId)?.Code ?? PlatformCurrencyCode;

    private bool _scopeLookupsIncomplete =>
        _loadingServices || _loadingOperationTypes || _loadingAircraftTypes || _loadingCurrencies;

    private bool IsDirty => _hasChangedInAddMode;

    protected override void OnInitialized()
    {
        _currentStep = 0;
        _furthestReached = 0;
        _hasChangedInAddMode = false;
    }

    private bool _lookupsLoadStarted;

    /// <remarks>
    /// Lookup fetches are deferred to <see cref="OnAfterRenderAsync"/> so the dialog's first paint
    /// (shell + dropdown skeletons) ships to the browser before we touch the DI container / MediatR
    /// pipeline / EF Core — all of which can run 100–500 ms of synchronous work on a cold hit and
    /// was the real source of the "dialog freeze before open". Once the lookups land, each list's
    /// loading flag flips individually so dropdowns fill in as their data arrives.
    /// </remarks>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _lookupsLoadStarted)
            return;

        _lookupsLoadStarted = true;

        await Task.WhenAll(
            LoadServicesAsync(),
            LoadOperationTypesAsync(),
            LoadAircraftTypesAsync(),
            LoadCurrenciesAsync());

        ApplyDefaultCurrencyFromPlatform();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadServicesAsync()
    {
        try
        {
            _services = (await LookupCache.GetServicesAsync(ScopedMediator)).ToList();
        }
        catch (Exception ex)
        {
            _loadError ??= ex.Message;
        }
        finally
        {
            _loadingServices = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadOperationTypesAsync()
    {
        try
        {
            _operationTypes = (await LookupCache.GetOperationTypesAsync(ScopedMediator)).ToList();
        }
        catch (Exception ex)
        {
            _loadError ??= ex.Message;
        }
        finally
        {
            _loadingOperationTypes = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadAircraftTypesAsync()
    {
        try
        {
            _aircraftTypes = (await LookupCache.GetAircraftTypesAsync(ScopedMediator)).ToList();
        }
        catch (Exception ex)
        {
            _loadError ??= ex.Message;
        }
        finally
        {
            _loadingAircraftTypes = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadCurrenciesAsync()
    {
        try
        {
            _currencies = (await LookupCache.GetCurrenciesAsync(ScopedMediator)).ToList();
        }
        catch (Exception ex)
        {
            _loadError ??= ex.Message;
        }
        finally
        {
            _loadingCurrencies = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ApplyDefaultCurrencyFromPlatform()
    {
        var match = _currencies.FirstOrDefault(x =>
            string.Equals(x.Code, PlatformCurrencyCode, StringComparison.OrdinalIgnoreCase));
        _scopeModel.CurrencyId = match?.Id ?? _currencies.FirstOrDefault()?.Id;
    }

    private Task<bool> ValidateCurrentStepAsync(int step)
    {
        // Step 0 = scope (form-validated). Step 1 = brackets (custom rule).
        if (step == 0)
        {
            var ok = _form?.EditContext?.Validate() ?? true;
            if (ok) ClearErrors();
            return Task.FromResult(ok);
        }
        if (step == 1)
        {
            var ok = BracketsValid();
            if (ok) ClearErrors();
            else NotificationService.Notify(NotificationSeverity.Warning, "Brackets", _bracketError ?? "Fix bracket rows.");
            return Task.FromResult(ok);
        }
        return Task.FromResult(true);
    }

    private async Task OnSaveClickedAsync()
    {
        if (_saving) return;
        if (!await ValidateAllStepsRenderedAsync()) { NotificationService.Notify(NotificationSeverity.Warning, "Cannot save", "Please fix the highlighted issues before saving."); return; }
        if (!BracketsValid()) { NotificationService.Notify(NotificationSeverity.Warning, "Brackets", _bracketError ?? "Fix bracket rows."); return; }
        await OnTemplateSubmitAsync(_scopeModel);
    }

    private async Task<bool> ValidateAllStepsRenderedAsync()
    {
        var back = _currentStep;
        try
        {
            for (var s = 0; s < _wizardSteps.Length; s++) { _currentStep = s; await InvokeAsync(StateHasChanged); await Task.Yield(); if (s == 0 && (_form?.EditContext is null || !_form.EditContext.Validate())) return false; }
            return true;
        }
        finally { _currentStep = back; await InvokeAsync(StateHasChanged); }
    }

    private async Task OnCancelAsync() { DialogService.Close(false); await Task.CompletedTask; }

    private Task OnFormFieldChangedAsync()
    {
        _hasChangedInAddMode = true;
        return Task.CompletedTask;
    }

    private void OnTemplateInvalidSubmit(FormInvalidSubmitEventArgs _) { }

    private async Task OnTemplateSubmitAsync(ServicePricePlanScopeFormModel _)
    {
        if (_saving || !IsDirty) return;
        _saving = true; ClearErrors(); await InvokeAsync(StateHasChanged);
        try
        {
            if (_scopeModel.ServiceId is not { } sid ||
                _scopeModel.OperationTypeId is not { } ot ||
                _scopeModel.CurrencyId is not { } cur)
            {
                NotificationService.Notify(NotificationSeverity.Warning, "Plan", "Select service, operation type, and currency.");
                return;
            }
            var brackets = PricePlanBracketMapping.ToCommandBrackets(_scopeModel.Basis, _brackets, _sharedBlock, _sharedBilling);
            var r = await ScopedMediator.Send(new CreateServicePricePlanCommand(sid, ot, _scopeModel.AircraftTypeId, cur, _scopeModel.Basis, brackets));
            if (r.IsFailure) { SetCommandError(r.Error.Description); NotificationService.Notify(NotificationSeverity.Error, "Could not save plan", r.Error.Description); return; }
            DialogService.Close(true);
        }
        catch (Exception ex) { SetCommandError(ex.Message); NotificationService.Notify(NotificationSeverity.Error, "Unexpected error", ex.Message); }
        finally { _saving = false; await InvokeAsync(StateHasChanged); }
    }

    private Task OnBasisChanged(PricingBasis b)
    {
        _hasChangedInAddMode = true;
        if (b == PricingBasis.Flat)
        {
            var v = _brackets.FirstOrDefault()?.Value ?? 0m;
            _brackets.Clear();
            _brackets.Add(new PriceBracketRowState { MinMinutes = 0, MaxMinutes = null, Value = v });
        }
        else
        {
            if (_brackets.Count == 0)
                _brackets.Add(new PriceBracketRowState { MinMinutes = 0, MaxMinutes = null, Value = 0 });
        }

        return Task.CompletedTask;
    }

    private Task OnSharedBlockChanged(int v)
    {
        _hasChangedInAddMode = true;
        _sharedBlock = Math.Max(1, v);
        return Task.CompletedTask;
    }

    private Task OnSharedBillingChanged(BracketBillingMode mode)
    {
        _hasChangedInAddMode = true;
        _sharedBilling = mode;
        return Task.CompletedTask;
    }

    private Task BracketsTouch()
    {
        _hasChangedInAddMode = true;
        _bracketError = null;
        return InvokeAsync(StateHasChanged);
    }

    private bool BracketsValid() =>
        PricePlanBracketRules.IsValid(_scopeModel.Basis, _brackets, _sharedBlock, out _bracketError);

}
