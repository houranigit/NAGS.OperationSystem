
@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="alert alert-error" role="alert">
        @if (Dismissible)
        {
            <button type="button" class="alert-dismiss" @onclick="Dismiss" aria-label="Close">&times;</button>
        }
        @Message
    </div>
}

@code {
    [Parameter, EditorRequired] public string? Message { get; set; }
    [Parameter] public bool Dismissible { get; set; }
    [Parameter] public EventCallback OnDismissed { get; set; }

    private async Task Dismiss()
    {
        Message = null;
        await OnDismissed.InvokeAsync();
    }
}
