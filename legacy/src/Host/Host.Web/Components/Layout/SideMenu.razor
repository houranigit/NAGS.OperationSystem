@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    [Parameter]
    public bool Collapsed { get; set; }

    /// <summary>At most one group key is expanded (accordion).</summary>
    private string? _openGroup;
    private bool _canManagePortal;
    private bool _canViewScheduler;

    private string NavClass() =>
        "ops-nav" + (Collapsed ? " ops-nav--collapsed" : null);

    /// <summary>Single tier-1 row style for leaf NavLinks and accordion headers.</summary>
    private string Tier1Class() =>
        "ops-nav-t1" + (Collapsed ? " ops-nav-t1--rail" : null);

    private string GroupClass(string key) =>
        "ops-nav-section"
        + (IsExpanded(key) ? " ops-nav-section--open" : null)
        + (IsActiveGroup(key) ? " ops-nav-section--branch-active" : null);

    protected override void OnInitialized()
    {
        SyncExpandedFromRoute();
        Nav.LocationChanged += OnLocationChanged;
    }

    protected override void OnParametersSet()
    {
        SyncExpandedFromRoute();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (AuthenticationStateTask is null)
            return;

        var user = (await AuthenticationStateTask).User;
        _canManagePortal = user.HasClaim("permissions", Permissions.Portal.Manage);
        _canViewScheduler = user.HasClaim("permissions", Permissions.Scheduler.Read);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        SyncExpandedFromRoute();
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }

    private void SyncExpandedFromRoute()
    {
        _openGroup = ResolveGroupFromPath();
    }

    private static string? ResolveGroupFromPath(string relativePathTrimmed)
    {
        var lower = relativePathTrimmed.TrimStart('/').ToLowerInvariant();
        if (lower.StartsWith("master-data/", StringComparison.Ordinal))
            return "master-data";
        if (lower.StartsWith("pricing/", StringComparison.Ordinal))
            return "pricing";
        if (lower.StartsWith("system/", StringComparison.Ordinal))
            return "system";
        return null;
    }

    private string? ResolveGroupFromPath() =>
        ResolveGroupFromPath(Nav.ToBaseRelativePath(Nav.Uri));

    private bool IsExpanded(string key) =>
        string.Equals(_openGroup, key, StringComparison.OrdinalIgnoreCase);

    private bool IsActiveGroup(string key) =>
        string.Equals(ResolveGroupFromPath(), key, StringComparison.OrdinalIgnoreCase);

    private void ToggleGroup(string key)
    {
        if (IsExpanded(key))
        {
            if (string.Equals(ResolveGroupFromPath(), key, StringComparison.OrdinalIgnoreCase))
                return;
            _openGroup = null;
            return;
        }

        _openGroup = key;
    }

}
